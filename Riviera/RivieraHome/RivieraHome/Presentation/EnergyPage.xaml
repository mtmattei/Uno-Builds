<Page x:Class="RivieraHome.Presentation.EnergyPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:RivieraHome.Presentation"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:controls="using:RivieraHome.Controls"
      Background="Transparent"
      NavigationCacheMode="Required">

  <mvux:FeedView Source="{Binding Energy}">
    <mvux:FeedView.ValueTemplate>
      <DataTemplate>
        <Grid ColumnSpacing="20" Padding="4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Left Column: Solar + Grid Power -->
          <StackPanel Grid.Column="0" Spacing="16" VerticalAlignment="Center">

            <TextBlock Text="SOLAR GENERATION"
                       Style="{StaticResource CrtLabel}"
                       x:Uid="EnergyPage.Label.Solar" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding Data.SolarKw}"
                         Style="{StaticResource CrtDisplayLG}"
                         AutomationProperties.Name="Solar generation kilowatts" />
              <TextBlock Text="kW"
                         Style="{StaticResource CrtDisplayMD}"
                         Foreground="{StaticResource PhosphorDimBrush}"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,8" />
            </StackPanel>

            <Border Height="1" Background="{StaticResource PhosphorDimBrush}" Opacity="0.15" />

            <TextBlock Text="GRID CONSUMPTION"
                       Style="{StaticResource CrtLabel}"
                       x:Uid="EnergyPage.Label.Grid" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding Data.GridKw}"
                         Style="{StaticResource CrtDisplayMD}"
                         AutomationProperties.Name="Grid consumption kilowatts" />
              <TextBlock Text="kW"
                         Style="{StaticResource CrtLabel}"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,4" />
            </StackPanel>

            <Border Height="1" Background="{StaticResource PhosphorDimBrush}" Opacity="0.15" />

            <TextBlock Text="DAILY USAGE"
                       Style="{StaticResource CrtLabel}"
                       x:Uid="EnergyPage.Label.DailyUsage" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <TextBlock Text="{Binding Data.DailyKwh}"
                         Style="{StaticResource CrtDisplayMD}"
                         AutomationProperties.Name="Daily kilowatt hours" />
              <TextBlock Text="kWh"
                         Style="{StaticResource CrtLabel}"
                         VerticalAlignment="Bottom"
                         Margin="0,0,0,4" />
            </StackPanel>
          </StackPanel>

          <!-- Right Column: Battery + Gauge -->
          <StackPanel Grid.Column="1" Spacing="16" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="BATTERY STATUS"
                       Style="{StaticResource CrtLabel}"
                       HorizontalAlignment="Center"
                       x:Uid="EnergyPage.Label.Battery" />

            <controls:GaugeArc Value="{Binding Data.BatteryPct}"
                               Maximum="100"
                               Label="BATTERY"
                               Unit="%"
                               GaugeSize="140"
                               AutomationProperties.Name="Battery percentage gauge" />

            <!-- Battery bar visualization -->
            <Border BorderBrush="{StaticResource PhosphorDimBrush}"
                    BorderThickness="1"
                    CornerRadius="2"
                    Padding="2"
                    Height="24"
                    HorizontalAlignment="Stretch">
              <Grid>
                <Border Background="{StaticResource PhosphorSubtleBrush}"
                        CornerRadius="1"
                        HorizontalAlignment="Left" />
                <Border Background="{StaticResource PhosphorPrimaryBrush}"
                        CornerRadius="1"
                        HorizontalAlignment="Left"
                        Opacity="0.6" />
              </Grid>
            </Border>

            <TextBlock Style="{StaticResource CrtBody}"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource PhosphorBrightBrush}">
              <Run Text="⚡" />
              <Run Text=" CHARGING" />
            </TextBlock>
          </StackPanel>
        </Grid>
      </DataTemplate>
    </mvux:FeedView.ValueTemplate>

    <mvux:FeedView.ProgressTemplate>
      <DataTemplate>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
          <ProgressRing IsActive="True" Foreground="{StaticResource PhosphorPrimaryBrush}" Width="48" Height="48" />
          <TextBlock Text="LOADING ENERGY DATA..." Style="{StaticResource CrtLabel}" HorizontalAlignment="Center" />
        </StackPanel>
      </DataTemplate>
    </mvux:FeedView.ProgressTemplate>

    <mvux:FeedView.ErrorTemplate>
      <DataTemplate>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
          <TextBlock Text="ENERGY FEED OFFLINE" Style="{StaticResource CrtHeading}" HorizontalAlignment="Center" />
          <TextBlock Text="Connection lost — retry" Style="{StaticResource CrtBody}" Foreground="{StaticResource PhosphorDimBrush}" HorizontalAlignment="Center" />
        </StackPanel>
      </DataTemplate>
    </mvux:FeedView.ErrorTemplate>
  </mvux:FeedView>
</Page>

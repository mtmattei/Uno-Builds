<UserControl x:Class="RivieraHome.Controls.GaugeArc"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid Width="{x:Bind GaugeSize, Mode=OneWay}"
        Height="{x:Bind GaugeSize, Mode=OneWay}">

    <!-- Arc background track -->
    <Canvas x:Name="ArcCanvas" />

    <!-- Center value display -->
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="0">
      <TextBlock x:Name="ValueText"
                 Style="{StaticResource CrtDisplayMD}"
                 HorizontalAlignment="Center" />
      <TextBlock x:Name="UnitText"
                 Style="{StaticResource CrtLabel}"
                 HorizontalAlignment="Center"
                 Margin="0,2,0,0" />
    </StackPanel>

    <!-- Label below -->
    <TextBlock x:Name="LabelText"
               Style="{StaticResource CrtLabel}"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,4" />
  </Grid>
</UserControl>

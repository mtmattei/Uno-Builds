<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="using:FluxTransit.Converters">

    <!-- Value Converters -->
    <converters:RouteTypeColorConverter x:Key="RouteTypeColorConverter" />
    <converters:CrowdLevelConverter x:Key="CrowdLevelConverter" />
    <converters:NetworkHealthConverter x:Key="NetworkHealthConverter" />
    <converters:NetworkHealthColorConverter x:Key="NetworkHealthColorConverter" />
    <converters:AlertSeverityColorConverter x:Key="AlertSeverityColorConverter" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />

    <!-- Flux Transit Custom Colors and Brushes -->

    <!-- Core Flux Colors -->
    <Color x:Key="FluxBackground">#0f172a</Color>
    <Color x:Key="FluxSurface">#1e293b</Color>
    <Color x:Key="FluxGlassPanel">#1e293b66</Color>
    <Color x:Key="FluxGlassIndigo">#312e811a</Color>
    <Color x:Key="FluxBorderSubtle">#ffffff0d</Color>
    <Color x:Key="FluxBorderLight">#ffffff1a</Color>

    <!-- Semantic Colors -->
    <Color x:Key="FluxPrimary">#818cf8</Color>
    <Color x:Key="FluxPrimaryStrong">#4f46e5</Color>
    <Color x:Key="FluxSuccess">#34d399</Color>
    <Color x:Key="FluxWarning">#fbbf24</Color>
    <Color x:Key="FluxError">#fb7185</Color>

    <!-- Text Colors -->
    <Color x:Key="FluxTextPrimary">#ffffff</Color>
    <Color x:Key="FluxTextSecondary">#94a3b8</Color>
    <Color x:Key="FluxTextMuted">#64748b</Color>

    <!-- Core Brushes -->
    <SolidColorBrush x:Key="FluxBackgroundBrush" Color="{StaticResource FluxBackground}" />
    <SolidColorBrush x:Key="FluxSurfaceBrush" Color="{StaticResource FluxSurface}" />
    <SolidColorBrush x:Key="FluxGlassPanelBrush" Color="{StaticResource FluxGlassPanel}" />
    <SolidColorBrush x:Key="FluxGlassIndigoBrush" Color="{StaticResource FluxGlassIndigo}" />
    <SolidColorBrush x:Key="FluxBorderSubtleBrush" Color="{StaticResource FluxBorderSubtle}" />
    <SolidColorBrush x:Key="FluxBorderLightBrush" Color="{StaticResource FluxBorderLight}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="FluxPrimaryBrush" Color="{StaticResource FluxPrimary}" />
    <SolidColorBrush x:Key="FluxPrimaryStrongBrush" Color="{StaticResource FluxPrimaryStrong}" />
    <SolidColorBrush x:Key="FluxSuccessBrush" Color="{StaticResource FluxSuccess}" />
    <SolidColorBrush x:Key="FluxWarningBrush" Color="{StaticResource FluxWarning}" />
    <SolidColorBrush x:Key="FluxErrorBrush" Color="{StaticResource FluxError}" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="FluxTextPrimaryBrush" Color="{StaticResource FluxTextPrimary}" />
    <SolidColorBrush x:Key="FluxTextSecondaryBrush" Color="{StaticResource FluxTextSecondary}" />
    <SolidColorBrush x:Key="FluxTextMutedBrush" Color="{StaticResource FluxTextMuted}" />

    <!-- Spacing Tokens -->
    <x:Double x:Key="FluxSpacingXS">4</x:Double>
    <x:Double x:Key="FluxSpacingS">8</x:Double>
    <x:Double x:Key="FluxSpacingM">16</x:Double>
    <x:Double x:Key="FluxSpacingL">24</x:Double>
    <x:Double x:Key="FluxSpacingXL">32</x:Double>
    <x:Double x:Key="FluxSpacingXXL">40</x:Double>

    <!-- Corner Radius -->
    <CornerRadius x:Key="FluxCornerRadiusSmall">8</CornerRadius>
    <CornerRadius x:Key="FluxCornerRadiusMedium">16</CornerRadius>
    <CornerRadius x:Key="FluxCornerRadiusLarge">24</CornerRadius>
    <CornerRadius x:Key="FluxCornerRadiusFull">9999</CornerRadius>

    <!-- Typography Styles -->

    <!-- H1: Greeting -->
    <Style x:Key="FluxHeadingLarge" TargetType="TextBlock">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextPrimaryBrush}" />
        <Setter Property="CharacterSpacing" Value="-20" />
    </Style>

    <!-- H2: Section Headers -->
    <Style x:Key="FluxHeadingSection" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextPrimaryBrush}" />
    </Style>

    <!-- H3: Card Headers -->
    <Style x:Key="FluxHeadingCard" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextPrimaryBrush}" />
    </Style>

    <!-- Body -->
    <Style x:Key="FluxBody" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextSecondaryBrush}" />
    </Style>

    <!-- Body Bold -->
    <Style x:Key="FluxBodyBold" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextPrimaryBrush}" />
    </Style>

    <!-- Micro (Labels) -->
    <Style x:Key="FluxMicro" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextMutedBrush}" />
    </Style>

    <!-- Glass Panel Style -->
    <Style x:Key="FluxGlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluxGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluxBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusLarge}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <!-- Status Pill Style -->
    <Style x:Key="FluxStatusPillStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluxGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluxBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusFull}" />
        <Setter Property="Padding" Value="12,8" />
    </Style>

    <!-- Transit Card Style -->
    <Style x:Key="FluxTransitCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluxGlassPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluxBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusMedium}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Progress Bar Style for Vehicle Position -->
    <Style x:Key="FluxProgressBarStyle" TargetType="ProgressBar">
        <Setter Property="Height" Value="6" />
        <Setter Property="Background" Value="#334155" />
        <Setter Property="Foreground" Value="{StaticResource FluxPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <!-- Primary Button Style -->
    <Style x:Key="FluxPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource FluxPrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FluxBackgroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusFull}" />
    </Style>

    <!-- Icon Button Style -->
    <Style x:Key="FluxIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource FluxGlassPanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource FluxTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluxBorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusFull}" />
    </Style>

    <!-- Secondary Button Style -->
    <Style x:Key="FluxSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FluxPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FluxPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="24,12" />
        <Setter Property="CornerRadius" Value="{StaticResource FluxCornerRadiusFull}" />
    </Style>

    <!-- Alert Badge Style -->
    <Style x:Key="FluxAlertBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluxErrorBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Success Badge Style -->
    <Style x:Key="FluxSuccessBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluxSuccessBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <!-- Subtle Divider Style -->
    <Style x:Key="FluxDividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource FluxBorderSubtleBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

</ResourceDictionary>

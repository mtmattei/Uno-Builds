<Application x:Class="CameraCaptureUISample.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utu="using:Uno.Toolkit.UI">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

        <!-- Material theme -->
        <MaterialTheme xmlns="using:Uno.Material" />
        <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
        <MaterialToolkitTheme xmlns="using:Uno.Toolkit.UI.Material" />

        <!-- Custom palette and styles -->
        <ResourceDictionary Source="ms-appx:///Styles/ColorPaletteOverride.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/AnnotationStyles.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/AppResources.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>

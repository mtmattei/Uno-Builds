<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
					xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Annotation badge colors -->
	<Color x:Key="BadgeCameraCaptureUIColor">#C4553D</Color>
	<Color x:Key="BadgeBitmapImageColor">#4A7C6F</Color>
	<Color x:Key="BadgeIStateColor">#8B6914</Color>
	<Color x:Key="BadgeAutoLayoutColor">#6B5B95</Color>

	<SolidColorBrush x:Key="BadgeCameraCaptureUIBrush" Color="{StaticResource BadgeCameraCaptureUIColor}" />
	<SolidColorBrush x:Key="BadgeBitmapImageBrush" Color="{StaticResource BadgeBitmapImageColor}" />
	<SolidColorBrush x:Key="BadgeIStateBrush" Color="{StaticResource BadgeIStateColor}" />
	<SolidColorBrush x:Key="BadgeAutoLayoutBrush" Color="{StaticResource BadgeAutoLayoutColor}" />

	<!-- Annotation panel -->
	<Color x:Key="AnnotationPanelBgColor">#EBF5F2ED</Color>
	<SolidColorBrush x:Key="AnnotationPanelBgBrush" Color="{StaticResource AnnotationPanelBgColor}" />

	<!-- Code block -->
	<Color x:Key="CodeBlockBgColor">#FF2C2926</Color>
	<Color x:Key="CodeBlockFgColor">#FFE2DED6</Color>
	<SolidColorBrush x:Key="CodeBlockBgBrush" Color="{StaticResource CodeBlockBgColor}" />
	<SolidColorBrush x:Key="CodeBlockFgBrush" Color="{StaticResource CodeBlockFgColor}" />

	<!-- Badge white overlay -->
	<SolidColorBrush x:Key="BadgeIconBgBrush" Color="#33FFFFFF" />

</ResourceDictionary>

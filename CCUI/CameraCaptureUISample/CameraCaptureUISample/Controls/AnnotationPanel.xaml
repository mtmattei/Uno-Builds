<UserControl x:Class="CameraCaptureUISample.Controls.AnnotationPanel"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 MaxWidth="380">

	<Grid x:Name="PanelRoot" Opacity="0">
		<Border CornerRadius="12"
				Background="{StaticResource AnnotationPanelBgBrush}"
				BorderBrush="{StaticResource BorderBrush}"
				BorderThickness="1"
				Padding="20"
				Translation="0,0,32">
			<Border.Shadow>
				<ThemeShadow />
			</Border.Shadow>

			<StackPanel Spacing="16">

				<!-- Header: dot + label + close -->
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<Ellipse x:Name="HeaderDot"
							 Width="10" Height="10"
							 VerticalAlignment="Center"
							 Margin="0,0,10,0" />

					<TextBlock x:Name="HeaderLabel"
							   Grid.Column="1"
							   Style="{StaticResource TitleSmall}"
							   Foreground="{StaticResource OnSurfaceBrush}"
							   VerticalAlignment="Center" />

					<Button x:Name="CloseButton"
							Grid.Column="2"
							Background="Transparent"
							BorderThickness="0"
							Padding="4"
							MinWidth="0" MinHeight="0"
							Click="CloseButton_Click">
						<FontIcon Glyph="&#xE711;"
								  FontSize="12"
								  Foreground="{StaticResource OnSurfaceVariantBrush}" />
					</Button>
				</Grid>

				<!-- Summary -->
				<TextBlock x:Name="SummaryText"
						   Style="{StaticResource BodyMedium}"
						   Foreground="{StaticResource OnSurfaceVariantBrush}"
						   TextWrapping="Wrap" />

				<!-- Platform selector -->
				<StackPanel x:Name="PlatformSelector"
							Orientation="Horizontal"
							Spacing="4">
					<ToggleButton x:Name="BtnWindows" Content="Win"
								  Style="{StaticResource PlatformSelectorButtonStyle}"
								  Click="PlatformButton_Click" Tag="windows" />
					<ToggleButton x:Name="BtnAndroid" Content="And"
								  Style="{StaticResource PlatformSelectorButtonStyle}"
								  Click="PlatformButton_Click" Tag="android" />
					<ToggleButton x:Name="BtnIos" Content="iOS"
								  Style="{StaticResource PlatformSelectorButtonStyle}"
								  Click="PlatformButton_Click" Tag="ios" />
					<ToggleButton x:Name="BtnWasm" Content="WASM"
								  Style="{StaticResource PlatformSelectorButtonStyle}"
								  Click="PlatformButton_Click" Tag="wasm" />
				</StackPanel>

				<!-- Platform detail -->
				<Border CornerRadius="8"
						Background="{StaticResource SurfaceBrush}"
						Padding="12">
					<StackPanel Spacing="4">
						<TextBlock x:Name="PlatformApiName"
								   Style="{StaticResource LabelMedium}"
								   Foreground="{StaticResource OnSurfaceBrush}"
								   FontFamily="Consolas" />
						<TextBlock x:Name="PlatformNote"
								   Style="{StaticResource BodySmall}"
								   Foreground="{StaticResource OnSurfaceVariantBrush}"
								   TextWrapping="Wrap" />
					</StackPanel>
				</Border>

				<!-- Code block -->
				<StackPanel Spacing="6">
					<TextBlock Text="IMPLEMENTATION"
							   Style="{StaticResource LabelSmall}"
							   Foreground="{StaticResource OnSurfaceVariantBrush}" />

					<Border CornerRadius="8"
							Background="{StaticResource CodeBlockBgBrush}"
							Padding="14">
						<ScrollViewer HorizontalScrollBarVisibility="Auto"
									  VerticalScrollBarVisibility="Disabled">
							<TextBlock x:Name="CodeSnippetText"
									   FontFamily="Consolas"
									   FontSize="12"
									   Foreground="{StaticResource CodeBlockFgBrush}"
									   TextWrapping="NoWrap" />
						</ScrollViewer>
					</Border>
				</StackPanel>

			</StackPanel>
		</Border>

		<Grid.Resources>
			<Storyboard x:Name="PanelEntranceAnimation">
				<DoubleAnimation Storyboard.TargetName="PanelRoot"
								 Storyboard.TargetProperty="Opacity"
								 From="0" To="1"
								 Duration="0:0:0.35">
					<DoubleAnimation.EasingFunction>
						<CubicEase EasingMode="EaseOut" />
					</DoubleAnimation.EasingFunction>
				</DoubleAnimation>
			</Storyboard>
		</Grid.Resources>
	</Grid>
</UserControl>

<UserControl x:Class="CameraCaptureUISample.Controls.LearnModeToggle"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d">

	<ToggleButton x:Name="LearnToggle"
				  Style="{StaticResource LearnModeToggleStyle}"
				  AutomationProperties.Name="Learn Mode"
				  AutomationProperties.LiveSetting="Polite"
				  Checked="LearnToggle_Changed"
				  Unchecked="LearnToggle_Changed">
		<StackPanel Orientation="Horizontal" Spacing="10">
			<Ellipse x:Name="LearnDot"
					 Width="8" Height="8" />
			<TextBlock x:Name="LearnLabel"
					   Style="{StaticResource LabelSmall}"
					   VerticalAlignment="Center" />
		</StackPanel>
	</ToggleButton>
</UserControl>

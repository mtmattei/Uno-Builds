<Page x:Class="CameraCaptureUISample.MainPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:utu="using:Uno.Toolkit.UI"
	  xmlns:controls="using:CameraCaptureUISample.Controls"
	  Background="{StaticResource BackgroundBrush}">

	<Grid>
		<!-- Core app content -->
		<utu:AutoLayout PrimaryAxisAlignment="Center"
						CounterAxisAlignment="Center"
						Spacing="0"
						Padding="24">

			<!-- Wordmark -->
			<TextBlock Text="CAPTURE"
					   Style="{StaticResource DisplaySmall}"
					   Opacity="0.45"
					   Margin="0,0,0,32"
					   HorizontalAlignment="Center"
					   x:Uid="MainPage_Wordmark"
					   AutomationProperties.Name="Capture camera app" />

			<!-- Viewfinder -->
			<Border x:Name="Viewfinder"
					CornerRadius="5"
					Background="{StaticResource SurfaceBrush}"
					Width="{utu:Responsive Narrow=340, Wide=540}"
					MinHeight="255"
					Translation="0,0,16">
				<Border.Shadow>
					<ThemeShadow />
				</Border.Shadow>

				<Grid>
					<!-- Flash overlay for capture animation -->
					<Border x:Name="FlashOverlay"
							Background="White"
							Opacity="0"
							CornerRadius="5" />

					<!-- Idle state: lens icon + hint -->
					<StackPanel x:Name="IdleContent"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="16">
						<Border Width="64" Height="64"
								CornerRadius="32"
								BorderBrush="{StaticResource BorderBrush}"
								BorderThickness="2"
								HorizontalAlignment="Center">
							<FontIcon Glyph="&#xE722;"
									  FontSize="24"
									  Foreground="{StaticResource OnSurfaceVariantBrush}"
									  HorizontalAlignment="Center"
									  VerticalAlignment="Center" />
						</Border>
						<TextBlock x:Name="HintText"
								   Text="tap to open camera"
								   Style="{StaticResource BodyMedium}"
								   Foreground="{StaticResource OnSurfaceVariantBrush}"
								   HorizontalAlignment="Center" />
					</StackPanel>

					<!-- Captured state: photo + timestamp -->
					<Grid x:Name="CapturedContent" Visibility="Collapsed">
						<Image x:Name="CapturedPhoto"
							   Stretch="UniformToFill"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center" />

						<!-- Timestamp patina -->
						<Border VerticalAlignment="Bottom"
								HorizontalAlignment="Right"
								Margin="12"
								Padding="8,4"
								CornerRadius="4"
								Background="#66000000">
							<TextBlock x:Name="TimestampText"
									   Style="{StaticResource LabelSmall}"
									   Foreground="White"
									   FontFamily="Consolas" />
						</Border>
					</Grid>
				</Grid>
			</Border>

			<!-- Controls below viewfinder -->
			<StackPanel Spacing="14"
						Margin="0,36,0,0"
						HorizontalAlignment="Center">

				<!-- Idle: open camera button -->
				<Button x:Name="OpenButton"
						Content="open camera"
						Style="{StaticResource CaptureOpenButtonStyle}"
						Click="OpenButton_Click"
						x:Uid="MainPage_OpenCamera"
						AutomationProperties.Name="Open camera to capture a photo" />

				<!-- Captured: shutter button for another capture -->
				<Button x:Name="ShutterButton"
						Style="{StaticResource CaptureShutterButtonStyle}"
						Click="ShutterButton_Click"
						Visibility="Collapsed"
						x:Uid="MainPage_Shutter"
						AutomationProperties.Name="Capture another photo" />

				<!-- Captured: take another link -->
				<Button x:Name="ResetButton"
						Content="take another"
						Style="{StaticResource CaptureTextButtonStyle}"
						Click="ResetButton_Click"
						Visibility="Collapsed"
						x:Uid="MainPage_Reset"
						AutomationProperties.Name="Reset and take another photo" />
			</StackPanel>
		</utu:AutoLayout>

		<!-- Learn mode toggle (top-right) -->
		<controls:LearnModeToggle x:Name="LearnToggle"
								  HorizontalAlignment="Right"
								  VerticalAlignment="Top"
								  Margin="0,16,16,0"
								  IsActive="True" />

		<!-- Annotation overlay -->
		<controls:AnnotationOverlay x:Name="AnnotationOverlayControl"
									IsHitTestVisible="True" />

		<!-- Visual State Storyboards -->
		<Grid.Resources>
			<Storyboard x:Name="FlashAnimation">
				<DoubleAnimationUsingKeyFrames Storyboard.TargetName="FlashOverlay"
											   Storyboard.TargetProperty="Opacity">
					<DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.8" />
					<LinearDoubleKeyFrame KeyTime="0:0:0.14" Value="0" />
				</DoubleAnimationUsingKeyFrames>
			</Storyboard>
			<Storyboard x:Name="PhotoRevealAnimation">
				<DoubleAnimation Storyboard.TargetName="CapturedContent"
								 Storyboard.TargetProperty="Opacity"
								 From="0" To="1"
								 Duration="0:0:0.55">
					<DoubleAnimation.EasingFunction>
						<CubicEase EasingMode="EaseOut" />
					</DoubleAnimation.EasingFunction>
				</DoubleAnimation>
			</Storyboard>
		</Grid.Resources>
	</Grid>
</Page>

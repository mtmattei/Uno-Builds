<UserControl x:Class="PhosphorProtocol.Views.EnergyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:PhosphorProtocol.SkiaControls"
             xmlns:uer="using:Uno.Extensions.Reactive.UI">
   <Grid Padding="14,14,18,14" RowSpacing="12">
       <Grid.RowDefinitions>
           <RowDefinition Height="Auto" />
           <RowDefinition Height="Auto" />
           <RowDefinition Height="Auto" />
           <RowDefinition Height="Auto" />
           <RowDefinition Height="Auto" />
       </Grid.RowDefinitions>

       <!-- Stats Row — bound via FeedView -->
       <uer:FeedView Grid.Row="0" Source="{Binding Energy}">
           <DataTemplate>
               <Grid ColumnSpacing="8">
                   <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="*" />
                   </Grid.ColumnDefinitions>
                   <Border Grid.Column="0" Background="{StaticResource OffBrush}" CornerRadius="8"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="8">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="TRIP" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.TripMiles}" Style="{StaticResource HeroStatsValue}" HorizontalAlignment="Center" />
                           <TextBlock Text="mi" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
                   <Border Grid.Column="1" Background="{StaticResource OffBrush}" CornerRadius="8"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="8">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="AVG DRAW" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.AverageDrawWh}" Style="{StaticResource HeroStatsValue}" HorizontalAlignment="Center" />
                           <TextBlock Text="Wh/mi" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
                   <Border Grid.Column="2" Background="{StaticResource OffBrush}" CornerRadius="8"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="8">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="ECONOMY" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.FuelEconomyMiPerKwh}" Style="{StaticResource HeroStatsValue}" HorizontalAlignment="Center" />
                           <TextBlock Text="mi/kWh" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
                   <Border Grid.Column="3" Background="{StaticResource OffBrush}" CornerRadius="8"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="8">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="RANGE" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.RangeMiles}" Style="{StaticResource HeroStatsValue}" HorizontalAlignment="Center" />
                           <TextBlock Text="mi" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
               </Grid>
           </DataTemplate>
       </uer:FeedView>

       <!-- Trip Data Row -->
       <uer:FeedView Grid.Row="1" Source="{Binding Energy}">
           <DataTemplate>
               <Grid ColumnSpacing="8">
                   <Grid.ColumnDefinitions>
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="*" />
                       <ColumnDefinition Width="*" />
                   </Grid.ColumnDefinitions>
                   <Border Grid.Column="0" Background="{StaticResource OffBrush}" CornerRadius="6"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="6">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="TRIP TIME" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.TripDurationHours}" Style="{StaticResource HeroChargeStats}" HorizontalAlignment="Center" />
                           <TextBlock Text="hrs" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
                   <Border Grid.Column="1" Background="{StaticResource OffBrush}" CornerRadius="6"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="6">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="AVG SPEED" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.AverageSpeedMph}" Style="{StaticResource HeroChargeStats}" HorizontalAlignment="Center" />
                           <TextBlock Text="mph" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
                   <Border Grid.Column="2" Background="{StaticResource OffBrush}" CornerRadius="6"
                           BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" Padding="6">
                       <StackPanel HorizontalAlignment="Center">
                           <TextBlock Text="INSTANT" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                           <TextBlock Text="{Binding Data.InstantDrawWh}" Style="{StaticResource HeroChargeStats}" HorizontalAlignment="Center" />
                           <TextBlock Text="Wh/mi" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" HorizontalAlignment="Center" />
                       </StackPanel>
                   </Border>
               </Grid>
           </DataTemplate>
       </uer:FeedView>

       <!-- Power Flow -->
       <Grid Grid.Row="2" HorizontalAlignment="Center">
           <Grid.ColumnDefinitions>
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="Auto" />
               <ColumnDefinition Width="Auto" />
           </Grid.ColumnDefinitions>
           <StackPanel Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center">
               <TextBlock Text="BATTERY" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
               <TextBlock Text="74%" Style="{StaticResource HeroBatteryInline}" HorizontalAlignment="Center" />
           </StackPanel>
           <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" Margin="12,0" VerticalAlignment="Center">
               <Border x:Name="Chev1" Width="14" Height="2" Background="{StaticResource BrightBrush}" CornerRadius="1" Opacity="0.1" />
               <Border x:Name="Chev2" Width="14" Height="2" Background="{StaticResource BrightBrush}" CornerRadius="1" Opacity="0.1" />
               <Border x:Name="Chev3" Width="14" Height="2" Background="{StaticResource BrightBrush}" CornerRadius="1" Opacity="0.1" />
               <Border x:Name="Chev4" Width="14" Height="2" Background="{StaticResource BrightBrush}" CornerRadius="1" Opacity="0.1" />
               <TextBlock x:Name="ChevArrow" Text="&#x25B8;" FontSize="10" Foreground="{StaticResource BrightBrush}" VerticalAlignment="Center" Opacity="0.1" />
           </StackPanel>
           <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
               <TextBlock Text="MOTOR" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
               <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                   <uer:FeedView Source="{Binding Energy}">
                       <DataTemplate>
                           <TextBlock Text="{Binding Data.MotorPowerKw}" Style="{StaticResource HeroBatteryInline}" />
                       </DataTemplate>
                   </uer:FeedView>
                   <TextBlock Text=" kW" Style="{StaticResource PhosphorLabelSmall}"
                              Foreground="{StaticResource DimBrush}"
                              VerticalAlignment="Bottom" Margin="2,0,0,3" />
               </StackPanel>
           </StackPanel>
       </Grid>

       <!-- Section Divider -->
       <Border Grid.Row="3"
               Height="1"
               Background="{StaticResource GhostBrush}"
               Opacity="0.6"
               Margin="0,2,0,2" />

       <!-- Energy Graph -->
       <StackPanel Grid.Row="4" Spacing="4">
           <TextBlock Text="CONSUMPTION — LAST 30 MIN" Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" />
           <Border BorderBrush="{StaticResource GhostBrush}" BorderThickness="1" CornerRadius="4">
               <skia:EnergyGraph Height="120" />
           </Border>
       </StackPanel>
   </Grid>
</UserControl>

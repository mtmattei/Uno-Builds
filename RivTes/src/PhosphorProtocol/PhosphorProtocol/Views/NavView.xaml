<UserControl x:Class="PhosphorProtocol.Views.NavView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:PhosphorProtocol.SkiaControls"
             xmlns:uer="using:Uno.Extensions.Reactive.UI">
  <Grid Background="{StaticResource CRTBrush}">
      <!-- VectorNavMap fills the full background -->
      <skia:VectorNavMap />

      <uer:FeedView Source="{Binding Navigation}">
          <DataTemplate>
              <Grid>
                  <!-- Turn instruction card — top-left -->
                  <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                          Margin="14,16"
                          Background="#ED020707"
                          BorderBrush="{StaticResource BrightBrush}" BorderThickness="1.5"
                          CornerRadius="10" Padding="10,8,16,10">
                      <StackPanel Spacing="3">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                              <TextBlock Text="{Binding Data.NextTurnDirection}" FontSize="24"
                                         Foreground="{StaticResource PeakBrush}"
                                         VerticalAlignment="Center" />
                              <TextBlock Style="{StaticResource HeroFrequency}" VerticalAlignment="Center">
                                  <Run Text="{Binding Data.NextTurnDistance}" /><Run Text=" mi" />
                              </TextBlock>
                          </StackPanel>
                          <TextBlock Text="{Binding Data.NextTurnRoad}"
                                     Style="{StaticResource PhosphorLabelMedium}"
                                     Foreground="{StaticResource BrightBrush}" />
                      </StackPanel>
                  </Border>

                  <!-- Destination overlay — top-right -->
                  <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                          Margin="0,16,14,0"
                          Background="#ED020707"
                          BorderBrush="{StaticResource BrightBrush}" BorderThickness="1.5"
                          CornerRadius="10" Padding="10,8,10,10">
                      <StackPanel Spacing="2">
                          <TextBlock Text="DESTINATION"
                                     Style="{StaticResource PhosphorLabelSmall}"
                                     Foreground="{StaticResource GlowBrush}" />
                          <TextBlock Text="{Binding Data.DestinationName}"
                                     Style="{StaticResource PhosphorBodyMedium}"
                                     Foreground="{StaticResource BloomBrush}" />
                          <TextBlock Text="2.1 mi remaining"
                                     Style="{StaticResource PhosphorLabelSmall}"
                                     Foreground="{StaticResource BrightBrush}"
                                     Margin="0,1,0,0" />
                      </StackPanel>
                  </Border>

                  <!-- ETA display — bottom-right -->
                  <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                          Margin="0,0,14,16"
                          Background="#ED020707"
                          BorderBrush="{StaticResource BrightBrush}" BorderThickness="1.5"
                          CornerRadius="10" Padding="12,8">
                      <StackPanel Spacing="2">
                          <TextBlock Text="ETA"
                                     Style="{StaticResource PhosphorLabelSmall}"
                                     Foreground="{StaticResource GlowBrush}"
                                     HorizontalAlignment="Center" />
                          <TextBlock Text="{Binding Data.ETA}"
                                     Style="{StaticResource HeroClock}"
                                     Foreground="{StaticResource PeakBrush}"
                                     HorizontalAlignment="Center" />
                      </StackPanel>
                  </Border>
              </Grid>
          </DataTemplate>
      </uer:FeedView>
  </Grid>
</UserControl>

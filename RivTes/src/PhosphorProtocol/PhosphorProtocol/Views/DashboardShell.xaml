<Page x:Class="PhosphorProtocol.Views.DashboardShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:PhosphorProtocol.Views"
      xmlns:ctrl="using:PhosphorProtocol.Controls"
      xmlns:skia="using:PhosphorProtocol.SkiaControls"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      Background="{StaticResource LeatherBrush}">

    <Grid>
        <ctrl:CRTFrame>
            <ctrl:CRTFrame.FrameContent>
                <Grid x:Name="RootLayout" uen:Region.Attached="True">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup x:Name="ResponsiveStates">
                            <!-- Wide: full layout (default) -->
                            <VisualState x:Name="WideState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="800" />
                                </VisualState.StateTriggers>
                            </VisualState>
                            <!-- Medium: narrower left panel -->
                            <VisualState x:Name="MediumState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="600" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="LeftPanel.Width" Value="160" />
                                </VisualState.Setters>
                            </VisualState>
                            <!-- Narrow: left panel collapsed -->
                            <VisualState x:Name="NarrowState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="0" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="LeftPanel.Visibility" Value="Collapsed" />
                                    <Setter Target="ClimateBar.Visibility" Value="Collapsed" />
                                    <Setter Target="CompactSpeedOverlay.Visibility" Value="Visible" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>

                    <!-- STATUS BAR -->
                    <Grid Grid.Row="0" Padding="16,0"
                          BorderBrush="{StaticResource GhostBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <TextBlock Text="LTE" Style="{StaticResource PhosphorBodySmall}" Foreground="{StaticResource DimBrush}" />
                            <TextBlock x:Name="LiveClock" Style="{StaticResource HeroClock}" />
                        </StackPanel>

                        <uer:FeedView Grid.Column="1" Grid.ColumnSpan="2" Source="{Binding Vehicle}">
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" VerticalAlignment="Center">
                                        <TextBlock Style="{StaticResource PhosphorLabelMedium}" VerticalAlignment="Center">
                                            <Run Text="{Binding Data.OutsideTemp}" /><Run Text="°F" />
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="P" Style="{StaticResource GearInactive}" VerticalAlignment="Center" />
                                            <TextBlock Text="R" Style="{StaticResource GearInactive}" VerticalAlignment="Center" />
                                            <TextBlock Text="N" Style="{StaticResource GearInactive}" VerticalAlignment="Center" />
                                            <TextBlock Text="D" Style="{StaticResource GearActive}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <ctrl:GCCButton Label="AUTOPILOT" IsActive="{Binding Data.AutopilotActive}" Click="OnAutopilotClick" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <ctrl:BatteryIndicator Percent="{Binding Data.BatteryPercent}" SegmentCount="20" ShowGlow="True" />
                                        <TextBlock Style="{StaticResource PhosphorLabelSmall}" Foreground="{StaticResource DimBrush}" VerticalAlignment="Center">
                                            <Run Text="{Binding Data.RangeMiles}" /><Run Text=" mi" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </uer:FeedView>
                    </Grid>

                    <!-- MAIN CONTENT -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LeftPanel" Width="220" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- LEFT PANEL: Driving Visualization -->
                        <Grid Grid.Column="0" BorderBrush="{StaticResource GhostBorderBrush}" BorderThickness="0,0,1,0">
                            <skia:DrivingVisualization />
                            <uer:FeedView Source="{Binding Vehicle}" IsHitTestVisible="False">
                                <DataTemplate>
                                    <Grid>
                                        <StackPanel Margin="16,12,0,0" VerticalAlignment="Top" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Data.Speed}" Style="{StaticResource HeroSpeed}" />
                                            <TextBlock Text="MPH" Style="{StaticResource PhosphorLabelMedium}" Margin="2,0,0,0" />
                                        </StackPanel>
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Margin="0,12,14,0"
                                                BorderBrush="{StaticResource DimBrush}" BorderThickness="1.5" CornerRadius="7"
                                                Padding="6,4">
                                            <StackPanel HorizontalAlignment="Center">
                                                <TextBlock Text="LIMIT" Style="{StaticResource PhosphorLabelSmall}" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding Data.SpeedLimit}" Style="{StaticResource HeroSpeedLimit}" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </uer:FeedView>
                        </Grid>

                        <!-- RIGHT PANEL: Tabs + Content -->
                        <Grid Grid.Column="1" uen:Region.Attached="True">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Compact speed overlay for narrow mode -->
                            <Border x:Name="CompactSpeedOverlay" Visibility="Collapsed"
                                    HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Margin="8,4,0,0" Padding="8,2"
                                    Background="{StaticResource CRTBrush}"
                                    BorderBrush="{StaticResource GhostBorderBrush}" BorderThickness="1" CornerRadius="6">
                                <uer:FeedView Source="{Binding Vehicle}" IsHitTestVisible="False">
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Data.Speed}" Style="{StaticResource HeroStatsValue}" />
                                            <TextBlock Text="MPH" Style="{StaticResource PhosphorLabelSmall}" VerticalAlignment="Center" Foreground="{StaticResource DimBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </uer:FeedView>
                            </Border>

                            <!-- Tab Bar -->
                            <utu:TabBar x:Name="MainTabBar" Grid.Row="0" uen:Region.Attached="True"
                                        Style="{StaticResource TopTabBarStyle}">
                                <utu:TabBar.Resources>
                                    <!-- Unselected: brighter for accessibility -->
                                    <SolidColorBrush x:Key="TopTabBarItemForeground" Color="{StaticResource GlowColor}" />
                                    <SolidColorBrush x:Key="TopTabBarItemForegroundSelected" Color="{StaticResource PeakColor}" />
                                    <SolidColorBrush x:Key="TopTabBarItemForegroundPointerOver" Color="{StaticResource PeakColor}" />
                                    <SolidColorBrush x:Key="TopTabBarItemForegroundPressed" Color="{StaticResource BrightColor}" />
                                    <SolidColorBrush x:Key="TopTabBarItemBackground" Color="Transparent" />
                                    <SolidColorBrush x:Key="TopTabBarItemBackgroundSelected" Color="#08FFFFFF" />
                                    <SolidColorBrush x:Key="TopTabBarItemBackgroundPointerOver" Color="#06FFFFFF" />
                                    <SolidColorBrush x:Key="MaterialTopTabBarItemActiveIndicatorBrush" Color="{StaticResource PeakColor}" />
                                    <SolidColorBrush x:Key="TopTabBarBackground" Color="Transparent" />
                                </utu:TabBar.Resources>
                                <utu:TabBarItem uen:Region.Name="Nav" Content="NAV" />
                                <utu:TabBarItem uen:Region.Name="Media" Content="MEDIA" />
                                <utu:TabBarItem uen:Region.Name="Energy" Content="ENERGY" />
                                <utu:TabBarItem uen:Region.Name="Charge" Content="CHARGE" />
                                <utu:TabBarItem uen:Region.Name="Controls" Content="CTRL" />
                                <utu:TabBarItem uen:Region.Name="Autopilot" Content="A.I." />
                            </utu:TabBar>

                            <!-- Content Region -->
                            <Grid Grid.Row="1" uen:Region.Attached="True" uen:Region.Navigator="Visibility">
                                <local:NavView uen:Region.Name="Nav" />
                                <local:MediaView uen:Region.Name="Media" />
                                <local:EnergyView uen:Region.Name="Energy" />
                                <local:ChargeView uen:Region.Name="Charge" />
                                <local:ControlsView uen:Region.Name="Controls" />
                                <local:AutopilotView uen:Region.Name="Autopilot" />
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- CLIMATE BAR -->
                    <Grid x:Name="ClimateBar" Grid.Row="2" Padding="8,0"
                          BorderBrush="{StaticResource GhostBorderBrush}" BorderThickness="0,1,0,0"
                          VerticalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" VerticalAlignment="Center">
                            <ctrl:SeatHeaterButton HeatLevel="{Binding SeatHeatLeft}" Side="L" />
                            <Border BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5" CornerRadius="7" Padding="6,3">
                                <ctrl:FanSpeedIndicator Level="{Binding FanSpeed}" />
                            </Border>
                            <ctrl:GCCButton Label="◂" Command="{Binding DecrementTemp}" />
                            <TextBlock Style="{StaticResource HeroTemperature}" MinWidth="48" TextAlignment="Center" VerticalAlignment="Center">
                                <Run Text="{Binding Temperature}" /><Run Text="°" />
                            </TextBlock>
                            <ctrl:GCCButton Label="▸" Command="{Binding IncrementTemp}" />
                            <Border Width="1" Height="20" Background="{StaticResource GhostBorderBrush}" />
                            <ctrl:GCCButton Label="A/C" IsActive="{Binding ACEnabled}" Command="{Binding ToggleAC}" />
                            <ctrl:GCCButton Label="DEFR" IsActive="{Binding DefrostEnabled}" Command="{Binding ToggleDefrost}" />
                            <Border Width="1" Height="20" Background="{StaticResource GhostBorderBrush}" />
                            <ctrl:SeatHeaterButton HeatLevel="{Binding SeatHeatRight}" Side="R" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </ctrl:CRTFrame.FrameContent>
        </ctrl:CRTFrame>

        <!-- Scan line overlay on top of everything -->
        <ctrl:ScanLineOverlay IsHitTestVisible="False" />
    </Grid>
</Page>

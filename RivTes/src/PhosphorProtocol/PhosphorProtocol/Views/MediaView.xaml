<UserControl x:Class="PhosphorProtocol.Views.MediaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:skia="using:PhosphorProtocol.SkiaControls"
             xmlns:uer="using:Uno.Extensions.Reactive.UI">
    <ScrollViewer>
        <StackPanel Padding="14,16,14,18" Spacing="14">

            <!-- Source Selector -->
            <StackPanel Orientation="Horizontal" Spacing="6">
                <!-- Active source: FM -->
                <Border BorderBrush="{StaticResource BrightBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="12,5"
                        Background="{StaticResource PeakSubtleGlowBrush}">
                    <TextBlock Text="FM" Style="{StaticResource PhosphorLabelMedium}"
                               Foreground="{StaticResource PeakBrush}" />
                </Border>
                <!-- Inactive sources -->
                <Border BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="12,5">
                    <TextBlock Text="STREAM" Style="{StaticResource PhosphorLabelMedium}"
                               Foreground="{StaticResource DimBrush}" />
                </Border>
                <Border BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="12,5">
                    <TextBlock Text="BT" Style="{StaticResource PhosphorLabelMedium}"
                               Foreground="{StaticResource DimBrush}" />
                </Border>
                <Border BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="12,5">
                    <TextBlock Text="USB" Style="{StaticResource PhosphorLabelMedium}"
                               Foreground="{StaticResource DimBrush}" />
                </Border>
            </StackPanel>

            <!-- Now Playing Card -->
            <Border Background="{StaticResource OffBrush}" CornerRadius="10"
                    BorderBrush="{StaticResource GlowBrush}" BorderThickness="1"
                    Padding="14,16">
                <uer:FeedView Source="{Binding Media}">
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="64" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Album Art Placeholder — 64×64 with GlowBrush accent -->
                            <Border Grid.Column="0"
                                    Width="64" Height="64" CornerRadius="10"
                                    BorderBrush="{StaticResource GlowBrush}" BorderThickness="1.5"
                                    Background="{StaticResource GhostBrush}">
                                <TextBlock Text="♫" FontSize="24"
                                           Foreground="{StaticResource GlowBrush}"
                                           Opacity="0.85"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>

                            <!-- Track Info -->
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" Spacing="4">
                                <TextBlock Text="{Binding Data.TrackTitle}"
                                           Style="{StaticResource PhosphorBodyLarge}"
                                           Foreground="{StaticResource BloomBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Data.Artist}"
                                           Style="{StaticResource PhosphorBodySmall}"
                                           Foreground="{StaticResource BrightBrush}" />

                                <!-- Progress bar -->
                                <ProgressBar Value="35" Maximum="100" Height="2"
                                             Background="{StaticResource GhostBrush}"
                                             Foreground="{StaticResource GlowBrush}"
                                             Margin="0,8,0,0" />
                                <Grid Margin="0,1,0,0">
                                    <TextBlock Text="{Binding Data.Position}"
                                               Style="{StaticResource PhosphorLabelSmall}"
                                               HorizontalAlignment="Left" />
                                    <TextBlock Text="{Binding Data.Duration}"
                                               Style="{StaticResource PhosphorLabelSmall}"
                                               HorizontalAlignment="Right" />
                                </Grid>

                                <!-- Transport Controls -->
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="18" Margin="0,8,0,0">
                                    <!-- Skip back -->
                                    <TextBlock Text="◂◂" FontSize="14"
                                               Foreground="{StaticResource BrightBrush}"
                                               VerticalAlignment="Center" />
                                    <!-- Play button — 40×40 with PeakBrush border -->
                                    <Border BorderBrush="{StaticResource PeakBrush}"
                                            BorderThickness="1.5" CornerRadius="20"
                                            Width="40" Height="40"
                                            Background="{StaticResource PeakSubtleGlowBrush}">
                                        <TextBlock Text="▸" FontSize="18"
                                                   Foreground="{StaticResource PeakBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Skip forward -->
                                    <TextBlock Text="▸▸" FontSize="14"
                                               Foreground="{StaticResource BrightBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </uer:FeedView>
            </Border>

            <!-- Spectrum Visualizer -->
            <skia:SpectrumVisualizer Height="44" />

            <!-- FM Presets -->
            <TextBlock Text="FM PRESETS"
                       Style="{StaticResource PhosphorLabelSmall}"
                       Foreground="{StaticResource GlowBrush}"
                       Margin="0,2,0,0" />
            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Active preset: 98.1 CHFI — brighter treatment -->
                <Border Grid.Column="0" Grid.Row="0"
                        BorderBrush="{StaticResource BrightBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8"
                        Background="{StaticResource PeakSubtleGlowBrush}"
                        HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="98.1" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource PeakBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="CHFI" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Inactive presets -->
                <Border Grid.Column="1" Grid.Row="0"
                        BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="99.9" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="CKFM" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Grid.Row="0"
                        BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="102.1" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="EDGE" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="0" Grid.Row="1"
                        BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="104.5" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="CHUM" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Grid.Row="1"
                        BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="107.1" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="CILQ" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Grid.Row="1"
                        BorderBrush="{StaticResource GhostBrush}" BorderThickness="1.5"
                        CornerRadius="7" Padding="6,8" HorizontalAlignment="Stretch">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="88.1" Style="{StaticResource HeroFrequency}"
                                   Foreground="{StaticResource BrightBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="CKLN" Style="{StaticResource PhosphorLabelSmall}"
                                   Foreground="{StaticResource DimBrush}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl x:Class="PhosphorProtocol.Controls.BatteryIndicator"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <Border x:Name="GlowBorder" Visibility="Collapsed"
                CornerRadius="4" Margin="-4" IsHitTestVisible="False" />
        <StackPanel x:Name="SegmentPanel" Orientation="Horizontal" Spacing="2"
                    VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
    </Grid>
</UserControl>

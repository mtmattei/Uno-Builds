<UserControl x:Class="PhosphorProtocol.Controls.CRTFrame"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Leather surround -->
    <Grid Background="{StaticResource LeatherBrush}">
        <!-- Walnut trim top -->
        <Border Height="7"
                VerticalAlignment="Top"
                Background="{StaticResource WalnutBrush}" />
        <!-- Walnut trim bottom -->
        <Border Height="7"
                VerticalAlignment="Bottom"
                Background="{StaticResource WalnutBrush}" />

        <!-- Chrome outer bezel -->
        <Border Margin="12,14"
                Background="{StaticResource ChromeMidBrush}"
                BorderBrush="{StaticResource ChromeHotBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="4">
            <!-- Dark plastic bezel -->
            <Border Background="#121010"
                    BorderBrush="#1E1C18"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="2">
                <!-- CRT glass area -->
                <Grid>
                    <Border Background="{StaticResource CRTBrush}"
                            CornerRadius="11">
                        <ContentPresenter x:Name="InnerContent"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch" />
                    </Border>

                    <!-- Vignette -->
                    <Border CornerRadius="11"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush>
                                <GradientStop Color="Transparent" Offset="0.5" />
                                <GradientStop Color="#1E000000" Offset="0.78" />
                                <GradientStop Color="#61000000" Offset="1.0" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Glass reflection -->
                    <Border CornerRadius="11"
                            Opacity="0.018"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="White" Offset="0" />
                                <GradientStop Color="Transparent" Offset="0.4" />
                                <GradientStop Color="Transparent" Offset="0.8" />
                                <GradientStop Color="White" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>
            </Border>
        </Border>

        <!-- Embossed label -->
        <TextBlock Text="GRAPHIC CONTROL CENTER &#x2014; RIVIERA EDITION"
                   FontSize="7"
                   CharacterSpacing="450"
                   Foreground="#24201A"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,3" />
    </Grid>
</UserControl>

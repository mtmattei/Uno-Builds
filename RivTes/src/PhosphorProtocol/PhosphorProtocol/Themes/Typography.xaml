<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font Family Definitions -->
    <FontFamily x:Key="ShareTechMonoFont">ms-appx:///Assets/Fonts/ShareTechMono-Regular.ttf#Share Tech Mono</FontFamily>
    <FontFamily x:Key="OrbitronFont">ms-appx:///Assets/Fonts/Orbitron-Regular.ttf#Orbitron</FontFamily>
    <FontFamily x:Key="GreatVibesFont">ms-appx:///Assets/Fonts/GreatVibes-Regular.ttf#Great Vibes</FontFamily>

    <!-- Elegant Script Style (Boot Screen Title) -->
    <Style x:Key="RivieraScript" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GreatVibesFont}" />
        <Setter Property="FontSize" Value="42" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="RivieraScriptSubtitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource GreatVibesFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource BrightBrush}" />
    </Style>

    <!-- Interface Text Styles (Share Tech Mono) -->
    <Style x:Key="PhosphorLabelSmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="CharacterSpacing" Value="140" />
        <Setter Property="Foreground" Value="{StaticResource GhostBrush}" />
    </Style>

    <Style x:Key="PhosphorLabelMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
    </Style>

    <Style x:Key="PhosphorLabelLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{StaticResource BrightBrush}" />
    </Style>

    <Style x:Key="PhosphorBodySmall" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource DimBrush}" />
    </Style>

    <Style x:Key="PhosphorBodyMedium" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource GlowBrush}" />
    </Style>

    <Style x:Key="PhosphorBodyLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ShareTechMonoFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CharacterSpacing" Value="40" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <!-- Hero Numeral Styles (Orbitron) -->
    <Style x:Key="HeroSpeed" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="50" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroTemperature" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroFrequency" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroBatteryInline" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroBatteryLarge" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="56" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroClock" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource GlowBrush}" />
    </Style>

    <Style x:Key="HeroSpeedLimit" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource GlowBrush}" />
    </Style>

    <Style x:Key="HeroStatsValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

    <Style x:Key="HeroChargeStats" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource BrightBrush}" />
    </Style>

    <!-- Gear Selector Styles -->
    <Style x:Key="GearInactive" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{StaticResource GhostBrush}" />
    </Style>

    <Style x:Key="GearActive" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource OrbitronFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{StaticResource PeakBrush}" />
    </Style>

</ResourceDictionary>

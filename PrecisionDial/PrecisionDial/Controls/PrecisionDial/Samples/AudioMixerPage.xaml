<Page
    x:Class="PrecisionDial.Samples.AudioMixerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrecisionDial.Controls"
    xmlns:samples="using:PrecisionDial.Samples"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Controls/PrecisionDial/Theme/PrecisionDialResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Padding="32">
        <Grid.Background>
            <RadialGradientBrush Center="0.5,0.4" RadiusX="0.7" RadiusY="0.7">
                <GradientStop Color="#141416" Offset="0" />
                <GradientStop Color="#0a0a0b" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="MIXER" Style="{StaticResource LabelSmall}"
                   Foreground="#40FFFFFF" Margin="0,0,0,32" CharacterSpacing="300" />

        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" ColumnSpacing="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="VOLUME" Foreground="#40FFFFFF" HorizontalAlignment="Center"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}" />
                <controls:PrecisionDial Value="{Binding Volume, Mode=TwoWay}" Minimum="0" Maximum="100"
                    DetentCount="20" IsHapticEnabled="True" AccentBrush="{StaticResource DialAccentBrush}"
                    Width="200" Height="200" AutomationProperties.Name="Volume" />
                <TextBlock Foreground="#80FFFFFF" HorizontalAlignment="Center" Style="{StaticResource BodyLarge}">
                    <Run Text="{Binding Volume}" />
                </TextBlock>
                <samples:SegmentBar Value="{Binding Volume}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="BASS" Foreground="#40FFFFFF" HorizontalAlignment="Center"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}" />
                <controls:PrecisionDial Value="{Binding Bass, Mode=TwoWay}" Minimum="0" Maximum="100"
                    DetentCount="10" IsHapticEnabled="True" AccentBrush="{StaticResource DialAccentBrush}"
                    Width="160" Height="160" AutomationProperties.Name="Bass" />
                <TextBlock Foreground="#80FFFFFF" HorizontalAlignment="Center" Style="{StaticResource BodyLarge}">
                    <Run Text="{Binding Bass}" />
                </TextBlock>
                <samples:SegmentBar Value="{Binding Bass}" HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="2" Spacing="12" HorizontalAlignment="Center">
                <TextBlock Text="TREBLE" Foreground="#40FFFFFF" HorizontalAlignment="Center"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}" />
                <controls:PrecisionDial Value="{Binding Treble, Mode=TwoWay}" Minimum="0" Maximum="100"
                    DetentCount="10" IsHapticEnabled="True" AccentBrush="{StaticResource DialAccentBrush}"
                    Width="160" Height="160" AutomationProperties.Name="Treble" />
                <TextBlock Foreground="#80FFFFFF" HorizontalAlignment="Center" Style="{StaticResource BodyLarge}">
                    <Run Text="{Binding Treble}" />
                </TextBlock>
                <samples:SegmentBar Value="{Binding Treble}" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>

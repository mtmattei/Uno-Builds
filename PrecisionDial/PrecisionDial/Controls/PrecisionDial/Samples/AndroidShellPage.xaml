<Page x:Class="PrecisionDial.Samples.AndroidShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrecisionDial.Controls"
    NavigationCacheMode="Required">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Controls/PrecisionDial/Theme/PrecisionDialResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Page.Background>
        <RadialGradientBrush Center="0.5,0.4" RadiusX="0.9" RadiusY="0.9">
            <GradientStop Color="#141416" Offset="0" />
            <GradientStop Color="#0a0a0b" Offset="1" />
        </RadialGradientBrush>
    </Page.Background>

    <Grid>
        <!-- Layer 0: ambient traveling-light perimeter — appears proportionally
             with the dial lift, controlled from code-behind. -->
        <controls:PerimeterLightCanvas
            x:Name="LightBorder"
            AccentBrush="{StaticResource DialAccentBrush}"
            CycleSeconds="11"
            Opacity="0"
            Visibility="Collapsed" />

        <!-- Top label / app name -->
        <TextBlock Text="PRECISION"
                   Foreground="#33FFFFFF" CharacterSpacing="400"
                   Style="{StaticResource LabelSmall}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,80,0,0" />

        <!-- Current selection — large readout in the upper-middle.
             The label is the only animated text — it slides + fades on change.
             SelectionLabel has its own RenderTransform / Opacity driven from
             code-behind via the SpringSolver in the page. -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,0,0,80"
                    Spacing="12">
            <TextBlock Text="NOW PLAYING"
                       Foreground="#22FFFFFF"
                       CharacterSpacing="300"
                       Style="{StaticResource LabelSmall}"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SelectionLabel"
                       Text="MUSIC"
                       Foreground="#FFD4A959"
                       FontSize="42"
                       FontWeight="Light"
                       CharacterSpacing="300"
                       HorizontalAlignment="Center"
                       Opacity="1">
                <TextBlock.RenderTransform>
                    <TranslateTransform x:Name="SelectionLabelTranslate" Y="0" />
                </TextBlock.RenderTransform>
            </TextBlock>
        </StackPanel>

        <!-- Hint text just above the peeking dial -->
        <TextBlock x:Name="HintText"
                   Text="TAP TO REVEAL · HOLD FOR VOLUME"
                   Foreground="#22FFFFFF"
                   CharacterSpacing="300"
                   Style="{StaticResource LabelSmall}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,200" />

        <!-- Backdrop: full-screen tap target that dismisses the sheet when
             the user taps anywhere outside the dial. IsHitTestVisible is
             toggled in code-behind based on lift state. Placed BEFORE the
             dial container in the visual tree so the dial (later sibling)
             draws and hit-tests on top. -->
        <Border x:Name="Backdrop"
                Background="Transparent"
                IsHitTestVisible="False"
                Tapped="OnBackdropTapped" />

        <!-- Bottom-sheet dial container — translates up/down with spring physics -->
        <Grid x:Name="DialContainer"
              Width="300" Height="300"
              HorizontalAlignment="Center"
              VerticalAlignment="Bottom"
              Margin="0,0,0,-20">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="DialTranslate" Y="170" />
            </Grid.RenderTransform>

            <controls:PrecisionDial x:Name="ModeDial"
                DialMode="Menu"
                IsHapticEnabled="True"
                Width="300" Height="300"
                AccentBrush="{StaticResource DialAccentBrush}" />

            <!-- Tap shield — sits over the dial; absorbs taps to lift the sheet
                 while it is collapsed. Short tap = menu mode, long press =
                 volume mode. Disabled (hit-test off) once lifted so the dial
                 gets pointer events for rotation. -->
            <Border x:Name="TapShield"
                    Background="Transparent"
                    Tapped="OnShieldTapped"
                    Holding="OnShieldHolding" />
        </Grid>
    </Grid>
</Page>

<Page x:Class="PrecisionDial.Samples.StudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrecisionDial.Controls"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Controls/PrecisionDial/Theme/PrecisionDialResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Page.Background>
        <RadialGradientBrush Center="0.5,0.4" RadiusX="0.7" RadiusY="0.7">
            <GradientStop Color="#141416" Offset="0" />
            <GradientStop Color="#0a0a0b" Offset="1" />
        </RadialGradientBrush>
    </Page.Background>

    <ScrollViewer>
        <Grid Padding="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="STUDIO"
                       Foreground="#33FFFFFF" CharacterSpacing="300"
                       Style="{StaticResource LabelSmall}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,40" />

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="64">

                <!-- ── Menu dial — DialMode=Menu, cone-of-light ── -->
                <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Top">
                    <TextBlock Text="MODE"
                               Foreground="#33FFFFFF" CharacterSpacing="300"
                               Style="{StaticResource LabelSmall}"
                               HorizontalAlignment="Center" />
                    <controls:PrecisionDial x:Name="ModeDial"
                        DialMode="Menu"
                        IsHapticEnabled="True"
                        Width="240" Height="240"
                        AccentBrush="{StaticResource DialAccentBrush}" />
                    <TextBlock x:Name="ModeReadout"
                               Text="MUSIC"
                               Foreground="#FFD4A959"
                               FontSize="14"
                               CharacterSpacing="300"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- ── Mixer rack — three value-mode dials ── -->
                <StackPanel Spacing="20" VerticalAlignment="Top">
                    <TextBlock Text="MIXER"
                               Foreground="#33FFFFFF" CharacterSpacing="300"
                               Style="{StaticResource LabelSmall}"
                               HorizontalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="32" HorizontalAlignment="Center">

                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="VOLUME"
                                       Foreground="#33FFFFFF" CharacterSpacing="200"
                                       Style="{StaticResource LabelSmall}"
                                       HorizontalAlignment="Center" />
                            <controls:PrecisionDial x:Name="VolumeDial"
                                Value="65" Minimum="0" Maximum="100" DetentCount="20"
                                IsHapticEnabled="True"
                                Width="140" Height="140"
                                AccentBrush="{StaticResource DialAccentBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="BASS"
                                       Foreground="#33FFFFFF" CharacterSpacing="200"
                                       Style="{StaticResource LabelSmall}"
                                       HorizontalAlignment="Center" />
                            <controls:PrecisionDial x:Name="BassDial"
                                Value="40" Minimum="0" Maximum="100" DetentCount="20"
                                IsHapticEnabled="True"
                                Width="140" Height="140"
                                AccentBrush="{StaticResource DialAccentBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="TREBLE"
                                       Foreground="#33FFFFFF" CharacterSpacing="200"
                                       Style="{StaticResource LabelSmall}"
                                       HorizontalAlignment="Center" />
                            <controls:PrecisionDial x:Name="TrebleDial"
                                Value="55" Minimum="0" Maximum="100" DetentCount="20"
                                IsHapticEnabled="True"
                                Width="140" Height="140"
                                AccentBrush="{StaticResource DialAccentBrush}" />
                        </StackPanel>

                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

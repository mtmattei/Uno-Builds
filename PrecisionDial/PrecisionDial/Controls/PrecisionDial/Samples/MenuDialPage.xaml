<Page x:Class="PrecisionDial.Samples.MenuDialPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrecisionDial.Controls"
    xmlns:samples="using:PrecisionDial.Samples"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Controls/PrecisionDial/Theme/PrecisionDialResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Page.Background>
        <RadialGradientBrush Center="0.5,0.4" RadiusX="0.7" RadiusY="0.7">
            <GradientStop Color="#141416" Offset="0" />
            <GradientStop Color="#0a0a0b" Offset="1" />
        </RadialGradientBrush>
    </Page.Background>

    <ScrollViewer>
        <StackPanel Padding="40" Spacing="56" HorizontalAlignment="Center">

            <TextBlock Text="MENU DIAL"
                       Foreground="#33FFFFFF" CharacterSpacing="300"
                       Style="{StaticResource LabelSmall}"
                       HorizontalAlignment="Center" />

            <!-- Navigation dial: 6 items -->
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="NAVIGATION" Foreground="#33FFFFFF"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}" />
                <controls:PrecisionMenuDial x:Name="NavDial"
                    DialSize="200"
                    AccentBrush="{StaticResource DialAccentBrush}" />
                <samples:IlluminatedReadout x:Name="NavReadout" Value="1" />
            </StackPanel>

            <!-- Quality dial: 4 items -->
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="QUALITY" Foreground="#33FFFFFF"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}" />
                <controls:PrecisionMenuDial x:Name="QualityDial"
                    DialSize="160"
                    AccentBrush="{StaticResource DialAccentBrush}" />
                <samples:IlluminatedReadout x:Name="QualityReadout" Value="1" />
            </StackPanel>

            <TextBlock Text="Drag up / down · Each detent is a menu position"
                       Foreground="#22FFFFFF" HorizontalAlignment="Center"
                       Style="{StaticResource LabelSmall}" CharacterSpacing="200" />

            <!-- ARC SELECTOR — icon only, reveals current selection -->
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <TextBlock Text="ARC SELECTOR" Foreground="#33FFFFFF"
                           CharacterSpacing="300" Style="{StaticResource LabelSmall}"
                           HorizontalAlignment="Center" />
                <Canvas Width="380" Height="280">
                    <!-- Dial center at canvas (190, 160); Canvas.Left=100, Canvas.Top=70 -->
                    <controls:PrecisionDial x:Name="ArcDial"
                        Value="2" Minimum="0" Maximum="4" DetentCount="4"
                        IsHapticEnabled="True" Width="180" Height="180"
                        AccentBrush="{StaticResource DialAccentBrush}"
                        Canvas.Left="100" Canvas.Top="70" />
                    <!-- All icons start hidden; reveal only the currently selected one. -->
                    <!-- -60° from top: center (68.8, 90) -->
                    <TextBlock x:Name="ArcPlay" Text="&#xE768;"
                               FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FFD4A959" Opacity="0"
                               Width="40" TextAlignment="Center"
                               Canvas.Left="49" Canvas.Top="74" />
                    <!-- -30° from top: center (120, 38.8) -->
                    <TextBlock x:Name="ArcPause" Text="&#xE769;"
                               FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FFD4A959" Opacity="0"
                               Width="40" TextAlignment="Center"
                               Canvas.Left="100" Canvas.Top="22" />
                    <!-- 0° from top: center (190, 20) -->
                    <TextBlock x:Name="ArcSkip" Text="&#xE893;"
                               FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FFD4A959" Opacity="0"
                               Width="40" TextAlignment="Center"
                               Canvas.Left="170" Canvas.Top="4" />
                    <!-- 30° from top: center (260, 38.8) -->
                    <TextBlock x:Name="ArcShuffle" Text="&#xE8B1;"
                               FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FFD4A959" Opacity="0"
                               Width="40" TextAlignment="Center"
                               Canvas.Left="240" Canvas.Top="22" />
                    <!-- 60° from top: center (311.2, 90) -->
                    <TextBlock x:Name="ArcRepeat" Text="&#xE8EE;"
                               FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FFD4A959" Opacity="0"
                               Width="40" TextAlignment="Center"
                               Canvas.Left="291" Canvas.Top="74" />
                </Canvas>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>

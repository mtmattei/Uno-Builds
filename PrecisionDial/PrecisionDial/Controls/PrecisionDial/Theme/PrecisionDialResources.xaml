<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="DialAccentColor">#d4a959</Color>
    <SolidColorBrush x:Key="DialAccentBrush" Color="{StaticResource DialAccentColor}" />
    <x:Double x:Key="DialAccentGlowOpacity">0.25</x:Double>
    <Color x:Key="DialKnobBaseColor">#2a2a2b</Color>
    <Color x:Key="DialKnobHighlightColor">#323233</Color>
    <Color x:Key="DialBezelDarkColor">#0a0a0b</Color>
    <Color x:Key="DialBezelLightColor">#1e1e1f</Color>
    <Color x:Key="DialCenterDimpleColor">#3a3a3b</Color>
    <Color x:Key="DialTrackColor">#19FFFFFF</Color>
    <SolidColorBrush x:Key="DialTrackBrush" Color="{StaticResource DialTrackColor}" />
    <x:Double x:Key="DialTickActiveMajorOpacity">0.8</x:Double>
    <x:Double x:Key="DialTickActiveMinorOpacity">0.4</x:Double>
    <x:Double x:Key="DialTickInactiveMajorOpacity">0.12</x:Double>
    <x:Double x:Key="DialTickInactiveMinorOpacity">0.05</x:Double>
    <Color x:Key="DialReadoutBaseColor">#80FFFFFF</Color>
    <Color x:Key="DialReadoutFullColor">#E0FFFFFF</Color>
    <SolidColorBrush x:Key="DialReadoutBrush" Color="{StaticResource DialReadoutBaseColor}" />
    <x:Double x:Key="DialPulseStrokeOpacity">0.15</x:Double>
    <x:Double x:Key="DialPulseDurationMs">150</x:Double>
    <x:Double x:Key="DialOuterPadding">14</x:Double>
    <x:Double x:Key="DialIndicatorWidth">2.5</x:Double>
    <x:Double x:Key="DialCenterDimpleRadius">6</x:Double>
    <x:Double x:Key="DialDefaultSize">200</x:Double>
    <x:Double x:Key="DialMinSize">120</x:Double>
    <x:Double x:Key="DialMaxSize">280</x:Double>
    <x:Double x:Key="DialSegmentWidth">6</x:Double>
    <x:Double x:Key="DialSegmentHeight">2</x:Double>
    <x:Double x:Key="DialSegmentGap">2</x:Double>
    <Color x:Key="DialSegmentInactiveColor">#0FFFFFFF</Color>
    <Color x:Key="DialSegmentHotColor">#D18C46</Color>

    <!-- ── v2 Tokens ── -->
    <x:Double x:Key="DialKnurlLineCount">160</x:Double>
    <x:Double x:Key="DialKnurlStrokeOpacity">0.04</x:Double>
    <x:Double x:Key="DialKnurlStrokeWidth">0.6</x:Double>
    <x:Double x:Key="DialBrushedLineCount">80</x:Double>
    <x:Double x:Key="DialCausticOpacity">0.07</x:Double>
    <x:Double x:Key="DialCausticAngle">-40</x:Double>
    <x:Double x:Key="DialParticleMaxPool">32</x:Double>
    <x:Double x:Key="DialParticleGlowRadius">2</x:Double>
    <x:Double x:Key="DialSpringStiffness">400</x:Double>
    <x:Double x:Key="DialSpringDamping">30</x:Double>
    <x:Double x:Key="DialInertiaDecayDefault">0.92</x:Double>
    <x:Double x:Key="DialVelocityThreshold">0.5</x:Double>

    <!-- ── v3 Tokens ── -->
    <x:Double x:Key="DialSegmentGapDeg">2.2</x:Double>
    <x:Double x:Key="DialMenuSegmentGapDeg">2.4</x:Double>
    <x:Double x:Key="DialConeBlurSigma1">18</x:Double>
    <x:Double x:Key="DialConeBlurSigma2">10</x:Double>
    <x:Double x:Key="DialConeBlurSigma3">5</x:Double>
    <x:Double x:Key="DialConeOpacity1">0.09</x:Double>
    <x:Double x:Key="DialConeOpacity2">0.06</x:Double>
    <x:Double x:Key="DialConeOpacity3">0.04</x:Double>
    <x:Double x:Key="DialConeWidthMultiplier">1.6</x:Double>
    <x:Double x:Key="DialClippedGrainOpacity">0.02</x:Double>
    <x:Double x:Key="DialOrbitingValueMinSize">56</x:Double>
    <x:Double x:Key="DialBrushedMetalMinSize">60</x:Double>
    <x:Double x:Key="DialMenuIconMinSize">60</x:Double>
    <x:Double x:Key="DialReadoutMinSize">72</x:Double>
    <x:Double x:Key="DialMenuLabelMinSize">96</x:Double>
</ResourceDictionary>

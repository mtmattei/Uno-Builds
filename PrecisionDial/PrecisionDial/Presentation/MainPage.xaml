<Page x:Class="PrecisionDial.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      NavigationCacheMode="Required"
      Background="#0a0a0b">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Tab bar -->
        <Border Grid.Row="0" Height="48"
                BorderBrush="#14FFFFFF" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Spacing="48">
                <TextBlock x:Name="TabMixerText" Text="MIXER"
                           Foreground="#FFD4A959" CharacterSpacing="300"
                           Style="{StaticResource LabelSmall}"
                           Tapped="OnTabMixerTapped" />
                <TextBlock x:Name="TabMenuText" Text="MENU"
                           Foreground="#40FFFFFF" CharacterSpacing="300"
                           Style="{StaticResource LabelSmall}"
                           Tapped="OnTabMenuTapped" />
                <TextBlock x:Name="TabStudioText" Text="STUDIO"
                           Foreground="#40FFFFFF" CharacterSpacing="300"
                           Style="{StaticResource LabelSmall}"
                           Tapped="OnTabStudioTapped" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Frame x:Name="ContentFrame" Grid.Row="1" />
    </Grid>
</Page>

<Page x:Class="ClaudeDash.Views.CostsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="16" MaxWidth="1400">

            <!-- Header -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x03BB;"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentLightBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="costs"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Token usage and estimated cost breakdown by model and project."
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- Stat cards -->
            <Grid RowSpacing="1" ColumnSpacing="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <controls:StatCard Grid.Row="0" Grid.Column="0"
                                   Label="THIS MONTH"
                                   IconGlyph="&#xE8EC;"
                                   Subtitle="{Binding Summary.MonthTotal}" />
                <controls:StatCard Grid.Row="0" Grid.Column="1"
                                   Label="DAILY AVG"
                                   IconGlyph="&#xE916;"
                                   Subtitle="{Binding Summary.DailyAvg}" />
                <controls:StatCard Grid.Row="1" Grid.Column="0"
                                   Label="TOKENS USED"
                                   IconGlyph="&#xE8EC;"
                                   Subtitle="{Binding Summary.TokensUsed}" />
                <controls:StatCard Grid.Row="1" Grid.Column="1"
                                   Label="VS LAST MONTH"
                                   IconGlyph="&#xE8AB;"
                                   Subtitle="{Binding Summary.VsLastMonth}" />
            </Grid>

            <!-- Cost by model -->
            <TextBlock Text="BY MODEL"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <ItemsRepeater ItemsSource="{Binding CostByModel}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding ModelName}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="12"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="$" /><Run Text="{Binding Amount}" />
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</Page>

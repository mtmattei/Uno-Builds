<Page x:Class="ClaudeDash.Views.SessionReplayPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:timeline="using:ClaudeDash.Models.Timeline"
      xmlns:vm="using:ClaudeDash.ViewModels"
      Background="{StaticResource AppBackgroundBrush}">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top bar: session info + back button -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Back + title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="4" Click="BackButton_Click"
                            ToolTipService.ToolTip="Back to Sessions">
                        <FontIcon Glyph="&#xE72B;" FontSize="14"
                                  Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                    <TextBlock Text="&#x25B6; SESSION REPLAY"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGreenBrush}"
                               CharacterSpacing="60"
                               VerticalAlignment="Center" />
                    <Border Background="{StaticResource SurfaceBackgroundBrush}"
                            CornerRadius="3" Padding="6,2"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock x:Name="SessionIdBadge"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Border>
                </StackPanel>

                <!-- Session metadata -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="ProjectText"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                    <TextBlock x:Name="BranchText"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                    <TextBlock x:Name="DurationLabel"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                    <TextBlock x:Name="CostLabel"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Stats bar -->
        <Border Grid.Row="1"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,6">
            <TextBlock x:Name="StatsBar"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}" />
        </Border>

        <!-- Main content: 2-panel layout -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="240" />
            </Grid.ColumnDefinitions>

            <!-- Loading state -->
            <StackPanel x:Name="LoadingPanel" Grid.ColumnSpan="2"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12">
                <ProgressRing IsActive="True" Width="32" Height="32" />
                <TextBlock x:Name="LoadingText"
                           FontFamily="Cascadia Code, Consolas, monospace"
                           FontSize="12"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Left panel: conversation timeline -->
            <ListView Grid.Column="0"
                      x:Name="TimelineList"
                      Background="Transparent"
                      Padding="20,12"
                      SelectionMode="Single"
                      SelectionChanged="TimelineList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="timeline:TimelineEntry">
                        <Grid Padding="8,6" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Entry index -->
                            <TextBlock Grid.Column="0"
                                       Text="{x:Bind Index}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="9"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Top"
                                       MinWidth="28"
                                       TextAlignment="Right" />

                            <!-- Type indicator -->
                            <Border Grid.Column="1" CornerRadius="2" Padding="4,1"
                                    VerticalAlignment="Top"
                                    MinWidth="40">
                                <TextBlock x:Name="TypeBadge"
                                           FontFamily="Cascadia Code, Consolas, monospace"
                                           FontSize="9"
                                           HorizontalAlignment="Center" />
                            </Border>

                            <!-- Content -->
                            <TextBlock Grid.Column="2"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       MaxLines="4"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Top" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- Right panel: file activity tree -->
            <Border Grid.Column="1"
                    Background="{StaticResource SurfaceBackgroundBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- File panel header -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8B7;" FontSize="12"
                                      Foreground="{StaticResource TextTertiaryBrush}" />
                            <TextBlock Text="FILES TOUCHED"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="10" FontWeight="SemiBold"
                                       CharacterSpacing="60"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                            <TextBlock x:Name="FileCountBadge"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- File list -->
                    <ListView Grid.Row="1"
                              x:Name="FilesList"
                              Background="Transparent"
                              Padding="4"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileActivityRecord">
                                <Grid Padding="8,5" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Hot indicator -->
                                    <Ellipse Grid.Column="0"
                                             Width="6" Height="6"
                                             VerticalAlignment="Center" />

                                    <!-- File name + directory -->
                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock Text="{x:Bind FileName}"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind Directory}"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="8"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <!-- Edit count -->
                                    <Border Grid.Column="2"
                                            Background="{StaticResource SurfaceBackgroundBrush}"
                                            CornerRadius="3" Padding="4,1"
                                            BorderBrush="{StaticResource BorderDefaultBrush}"
                                            BorderThickness="1"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind EditCount}"
                                                   FontFamily="Cascadia Code, Consolas, monospace"
                                                   FontSize="9"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom: playback controls + scrubber -->
        <Border Grid.Row="3"
                Background="{StaticResource SurfaceBackgroundBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,8">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Playback buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4"
                            VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="6,4" Click="JumpToStart_Click"
                            ToolTipService.ToolTip="Jump to start">
                        <FontIcon Glyph="&#xE892;" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="6,4" Click="StepBack_Click"
                            ToolTipService.ToolTip="Step back">
                        <FontIcon Glyph="&#xE76B;" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                    <Button x:Name="PlayPauseButton"
                            Background="Transparent" BorderThickness="0"
                            Padding="8,4" Click="PlayPause_Click"
                            ToolTipService.ToolTip="Play / Pause">
                        <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="16"
                                  Foreground="{StaticResource AccentGreenBrush}" />
                    </Button>
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="6,4" Click="StepForward_Click"
                            ToolTipService.ToolTip="Step forward">
                        <FontIcon Glyph="&#xE76C;" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="6,4" Click="JumpToEnd_Click"
                            ToolTipService.ToolTip="Jump to end">
                        <FontIcon Glyph="&#xE893;" FontSize="12"
                                  Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                    <Button Background="Transparent" BorderThickness="0"
                            Padding="6,4" Click="Speed_Click"
                            ToolTipService.ToolTip="Change speed">
                        <TextBlock x:Name="SpeedLabel"
                                   Text="1x"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                    </Button>
                </StackPanel>

                <!-- Timeline scrubber -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Slider x:Name="TimelineScrubber"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            ValueChanged="Scrubber_ValueChanged"
                            IsThumbToolTipEnabled="False" />
                </Grid>

                <!-- Position display -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="PositionText"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextTertiaryBrush}" />
                    <TextBlock x:Name="TimestampText"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

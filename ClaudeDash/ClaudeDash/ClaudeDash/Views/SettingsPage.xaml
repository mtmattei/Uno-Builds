<Page x:Class="ClaudeDash.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="16" MaxWidth="1400">

            <!-- Header -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x03BB;"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentLightBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="settings"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Claude Code configuration, permissions, and environment settings."
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- MODEL PREFERENCES -->
            <TextBlock Text="MODEL PREFERENCES"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="default model"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding DefaultModel, Mode=TwoWay}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="fallback model"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding FallbackModel, Mode=TwoWay}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     FontSize="11" />
                        </StackPanel>
                    </Grid>
                    <CheckBox Content="Auto-select model by task complexity"
                              IsChecked="{Binding AutoSelectByTask, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="4">
                            <TextBlock Text="max tokens/turn"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding MaxTokensPerTurn, Mode=TwoWay}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Text="monthly budget cap"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding MonthlyBudgetCap, Mode=TwoWay}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Text="warning threshold"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       FontSize="10" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBox Text="{Binding BudgetWarningThreshold, Mode=TwoWay}"
                                     FontFamily="{StaticResource MonoFontFamily}"
                                     FontSize="11" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- PERMISSIONS & SAFETY -->
            <TextBlock Text="PERMISSIONS &amp; SAFETY"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                <StackPanel Spacing="8">
                    <CheckBox Content="Auto-approve file edits"
                              IsChecked="{Binding AutoApproveFileEdits, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <CheckBox Content="Auto-approve shell commands"
                              IsChecked="{Binding AutoApproveShellCommands, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <CheckBox Content="Network access"
                              IsChecked="{Binding NetworkAccess, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <CheckBox Content="Sandbox mode"
                              IsChecked="{Binding SandboxMode, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <CheckBox Content="Git push protection"
                              IsChecked="{Binding GitPushProtection, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                    <CheckBox Content="Secret detection"
                              IsChecked="{Binding SecretDetection, Mode=TwoWay}"
                              FontFamily="{StaticResource MonoFontFamily}"
                              FontSize="11" />
                </StackPanel>
            </Border>

            <!-- CONFIG PREVIEW -->
            <TextBlock Text="CONFIG PREVIEW"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                <TextBlock Text="{Binding SettingsContent}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</Page>

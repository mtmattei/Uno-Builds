<Page x:Class="ClaudeDash.Views.UnoPlatformOverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="16" MaxWidth="1400" HorizontalAlignment="Stretch">

            <!-- Header -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x03BB;"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentLightBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="uno platform"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Uno Platform SDK, tooling, and environment overview."
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- Stat cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard Grid.Column="0"
                                   Label="CHECK PASSED"
                                   IconGlyph="&#xE73E;"
                                   Value="{Binding CheckPassedCount}" />
                <controls:StatCard Grid.Column="1"
                                   Label="WARNINGS"
                                   IconGlyph="&#xE7BA;"
                                   Value="{Binding CheckWarningCount}" />
                <controls:StatCard Grid.Column="2"
                                   Label="ERRORS"
                                   IconGlyph="&#xE711;"
                                   Value="{Binding CheckErrorCount}" />
            </Grid>

            <!-- SDK Info section -->
            <TextBlock Text="SDK ENVIRONMENT"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Uno SDK -->
                <Border Grid.Row="0" Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="UNO SDK"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.SdkVersion}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- .NET SDK -->
                <Border Grid.Row="0" Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text=".NET SDK"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.DotNetSdkVersion}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- IDE -->
                <Border Grid.Row="0" Grid.Column="2"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="IDE"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.DetectedIde}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Hot Reload -->
                <Border Grid.Row="1" Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="HOT RELOAD"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.HotReloadStatus}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Hot Design -->
                <Border Grid.Row="1" Grid.Column="1"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="HOT DESIGN"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.HotDesignStatus}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- License -->
                <Border Grid.Row="1" Grid.Column="2"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12,10">
                    <StackPanel Spacing="4">
                        <TextBlock Text="LICENSE"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   CharacterSpacing="60" />
                        <TextBlock Text="{Binding UnoInfo.LicenseTier}"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <TextBlock Text="QUICK ACTIONS"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Style="{StaticResource DashOutlineButtonStyle}" Padding="12,6"
                        Command="{Binding RunUnoCheck}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE72C;" FontSize="12" />
                        <TextBlock Text="run uno-check"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="10" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DashOutlineButtonStyle}" Padding="12,6"
                        Command="{Binding OpenDocs}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A7;" FontSize="12" />
                        <TextBlock Text="docs"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="10" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource DashOutlineButtonStyle}" Padding="12,6"
                        Command="{Binding OpenSamples}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE943;" FontSize="12" />
                        <TextBlock Text="samples"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="10" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Check Results -->
            <TextBlock Text="CHECK RESULTS"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <ItemsRepeater ItemsSource="{Binding CheckResults}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1" CornerRadius="6" Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Detail}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Category}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="9"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0" />
                                <Border Grid.Column="2"
                                        Background="{StaticResource SurfaceBackgroundBrush}"
                                        CornerRadius="4" Padding="8,3">
                                    <TextBlock Text="{Binding Status}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="ClaudeDash.Views.MemoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="24" MaxWidth="1400">

            <StackPanel Spacing="4">
                <TextBlock Text="Memory"
                           Style="{StaticResource GreetingTextStyle}" />
                <TextBlock Text="Claude Code memory files and project instructions."
                           Style="{StaticResource GreetingSubtitleStyle}" />
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard x:Name="TotalFilesCard" Grid.Column="0"
                                   Label="Memory Files" />
                <controls:StatCard x:Name="ProjectsCard" Grid.Column="1"
                                   Label="Projects" />
            </Grid>

            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource AccentRedBrush}"
                       Style="{StaticResource BodyTextStyle}"
                       Visibility="Collapsed" />

            <StackPanel x:Name="MemoryCardsPanel" Spacing="12" />

        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="ClaudeDash.Views.WorktreesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="24" MaxWidth="1400">

            <StackPanel Spacing="4">
                <TextBlock Text="worktrees"
                           Style="{StaticResource GreetingTextStyle}" />
                <TextBlock Text="git worktrees across all tracked repositories."
                           Style="{StaticResource GreetingSubtitleStyle}" />
            </StackPanel>

            <Grid ColumnSpacing="1"
                  Background="{StaticResource BorderSubtleBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard x:Name="TotalCard" Grid.Column="0"
                                   Label="TOTAL WORKTREES" />
                <controls:StatCard x:Name="ReposCard" Grid.Column="1"
                                   Label="REPOS WITH WORKTREES" />
            </Grid>

            <TextBlock x:Name="ErrorText"
                       Foreground="{StaticResource AccentRedBrush}"
                       Style="{StaticResource BodyTextStyle}"
                       Visibility="Collapsed" />

            <TextBlock x:Name="WorktreesDivider"
                       Style="{StaticResource PipeDividerStyle}" />

            <Border Style="{StaticResource DashboardCardStyle}">
                <StackPanel Spacing="0">
                    <!-- Column headers -->
                    <Grid Margin="12,8,12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text=""
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10" CharacterSpacing="80"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Grid.Column="1" Text="PATH"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10" CharacterSpacing="80"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Grid.Column="2" Text="BRANCH"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10" CharacterSpacing="80"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Grid.Column="3" Text="HEAD"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10" CharacterSpacing="80"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                        <TextBlock Grid.Column="4" Text="ACTIONS"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="10" CharacterSpacing="80"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                    </Grid>

                    <Border Height="1" Background="{StaticResource BorderSubtleBrush}" />

                    <StackPanel x:Name="WorktreesPanel" Spacing="0" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

<Page x:Class="ClaudeDash.Views.HooksMemoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="16" MaxWidth="1400">

            <!-- Header -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x03BB;"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentLightBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="hooks &amp; memory"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Hook configurations and memory files across your projects."
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- Stat cards -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <controls:StatCard Grid.Column="0"
                                   Label="TOTAL HOOKS"
                                   IconGlyph="&#xE7F4;"
                                   Value="{Binding TotalHooks}" />
                <controls:StatCard Grid.Column="1"
                                   Label="ACTIVE"
                                   IconGlyph="&#xE73E;"
                                   Value="{Binding ActiveCount}" />
            </Grid>

            <!-- Hooks list -->
            <TextBlock Text="HOOKS"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <ItemsRepeater ItemsSource="{Binding Hooks}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         Fill="{StaticResource StatusGreenBrush}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0" />

                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding Description}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>

                                <Border Grid.Column="2"
                                        Background="{StaticResource SurfaceBackgroundBrush}"
                                        CornerRadius="4" Padding="8,3"
                                        VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding TriggerType}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="9" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}" />
                                </Border>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding Command}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{StaticResource AccentLightBrush}"
                                           VerticalAlignment="Center"
                                           MinWidth="120" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Config preview -->
            <TextBlock Text="CONFIG PREVIEW"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <Border Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="14,12">
                <TextBlock Text="{Binding ConfigPreview}"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap" />
            </Border>

            <!-- Allowed domains -->
            <TextBlock Text="ALLOWED DOMAINS"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,8,0,4" />

            <ItemsRepeater ItemsSource="{Binding AllowedDomains}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="12,6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE774;" FontSize="11"
                                          Foreground="{StaticResource AccentGreenBrush}"
                                          VerticalAlignment="Center" />
                                <TextBlock Text="{Binding}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</Page>

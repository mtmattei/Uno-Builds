<Page x:Class="ClaudeDash.Views.SessionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:ClaudeDash.Controls"
      Background="{StaticResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,24">
        <StackPanel Spacing="0" MaxWidth="1400">

            <!-- Header -->
            <StackPanel Spacing="4" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="&#x03BB;"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentLightBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="sessions"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Active and completed Claude Code sessions across all projects."
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}" />
            </StackPanel>

            <!-- 2x2 stat cards -->
            <Grid ColumnSpacing="1" RowSpacing="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <controls:StatCard Grid.Row="0" Grid.Column="0"
                                   Label="ACTIVE NOW"
                                   IconGlyph="&#xEA8A;"
                                   Value="{Binding Stats.ActiveCount}" />
                <controls:StatCard Grid.Row="0" Grid.Column="1"
                                   Label="TOTAL TOKENS TODAY"
                                   IconGlyph="&#xE8EC;"
                                   Value="{Binding Stats.TotalTokensToday}" />
                <controls:StatCard Grid.Row="1" Grid.Column="0"
                                   Label="AVG SESSION LENGTH"
                                   IconGlyph="&#xE916;"
                                   Subtitle="{Binding Stats.AvgSessionLength}" />
                <controls:StatCard Grid.Row="1" Grid.Column="1"
                                   Label="COST TODAY"
                                   IconGlyph="&#xE8EC;"
                                   Subtitle="{Binding Stats.CostToday}" />
            </Grid>

            <!-- Sessions list -->
            <TextBlock Text="ALL SESSIONS"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10" FontWeight="SemiBold"
                       CharacterSpacing="80"
                       Foreground="{StaticResource TextMutedBrush}"
                       Margin="0,0,0,8" />

            <ItemsRepeater ItemsSource="{Binding Sessions}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="2" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status dot -->
                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{StaticResource StatusGreen}" />
                                    </Ellipse.Fill>
                                </Ellipse>

                                <!-- Project + message -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding RepoName}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Model}"
                                                   FontFamily="{StaticResource MonoFontFamily}"
                                                   FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding FirstUserMessage}"
                                               FontFamily="{StaticResource MonoFontFamily}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                </StackPanel>

                                <!-- Token count -->
                                <TextBlock Grid.Column="2"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="12,0">
                                    <Run Text="{Binding TokenCount}" /><Run Text=" tok" />
                                </TextBlock>

                                <!-- Messages -->
                                <TextBlock Grid.Column="3"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0">
                                    <Run Text="{Binding MessageCount}" /><Run Text=" msgs" />
                                </TextBlock>

                                <!-- Duration / time ago -->
                                <TextBlock Grid.Column="4"
                                           Text="{Binding Duration}"
                                           FontFamily="{StaticResource MonoFontFamily}"
                                           FontSize="10"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"
                                           MinWidth="60"
                                           TextAlignment="Right" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</Page>

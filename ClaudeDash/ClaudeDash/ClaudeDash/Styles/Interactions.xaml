<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI">

    <!-- ============================================================ -->
    <!-- INTERACTION DESIGN SYSTEM                                     -->
    <!-- Proper Uno Platform lightweight styling via                   -->
    <!-- utu:ResourceExtensions.Resources for hover/pressed/disabled   -->
    <!-- ============================================================ -->

    <!-- ─── Global theme overrides for popups, dialogs, flyouts ─── -->

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">

            <!-- ContentDialog -->
            <SolidColorBrush x:Key="ContentDialogBackground" Color="#0E0E0F" />
            <SolidColorBrush x:Key="ContentDialogForeground" Color="#D2D2D4" />
            <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="#262629" />
            <SolidColorBrush x:Key="ContentDialogSeparatorBorderBrush" Color="#1A1A1C" />
            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="Transparent" />
            <SolidColorBrush x:Key="ContentDialogSmokeFill" Color="#CC000000" />

            <!-- Flyout -->
            <SolidColorBrush x:Key="FlyoutPresenterBackground" Color="#0E0E0F" />
            <SolidColorBrush x:Key="FlyoutBorderThemeBrush" Color="#262629" />

            <!-- MenuFlyout -->
            <SolidColorBrush x:Key="MenuFlyoutPresenterBackground" Color="#0E0E0F" />
            <SolidColorBrush x:Key="MenuFlyoutPresenterBorderBrush" Color="#262629" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackground" Color="Transparent" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPointerOver" Color="#121214" />
            <SolidColorBrush x:Key="MenuFlyoutItemBackgroundPressed" Color="#1A1A1C" />
            <SolidColorBrush x:Key="MenuFlyoutItemForeground" Color="#D2D2D4" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPointerOver" Color="#F5F5F6" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundPressed" Color="#F5F5F6" />
            <SolidColorBrush x:Key="MenuFlyoutItemForegroundDisabled" Color="#434348" />
            <SolidColorBrush x:Key="MenuFlyoutSeparatorBackground" Color="#1A1A1C" />

            <!-- ToolTip -->
            <SolidColorBrush x:Key="ToolTipBackground" Color="#121214" />
            <SolidColorBrush x:Key="ToolTipForeground" Color="#D2D2D4" />
            <SolidColorBrush x:Key="ToolTipBorderBrush" Color="#262629" />
            <SolidColorBrush x:Key="ToolTipBackgroundBrush" Color="#121214" />
            <SolidColorBrush x:Key="ToolTipForegroundBrush" Color="#D2D2D4" />

        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ============================================================ -->
    <!-- GHOST BUTTON                                                  -->
    <!-- Transparent bg, no border                                     -->
    <!-- Use for: toolbar actions, nav triggers, secondary actions     -->
    <!-- ============================================================ -->

    <Style x:Key="DashGhostButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#121214" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1A1A1C" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#74747A" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D2D2D4" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F5F5F6" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- OUTLINE BUTTON                                                -->
    <!-- 1px border, transparent bg                                    -->
    <!-- Use for: quick actions, form buttons, secondary CTAs          -->
    <!-- ============================================================ -->

    <Style x:Key="DashOutlineButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#121214" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1A1A1C" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#74747A" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#D2D2D4" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#F5F5F6" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#262629" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#1A1A1C" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- PRIMARY BUTTON                                                -->
    <!-- Green accent, dark text                                       -->
    <!-- Use for: main CTAs, confirm, send, connect, apply             -->
    <!-- ============================================================ -->

    <Style x:Key="DashPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="#4ADE80" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#3DBA6E" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#35A05F" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#1A3D2A" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#0A0A0C" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#0A0A0C" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#0A0A0C" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- DANGER BUTTON                                                 -->
    <!-- Red accent for destructive actions                            -->
    <!-- Use for: delete, remove, clear, disconnect                    -->
    <!-- ============================================================ -->

    <Style x:Key="DashDangerButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A0A0A" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2A1010" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#EF4444" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#DC3535" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#C42D2D" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#EF4444" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#DC3535" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#C42D2D" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#434348" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- ACCENT OUTLINE BUTTON                                         -->
    <!-- Green border, transparent bg                                  -->
    <!-- Use for: send button, positive secondary actions              -->
    <!-- ============================================================ -->

    <Style x:Key="DashAccentOutlineButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0A1A0E" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#0E2A14" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#4ADE80" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#3DBA6E" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#35A05F" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#4ADE80" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#3DBA6E" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#35A05F" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#434348" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- WARNING OUTLINE BUTTON                                        -->
    <!-- Yellow/orange border for caution actions                      -->
    <!-- Use for: hygiene actions, warnings                            -->
    <!-- ============================================================ -->

    <Style x:Key="DashWarningOutlineButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#1A1500" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#2A2200" />
                            <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="#FBBF24" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFD454" />
                            <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#E6A820" />
                            <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#434348" />
                            <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FBBF24" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#FFD454" />
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#E6A820" />
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#434348" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- TEXT INPUT                                                     -->
    <!-- Dark surface, consistent font, focus accent                   -->
    <!-- Use for: search, chat input, API key entry, settings fields   -->
    <!-- ============================================================ -->

    <Style x:Key="DashTextBoxStyle" TargetType="TextBox">
        <Setter Property="Padding" Value="12,16" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Background" Value="#0F0F12" />
        <Setter Property="Foreground" Value="#9A9898" />
        <Setter Property="BorderBrush" Value="#1E1E22" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <!-- Rest: dark bg, subtle border -->
                            <SolidColorBrush x:Key="TextControlBackground" Color="#0F0F12" />
                            <!-- Hover: lighter grey bg + border -->
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#18181C" />
                            <!-- Focus: dark bg, white border -->
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#0F0F12" />
                            <SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#0A0A0C" />
                            <SolidColorBrush x:Key="TextControlForeground" Color="#9A9898" />
                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#C8C6C3" />
                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F0EEEB" />
                            <SolidColorBrush x:Key="TextControlForegroundDisabled" Color="#454340" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="#1E1E22" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3A3A40" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#E0E0E0" />
                            <SolidColorBrush x:Key="TextControlBorderBrushDisabled" Color="#141416" />
                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#454340" />
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#5F5D5B" />
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#5F5D5B" />
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundDisabled" Color="#454340" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- TOGGLE SWITCH                                                 -->
    <!-- Dark track, peach accent when on                              -->
    <!-- Use for: settings toggles, feature flags                      -->
    <!-- ============================================================ -->

    <Style x:Key="DashToggleSwitchStyle" TargetType="ToggleSwitch">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#FB923C" />
                            <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#E8833A" />
                            <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#D07533" />
                            <SolidColorBrush x:Key="ToggleSwitchFillOff" Color="#262629" />
                            <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver" Color="#434348" />
                            <SolidColorBrush x:Key="ToggleSwitchStrokeOff" Color="#434348" />
                            <SolidColorBrush x:Key="ToggleSwitchStrokeOffPointerOver" Color="#55555A" />
                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#0A0A0C" />
                            <SolidColorBrush x:Key="ToggleSwitchKnobFillOff" Color="#ADADAF" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- CONTENT DIALOG STYLE                                          -->
    <!-- Dark panel with monospace text, matching app theme             -->
    <!-- ============================================================ -->

    <Style x:Key="DashContentDialogStyle" TargetType="ContentDialog">
        <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="utu:ResourceExtensions.Resources">
            <Setter.Value>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ContentDialogBackground" Color="#0E0E0F" />
                            <SolidColorBrush x:Key="ContentDialogForeground" Color="#D2D2D4" />
                            <SolidColorBrush x:Key="ContentDialogBorderBrush" Color="#262629" />
                            <SolidColorBrush x:Key="ContentDialogTopOverlay" Color="Transparent" />
                            <SolidColorBrush x:Key="ContentDialogSeparatorBorderBrush" Color="#1A1A1C" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================================ -->
    <!-- SPACING TOKENS                                                -->
    <!-- ============================================================ -->

    <Thickness x:Key="SpacingXS">4</Thickness>
    <Thickness x:Key="SpacingSM">8</Thickness>
    <Thickness x:Key="SpacingMD">12</Thickness>
    <Thickness x:Key="SpacingLG">16</Thickness>
    <Thickness x:Key="SpacingXL">24</Thickness>
    <Thickness x:Key="SpacingXXL">32</Thickness>
    <Thickness x:Key="PagePadding">32,24</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="CardPaddingCompact">12,8</Thickness>
    <Thickness x:Key="ButtonPaddingSmall">8,4</Thickness>
    <Thickness x:Key="ButtonPaddingDefault">12,6</Thickness>
    <Thickness x:Key="ButtonPaddingLarge">16,8</Thickness>

    <!-- ============================================================ -->
    <!-- CORNER RADIUS TOKENS                                          -->
    <!-- ============================================================ -->

    <CornerRadius x:Key="RadiusNone">0</CornerRadius>
    <CornerRadius x:Key="RadiusSM">6</CornerRadius>
    <CornerRadius x:Key="RadiusMD">8</CornerRadius>
    <CornerRadius x:Key="RadiusLG">14</CornerRadius>
    <CornerRadius x:Key="RadiusXL">16</CornerRadius>

</ResourceDictionary>

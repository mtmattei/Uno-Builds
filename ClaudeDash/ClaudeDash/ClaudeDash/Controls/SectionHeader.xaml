<UserControl x:Class="ClaudeDash.Controls.SectionHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Bullet glyph -->
        <TextBlock x:Name="BulletText" Grid.Column="0"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="11"
                   Foreground="{StaticResource AccentTealBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0" />

        <!-- Title (uppercase) -->
        <TextBlock x:Name="TitleText" Grid.Column="1"
                   Style="{StaticResource SectionHeaderStyle}"
                   VerticalAlignment="Center" />

        <!-- Spacer -->
        <Border Grid.Column="2" />

        <!-- Right subtitle -->
        <TextBlock x:Name="SubtitleText" Grid.Column="3"
                   Style="{StaticResource CodeTextStyle}"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>

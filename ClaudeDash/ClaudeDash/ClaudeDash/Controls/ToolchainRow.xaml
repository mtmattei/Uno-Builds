<UserControl x:Class="ClaudeDash.Controls.ToolchainRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid" Padding="4,5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Status dot -->
        <Ellipse x:Name="StatusDot" Grid.Column="0"
                 Width="5" Height="5"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left" />

        <!-- Name -->
        <TextBlock x:Name="NameText" Grid.Column="1"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Version -->
        <TextBlock x:Name="VersionText" Grid.Column="2"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="10"
                   Foreground="{StaticResource TextTertiaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Detail -->
        <TextBlock x:Name="DetailText" Grid.Column="3"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="10"
                   Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Fix button -->
        <Button x:Name="FixButton" Grid.Column="4"
                Style="{StaticResource DashOutlineButtonStyle}"
                Padding="8,3"
                Visibility="Collapsed"
                Click="FixButton_Click">
            <TextBlock x:Name="FixButtonText"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="10"
                       Foreground="{StaticResource AccentPeachBrush}" />
        </Button>
    </Grid>
</UserControl>

<UserControl x:Class="ClaudeDash.Controls.SessionListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Compact session row: dot + description + repo badge + aligned timestamp -->
    <Grid Padding="4,5" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="44" />
        </Grid.ColumnDefinitions>

        <!-- Color-coded status dot (green=ok, red=error) -->
        <Ellipse x:Name="StatusDot" Grid.Column="0"
                 Width="6" Height="6"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Left" />

        <!-- Description -->
        <TextBlock x:Name="DescriptionText" Grid.Column="1"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="11"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Repo badge -->
        <Border Grid.Column="2"
                Style="{StaticResource RepoBadgeStyle}"
                VerticalAlignment="Center">
            <TextBlock x:Name="RepoBadgeText"
                       Style="{StaticResource BadgeTextStyle}" />
        </Border>

        <!-- Right-aligned monospaced timestamp -->
        <TextBlock x:Name="TimeText" Grid.Column="3"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="10"
                   Foreground="{StaticResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right" />
    </Grid>
</UserControl>

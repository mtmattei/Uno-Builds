<UserControl x:Class="ClaudeDash.Controls.SlideOverPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <Grid>
        <!-- Semi-transparent backdrop -->
        <Border x:Name="Backdrop"
                Background="#80000000"
                Tapped="Backdrop_Tapped" />

        <!-- Right-aligned slide panel -->
        <Border x:Name="PanelBorder"
                HorizontalAlignment="Right"
                Width="400"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1,0,0,0"
                Translation="0,0,32">
            <Border.RenderTransform>
                <TranslateTransform x:Name="PanelTranslate" X="400" />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header row -->
                <Grid Grid.Row="0" Margin="20,16,12,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"
                               CharacterSpacing="40" />

                    <Button Grid.Column="1"
                            Style="{StaticResource DashGhostButtonStyle}"
                            Padding="8,4"
                            Click="Close_Click">
                        <FontIcon Glyph="&#xE711;" FontSize="12"
                                  Foreground="{StaticResource TextMutedBrush}" />
                    </Button>
                </Grid>

                <!-- Divider -->
                <Border Grid.Row="1" Height="1"
                        Background="{StaticResource BorderSubtleBrush}" />

                <!-- Scrollable content host -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              Padding="20,16">
                    <ContentPresenter x:Name="ContentHost" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>

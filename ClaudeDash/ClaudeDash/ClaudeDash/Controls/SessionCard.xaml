<UserControl x:Class="ClaudeDash.Controls.SessionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="CardBorder"
            Style="{StaticResource DashboardCardStyle}"
            Padding="0"
            PointerEntered="Card_PointerEntered"
            PointerExited="Card_PointerExited"
            Tapped="Card_Tapped">
        <Grid>
            <!-- 2px accent bar at top -->
            <Border x:Name="AccentBar"
                    Height="2"
                    VerticalAlignment="Top"
                    CornerRadius="4,4,0,0" />

            <StackPanel Padding="16,14,16,12" Spacing="8">
                <!-- Row 1: Status dot + Title + Time ago -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Ellipse x:Name="StatusDot"
                             Width="7" Height="7"
                             VerticalAlignment="Center"
                             Margin="0,0,8,0" />

                    <TextBlock x:Name="TitleText" Grid.Column="1"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1" />

                    <TextBlock x:Name="TimeAgoText" Grid.Column="2"
                               FontFamily="{StaticResource MonoFontFamily}"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </Grid>

                <!-- Row 2: Model badge + Repo badge -->
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Border x:Name="ModelBadge"
                            Background="{StaticResource SurfaceBackgroundBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,2">
                        <TextBlock x:Name="ModelText"
                                   FontFamily="{StaticResource MonoFontFamily}"
                                   FontSize="9"
                                   Foreground="{StaticResource TextTertiaryBrush}" />
                    </Border>

                    <Border x:Name="RepoBadge"
                            Style="{StaticResource RepoBadgeStyle}"
                            Visibility="Collapsed">
                        <TextBlock x:Name="RepoText"
                                   Style="{StaticResource BadgeTextStyle}" />
                    </Border>
                </StackPanel>

                <!-- Row 3: First user message (description) -->
                <TextBlock x:Name="DescriptionText"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="2"
                           TextWrapping="Wrap"
                           LineHeight="16" />

                <!-- Row 4: Metrics row -->
                <TextBlock x:Name="MetricsText"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="9"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

<UserControl x:Class="ClaudeDash.Controls.CostBarRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="0,5" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="60" />
        </Grid.ColumnDefinitions>

        <!-- Model name -->
        <TextBlock x:Name="ModelNameText" Grid.Column="0"
                   FontFamily="{StaticResource MonoFontFamily}"
                   FontSize="11"
                   Foreground="{StaticResource TextTertiaryBrush}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />

        <!-- Proportional fill bar -->
        <Grid Grid.Column="1" VerticalAlignment="Center">
            <!-- Track background -->
            <Border CornerRadius="2" Height="6"
                    Background="{StaticResource SurfaceBackgroundBrush}" />
            <!-- Fill bar -->
            <Border x:Name="CostBarFill" CornerRadius="2" Height="6"
                    HorizontalAlignment="Left" />
        </Grid>

        <!-- Dollar amount -->
        <TextBlock x:Name="AmountText" Grid.Column="2"
                   Style="{StaticResource CostAmountStyle}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>

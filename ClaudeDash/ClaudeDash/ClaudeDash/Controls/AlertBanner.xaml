<UserControl x:Class="ClaudeDash.Controls.AlertBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <Storyboard x:Key="PulseDotStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseDot"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.0" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:2.4" Value="1.0" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <!-- Left-border alert with semantic status colors -->
    <Border x:Name="AlertBorder"
            Padding="16,10"
            BorderThickness="2,0,0,0"
            CornerRadius="0,4,4,0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Pulsing status dot (visible for ERR) -->
            <Ellipse x:Name="PulseDot" Grid.Column="0"
                     Width="8" Height="8"
                     VerticalAlignment="Center"
                     Margin="0,0,10,0"
                     Visibility="Collapsed" />

            <!-- Log level label (WARN / ERR / INFO) -->
            <TextBlock Grid.Column="1"
                       x:Name="LevelLabel"
                       FontFamily="{StaticResource MonoFontFamily}"
                       FontSize="11"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0" />

            <!-- Message -->
            <TextBlock Grid.Column="2"
                       x:Name="AlertMessage"
                       Style="{StaticResource AlertTextStyle}"
                       VerticalAlignment="Center" />

            <!-- Action link (visible for ERR) -->
            <Button x:Name="ActionLink" Grid.Column="3"
                    Style="{StaticResource DashGhostButtonStyle}"
                    Padding="8,4"
                    Visibility="Collapsed"
                    Margin="12,0,0,0">
                <TextBlock x:Name="ActionText"
                           FontFamily="{StaticResource MonoFontFamily}"
                           FontSize="10"
                           Foreground="{StaticResource AccentPurpleBrush}" />
            </Button>
        </Grid>
    </Border>
</UserControl>

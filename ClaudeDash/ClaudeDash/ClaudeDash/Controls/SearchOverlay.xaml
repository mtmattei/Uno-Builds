<UserControl x:Class="ClaudeDash.Controls.SearchOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:ClaudeDash.Converters"
             xmlns:search="using:ClaudeDash.Models.Search"
             x:Name="SearchRoot"
             Visibility="Collapsed">

    <UserControl.Resources>
        <converters:SearchResultTypeToColorConverter x:Key="TypeToColor" />
        <converters:SearchResultTypeToLabelConverter x:Key="TypeToLabel" />
        <converters:SearchResultTypeToBadgeBgConverter x:Key="TypeToBadgeBg" />
    </UserControl.Resources>

    <!-- Full overlay: dimmed background + centered panel -->
    <Grid>
        <!-- Backdrop -->
        <Border Background="#CC000000"
                Tapped="Backdrop_Tapped" />

        <!-- Search panel -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,80,0,0"
                Width="560"
                MaxHeight="520"
                Background="{StaticResource CardGradientBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Translation="0,0,32">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search input row -->
                <Grid Grid.Row="0" Padding="16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <FontIcon Grid.Column="0"
                              Glyph="&#xE721;"
                              FontSize="16"
                              Foreground="{StaticResource TextTertiaryBrush}"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0" />

                    <TextBox Grid.Column="1"
                             x:Name="SearchInput"
                             PlaceholderText="Search sessions, projects, skills..."
                             Text="{x:Bind ViewModel.QueryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Code, Consolas, monospace"
                             FontSize="14"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalAlignment="Center"
                             KeyDown="SearchInput_KeyDown" />

                    <Border Grid.Column="2"
                            Background="{StaticResource SurfaceBackgroundBrush}"
                            CornerRadius="3"
                            Padding="6,2"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            VerticalAlignment="Center">
                        <TextBlock Text="ESC"
                                   FontFamily="Cascadia Code, Consolas, monospace"
                                   FontSize="9"
                                   Foreground="{StaticResource TextMutedBrush}" />
                    </Border>
                </Grid>

                <!-- Divider -->
                <Border Grid.Row="1"
                        Height="1"
                        Background="{StaticResource BorderSubtleBrush}" />

                <!-- Results list -->
                <ListView Grid.Row="2"
                          x:Name="ResultsList"
                          ItemsSource="{x:Bind ViewModel.Results}"
                          SelectedIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}"
                          SelectionMode="Single"
                          Background="Transparent"
                          Padding="4"
                          MaxHeight="380"
                          ItemClick="ResultsList_ItemClick"
                          IsItemClickEnabled="True">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="search:SearchResult">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <FontIcon Grid.Column="0"
                                          Glyph="{x:Bind Icon}"
                                          FontSize="14"
                                          Foreground="{x:Bind Type, Converter={StaticResource TypeToColor}}"
                                          VerticalAlignment="Center" />

                                <!-- Title + Subtitle -->
                                <StackPanel Grid.Column="1"
                                            Spacing="2"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Title}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="{x:Bind Subtitle}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="10"
                                               Foreground="{StaticResource TextTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                </StackPanel>

                                <!-- Type badge -->
                                <Border Grid.Column="2"
                                        Background="{x:Bind Type, Converter={StaticResource TypeToBadgeBg}}"
                                        CornerRadius="3"
                                        Padding="6,2"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Type, Converter={StaticResource TypeToLabel}}"
                                               FontFamily="Cascadia Code, Consolas, monospace"
                                               FontSize="9"
                                               Foreground="{x:Bind Type, Converter={StaticResource TypeToColor}}"
                                               CharacterSpacing="60" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Footer: status + shortcuts -->
                <Grid Grid.Row="3"
                      Padding="16,8"
                      Background="{StaticResource SurfaceBackgroundBrush}"
                      BorderBrush="{StaticResource BorderSubtleBrush}"
                      BorderThickness="0,1,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <TextBlock Grid.Column="0"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontFamily="Cascadia Code, Consolas, monospace"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center" />

                    <!-- Keyboard hints -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource SurfaceBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="4,1">
                                <TextBlock Text="&#x2191;&#x2193;"
                                           FontSize="9"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </Border>
                            <TextBlock Text="navigate"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="9"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Border Background="{StaticResource SurfaceBackgroundBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    Padding="4,1">
                                <TextBlock Text="&#x23CE;"
                                           FontSize="9"
                                           Foreground="{StaticResource TextMutedBrush}" />
                            </Border>
                            <TextBlock Text="open"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="9"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>

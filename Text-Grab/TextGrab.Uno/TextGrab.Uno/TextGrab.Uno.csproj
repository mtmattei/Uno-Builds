<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-windows10.0.26100;net10.0-browserwasm;net10.0-desktop;net10.0</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>Text Grab</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>net.textgrab.app</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>5.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>Joseph Finney</ApplicationPublisher>
    <!-- Package Description -->
    <Description>Text Grab - OCR utility for capturing text from screens, images, and files.</Description>
    <RootNamespace>TextGrab</RootNamespace>
    <!--
      If you encounter this error message:

        error NETSDK1148: A referenced assembly was compiled using a newer version of Microsoft.Windows.SDK.NET.dll.
        Please update to a newer .NET SDK in order to reference this assembly.

      This means that the two packages below must be aligned with the "build" version number of
      the "Microsoft.Windows.SDK.BuildTools" package above, and the "revision" version number
      must be the highest found in https://www.nuget.org/packages/Microsoft.Windows.SDK.NET.Ref.
    -->
    <!-- <WindowsSdkPackageVersion>10.0.22621.28</WindowsSdkPackageVersion> -->

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <UnoFeatures>
      Material;
      Dsp;
      Svg;
      Hosting;
      Toolkit;
      Logging;
      MVUX;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      ThemeService;
      SkiaRenderer;
    </UnoFeatures>
  </PropertyGroup>

  <ItemGroup>
    <!-- Portable dependencies from original Text-Grab -->
    <!-- NCalcAsync deferred to Phase 2 (Parlot global using conflicts on Wasm) -->
    <PackageReference Include="Humanizer.Core" />
    <PackageReference Include="ZXing.Net" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
    <!-- Windows-only dependencies -->
    <PackageReference Include="CliWrap" />
  </ItemGroup>

</Project>

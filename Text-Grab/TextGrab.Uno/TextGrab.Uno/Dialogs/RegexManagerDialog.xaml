<ContentDialog
    x:Class="TextGrab.Dialogs.RegexManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Regex Pattern Manager"
    PrimaryButtonText="Use in Find"
    CloseButtonText="Close"
    DefaultButton="Close"
    PrimaryButtonClick="UseButton_Click">

  <Grid Width="600" MinHeight="400">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Pattern list -->
    <ListView x:Name="PatternListView"
              SelectionMode="Single"
              SelectionChanged="PatternListView_SelectionChanged">
      <ListView.ItemTemplate>
        <DataTemplate>
          <Grid Padding="4,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Name}"
                       Style="{StaticResource TitleSmall}"
                       TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1"
                       Text="{Binding Pattern}"
                       Style="{StaticResource BodySmall}"
                       Opacity="0.7"
                       FontFamily="Cascadia Code, Consolas, monospace"
                       TextTrimming="CharacterEllipsis" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <!-- Action buttons -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
      <Button Content="Add" Click="AddButton_Click" />
      <Button x:Name="EditButton" Content="Edit" Click="EditButton_Click" IsEnabled="False" />
      <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click" IsEnabled="False" />
      <Button x:Name="ExplainButton" Content="Explain" Click="ExplainButton_Click" IsEnabled="False" />
    </StackPanel>

    <!-- Test panel -->
    <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <TextBlock Text="Test:" Style="{StaticResource TitleSmall}" VerticalAlignment="Center" />
        <TextBlock x:Name="MatchCountText" Text="0 matches"
                   Style="{StaticResource BodySmall}" Opacity="0.7"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBox x:Name="TestTextBox"
               PlaceholderText="Enter test text here..."
               AcceptsReturn="True"
               MinHeight="60"
               MaxHeight="120"
               TextWrapping="Wrap"
               TextChanged="TestTextBox_TextChanged" />
    </StackPanel>
  </Grid>
</ContentDialog>

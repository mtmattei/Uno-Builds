<ContentDialog
    x:Class="TextGrab.Dialogs.PostGrabActionEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Post-Capture Actions"
    PrimaryButtonText="Save"
    SecondaryButtonText="Reset Defaults"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="SaveButton_Click"
    SecondaryButtonClick="ResetButton_Click">

  <Grid Width="650" MinHeight="350">
    <Grid ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- Available actions -->
      <StackPanel>
        <TextBlock Text="Available Actions" Style="{StaticResource TitleSmall}" Margin="0,0,0,8" />
        <ListView x:Name="AvailableListView"
                  SelectionMode="Single"
                  MaxHeight="280">
          <ListView.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding ButtonText}" Margin="4,2" />
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </StackPanel>

      <!-- Add/Remove + Move buttons -->
      <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
        <Button Content="&#xE72A;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Click="AddButton_Click" Width="40" HorizontalAlignment="Center" />
        <Button Content="&#xE72B;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Click="RemoveButton_Click" Width="40" HorizontalAlignment="Center" />
        <Border Height="16" />
        <Button Content="&#xE74A;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Click="MoveUpButton_Click" Width="40" HorizontalAlignment="Center" />
        <Button Content="&#xE74B;" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                Click="MoveDownButton_Click" Width="40" HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Enabled actions -->
      <StackPanel Grid.Column="2">
        <TextBlock Text="Enabled Actions" Style="{StaticResource TitleSmall}" Margin="0,0,0,8" />
        <ListView x:Name="EnabledListView"
                  SelectionMode="Single"
                  MaxHeight="280">
          <ListView.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding ButtonText}" Margin="4,2" />
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <TextBlock x:Name="EmptyStateText"
                   Text="All actions are currently enabled"
                   Style="{StaticResource BodySmall}"
                   Opacity="0.5"
                   Margin="0,8,0,0"
                   Visibility="Collapsed" />
      </StackPanel>
    </Grid>
  </Grid>
</ContentDialog>

<Page x:Class="TextGrab.Presentation.EditTextPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Menu Bar -->
    <MenuBar Grid.Row="0">

      <!-- FILE -->
      <MenuBarItem Title="File">
        <MenuFlyoutItem Text="Open File..." Click="OpenFile_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="O" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSubItem x:Name="RecentFilesMenu" Text="Recent Files" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Save" Click="Save_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="S" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Save As..." Click="SaveAs_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="S" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Copy All and Close" Click="CopyClose_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Settings..." Click="Settings_Click" />
      </MenuBarItem>

      <!-- EDIT -->
      <MenuBarItem Title="Edit">
        <MenuFlyoutItem Text="Undo" Click="Undo_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="Z" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Redo" Click="Redo_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="Y" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Cut" Click="Cut_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="X" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Copy" Click="Copy_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="C" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Paste" Click="Paste_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="V" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="OCR Paste (Clipboard Image)" Click="OcrPaste_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="V" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Make Single Line" Click="MakeSingleLine_Click" />
        <MenuFlyoutItem Text="Trim Each Line" Click="TrimEachLine_Click" />
        <MenuFlyoutItem Text="Try To Make Numbers" Click="TryToNumbers_Click" />
        <MenuFlyoutItem Text="Try To Make Letters" Click="TryToLetters_Click" />
        <MenuFlyoutItem Text="Correct Common GUID Errors" Click="CorrectGuids_Click" />
        <MenuFlyoutItem Text="Toggle Case" Click="ToggleCase_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Shift" Key="F3" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Remove Duplicate Lines" Click="RemoveDuplicateLines_Click" />
        <MenuFlyoutItem Text="Replace Reserved Characters" Click="ReplaceReservedChars_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="R" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Unstack Text (Top Row)" Click="Unstack_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="U" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Unstack Text (Column)" Click="UnstackGroup_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Add or Remove at Position..." Click="AddRemoveAt_Click" />
      </MenuBarItem>

      <!-- SELECTION -->
      <MenuBarItem Title="Selection">
        <MenuFlyoutItem Text="Find and Replace..." Click="FindAndReplace_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="F" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Regex Manager..." Click="RegexManager_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Web Search Selected Text" Click="WebSearch_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Select Word" Click="SelectWord_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="W" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Select Line" Click="SelectLine_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="L" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Select All" Click="SelectAll_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="A" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Select None" Click="SelectNone_Click" />
        <MenuFlyoutItem Text="Delete Selected Text" Click="DeleteSelected_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Move Selection Up" Click="MoveLineUp_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Menu" Key="Up" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Move Selection Down" Click="MoveLineDown_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Menu" Key="Down" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Isolate Selected Text" Click="IsolateSelection_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="I" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Delete All Instances of Selection" Click="DeleteAllSelection_Click" />
        <MenuFlyoutItem Text="Delete All Instances (Pattern)" Click="DeleteAllSelectionPattern_Click" />
        <MenuFlyoutItem Text="Insert Selection on Every Line" Click="InsertOnEveryLine_Click" />
        <MenuFlyoutItem Text="Split Before Each Selection" Click="SplitOnSelection_Click" />
        <MenuFlyoutItem Text="Split After Each Selection" Click="SplitAfterSelection_Click" />
      </MenuBarItem>

      <!-- CAPTURE -->
      <MenuBarItem Title="Capture">
        <MenuFlyoutItem Text="OCR from Image File..." Click="OcrFromImage_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="O" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="OCR from Clipboard Image" Click="OcrFromClipboard_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control,Shift" Key="V" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="New Fullscreen Grab" Click="NavigateFullscreenGrab_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="F" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="New Grab Frame" Click="NavigateGrabFrame_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="G" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutItem Text="Quick Simple Lookup" Click="NavigateQuickLookup_Click">
          <MenuFlyoutItem.KeyboardAccelerators>
            <KeyboardAccelerator Modifiers="Control" Key="Q" />
          </MenuFlyoutItem.KeyboardAccelerators>
        </MenuFlyoutItem>
        <MenuFlyoutSeparator />
        <ToggleMenuFlyoutItem x:Name="ClipboardWatcherToggle"
                              Text="Watch Clipboard for Images"
                              Click="ClipboardWatcher_Click" />
      </MenuBarItem>

      <!-- FORMAT -->
      <MenuBarItem Title="Format">
        <ToggleMenuFlyoutItem x:Name="WrapTextToggle"
                              Text="Wrap Text"
                              IsChecked="True"
                              Click="WrapText_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Font..." Click="Font_Click" />
        <MenuFlyoutItem Text="Bottom Bar Settings..." Click="BottomBarSettings_Click" />
      </MenuBarItem>

      <!-- WINDOW -->
      <MenuBarItem Title="Window">
        <MenuFlyoutItem Text="Make QR Code from Selection" Click="MakeQrCode_Click" />
        <MenuFlyoutSeparator />
        <ToggleMenuFlyoutItem x:Name="AlwaysOnTopToggle"
                              Text="Always On Top"
                              Click="AlwaysOnTop_Click" />
        <ToggleMenuFlyoutItem x:Name="HideBottomBarToggle"
                              Text="Hide Bottom Bar"
                              Click="HideBottomBar_Click" />
      </MenuBarItem>

      <!-- HELP -->
      <MenuBarItem Title="Help">
        <MenuFlyoutItem Text="About Text Grab" Click="About_Click" />
        <MenuFlyoutSeparator />
        <MenuFlyoutItem Text="Contact the Developer" Click="Contact_Click" />
        <MenuFlyoutItem Text="Rate and Review" Click="RateReview_Click" />
        <MenuFlyoutItem Text="Feedback" Click="Feedback_Click" />
      </MenuBarItem>
    </MenuBar>

    <!-- Main text editing area -->
    <TextBox x:Name="PassedTextControl"
             Grid.Row="1"
             AcceptsReturn="True"
             IsSpellCheckEnabled="True"
             TextWrapping="Wrap"
             PlaceholderText="Paste or type text here..."
             Margin="0"
             Padding="12"
             BorderThickness="0"
             Background="Transparent"
             FontFamily="Segoe UI"
             FontSize="14"
             SelectionChanged="PassedTextControl_SelectionChanged"
             TextChanged="PassedTextControl_TextChanged"
             AllowDrop="True"
             DragOver="PassedTextControl_DragOver"
             Drop="PassedTextControl_Drop"
             ScrollViewer.VerticalScrollBarVisibility="Auto"
             ScrollViewer.HorizontalScrollBarVisibility="Auto">
      <TextBox.ContextFlyout>
        <MenuFlyout>
          <MenuFlyoutItem Text="Cut" Click="Cut_Click" />
          <MenuFlyoutItem Text="Copy" Click="Copy_Click" />
          <MenuFlyoutItem Text="Paste" Click="Paste_Click" />
          <MenuFlyoutSeparator />
          <MenuFlyoutItem Text="Select All" Click="SelectAll_Click" />
          <MenuFlyoutItem Text="Select Line" Click="SelectLine_Click" />
          <MenuFlyoutSeparator />
          <MenuFlyoutItem Text="Toggle Case" Click="ToggleCase_Click" />
          <MenuFlyoutItem Text="Web Search" Click="WebSearch_Click" />
          <MenuFlyoutItem Text="Delete Selected" Click="DeleteSelected_Click" />
        </MenuFlyout>
      </TextBox.ContextFlyout>
    </TextBox>

    <!-- Status Bar -->
    <Grid Grid.Row="2"
          Padding="12,6"
          ColumnSpacing="16"
          Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock x:Name="StatusBarText"
                 Grid.Column="0"
                 Text="Ready"
                 Style="{StaticResource LabelSmall}"
                 VerticalAlignment="Center" />

      <TextBlock x:Name="WordCountText"
                 Grid.Column="1"
                 Text="Words: 0"
                 Style="{StaticResource LabelSmall}"
                 VerticalAlignment="Center"
                 Opacity="0.7" />

      <TextBlock x:Name="CharCountText"
                 Grid.Column="2"
                 Text="Chars: 0"
                 Style="{StaticResource LabelSmall}"
                 VerticalAlignment="Center"
                 Opacity="0.7" />

      <TextBlock x:Name="LineColText"
                 Grid.Column="3"
                 Text="Ln 1, Col 0"
                 Style="{StaticResource LabelSmall}"
                 VerticalAlignment="Center"
                 Opacity="0.7" />
    </Grid>
  </Grid>
</Page>

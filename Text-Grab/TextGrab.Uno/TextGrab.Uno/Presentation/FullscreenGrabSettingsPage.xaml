<Page x:Class="TextGrab.Presentation.FullscreenGrabSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      NavigationCacheMode="Required">

  <ScrollViewer>
    <StackPanel Spacing="4" Padding="20,12,40,40">

      <TextBlock Text="Fullscreen Grab Settings"
                 Style="{StaticResource TitleLarge}" />

      <!-- Start mode -->
      <TextBlock Text="Defaults"
                 Style="{StaticResource TitleMedium}"
                 Margin="0,16,0,4" />
      <TextBlock Text="Start mode:"
                 Style="{StaticResource BodyMedium}" />
      <RadioButtons x:Name="StartModeRadioButtons"
                    SelectionChanged="StartModeRadioButtons_SelectionChanged"
                    Margin="0,4,0,0">
        <RadioButton Content="Default (Standard)" Tag="Default" />
        <RadioButton Content="Single Line" Tag="SingleLine" />
        <RadioButton Content="Table" Tag="Table" />
      </RadioButtons>
      <TextBlock Text="Single Line outputs captures as a single line. Table mode requires Windows OCR/AI languages."
                 Style="{StaticResource BodyMedium}"
                 Opacity="0.7"
                 TextWrapping="Wrap"
                 Margin="24,4,0,8" />

      <!-- Send to Edit Text Window -->
      <ToggleSwitch x:Name="SendToEtwToggle"
                    Toggled="SendToEtwToggle_Toggled"
                    Header="Send output to Edit Text Window by default" />
      <TextBlock Text="Automatically route captured text into the Edit Text Window."
                 Style="{StaticResource BodyMedium}"
                 Opacity="0.7"
                 Margin="24,0,0,8" />

      <!-- Shade overlay -->
      <ToggleSwitch x:Name="ShadeOverlayToggle"
                    Toggled="ShadeOverlayToggle_Toggled"
                    Header="Dim screen with translucent overlay while selecting" />
      <TextBlock Text="Controls the transparent overlay shown during Fullscreen Grab selection."
                 Style="{StaticResource BodyMedium}"
                 Opacity="0.7"
                 Margin="24,0,0,8" />

      <!-- Post-capture insert -->
      <TextBlock Text="Post-capture insert"
                 Style="{StaticResource TitleMedium}"
                 Margin="0,16,0,4" />
      <ToggleSwitch x:Name="TryInsertToggle"
                    Toggled="TryInsertToggle_Toggled"
                    Header="Insert captured text into the focused app after closing" />
      <StackPanel Orientation="Horizontal" Margin="24,8,0,0" Spacing="12">
        <TextBlock Text="Insert delay (seconds):"
                   VerticalAlignment="Center"
                   Style="{StaticResource BodyMedium}" />
        <Slider x:Name="InsertDelaySlider"
                Width="200"
                Minimum="0"
                Maximum="5"
                StepFrequency="0.1"
                SnapsTo="StepValues"
                ValueChanged="InsertDelaySlider_ValueChanged" />
        <TextBlock x:Name="InsertDelayValueText"
                   VerticalAlignment="Center"
                   Style="{StaticResource BodyMedium}" />
      </StackPanel>
      <TextBlock Text="How long to wait before simulating paste (Ctrl+V)."
                 Style="{StaticResource BodyMedium}"
                 Opacity="0.7"
                 Margin="24,2,0,0" />

    </StackPanel>
  </ScrollViewer>
</Page>

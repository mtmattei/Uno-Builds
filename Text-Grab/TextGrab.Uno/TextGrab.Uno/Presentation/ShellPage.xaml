<Page x:Class="TextGrab.Presentation.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <NavigationView x:Name="NavView"
                    PaneDisplayMode="LeftCompact"
                    IsBackButtonVisible="Collapsed"
                    IsSettingsVisible="False"
                    SelectionChanged="NavView_SelectionChanged">

      <NavigationView.MenuItems>
        <NavigationViewItem Content="Edit Text" Tag="EditText">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Edit" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Fullscreen Grab" Tag="FullscreenGrab">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE7A0;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Grab Frame" Tag="GrabFrame">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8B7;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Quick Lookup" Tag="QuickLookup">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Find" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
        <NavigationViewItem Content="Settings" Tag="Settings">
          <NavigationViewItem.Icon>
            <SymbolIcon Symbol="Setting" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <Frame x:Name="ContentFrame" />

    </NavigationView>

    <!-- Notification overlay -->
    <StackPanel x:Name="NotificationHost"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,48,0,0" />
  </Grid>
</Page>

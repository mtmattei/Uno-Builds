<ContentDialog x:Class="TextGrab.Presentation.FindReplaceDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               Title="Find and Replace"
               PrimaryButtonText="Close"
               DefaultButton="Primary">

  <StackPanel Spacing="12" MinWidth="400">

    <!-- Find -->
    <TextBox x:Name="FindTextBox"
             Header="Find"
             PlaceholderText="Search text..."
             TextChanged="FindTextBox_TextChanged" />

    <!-- Replace -->
    <TextBox x:Name="ReplaceTextBox"
             Header="Replace with"
             PlaceholderText="Replacement text..." />

    <!-- Options -->
    <StackPanel Orientation="Horizontal" Spacing="16">
      <CheckBox x:Name="MatchCaseCheckBox"
                Content="Match case"
                IsChecked="False"
                Click="Option_Changed" />
      <CheckBox x:Name="UseRegexCheckBox"
                Content="Use regex"
                IsChecked="False"
                Click="Option_Changed" />
    </StackPanel>

    <!-- Match count -->
    <TextBlock x:Name="MatchCountText"
               Text="0 matches"
               Style="{StaticResource BodySmall}"
               Opacity="0.7" />

    <!-- Action buttons -->
    <StackPanel Orientation="Horizontal" Spacing="8">
      <Button Content="Find Next" Click="FindNext_Click" />
      <Button Content="Replace" Click="Replace_Click" />
      <Button Content="Replace All" Click="ReplaceAll_Click" />
    </StackPanel>

  </StackPanel>
</ContentDialog>

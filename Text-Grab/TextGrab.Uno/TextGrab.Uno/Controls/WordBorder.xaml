<UserControl
    x:Class="TextGrab.Controls.WordBorder"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="WordBorderControl"
    PointerEntered="WordBorder_PointerEntered"
    PointerExited="WordBorder_PointerExited">

  <Grid>
    <!-- Main word display/edit border -->
    <Border x:Name="WordBorderBorder"
            BorderBrush="{ThemeResource PrimaryBrush}"
            BorderThickness="0,0,0,2"
            CornerRadius="0">
      <Border.ContextFlyout>
        <MenuFlyout>
          <MenuFlyoutItem Text="Copy Text" Click="CopyWordMenuItem_Click" />
          <MenuFlyoutItem Text="Try To Make Numbers" Click="TryToNumberMenuItem_Click" />
          <MenuFlyoutItem Text="Try To Make Letters" Click="TryToAlphaMenuItem_Click" />
          <MenuFlyoutItem Text="Make Single Line" Click="MakeSingleLineMenuItem_Click" />
          <MenuFlyoutSeparator />
          <MenuFlyoutItem Text="Merge Selected" Click="MergeWordBordersMenuItem_Click" />
          <MenuFlyoutItem Text="Break into Words" Click="BreakIntoWordsMenuItem_Click" />
          <MenuFlyoutItem Text="Search for Similar" Click="SearchForSimilarMenuItem_Click" />
          <MenuFlyoutSeparator />
          <MenuFlyoutItem Text="Delete" Click="DeleteWordMenuItem_Click" />
        </MenuFlyout>
      </Border.ContextFlyout>

      <Grid x:Name="MainGrid" Background="Transparent">
        <Viewbox x:Name="EditTextViewBox">
          <TextBox x:Name="EditWordTextBox"
                   MinWidth="10"
                   MinHeight="14"
                   Margin="-1,-3,-1,-1"
                   AcceptsReturn="True"
                   FontFamily="Segoe UI"
                   FontSize="12"
                   FontWeight="Medium"
                   Foreground="White"
                   Background="Transparent"
                   BorderThickness="0"
                   GotFocus="EditWordTextBox_GotFocus"
                   PointerPressed="EditWordTextBox_PointerPressed"
                   TextChanged="EditWordTextBox_TextChanged" />
        </Viewbox>
      </Grid>
    </Border>

    <!-- Move/Resize overlay (shown on Ctrl+hover) -->
    <Border x:Name="MoveResizeBorder"
            Background="Transparent"
            BorderBrush="{ThemeResource PrimaryBrush}"
            BorderThickness="2"
            CornerRadius="2"
            Visibility="Collapsed">
      <Grid>
        <Grid Background="Transparent" PointerPressed="MoveResizeBorder_PointerPressed" />
        <!-- Left resize handle -->
        <Border Width="6" Height="12" Margin="-4"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="1"
                PointerPressed="SizeHandle_PointerPressed" Tag="Left" />
        <!-- Top resize handle -->
        <Border Width="20" Height="6" Margin="-4"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="1"
                PointerPressed="SizeHandle_PointerPressed" Tag="Top" />
        <!-- Right resize handle -->
        <Border Width="6" Height="12" Margin="-4"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="1"
                PointerPressed="SizeHandle_PointerPressed" Tag="Right" />
        <!-- Bottom resize handle -->
        <Border Width="20" Height="6" Margin="-4"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Background="{ThemeResource PrimaryContainerBrush}" CornerRadius="1"
                PointerPressed="SizeHandle_PointerPressed" Tag="Bottom" />
      </Grid>
    </Border>
  </Grid>
</UserControl>

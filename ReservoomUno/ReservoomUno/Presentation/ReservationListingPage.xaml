<Page x:Class="ReservoomUno.Presentation.ReservationListingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ReservoomUno.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:converters="using:ReservoomUno.Converters"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <utu:NavigationBar Content="Reservoom"
                       Grid.Row="0" />

    <!-- Content -->
    <ScrollViewer Grid.Row="1">
      <Grid MaxWidth="600"
            Padding="24,16,24,24"
            HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Action bar -->
        <Grid Grid.Row="0"
              Margin="0,0,0,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="Reservations"
                     Style="{StaticResource TitleLargeTextBlockStyle}"
                     VerticalAlignment="Center" />

          <Button Grid.Column="1"
                  Content="New Reservation"
                  Style="{StaticResource FilledButtonStyle}"
                  AutomationProperties.AutomationId="MakeReservationButton"
                  uen:Navigation.Request="MakeReservation" />
        </Grid>

        <!-- Loading state -->
        <ProgressRing Grid.Row="1"
                      IsActive="{Binding IsLoading}"
                      Visibility="{Binding IsLoading}"
                      Width="48"
                      Height="48"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="0,48,0,0" />

        <!-- Error state -->
        <TextBlock Grid.Row="1"
                   Text="{Binding ErrorMessage}"
                   Visibility="{Binding HasErrorMessage}"
                   Foreground="{ThemeResource ErrorBrush}"
                   Style="{StaticResource BodyLargeTextBlockStyle}"
                   Margin="0,24,0,0"
                   TextWrapping="Wrap" />

        <!-- Empty state -->
        <TextBlock Grid.Row="1"
                   Text="No reservations have been made yet."
                   Style="{StaticResource BodyLargeTextBlockStyle}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,48,0,0">
          <TextBlock.Visibility>
            <Binding Path="HasReservations"
                     Converter="{StaticResource InverseBoolConverter}" />
          </TextBlock.Visibility>
        </TextBlock>

        <!-- Reservation list -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Reservations}"
                  Visibility="{Binding HasReservations}"
                  SelectionMode="None"
                  Margin="0,8,0,0">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border Background="{ThemeResource SurfaceBrush}"
                      CornerRadius="12"
                      Padding="16"
                      Margin="0,4"
                      Translation="0,0,8">
                <Border.Shadow>
                  <ThemeShadow />
                </Border.Shadow>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <StackPanel Grid.Row="0"
                              Orientation="Horizontal"
                              Spacing="8">
                    <TextBlock Text="{Binding RoomID}"
                               Style="{StaticResource TitleMediumTextBlockStyle}"
                               Foreground="{ThemeResource PrimaryBrush}" />
                    <TextBlock Text="·"
                               Style="{StaticResource TitleMediumTextBlockStyle}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                    <TextBlock Text="{Binding Username}"
                               Style="{StaticResource TitleMediumTextBlockStyle}" />
                  </StackPanel>

                  <StackPanel Grid.Row="1"
                              Orientation="Horizontal"
                              Spacing="4"
                              Margin="0,4,0,0">
                    <TextBlock Style="{StaticResource BodyMediumTextBlockStyle}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                      <Run Text="{Binding StartDate}" />
                      <Run Text=" — " />
                      <Run Text="{Binding EndDate}" />
                    </TextBlock>
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="HorizontalContentAlignment"
                      Value="Stretch" />
              <Setter Property="Padding"
                      Value="0" />
              <Setter Property="Margin"
                      Value="0" />
            </Style>
          </ListView.ItemContainerStyle>
        </ListView>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>

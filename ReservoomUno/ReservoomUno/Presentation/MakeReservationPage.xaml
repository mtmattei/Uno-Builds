<Page x:Class="ReservoomUno.Presentation.MakeReservationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:ReservoomUno.Presentation"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:converters="using:ReservoomUno.Converters"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <converters:DateTimeToDateTimeOffsetConverter x:Key="DateTimeToDateTimeOffsetConverter" />
    <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
  </Page.Resources>

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back -->
    <utu:NavigationBar Content="New Reservation"
                       Grid.Row="0">
      <utu:NavigationBar.MainCommand>
        <AppBarButton uen:Navigation.Request="-">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE72B;" />
          </AppBarButton.Icon>
        </AppBarButton>
      </utu:NavigationBar.MainCommand>
    </utu:NavigationBar>

    <!-- Form -->
    <ScrollViewer Grid.Row="1">
      <StackPanel MaxWidth="600"
                  Padding="24,16,24,24"
                  Spacing="16"
                  HorizontalAlignment="Stretch">

        <!-- Username -->
        <TextBox Header="Username"
                 Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Enter username"
                 AutomationProperties.AutomationId="MakeReservationUsernameTextBox" />

        <!-- Room details -->
        <Grid ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBox Grid.Column="0"
                   Header="Floor Number"
                   Text="{Binding FloorNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="1"
                   AutomationProperties.AutomationId="MakeReservationFloorNumberTextBox" />

          <TextBox Grid.Column="1"
                   Header="Room Number"
                   Text="{Binding RoomNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="0"
                   AutomationProperties.AutomationId="MakeReservationRoomNumberTextBox" />
        </Grid>

        <!-- Dates -->
        <CalendarDatePicker Header="Start Date"
                            Date="{Binding StartDate, Mode=TwoWay, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="MakeReservationStartDatePicker" />

        <CalendarDatePicker Header="End Date"
                            Date="{Binding EndDate, Mode=TwoWay, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.AutomationId="MakeReservationEndDatePicker" />

        <!-- Actions -->
        <Grid Margin="0,8,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  Content="Submit"
                  Style="{StaticResource FilledButtonStyle}"
                  Command="{Binding SubmitCommand}"
                  AutomationProperties.AutomationId="MakeReservationSubmitButton" />

          <Button Grid.Column="1"
                  Content="Cancel"
                  Style="{StaticResource TextButtonStyle}"
                  Margin="8,0,0,0"
                  IsEnabled="{Binding IsSubmitting, Converter={StaticResource InverseBoolConverter}}"
                  uen:Navigation.Request="-" />

          <ProgressRing Grid.Column="2"
                        IsActive="{Binding IsSubmitting}"
                        Visibility="{Binding IsSubmitting}"
                        Width="24"
                        Height="24"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center" />
        </Grid>

        <!-- Error message -->
        <TextBlock Text="{Binding SubmitErrorMessage}"
                   Visibility="{Binding HasSubmitErrorMessage}"
                   Foreground="{ThemeResource ErrorBrush}"
                   Style="{StaticResource BodyLargeTextBlockStyle}"
                   TextWrapping="Wrap"
                   AutomationProperties.AutomationId="MakeReservationSubmitErrorMessage" />

      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>

<UserControl x:Class="RadialActionMenuDemo.Controls.RadialActionMenu"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:RadialActionMenuDemo.Controls"
             AutomationProperties.Name="Actions menu">

    <Grid x:Name="RootGrid">
        <!-- Backdrop overlay - dark CRT fade -->
        <Border x:Name="Backdrop"
                Background="#C0000000"
                Opacity="0"
                IsHitTestVisible="False"/>

        <!-- Menu items container -->
        <Canvas x:Name="MenuCanvas">
            <!-- Item 0 -->
            <Border x:Name="MenuItem0"
                    Width="48"
                    Height="48"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="MenuItem0Transform" ScaleX="0" ScaleY="0" Rotation="-180"/>
                </Border.RenderTransform>
                <Button x:Name="MenuItem0Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnMenuItemClick">
                    <FontIcon x:Name="MenuItem0Icon"
                              Glyph="&#xE72D;"
                              FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"/>
                </Button>
            </Border>

            <!-- Item 1 -->
            <Border x:Name="MenuItem1"
                    Width="48"
                    Height="48"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="MenuItem1Transform" ScaleX="0" ScaleY="0" Rotation="-180"/>
                </Border.RenderTransform>
                <Button x:Name="MenuItem1Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnMenuItemClick">
                    <FontIcon x:Name="MenuItem1Icon"
                              Glyph="&#xE70F;"
                              FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"/>
                </Button>
            </Border>

            <!-- Item 2 -->
            <Border x:Name="MenuItem2"
                    Width="48"
                    Height="48"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="MenuItem2Transform" ScaleX="0" ScaleY="0" Rotation="-180"/>
                </Border.RenderTransform>
                <Button x:Name="MenuItem2Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnMenuItemClick">
                    <FontIcon x:Name="MenuItem2Icon"
                              Glyph="&#xE74D;"
                              FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"/>
                </Button>
            </Border>

            <!-- Item 3 -->
            <Border x:Name="MenuItem3"
                    Width="48"
                    Height="48"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="MenuItem3Transform" ScaleX="0" ScaleY="0" Rotation="-180"/>
                </Border.RenderTransform>
                <Button x:Name="MenuItem3Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnMenuItemClick">
                    <FontIcon x:Name="MenuItem3Icon"
                              Glyph="&#xE734;"
                              FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"/>
                </Button>
            </Border>

            <!-- Item 4 -->
            <Border x:Name="MenuItem4"
                    Width="48"
                    Height="48"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    Opacity="0"
                    IsHitTestVisible="False"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="MenuItem4Transform" ScaleX="0" ScaleY="0" Rotation="-180"/>
                </Border.RenderTransform>
                <Button x:Name="MenuItem4Button"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="OnMenuItemClick">
                    <FontIcon x:Name="MenuItem4Icon"
                              Glyph="&#xE713;"
                              FontSize="20"
                              Foreground="{ThemeResource PrimaryBrush}"/>
                </Button>
            </Border>

            <!-- Pulse Ring - square pixel burst -->
            <Ellipse x:Name="PulseRing"
                     Width="56"
                     Height="56"
                     Stroke="{ThemeResource PrimaryBrush}"
                     StrokeThickness="3"
                     Opacity="0"
                     IsHitTestVisible="False"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <ScaleTransform x:Name="PulseRingScale" ScaleX="1" ScaleY="1"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Trigger FAB Button - square pixel style -->
            <Border x:Name="TriggerBorder"
                    Width="56"
                    Height="56"
                    CornerRadius="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource PrimaryBrush}"
                    BorderThickness="2"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="TriggerTransform"/>
                </Border.RenderTransform>
                <Button x:Name="TriggerButton"
                        Background="Transparent"
                        BorderThickness="0"
                        Width="56"
                        Height="56"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        AutomationProperties.Name="Open actions menu"
                        Click="OnTriggerClick">
                    <Grid>
                        <FontIcon x:Name="PlusIcon"
                                  Glyph="&#xE710;"
                                  FontSize="24"
                                  Foreground="{ThemeResource PrimaryBrush}"
                                  RenderTransformOrigin="0.5,0.5">
                            <FontIcon.RenderTransform>
                                <RotateTransform x:Name="PlusIconRotation"/>
                            </FontIcon.RenderTransform>
                        </FontIcon>
                    </Grid>
                </Button>
            </Border>
        </Canvas>
    </Grid>
</UserControl>

<Page x:Class="SplitFlap.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SplitFlap"
      xmlns:controls="using:SplitFlap.Controls"
      Background="#0a0a0a">

    <Grid HorizontalAlignment="Center"
          VerticalAlignment="Center">

        <StackPanel Spacing="24">
            <controls:SplitFlapCard x:Name="SingleCard"
                                     Character="0"
                                     Theme="Dark"
                                     Size="Large"/>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        HorizontalAlignment="Center">
                <Button Content="0" Click="OnCardButtonClick" Tag="0" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="1" Click="OnCardButtonClick" Tag="1" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="2" Click="OnCardButtonClick" Tag="2" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="3" Click="OnCardButtonClick" Tag="3" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="4" Click="OnCardButtonClick" Tag="4" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="5" Click="OnCardButtonClick" Tag="5" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="6" Click="OnCardButtonClick" Tag="6" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="7" Click="OnCardButtonClick" Tag="7" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="8" Click="OnCardButtonClick" Tag="8" Width="40" Background="#27272a" Foreground="#fef3c7"/>
                <Button Content="9" Click="OnCardButtonClick" Tag="9" Width="40" Background="#27272a" Foreground="#fef3c7"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Page>

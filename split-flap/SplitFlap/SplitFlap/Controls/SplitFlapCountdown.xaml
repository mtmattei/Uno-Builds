<UserControl x:Class="SplitFlap.Controls.SplitFlapCountdown"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:SplitFlap.Controls">

    <StackPanel x:Name="CountdownPanel"
                Orientation="Horizontal"
                Spacing="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

        <!-- Days -->
        <StackPanel x:Name="DaysPanel" Spacing="4">
            <local:SplitFlapDisplay x:Name="DaysDisplay"
                                     Length="3"
                                     StaggerDelay="30"
                                     PadCharacter="0"/>
            <TextBlock x:Name="DaysLabel"
                       Text="DAYS"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Hours -->
        <StackPanel Spacing="4">
            <local:SplitFlapDisplay x:Name="HoursDisplay"
                                     Length="2"
                                     StaggerDelay="30"
                                     PadCharacter="0"/>
            <TextBlock x:Name="HoursLabel"
                       Text="HOURS"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Minutes -->
        <StackPanel Spacing="4">
            <local:SplitFlapDisplay x:Name="MinutesDisplay"
                                     Length="2"
                                     StaggerDelay="30"
                                     PadCharacter="0"/>
            <TextBlock x:Name="MinutesLabel"
                       Text="MINS"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Seconds -->
        <StackPanel Spacing="4">
            <local:SplitFlapDisplay x:Name="SecondsDisplay"
                                     Length="2"
                                     StaggerDelay="30"
                                     PadCharacter="0"/>
            <TextBlock x:Name="SecondsLabel"
                       Text="SECS"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
        </StackPanel>

    </StackPanel>

</UserControl>

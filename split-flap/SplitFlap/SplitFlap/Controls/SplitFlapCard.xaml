<UserControl x:Class="SplitFlap.Controls.SplitFlapCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:SplitFlap.Controls">

    <UserControl.Resources>
        <!-- Top flap collapse animation (simulates rotate down via ScaleY) -->
        <Storyboard x:Name="FlipTopStoryboard">
            <DoubleAnimation x:Name="FlipTopAnimation"
                             Storyboard.TargetName="TopFlapScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0"
                             Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DynamicShadow"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="0.4"
                             Duration="0:0:0.15"/>
        </Storyboard>

        <!-- Bottom flap expand animation (simulates rotate up via ScaleY) -->
        <Storyboard x:Name="FlipBottomStoryboard">
            <DoubleAnimation x:Name="FlipBottomAnimation"
                             Storyboard.TargetName="BottomFlapScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="0" To="1"
                             Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="DynamicShadow"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="0"
                             Duration="0:0:0.15"/>
        </Storyboard>
    </UserControl.Resources>

    <!-- Outer Frame with metallic appearance -->
    <Border x:Name="OuterFrame"
            CornerRadius="8"
            Padding="4">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop x:Name="FrameGradientTop" Color="#09090b" Offset="0"/>
                <GradientStop x:Name="FrameGradientBottom" Color="#000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <!-- Corner Rivets -->
            <Ellipse x:Name="RivetTopLeft"
                     Width="6" Height="6"
                     HorizontalAlignment="Left" VerticalAlignment="Top"
                     Margin="2,2,0,0">
                <Ellipse.Fill>
                    <SolidColorBrush x:Name="RivetBrush" Color="#52525b"/>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="6" Height="6"
                     Fill="{Binding Fill, ElementName=RivetTopLeft}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,2,2,0"/>
            <Ellipse Width="6" Height="6"
                     Fill="{Binding Fill, ElementName=RivetTopLeft}"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom"
                     Margin="2,0,0,2"/>
            <Ellipse Width="6" Height="6"
                     Fill="{Binding Fill, ElementName=RivetTopLeft}"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom"
                     Margin="0,0,2,2"/>

            <!-- Card Container -->
            <Grid x:Name="CardContainer" Margin="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Static Base - Top Half (shows NEW character) -->
                <Border x:Name="StaticTopHalf"
                        Grid.Row="0"
                        CornerRadius="4,4,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop x:Name="CardGradientTop" Color="#27272a" Offset="0"/>
                            <GradientStop x:Name="CardGradientMid" Color="#1f1f23" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Character - positioned to show bottom portion (clipped by parent) -->
                        <TextBlock x:Name="StaticTopChar"
                                   Text="0"
                                   FontFamily="Arial Black"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush x:Name="TextBrush" Color="#fef3c7"/>
                            </TextBlock.Foreground>
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="StaticTopCharTransform" Y="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <!-- Top Highlight Overlay -->
                        <Border CornerRadius="4,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#19FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.25"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- Center Divider -->
                <Border x:Name="CenterDivider"
                        Grid.Row="1"
                        Height="2">
                    <Border.Background>
                        <SolidColorBrush x:Name="DividerBrush" Color="#09090b"/>
                    </Border.Background>
                </Border>

                <!-- Static Base - Bottom Half (shows NEW character) -->
                <Border x:Name="StaticBottomHalf"
                        Grid.Row="2"
                        CornerRadius="0,0,4,4">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop x:Name="CardGradientMid2" Color="#1f1f23" Offset="0"/>
                            <GradientStop x:Name="CardGradientBottom" Color="#18181b" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <!-- Character - positioned to show top portion -->
                        <TextBlock x:Name="StaticBottomChar"
                                   Text="0"
                                   FontFamily="Arial Black"
                                   FontWeight="Bold"
                                   Foreground="{Binding Foreground, ElementName=StaticTopChar}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="StaticBottomCharTransform" Y="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                        <!-- Bottom Shadow Overlay -->
                        <Border CornerRadius="0,0,4,4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#33000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.25"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- Animated Top Flap (shows OLD character, collapses down) -->
                <Border x:Name="AnimatedTopFlap"
                        Grid.Row="0"
                        CornerRadius="4,4,0,0"
                        Visibility="Collapsed"
                        RenderTransformOrigin="0.5,1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#27272a" Offset="0"/>
                            <GradientStop Color="#1f1f23" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="TopFlapScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <Grid>
                        <TextBlock x:Name="AnimatedTopChar"
                                   Text="0"
                                   FontFamily="Arial Black"
                                   FontWeight="Bold"
                                   Foreground="{Binding Foreground, ElementName=StaticTopChar}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="AnimatedTopCharTransform" Y="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <Border CornerRadius="4,4,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#19FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.25"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- Animated Bottom Flap (shows NEW character, expands from top) -->
                <Border x:Name="AnimatedBottomFlap"
                        Grid.Row="2"
                        CornerRadius="0,0,4,4"
                        Visibility="Collapsed"
                        RenderTransformOrigin="0.5,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#1f1f23" Offset="0"/>
                            <GradientStop Color="#18181b" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="BottomFlapScale" ScaleX="1" ScaleY="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <TextBlock x:Name="AnimatedBottomChar"
                                   Text="0"
                                   FontFamily="Arial Black"
                                   FontWeight="Bold"
                                   Foreground="{Binding Foreground, ElementName=StaticTopChar}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="AnimatedBottomCharTransform" Y="0"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        <Border CornerRadius="0,0,4,4">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                    <GradientStop Color="#33000000" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.25"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

                <!-- Dynamic Shadow during flip -->
                <Border x:Name="DynamicShadow"
                        Grid.Row="2"
                        VerticalAlignment="Top"
                        Height="32"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#66000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>

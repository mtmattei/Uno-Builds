<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Size Variants -->
    <!-- Small -->
    <x:Double x:Key="SplitFlapSmallWidth">40</x:Double>
    <x:Double x:Key="SplitFlapSmallHeight">56</x:Double>
    <x:Double x:Key="SplitFlapSmallFontSize">30</x:Double>
    <x:Double x:Key="SplitFlapSmallGap">1</x:Double>
    <x:Double x:Key="SplitFlapSmallRivetSize">4</x:Double>
    <Thickness x:Key="SplitFlapSmallPadding">3</Thickness>

    <!-- Medium -->
    <x:Double x:Key="SplitFlapMediumWidth">64</x:Double>
    <x:Double x:Key="SplitFlapMediumHeight">88</x:Double>
    <x:Double x:Key="SplitFlapMediumFontSize">48</x:Double>
    <x:Double x:Key="SplitFlapMediumGap">2</x:Double>
    <x:Double x:Key="SplitFlapMediumRivetSize">6</x:Double>
    <Thickness x:Key="SplitFlapMediumPadding">4</Thickness>

    <!-- Large -->
    <x:Double x:Key="SplitFlapLargeWidth">96</x:Double>
    <x:Double x:Key="SplitFlapLargeHeight">128</x:Double>
    <x:Double x:Key="SplitFlapLargeFontSize">72</x:Double>
    <x:Double x:Key="SplitFlapLargeGap">3</x:Double>
    <x:Double x:Key="SplitFlapLargeRivetSize">8</x:Double>
    <Thickness x:Key="SplitFlapLargePadding">6</Thickness>

    <!-- Dark Theme (Default) -->
    <Color x:Key="SplitFlapDarkFrameBackground">#09090b</Color>
    <Color x:Key="SplitFlapDarkFrameBackgroundDark">#000000</Color>
    <Color x:Key="SplitFlapDarkCardTop">#27272a</Color>
    <Color x:Key="SplitFlapDarkCardBottom">#18181b</Color>
    <Color x:Key="SplitFlapDarkCardBorder">#3f3f46</Color>
    <Color x:Key="SplitFlapDarkTextColor">#fef3c7</Color>
    <Color x:Key="SplitFlapDarkDividerColor">#09090b</Color>
    <Color x:Key="SplitFlapDarkRivetColor">#52525b</Color>
    <Color x:Key="SplitFlapDarkHighlightColor">#19FFFFFF</Color>
    <Color x:Key="SplitFlapDarkShadowColor">#33000000</Color>

    <!-- Light Theme -->
    <Color x:Key="SplitFlapLightFrameBackground">#d6d3d1</Color>
    <Color x:Key="SplitFlapLightFrameBackgroundDark">#a8a29e</Color>
    <Color x:Key="SplitFlapLightCardTop">#f5f5f4</Color>
    <Color x:Key="SplitFlapLightCardBottom">#e7e5e4</Color>
    <Color x:Key="SplitFlapLightCardBorder">#d6d3d1</Color>
    <Color x:Key="SplitFlapLightTextColor">#1c1917</Color>
    <Color x:Key="SplitFlapLightDividerColor">#a8a29e</Color>
    <Color x:Key="SplitFlapLightRivetColor">#a8a29e</Color>
    <Color x:Key="SplitFlapLightHighlightColor">#19FFFFFF</Color>
    <Color x:Key="SplitFlapLightShadowColor">#33000000</Color>

    <!-- Vintage Theme -->
    <Color x:Key="SplitFlapVintageFrameBackground">#92400e</Color>
    <Color x:Key="SplitFlapVintageFrameBackgroundDark">#78350f</Color>
    <Color x:Key="SplitFlapVintageCardTop">#fef3c7</Color>
    <Color x:Key="SplitFlapVintageCardBottom">#fde68a</Color>
    <Color x:Key="SplitFlapVintageCardBorder">#fcd34d</Color>
    <Color x:Key="SplitFlapVintageTextColor">#451a03</Color>
    <Color x:Key="SplitFlapVintageDividerColor">#fbbf24</Color>
    <Color x:Key="SplitFlapVintageRivetColor">#b45309</Color>
    <Color x:Key="SplitFlapVintageHighlightColor">#19FFFFFF</Color>
    <Color x:Key="SplitFlapVintageShadowColor">#4D451a03</Color>

    <!-- Animation Durations -->
    <Duration x:Key="SplitFlapFlipDuration">0:0:0.15</Duration>
    <Duration x:Key="SplitFlapTotalDuration">0:0:0.30</Duration>

</ResourceDictionary>

<Page x:Class="settingspage.Presentation.SettingsPage"
	  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	  xmlns:local="using:settingspage.Presentation"
	  xmlns:uen="using:Uno.Extensions.Navigation.UI"
	  xmlns:utu="using:Uno.Toolkit.UI"
	  xmlns:um="using:Uno.Material"
	  NavigationCacheMode="Required"
	  Background="{ThemeResource BackgroundBrush}">
  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>
    <utu:NavigationBar Content="Settings"
                       uen:Navigation.Request="/" />

    <StackPanel Grid.Row="1"
                Padding="24"
                Spacing="16">
      <ToggleSwitch Header="Enable Notifications"
                    IsOn="{Binding EnableNotifications, Mode=TwoWay}"
                    AutomationProperties.AutomationId="EnableNotificationsToggle" />
      <ToggleSwitch Header="Dark Mode"
                    IsOn="{Binding DarkMode, Mode=TwoWay}"
                    AutomationProperties.AutomationId="DarkModeToggle" />
      <ToggleSwitch Header="Auto Save"
                    IsOn="{Binding AutoSave, Mode=TwoWay}"
                    AutomationProperties.AutomationId="AutoSaveToggle" />
    </StackPanel>
  </Grid>
</Page>

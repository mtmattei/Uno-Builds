<Application x:Class="FieldOpsPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utum="using:Uno.Toolkit.UI.Material"
             RequestedTheme="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

        <!-- Material Theme with Color Overrides -->
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml" />

        <!-- FieldOps Pro Custom Resources -->
        <ResourceDictionary Source="ms-appx:///Styles/FieldOpsResources.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Mobile Nav Button Style -->
      <Style x:Key="MobileNavButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
      </Style>

    </ResourceDictionary>
  </Application.Resources>

</Application>

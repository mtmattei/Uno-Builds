<UserControl x:Class="FieldOpsPro.Presentation.Controls.TaskCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited">
             x:Uid="TaskCard">

    <Border x:Name="CardBorder"
      Background="{StaticResource BgTertiaryBrush}"
      BorderBrush="Transparent"
      BorderThickness="1"
      CornerRadius="14"
      Padding="18"
      AutomationProperties.Name="{x:Bind TaskItem.Title}">
    <Border.RenderTransform>
      <CompositeTransform x:Name="CardTransform" />
    </Border.RenderTransform>

    <Grid RowSpacing="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="4" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Priority Indicator -->
        <Border x:Name="PriorityIndicator"
                Grid.Column="0"
                Width="4"
                CornerRadius="2"
                VerticalAlignment="Stretch"
                Margin="-18,0,0,0" />

        <!-- Task Content -->
        <StackPanel Grid.Column="1" Spacing="4">
          <TextBlock x:Name="TitleText"
                     Style="{StaticResource BodyMediumStyle}"
                     TextTrimming="CharacterEllipsis"
                     MaxLines="2" />

            <StackPanel Orientation="Horizontal" Spacing="12">
            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon x:Name="LocationIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE707;"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock x:Name="LocationText"
                         Style="{StaticResource CaptionStyle}"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="4">
              <FontIcon x:Name="DurationIcon" FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE823;"
                        FontSize="12"
                        Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock x:Name="DurationText"
                         Style="{StaticResource CaptionStyle}" />
            </StackPanel>

                <!-- SLA Timer -->
                <Border x:Name="SlaTimerBorder"
                  Background="{StaticResource BgElevatedBrush}"
                  CornerRadius="4"
                  Padding="6,2"
                  Visibility="Collapsed"
                  x:Uid="TaskCard.SlaTimer">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <FontIcon x:Name="SlaIcon"
                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                          Glyph="&#xE121;"
                          FontSize="11"
                          Foreground="#C0C0C0" />
                <TextBlock x:Name="SlaTimerText"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#C0C0C0" />
              </StackPanel>
            </Border>
          </StackPanel>
        </StackPanel>

        <!-- Assignee Avatar -->
        <local:Avatar x:Name="AssigneeAvatar"
                      Grid.Column="2"
                      Size="36"
                      VerticalAlignment="Center" />

        <!-- Status Badge -->
        <local:StatusBadge x:Name="TaskStatusBadge"
                           Grid.Column="3"
                           VerticalAlignment="Center" />
      </Grid>

      <!-- Photo Thumbnails Row -->
      <StackPanel x:Name="PhotosPanel"
                  Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="8"
                  Margin="4,0,0,0"
                  Visibility="Collapsed">
        <Border x:Name="Photo1"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="#1A1A1A">
          <Image x:Name="PhotoImage1"
                 Stretch="UniformToFill" />
        </Border>
        <Border x:Name="Photo2"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="#1A1A1A">
          <Image x:Name="PhotoImage2"
                 Stretch="UniformToFill" />
        </Border>
        <Border x:Name="Photo3"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="#1A1A1A">
          <Image x:Name="PhotoImage3"
                 Stretch="UniformToFill" />
        </Border>
        <!-- More photos indicator -->
        <Border x:Name="MorePhotosIndicator"
                Width="40"
                Height="40"
                CornerRadius="6"
                Background="#252525"
                Visibility="Collapsed">
          <TextBlock x:Name="MorePhotosText"
                     FontSize="12"
                     FontWeight="SemiBold"
                     Foreground="#808080"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </StackPanel>
    </Grid>
  </Border>
</UserControl>

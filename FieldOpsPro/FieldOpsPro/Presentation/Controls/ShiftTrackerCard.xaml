<UserControl x:Class="FieldOpsPro.Presentation.Controls.ShiftTrackerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border Style="{StaticResource FieldOpsCardStyle}">
    <utu:AutoLayout Orientation="Vertical" Spacing="20">
      <!-- Header -->
      <Grid>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE823;"
                    FontSize="18"
                    Foreground="#808080" />
          <TextBlock Text="Shift Progress"
                     Style="{StaticResource SectionTitleStyle}" />
        </StackPanel>
        <TextBlock x:Name="TimeRemainingText"
                   Text="4h 32m remaining"
                   FontSize="12"
                   Foreground="#606060"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- Progress Bar -->
      <Grid>
        <Border Background="#1A1A1A"
                CornerRadius="4"
                Height="8" />
        <Border x:Name="ProgressFill"
                Background="#FFFFFF"
                CornerRadius="4"
                Height="8"
                HorizontalAlignment="Left"
                Width="200" />
      </Grid>

      <!-- Timeline -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Start -->
        <StackPanel Grid.Column="0" HorizontalAlignment="Left">
          <Ellipse Width="10" Height="10" Fill="#FFFFFF" />
          <TextBlock Text="8:00 AM"
                     FontSize="10"
                     Foreground="#606060"
                     Margin="0,4,0,0" />
          <TextBlock Text="Start"
                     FontSize="9"
                     Foreground="#404040" />
        </StackPanel>

        <!-- Break Start -->
        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
          <Ellipse Width="10" Height="10" Fill="#FFFFFF" />
          <TextBlock Text="12:00 PM"
                     FontSize="10"
                     Foreground="#606060"
                     Margin="0,4,0,0" />
          <TextBlock Text="Break"
                     FontSize="9"
                     Foreground="#404040" />
        </StackPanel>

        <!-- Current -->
        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
          <Border Width="14" Height="14"
                  CornerRadius="7"
                  BorderBrush="#FFFFFF"
                  BorderThickness="2"
                  Background="#000000">
            <Ellipse Width="6" Height="6"
                     Fill="#FFFFFF"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
          </Border>
          <TextBlock x:Name="CurrentTimeText"
                     Text="3:28 PM"
                     FontSize="10"
                     Foreground="#FFFFFF"
                     FontWeight="SemiBold"
                     Margin="0,4,0,0" />
          <TextBlock Text="Now"
                     FontSize="9"
                     Foreground="#808080" />
        </StackPanel>

        <!-- Break End marker hidden -->
        <StackPanel Grid.Column="3" HorizontalAlignment="Center" Opacity="0.5">
          <Ellipse Width="8" Height="8" Fill="#404040" />
        </StackPanel>

        <!-- End -->
        <StackPanel Grid.Column="4" HorizontalAlignment="Right">
          <Ellipse Width="10" Height="10" Fill="#404040" />
          <TextBlock Text="5:00 PM"
                     FontSize="10"
                     Foreground="#606060"
                     Margin="0,4,0,0" />
          <TextBlock Text="End"
                     FontSize="9"
                     Foreground="#404040" />
        </StackPanel>
      </Grid>

      <!-- Stats Row -->
      <Grid ColumnSpacing="16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0D0D0D"
                CornerRadius="8"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="7.5h"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Worked"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#0D0D0D"
                CornerRadius="8"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="45m"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#C0C0C0"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Break"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="#0D0D0D"
                CornerRadius="8"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="12"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#808080"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Tasks"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>
    </utu:AutoLayout>
  </Border>
</UserControl>

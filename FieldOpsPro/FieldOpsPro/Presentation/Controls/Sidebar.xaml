<UserControl x:Class="FieldOpsPro.Presentation.Controls.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Grid Background="{StaticResource BgSecondaryBrush}"
        BorderBrush="{StaticResource BorderColorBrush}"
        BorderThickness="0,0,1,0">

    <!-- Left Accent Bar -->
    <Border Width="4"
            HorizontalAlignment="Left"
            VerticalAlignment="Stretch">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#FFFFFF" Offset="0" />
          <GradientStop Color="#808080" Offset="1" />
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Decorative Radial -->
    <Ellipse Width="300"
             Height="300"
             HorizontalAlignment="Left"
             VerticalAlignment="Bottom"
             Margin="-100,-0,-0,-100"
             Opacity="0.08">
      <Ellipse.Fill>
        <RadialGradientBrush>
          <GradientStop Color="#FFFFFF" Offset="0" />
          <GradientStop Color="Transparent" Offset="1" />
        </RadialGradientBrush>
      </Ellipse.Fill>
    </Ellipse>

    <!-- Main Content -->
    <utu:AutoLayout Orientation="Vertical"
                    Padding="24,32"
                    Spacing="0">

      <!-- Logo Section -->
      <StackPanel Orientation="Horizontal"
                  Spacing="14"
                  Margin="0,0,0,48">
        <!-- Logo Icon Box -->
        <Border Width="44"
                Height="44"
                CornerRadius="12"
                RenderTransformOrigin="0.5,0.5">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Color="#FFFFFF" Offset="0" />
              <GradientStop Color="#C0C0C0" Offset="1" />
            </LinearGradientBrush>
          </Border.Background>
          <Border.RenderTransform>
            <RotateTransform Angle="-3" />
          </Border.RenderTransform>
          <TextBlock Text="FO"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="Black"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>

        <!-- Logo Text -->
        <TextBlock VerticalAlignment="Center">
          <Run Text="Field" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" />
          <Run Text="Ops" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}" />
        </TextBlock>
      </StackPanel>

      <!-- Main Menu Section -->
      <TextBlock Text="MAIN MENU"
                 Style="{StaticResource MonoLabelStyle}"
                 Margin="16,0,0,12" />

      <StackPanel Spacing="4" Margin="0,0,0,32">
        <local:NavItem Label="Dashboard"
                       IconGlyph="&#xF246;"
                       IsActive="True"
                       Route="Dashboard" />
        <local:NavItem Label="Live Map"
                       IconGlyph="&#xE707;"
                       BadgeCount="12"
                       Route="Map" />
        <local:NavItem Label="Work Orders"
                       IconGlyph="&#xE762;"
                       Route="Tasks" />
        <local:NavItem Label="Team"
                       IconGlyph="&#xE716;"
                       Route="Team" />
        <local:NavItem Label="Schedule"
                       IconGlyph="&#xE787;"
                       Route="Schedule" />
      </StackPanel>

      <!-- Management Section -->
      <TextBlock Text="MANAGEMENT"
                 Style="{StaticResource MonoLabelStyle}"
                 Margin="16,0,0,12" />

      <StackPanel Spacing="4">
        <local:NavItem Label="Reports"
                       IconGlyph="&#xE7C3;"
                       Route="Reports" />
        <local:NavItem Label="Settings"
                       IconGlyph="&#xE713;"
                       Route="Settings" />
      </StackPanel>

      <!-- Spacer -->
      <Border utu:AutoLayout.PrimaryAlignment="Stretch" />

      <!-- User Profile Card -->
      <Border Background="{StaticResource BgTertiaryBrush}"
              CornerRadius="16"
              Padding="20">
        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <local:Avatar x:Name="UserAvatar"
                        Grid.Column="0"
                        Size="46"
                        Initials="MK"
                        AvatarColor="Blue" />

          <StackPanel Grid.Column="1"
                      VerticalAlignment="Center"
                      Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Marcus Klein"
                         Style="{StaticResource BodyMediumStyle}" />
              <Ellipse Width="10"
                       Height="10"
                       VerticalAlignment="Center">
                <Ellipse.Fill>
                  <SolidColorBrush Color="#FFFFFF" />
                </Ellipse.Fill>
              </Ellipse>
            </StackPanel>
            <TextBlock Text="Ops Manager"
                       Style="{StaticResource CaptionStyle}" />
          </StackPanel>
        </Grid>
      </Border>

    </utu:AutoLayout>
  </Grid>
</UserControl>

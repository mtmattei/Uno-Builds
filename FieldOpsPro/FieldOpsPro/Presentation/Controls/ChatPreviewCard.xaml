<UserControl x:Class="FieldOpsPro.Presentation.Controls.ChatPreviewCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border Style="{StaticResource FieldOpsCardStyle}">
    <utu:AutoLayout Orientation="Vertical" Spacing="16">
      <!-- Header -->
      <Grid>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE8BD;"
                    FontSize="18"
                    Foreground="#808080" />
          <TextBlock Text="Team Chat"
                     Style="{StaticResource SectionTitleStyle}" />
          <!-- Unread Badge -->
          <Border Background="#FFFFFF"
                  CornerRadius="10"
                  Padding="8,2"
                  Margin="8,0,0,0"
                  VerticalAlignment="Center">
            <TextBlock x:Name="UnreadCountText"
                       Text="4"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#000000" />
          </Border>
        </StackPanel>
        <Button Content="OPEN CHAT"
                Style="{StaticResource GhostButtonStyle}"
                HorizontalAlignment="Right" />
      </Grid>

      <!-- Chat Messages -->
      <StackPanel Spacing="12">
        <!-- Message 1 - Unread -->
        <Border Background="#1A1A1A"
                CornerRadius="10"
                Padding="14"
                BorderBrush="#2A2A2A"
                BorderThickness="1">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <local:Avatar Grid.Column="0"
                          Size="36"
                          Initials="SK"
                          AvatarColor="Cyan" />

            <StackPanel Grid.Column="1" Spacing="4">
              <Grid>
                <TextBlock Text="Sarah K."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
                <TextBlock Text="2m ago"
                           FontSize="10"
                           Foreground="#606060"
                           HorizontalAlignment="Right" />
              </Grid>
              <TextBlock Text="The client approved the installation. Ready to proceed with WO-1247"
                         FontSize="12"
                         Foreground="#909090"
                         TextWrapping="Wrap"
                         MaxLines="2"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Unread Indicator -->
            <Ellipse Grid.Column="2"
                     Width="8"
                     Height="8"
                     Fill="#FFFFFF"
                     VerticalAlignment="Top"
                     Margin="0,4,0,0" />
          </Grid>
        </Border>

        <!-- Message 2 - Unread -->
        <Border Background="#1A1A1A"
                CornerRadius="10"
                Padding="14"
                BorderBrush="#2A2A2A"
                BorderThickness="1">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <local:Avatar Grid.Column="0"
                          Size="36"
                          Initials="JM"
                          AvatarColor="Purple" />

            <StackPanel Grid.Column="1" Spacing="4">
              <Grid>
                <TextBlock Text="Jake M."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
                <TextBlock Text="15m ago"
                           FontSize="10"
                           Foreground="#606060"
                           HorizontalAlignment="Right" />
              </Grid>
              <TextBlock Text="Need backup at downtown location, customer has additional requests"
                         FontSize="12"
                         Foreground="#909090"
                         TextWrapping="Wrap"
                         MaxLines="2"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- Unread Indicator -->
            <Ellipse Grid.Column="2"
                     Width="8"
                     Height="8"
                     Fill="#FFFFFF"
                     VerticalAlignment="Top"
                     Margin="0,4,0,0" />
          </Grid>
        </Border>

        <!-- Message 3 - Read -->
        <Border Background="#0D0D0D"
                CornerRadius="10"
                Padding="14"
                BorderBrush="#1A1A1A"
                BorderThickness="1">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <local:Avatar Grid.Column="0"
                          Size="36"
                          Initials="MK"
                          AvatarColor="Blue" />

            <StackPanel Grid.Column="1" Spacing="4">
              <Grid>
                <TextBlock Text="Marcus K."
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#808080" />
                <TextBlock Text="1h ago"
                           FontSize="10"
                           Foreground="#404040"
                           HorizontalAlignment="Right" />
              </Grid>
              <TextBlock Text="Team meeting at 4pm to discuss tomorrow's route optimization"
                         FontSize="12"
                         Foreground="#606060"
                         TextWrapping="Wrap"
                         MaxLines="2"
                         TextTrimming="CharacterEllipsis" />
            </StackPanel>
          </Grid>
        </Border>
      </StackPanel>

      <!-- Quick Reply -->
      <Border Background="#0D0D0D"
              BorderBrush="#252525"
              BorderThickness="1"
              CornerRadius="8"
              Padding="8,6">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <TextBox x:Name="ReplyTextBox"
                   Grid.Column="0"
                   FontSize="13"
                   Foreground="#FFFFFF"
                   Background="Transparent"
                   BorderThickness="0"
                   VerticalContentAlignment="Center"
                   PlaceholderText="Type a message..."
                   AcceptsReturn="False"
                   KeyDown="OnReplyTextBoxKeyDown" />

          <Button x:Name="SendButton"
                  Grid.Column="1"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="8"
                  Click="OnSendButtonClick"
                  ToolTipService.ToolTip="Send">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE724;"
                      FontSize="18"
                      Foreground="#808080" />
          </Button>
        </Grid>
      </Border>
    </utu:AutoLayout>
  </Border>
</UserControl>

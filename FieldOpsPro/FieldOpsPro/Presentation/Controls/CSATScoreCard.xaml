<UserControl x:Class="FieldOpsPro.Presentation.Controls.CSATScoreCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border Style="{StaticResource FieldOpsCardStyle}">
    <utu:AutoLayout Orientation="Vertical" Spacing="20">
      <!-- Header -->
      <Grid>
        <StackPanel Orientation="Horizontal" Spacing="10">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE734;"
                    FontSize="18"
                    Foreground="#808080" />
          <TextBlock Text="Customer Satisfaction"
                     Style="{StaticResource SectionTitleStyle}" />
        </StackPanel>
        <TextBlock Text="This Week"
                   FontSize="11"
                   Foreground="#606060"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center" />
      </Grid>

      <!-- Main Score -->
      <Grid ColumnSpacing="24">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Score Display -->
        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="4">
            <TextBlock x:Name="ScoreText"
                       Text="4.8"
                       FontSize="42"
                       FontWeight="Light"
                       Foreground="#FFFFFF" />
            <TextBlock Text="/5"
                       FontSize="18"
                       Foreground="#606060"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,10" />
          </StackPanel>

          <!-- Star Rating -->
          <StackPanel x:Name="StarsPanel"
                      Orientation="Horizontal"
                      Spacing="4"
                      HorizontalAlignment="Center"
                      Margin="0,4,0,0">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE735;"
                      FontSize="16"
                      Foreground="#FFFFFF" />
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE735;"
                      FontSize="16"
                      Foreground="#FFFFFF" />
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE735;"
                      FontSize="16"
                      Foreground="#FFFFFF" />
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE735;"
                      FontSize="16"
                      Foreground="#FFFFFF" />
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE7C6;"
                      FontSize="16"
                      Foreground="#606060" />
          </StackPanel>
        </StackPanel>

        <!-- Breakdown -->
        <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
          <!-- 5 Star -->
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="5" FontSize="11" Foreground="#808080" />
            <Grid Grid.Column="1">
              <Border Background="#1A1A1A" CornerRadius="2" Height="6" />
              <Border Background="#FFFFFF" CornerRadius="2" Height="6" HorizontalAlignment="Left" Width="85" />
            </Grid>
            <TextBlock Grid.Column="2" Text="85%" FontSize="10" Foreground="#606060" HorizontalAlignment="Right" />
          </Grid>

          <!-- 4 Star -->
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="4" FontSize="11" Foreground="#808080" />
            <Grid Grid.Column="1">
              <Border Background="#1A1A1A" CornerRadius="2" Height="6" />
              <Border Background="#C0C0C0" CornerRadius="2" Height="6" HorizontalAlignment="Left" Width="10" />
            </Grid>
            <TextBlock Grid.Column="2" Text="10%" FontSize="10" Foreground="#606060" HorizontalAlignment="Right" />
          </Grid>

          <!-- 3 Star -->
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="3" FontSize="11" Foreground="#808080" />
            <Grid Grid.Column="1">
              <Border Background="#1A1A1A" CornerRadius="2" Height="6" />
              <Border Background="#808080" CornerRadius="2" Height="6" HorizontalAlignment="Left" Width="3" />
            </Grid>
            <TextBlock Grid.Column="2" Text="3%" FontSize="10" Foreground="#606060" HorizontalAlignment="Right" />
          </Grid>

          <!-- 2 Star -->
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="2" FontSize="11" Foreground="#808080" />
            <Grid Grid.Column="1">
              <Border Background="#1A1A1A" CornerRadius="2" Height="6" />
              <Border Background="#606060" CornerRadius="2" Height="6" HorizontalAlignment="Left" Width="1" />
            </Grid>
            <TextBlock Grid.Column="2" Text="1%" FontSize="10" Foreground="#606060" HorizontalAlignment="Right" />
          </Grid>

          <!-- 1 Star -->
          <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="20" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="30" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="1" FontSize="11" Foreground="#808080" />
            <Grid Grid.Column="1">
              <Border Background="#1A1A1A" CornerRadius="2" Height="6" />
              <Border Background="#404040" CornerRadius="2" Height="6" HorizontalAlignment="Left" Width="1" />
            </Grid>
            <TextBlock Grid.Column="2" Text="1%" FontSize="10" Foreground="#606060" HorizontalAlignment="Right" />
          </Grid>
        </StackPanel>
      </Grid>

      <!-- Footer Stats -->
      <Border Background="#0D0D0D"
              CornerRadius="8"
              Padding="16,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="127"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Responses"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <Border Grid.Column="1"
                  Width="1"
                  Background="#252525"
                  Margin="16,0" />

          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE74A;"
                        FontSize="12"
                        Foreground="#C0C0C0" />
              <TextBlock Text="+0.3"
                         FontSize="18"
                         FontWeight="SemiBold"
                         Foreground="#C0C0C0" />
            </StackPanel>
            <TextBlock Text="vs Last Week"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>
      </Border>
    </utu:AutoLayout>
  </Border>
</UserControl>

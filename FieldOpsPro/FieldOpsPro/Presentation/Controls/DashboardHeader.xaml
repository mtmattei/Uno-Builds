<UserControl x:Class="FieldOpsPro.Presentation.Controls.DashboardHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <!-- Animations handled in code-behind via DispatcherTimer for cross-platform compatibility -->

  <StackPanel Spacing="16">

    <!-- ========== URGENT ALERT BANNER ========== -->
    <Border x:Name="AlertBanner"
            Background="#1A1A1A"
            BorderBrush="#2A2A2A"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16,12"
            Visibility="Visible"
            RenderTransformOrigin="0.5,0.5"
            PointerEntered="OnAlertBannerPointerEntered"
            PointerExited="OnAlertBannerPointerExited">
      <Border.RenderTransform>
        <ScaleTransform ScaleX="1" ScaleY="1" />
      </Border.RenderTransform>
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Alert Icon with Glow Effect -->
        <Grid Grid.Column="0" Margin="0,0,14,0">
          <Ellipse x:Name="AlertIconGlow"
                   Width="32" Height="32"
                   Fill="#FFFFFF"
                   Opacity="0.2" />
          <Border Width="28" Height="28"
                  CornerRadius="14"
                  Background="#FFFFFF">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE7BA;"
                      FontSize="14"
                      Foreground="#000000"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
        </Grid>

        <!-- Alert Content -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
          <TextBlock x:Name="AlertTitleText"
                     Text="URGENT: Power Outage Reported"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="#FFFFFF" />
          <TextBlock x:Name="AlertMessageText"
                     Text="3 work orders affected in Downtown District - Immediate attention required"
                     FontSize="12"
                     Foreground="#909090"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <!-- View Details Button -->
        <Button Grid.Column="2"
                Content="VIEW"
                Background="Transparent"
                BorderBrush="#404040"
                BorderThickness="1"
                Foreground="#FFFFFF"
                FontSize="11"
                FontWeight="SemiBold"
                Padding="14,6"
                CornerRadius="4"
                Margin="12,0,8,0"
                VerticalAlignment="Center" />

        <!-- Dismiss Button -->
        <Button x:Name="DismissAlertButton"
                Grid.Column="3"
                Background="Transparent"
                BorderThickness="0"
                Padding="8"
                VerticalAlignment="Center"
                Click="OnDismissAlertClick">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                    Glyph="&#xE711;"
                    FontSize="14"
                    Foreground="#606060" />
        </Button>
      </Grid>
    </Border>

    <!-- ========== HEADER INFO ROW ========== -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Title Section (left side - will be replaced by page content) -->
      <ContentPresenter x:Name="TitleContent"
                        Grid.Column="0"
                        Content="{x:Bind TitleArea, Mode=OneWay}" />

      <!-- Right Side Widgets -->
      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="20">

        <!-- ========== LIVE STATUS INDICATOR ========== -->
        <Border Background="#0D0D0D"
                BorderBrush="#252525"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <Grid>
              <!-- Outer glow ring -->
              <Ellipse Width="12" Height="12"
                       Fill="#1A1A1A"
                       Stroke="#404040"
                       StrokeThickness="1" />
              <!-- Pulsing dot -->
              <Ellipse x:Name="LiveStatusDot"
                       Width="8" Height="8"
                       Fill="#FFFFFF"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Grid>
            <TextBlock x:Name="LiveStatusText"
                       Text="LIVE"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#909090"
                       VerticalAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- ========== WEATHER WIDGET ========== -->
        <Border Background="#0D0D0D"
                BorderBrush="#252525"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="12">
            <!-- Weather Icon -->
            <FontIcon x:Name="WeatherIcon"
                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE9BD;"
                      FontSize="20"
                      Foreground="#C0C0C0"
                      VerticalAlignment="Center" />

            <!-- Temperature and Conditions -->
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock x:Name="TemperatureText"
                           Text="72"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF" />
                <TextBlock Text="F"
                           FontSize="11"
                           Foreground="#606060"
                           VerticalAlignment="Top"
                           Margin="0,2,0,0" />
              </StackPanel>
              <TextBlock x:Name="WeatherConditionText"
                         Text="Partly Cloudy"
                         FontSize="10"
                         Foreground="#606060" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- ========== LIVE CLOCK ========== -->
        <Border Background="#0D0D0D"
                BorderBrush="#252525"
                BorderThickness="1"
                CornerRadius="6"
                Padding="14,8"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <!-- Clock Icon -->
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE823;"
                      FontSize="16"
                      Foreground="#808080"
                      VerticalAlignment="Center" />

            <!-- Time Display -->
            <StackPanel VerticalAlignment="Center" Spacing="0">
              <TextBlock x:Name="TimeText"
                         Text="12:00:00"
                         FontSize="14"
                         FontWeight="SemiBold"
                         Foreground="#FFFFFF"
                         FontFamily="Consolas" />
              <TextBlock x:Name="TimezoneText"
                         Text="EST"
                         FontSize="10"
                         Foreground="#606060" />
            </StackPanel>
          </StackPanel>
        </Border>

      </StackPanel>
    </Grid>

  </StackPanel>
</UserControl>

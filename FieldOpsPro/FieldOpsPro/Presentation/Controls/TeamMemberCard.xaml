<UserControl x:Class="FieldOpsPro.Presentation.Controls.TeamMemberCard"
                                                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                                                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                                                 xmlns:local="using:FieldOpsPro.Presentation.Controls"
                                                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                                                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                                 mc:Ignorable="d"
                                                 PointerEntered="OnPointerEntered"
                                                 PointerExited="OnPointerExited"
                                                 x:Uid="TeamMemberCard">

        <Border x:Name="CardBorder"
                                                                                                                                                                Background="{StaticResource BgTertiaryBrush}"
                                                                                                                                                                BorderBrush="Transparent"
                                                                                                                                                                BorderThickness="1"
                                                                                                                                                                CornerRadius="14"
                                                                                                                                                                Padding="16"
                                                                                                                                                                AutomationProperties.Name="{x:Bind Member.Name}">
                <Border.RenderTransform>
                        <CompositeTransform x:Name="CardTransform" />
                </Border.RenderTransform>

    <Grid ColumnSpacing="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Avatar with Status -->
      <local:Avatar x:Name="MemberAvatar"
                    Grid.Column="0"
                    Size="44"
                    VerticalAlignment="Center" />

      <!-- Member Info -->
      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Spacing="2">
        <TextBlock x:Name="NameText"
                   Style="{StaticResource BodyMediumStyle}"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   x:Uid="TeamMemberCard.NameText" />
        <TextBlock x:Name="LocationText"
                   Style="{StaticResource CaptionStyle}"
                   TextTrimming="CharacterEllipsis"
                   MaxLines="1"
                   x:Uid="TeamMemberCard.LocationText" />
      </StackPanel>

      <!-- Device Status Indicators -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="8"
                  VerticalAlignment="Center">

        <!-- Signal Strength -->
        <Grid Width="20" Height="16" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal"
                      Spacing="2"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Bottom">
            <Border x:Name="Signal1"
                    Width="3" Height="4"
                    Background="{StaticResource TextPrimaryBrush}"
                    CornerRadius="1"
                    VerticalAlignment="Bottom" />
            <Border x:Name="Signal2"
                    Width="3" Height="7"
                    Background="{StaticResource TextPrimaryBrush}"
                    CornerRadius="1"
                    VerticalAlignment="Bottom" />
            <Border x:Name="Signal3"
                    Width="3" Height="10"
                    Background="{StaticResource TextPrimaryBrush}"
                    CornerRadius="1"
                    VerticalAlignment="Bottom" />
            <Border x:Name="Signal4"
                    Width="3" Height="14"
                    Background="{StaticResource TextMutedBrush}"
                    CornerRadius="1"
                    VerticalAlignment="Bottom" />
          </StackPanel>
        </Grid>

        <!-- Battery Indicator -->
        <Grid Width="26" Height="14" VerticalAlignment="Center">
          <!-- Battery Body -->
          <Border BorderBrush="{StaticResource TextMutedBrush}"
                  BorderThickness="1"
                  CornerRadius="2"
                  Width="22"
                  Height="12"
                  HorizontalAlignment="Left">
            <Border x:Name="BatteryFill"
                    Background="{StaticResource TextPrimaryBrush}"
                    CornerRadius="1"
                    Margin="1"
                    HorizontalAlignment="Left"
                    Width="16" />
          </Border>
          <!-- Battery Cap -->
          <Border Background="{StaticResource TextMutedBrush}"
                  Width="2"
                  Height="6"
                  CornerRadius="0,1,1,0"
                  HorizontalAlignment="Right"
                  Margin="0,0,0,0" />
        </Grid>

        <!-- Low Battery Warning -->
        <FontIcon x:Name="LowBatteryWarning"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Glyph="&#xE7BA;"
                  FontSize="14"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  Visibility="Collapsed" />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>

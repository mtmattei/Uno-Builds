<UserControl x:Class="FieldOpsPro.Presentation.Controls.ActivityItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Grid ColumnSpacing="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Icon with Timeline -->
    <Grid Grid.Column="0">
      <!-- Timeline Line (shown except for last item) -->
      <Border x:Name="TimelineLine"
              Width="2"
              Background="{StaticResource BorderColorBrush}"
              HorizontalAlignment="Center"
              VerticalAlignment="Stretch"
              Margin="0,44,0,-8" />

      <!-- Activity Icon -->
      <Border x:Name="IconContainer"
              Width="40"
              Height="40"
              Background="{StaticResource BgTertiaryBrush}"
              CornerRadius="12"
              VerticalAlignment="Top">
        <FontIcon x:Name="ActivityIcon"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  FontSize="18"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center" />
      </Border>
    </Grid>

    <!-- Activity Content -->
    <StackPanel Grid.Column="1"
                Spacing="4"
                Padding="0,4,0,0">
      <TextBlock x:Name="MessageText"
                 Style="{StaticResource BodyStyle}"
                 TextWrapping="Wrap">
        <Run x:Name="ActorRun" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
        <Run x:Name="ActionRun" />
      </TextBlock>

      <TextBlock x:Name="TimestampText"
                 Style="{StaticResource CaptionStyle}"
                 FontSize="11" />
    </StackPanel>
  </Grid>
</UserControl>

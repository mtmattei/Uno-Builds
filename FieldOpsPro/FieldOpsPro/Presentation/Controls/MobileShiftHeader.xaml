<UserControl x:Class="FieldOpsPro.Presentation.Controls.MobileShiftHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Border CornerRadius="0,0,24,24"
          Padding="24,16,24,24">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A1A1A" Offset="0" />
        <GradientStop Color="#0D0D0D" Offset="1" />
      </LinearGradientBrush>
    </Border.Background>

    <utu:AutoLayout Orientation="Vertical" Spacing="20">

      <!-- Top Row: Greeting + Avatar + Time -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Spacing="2">
          <TextBlock x:Name="GreetingText"
                     Text="Good Afternoon"
                     FontSize="12"
                     Foreground="#606060" />
          <TextBlock x:Name="UserNameText"
                     Text="Jake"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#FFFFFF" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12">
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="CurrentTimeText"
                       Text="3:28 PM"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Right" />
            <TextBlock x:Name="TimeRemainingText"
                       Text="4h 32m left"
                       FontSize="11"
                       Foreground="#808080"
                       HorizontalAlignment="Right" />
          </StackPanel>
          <local:Avatar Size="44"
                        Initials="JD"
                        AvatarColor="Blue"
                        Status="OnSite" />
        </StackPanel>
      </Grid>

      <!-- Compact alert for mobile (appears after delay) -->
      <Border x:Name="MobileAlertBanner"
              Background="#1A1A1A"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12"
              Visibility="Collapsed"
              RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
          <ScaleTransform ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border Width="28" Height="28" CornerRadius="14" Background="#FFFFFF" Margin="0,0,10,0">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE7BA;" FontSize="14" Foreground="#000000" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>

          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock x:Name="MobileAlertTitle" Text="URGENT" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" />
            <TextBlock x:Name="MobileAlertMessage" Text="3 work orders affected" FontSize="11" Foreground="#909090" TextTrimming="CharacterEllipsis" />
          </StackPanel>

          <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="6" Click="OnMobileDismissAlert">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE711;" FontSize="14" Foreground="#606060" />
          </Button>
        </Grid>
      </Border>

      <!-- Current Status Banner -->
      <Border Background="#252525"
              CornerRadius="12"
              Padding="16,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="CURRENT STATUS"
                       FontSize="9"
                       Foreground="#606060"
                       FontWeight="Medium" />
            <TextBlock x:Name="StatusTitle"
                       Text="En Route to Site"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF" />
            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE707;"
                        FontSize="12"
                        Foreground="#808080" />
              <TextBlock x:Name="DestinationText"
                         Text="142 Oak Street"
                         FontSize="12"
                         Foreground="#C0C0C0" />
              <TextBlock Text="·"
                         FontSize="12"
                         Foreground="#606060" />
              <TextBlock x:Name="EtaText"
                         Text="ETA 8 min"
                         FontSize="12"
                         Foreground="#808080" />
            </StackPanel>
          </StackPanel>

          <!-- Navigate Button -->
          <Border Grid.Column="1"
                  Width="44"
                  Height="44"
                  CornerRadius="12"
                  Background="#FFFFFF"
                  VerticalAlignment="Center">
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE816;"
                      FontSize="18"
                      Foreground="#000000"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
          </Border>
        </Grid>
      </Border>

      <!-- Shift Progress Bar -->
      <StackPanel Spacing="8">
        <Grid>
          <TextBlock Text="Shift Progress"
                     FontSize="11"
                     Foreground="#606060" />
          <TextBlock x:Name="ShiftPercentText"
                     Text="68%"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Foreground="#FFFFFF"
                     HorizontalAlignment="Right" />
        </Grid>
        <Grid>
          <Border Background="#252525"
                  CornerRadius="4"
                  Height="6" />
          <Border x:Name="ProgressFill"
                  CornerRadius="4"
                  Height="6"
                  HorizontalAlignment="Left"
                  Width="200">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#808080" Offset="0" />
                <GradientStop Color="#FFFFFF" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
          </Border>
        </Grid>
        <Grid>
          <TextBlock Text="8:00 AM"
                     FontSize="10"
                     Foreground="#404040" />
          <TextBlock Text="5:00 PM"
                     FontSize="10"
                     Foreground="#404040"
                     HorizontalAlignment="Right" />
        </Grid>
      </StackPanel>

      <!-- Stats Row -->
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#1A1A1A"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="7.5h"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#FFFFFF"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Worked"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1"
                Background="#1A1A1A"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="3/5"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#C0C0C0"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Tasks"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>

        <Border Grid.Column="2"
                Background="#1A1A1A"
                CornerRadius="10"
                Padding="12,10">
          <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="4.9"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="#808080"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Rating"
                       FontSize="10"
                       Foreground="#606060"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Border>
      </Grid>

    </utu:AutoLayout>
  </Border>
</UserControl>

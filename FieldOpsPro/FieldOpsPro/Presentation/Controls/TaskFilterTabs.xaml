<UserControl x:Class="FieldOpsPro.Presentation.Controls.TaskFilterTabs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- Filter Tabs -->
    <Border Grid.Column="0"
            Background="#0D0D0D"
            BorderBrush="#252525"
            BorderThickness="1"
            CornerRadius="6"
            Padding="4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <Button x:Name="AllTab"
                Content="All"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="All" />
        <Button x:Name="UrgentTab"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Urgent">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Urgent" VerticalAlignment="Center" />
            <Border x:Name="UrgentBadge"
                    Background="#FFFFFF"
                    CornerRadius="8"
                    Padding="6,2"
                    MinWidth="20">
              <TextBlock x:Name="UrgentCountText"
                         Text="3"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="#000000"
                         HorizontalAlignment="Center" />
            </Border>
          </StackPanel>
        </Button>
        <Button x:Name="ScheduledTab"
                Content="Scheduled"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Scheduled" />
        <Button x:Name="UnassignedTab"
                Style="{StaticResource FilterTabButtonStyle}"
                Click="OnTabClick"
                Tag="Unassigned">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Unassigned" VerticalAlignment="Center" />
            <Border x:Name="UnassignedBadge"
                    Background="#606060"
                    CornerRadius="8"
                    Padding="6,2"
                    MinWidth="20">
              <TextBlock x:Name="UnassignedCountText"
                         Text="5"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="#FFFFFF"
                         HorizontalAlignment="Center" />
            </Border>
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- New Task Button -->
    <Button x:Name="NewTaskButton"
            Grid.Column="1"
            Margin="12,0,0,0"
            Background="#FFFFFF"
            Foreground="#000000"
            CornerRadius="6"
            Padding="14,8"
            Click="OnNewTaskClick">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  Glyph="&#xE710;"
                  FontSize="14"
                  Foreground="#000000" />
        <TextBlock Text="New Task"
                   FontSize="13"
                   FontWeight="SemiBold" />
      </StackPanel>
    </Button>
  </Grid>
</UserControl>

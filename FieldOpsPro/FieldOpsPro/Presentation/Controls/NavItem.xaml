<UserControl x:Class="FieldOpsPro.Presentation.Controls.NavItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             PointerEntered="OnPointerEntered"
             PointerExited="OnPointerExited"
             Tapped="OnTapped">

  <Grid>
    <!-- Active Indicator -->
    <Border x:Name="ActiveIndicator"
            Width="3"
            Height="24"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            CornerRadius="0,2,2,0"
            Background="{StaticResource AccentPrimaryBrush}"
            Visibility="Collapsed"
            Margin="-16,0,0,0" />

    <!-- Nav Item Button -->
    <Border x:Name="ItemBorder"
            Background="Transparent"
            CornerRadius="12"
            Padding="14,14">
      <Grid ColumnSpacing="14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <FontIcon x:Name="NavIcon"
                  Grid.Column="0"
                  FontFamily="{ThemeResource SymbolThemeFontFamily}"
                  FontSize="22"
                  Foreground="{StaticResource TextSecondaryBrush}"
                  Opacity="0.7" />

        <TextBlock x:Name="NavLabel"
                   Grid.Column="1"
                   Style="{StaticResource NavLabelStyle}"
                   VerticalAlignment="Center" />

        <!-- Badge -->
        <Border x:Name="BadgeBorder"
                Grid.Column="2"
                Background="{StaticResource AccentPrimaryBrush}"
                CornerRadius="10"
                Padding="8,2"
                MinWidth="20"
                Visibility="Collapsed">
          <TextBlock x:Name="BadgeText"
                     Foreground="White"
                     FontSize="11"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
      </Grid>
    </Border>
  </Grid>
</UserControl>

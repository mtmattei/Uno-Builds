<UserControl x:Class="FieldOpsPro.Presentation.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FieldOpsPro.Presentation"
             xmlns:controls="using:FieldOpsPro.Presentation.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

  <utu:SafeArea>
    <Grid x:Name="RootGrid" Background="{StaticResource BgPrimaryBrush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition x:Name="SidebarColumn" Width="280" />
        <ColumnDefinition x:Name="ContentColumn" Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition x:Name="BottomNavRow" Height="0" />
      </Grid.RowDefinitions>

      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="LayoutStates">
            <!-- Narrow: 0 - 599px -->
            <VisualState x:Name="NarrowLayout">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="0" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="DesktopSidebar.Visibility" Value="Collapsed" />
                <Setter Target="MobileBottomNav.Visibility" Value="Visible" />
                <Setter Target="SidebarColumn.Width" Value="0" />
                <Setter Target="BottomNavRow.Height" Value="90" />
              </VisualState.Setters>
            </VisualState>

            <!-- Normal: 600px - 1023px -->
            <VisualState x:Name="NormalLayout">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="600" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="DesktopSidebar.Visibility" Value="Visible" />
                <Setter Target="MobileBottomNav.Visibility" Value="Collapsed" />
                <Setter Target="SidebarColumn.Width" Value="200" />
                <Setter Target="BottomNavRow.Height" Value="0" />
              </VisualState.Setters>
            </VisualState>

            <!-- Wide: 1024px+ -->
            <VisualState x:Name="WideLayout">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="1024" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="DesktopSidebar.Visibility" Value="Visible" />
                <Setter Target="MobileBottomNav.Visibility" Value="Collapsed" />
                <Setter Target="SidebarColumn.Width" Value="280" />
                <Setter Target="BottomNavRow.Height" Value="0" />
              </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>

      <!-- Desktop Sidebar -->
      <controls:Sidebar x:Name="DesktopSidebar"
                        Grid.Column="0"
                        Grid.RowSpan="2" />

      <!-- Main Content Frame -->
      <Border Grid.Column="1"
              Grid.Row="0"
              Background="{StaticResource BgPrimaryBrush}">
        <Frame x:Name="ContentFrame"
               uen:Navigation.Request="-" />
      </Border>

      <!-- Mobile Bottom Navigation -->
      <Border x:Name="MobileBottomNav"
              Grid.Column="0"
              Grid.ColumnSpan="2"
              Grid.Row="1"
              Background="{StaticResource BgSecondaryBrush}"
              BorderBrush="{StaticResource BorderColorBrush}"
              BorderThickness="0,1,0,0"
              Visibility="Collapsed">

        <Grid Padding="0,12,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Home -->
          <Button Grid.Column="0"
                  Style="{StaticResource MobileNavButtonStyle}"
                  Tag="Dashboard">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE80F;"
                        FontSize="22"
                        Foreground="{StaticResource AccentPrimaryBrush}" />
              <TextBlock Text="Home"
                         FontSize="10"
                         FontWeight="Medium"
                         Foreground="{StaticResource AccentPrimaryBrush}" />
            </StackPanel>
          </Button>

          <!-- Map -->
          <Button Grid.Column="1"
                  Style="{StaticResource MobileNavButtonStyle}"
                  Tag="Map">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE707;"
                        FontSize="22"
                        Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="Map"
                         FontSize="10"
                         FontWeight="Medium"
                         Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
          </Button>

          <!-- Center FAB -->
          <Button Grid.Column="2"
                  Width="60"
                  Height="60"
                  CornerRadius="20"
                  Margin="0,-20,0,0"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Center">
            <Button.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0" />
                <GradientStop Color="#E0E0E0" Offset="1" />
              </LinearGradientBrush>
            </Button.Background>
            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                      Glyph="&#xE710;"
                      FontSize="26"
                      Foreground="Black" />
          </Button>

          <!-- Tasks -->
          <Button Grid.Column="3"
                  Style="{StaticResource MobileNavButtonStyle}"
                  Tag="Tasks">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE762;"
                        FontSize="22"
                        Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="Tasks"
                         FontSize="10"
                         FontWeight="Medium"
                         Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
          </Button>

          <!-- Profile -->
          <Button Grid.Column="4"
                  Style="{StaticResource MobileNavButtonStyle}"
                  Tag="Profile">
            <StackPanel Spacing="6" HorizontalAlignment="Center">
              <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="&#xE77B;"
                        FontSize="22"
                        Foreground="{StaticResource TextMutedBrush}" />
              <TextBlock Text="Profile"
                         FontSize="10"
                         FontWeight="Medium"
                         Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </utu:SafeArea>
</UserControl>

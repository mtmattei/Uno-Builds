<Page x:Class="FieldOpsPro.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FieldOpsPro.Presentation"
      xmlns:models="using:FieldOpsPro.Models"
      xmlns:controls="using:FieldOpsPro.Presentation.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="{StaticResource BgPrimaryBrush}">

  <Grid>
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup x:Name="LayoutStates">
        <!-- Desktop Layout -->
        <VisualState x:Name="DesktopLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1024" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopContent.Visibility" Value="Visible" />
            <Setter Target="MobileContent.Visibility" Value="Collapsed" />
          </VisualState.Setters>
        </VisualState>

        <!-- Mobile Layout -->
        <VisualState x:Name="MobileLayout">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0" />
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="DesktopContent.Visibility" Value="Collapsed" />
            <Setter Target="MobileContent.Visibility" Value="Visible" />
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

    <!-- ==================== -->
    <!-- DESKTOP CONTENT      -->
    <!-- ==================== -->
    <ScrollViewer x:Name="DesktopContent"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <utu:AutoLayout Orientation="Vertical"
                      Padding="40,32"
                      Spacing="32"
                      MaxWidth="1400">

        <!-- Enhanced Dashboard Header -->
        <controls:DashboardHeader AlertTitle="URGENT: Power Outage Reported"
                                  AlertMessage="3 work orders affected in Downtown District - Immediate attention required"
                                  ShowAlert="True"
                                  Temperature="72"
                                  WeatherCondition="Partly Cloudy"
                                  IsConnected="True">
          <controls:DashboardHeader.TitleArea>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <!-- Title Section -->
              <StackPanel Grid.Column="0" Spacing="8">
                <TextBlock Text="Command Center"
                           Style="{StaticResource PageTitleStyle}" />
                <TextBlock Style="{StaticResource BodyStyle}">
                  <Run Text="{Binding CurrentDate}" />
                  <Run Text=" - " />
                  <Run Text="12 active field agents" />
                </TextBlock>
              </StackPanel>

              <!-- Search and Actions -->
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          Spacing="16"
                          Margin="0,0,24,0">
                <!-- Search Bar -->
                    <Border Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14,8"
                    Width="280"
                    VerticalAlignment="Center">
                  <StackPanel Orientation="Horizontal" Spacing="10">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xE721;"
                              FontSize="16"
                      Foreground="{StaticResource TextMutedBrush}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="Search work orders..."
                       Foreground="{StaticResource TextMutedBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </Border>

                <!-- Notification Button -->
                <Button Style="{StaticResource IconButtonStyle}">
                  <Grid>
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                              Glyph="&#xEA8F;"
                              FontSize="20"
                              Foreground="{StaticResource TextSecondaryBrush}" />
                    <Ellipse Width="8" Height="8"
                             HorizontalAlignment="Right"
                             VerticalAlignment="Top"
                             Margin="0,-4,-4,0"
                             Fill="{StaticResource DangerBrush}" />
                  </Grid>
                </Button>

                <!-- Messages Button -->
                <Button Style="{StaticResource IconButtonStyle}">
                  <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Glyph="&#xE715;"
                            FontSize="20"
                            Foreground="{StaticResource TextSecondaryBrush}" />
                </Button>
              </StackPanel>
            </Grid>
          </controls:DashboardHeader.TitleArea>
        </controls:DashboardHeader>

        <!-- Stats Grid -->
        <Grid ColumnSpacing="20">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <controls:StatCard Grid.Column="0"
                             Label="Active Work Orders"
                             Value="47"
                             ChangePercent="12"
                             IconGlyph="&#xE762;"
                             AccentColor="Primary" />

          <controls:StatCard Grid.Column="1"
                             Label="Field Agents Online"
                             Value="12/15"
                             Subtitle="3 on break"
                             IconGlyph="&#xE716;"
                             AccentColor="Secondary" />

          <controls:StatCard Grid.Column="2"
                             Label="Avg Response Time"
                             Value="24m"
                             ChangePercent="-12.5"
                             IconGlyph="&#xE823;"
                             AccentColor="Tertiary" />

          <controls:StatCard Grid.Column="3"
                             Label="Completion Rate"
                             Value="94%"
                             ChangePercent="2.2"
                             IconGlyph="&#xE73E;"
                             AccentColor="Success" />
        </Grid>

        <!-- Main Content Grid -->
        <Grid ColumnSpacing="24">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="480" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Live Map Card -->
          <controls:MapCard Grid.Column="0"
                            Grid.Row="0"
                            Agents="{Binding MapAgents}" />

          <!-- Team Status Card (aligned with Map) -->
          <Border Grid.Column="1"
                  Grid.Row="0"
                  Style="{StaticResource FieldOpsCardStyle}">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <Grid>
                <TextBlock Text="Team Status"
                           Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <ItemsRepeater ItemsSource="{Binding TeamMembers}">
                <ItemsRepeater.Layout>
                  <UniformGridLayout MinColumnSpacing="12"
                                     MinRowSpacing="12"
                                     MinItemWidth="180"
                                     MaximumRowsOrColumns="2"
                                     ItemsStretch="Fill" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:TeamMember">
                    <controls:TeamMemberCard Member="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>

          <!-- Priority Tasks Card -->
          <Border Grid.Column="0"
                  Grid.Row="1"
                  Style="{StaticResource FieldOpsCardStyle}"
                  Margin="0,24,0,0">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <!-- Header -->
              <Grid>
                <TextBlock Text="Priority Tasks"
                           Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <!-- Task List -->
              <ItemsRepeater ItemsSource="{Binding PriorityTasks}">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="12" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:TaskItem">
                    <controls:TaskCard TaskItem="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>

          <!-- Activity Feed Card -->
          <Border Grid.Column="1"
                  Grid.Row="1"
                  Style="{StaticResource FieldOpsCardStyle}"
                  Margin="0,24,0,0">
            <utu:AutoLayout Orientation="Vertical" Spacing="24">
              <Grid>
                <TextBlock Text="Recent Activity"
                         Style="{StaticResource SectionTitleStyle}" />
                <Button Content="VIEW ALL"
                        Style="{StaticResource GhostButtonStyle}"
                        HorizontalAlignment="Right" />
              </Grid>

              <ItemsRepeater ItemsSource="{Binding RecentActivity}">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="20" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="models:Activity">
                    <controls:ActivityItem Activity="{x:Bind}" />
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </utu:AutoLayout>
          </Border>
        </Grid>

      </utu:AutoLayout>
    </ScrollViewer>

    <!-- ==================== -->
    <!-- MOBILE CONTENT       -->
    <!-- ==================== -->
    <ScrollViewer x:Name="MobileContent"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Visibility="Collapsed">
      <StackPanel>
        <!-- New Combined Shift Header -->
        <controls:MobileShiftHeader />

        <utu:AutoLayout Orientation="Vertical"
                        Padding="24,24"
                        Spacing="28">

          <!-- Quick Actions Section -->
          <StackPanel Spacing="16">
            <TextBlock Text="Quick Actions"
                       Style="{StaticResource SectionTitleStyle}" />

            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <controls:QuickActionButton Grid.Column="0"
                                          Label="Check In"
                                          IconGlyph="&#xE73E;"
                                          AccentColor="Success" />

              <controls:QuickActionButton Grid.Column="1"
                                          Label="Photo"
                                          IconGlyph="&#xE722;"
                                          AccentColor="Primary" />

              <controls:QuickActionButton Grid.Column="2"
                                          Label="Notes"
                                          IconGlyph="&#xE70B;"
                                          AccentColor="Tertiary" />

              <controls:QuickActionButton Grid.Column="3"
                                          Label="Call"
                                          IconGlyph="&#xE717;"
                                          AccentColor="Secondary" />
            </Grid>
          </StackPanel>

        <!-- Today's Tasks Section with Filter Tabs -->
        <StackPanel Spacing="16">
          <Grid>
            <TextBlock Text="Today's Tasks"
                       Style="{StaticResource SectionTitleStyle}" />
            <Button Content="ALL"
                    Style="{StaticResource GhostButtonStyle}"
                    HorizontalAlignment="Right" />
          </Grid>

          <!-- Task Filter Tabs -->
          <controls:TaskFilterTabs UrgentCount="3"
                                   UnassignedCount="5" />

          <ItemsRepeater ItemsSource="{Binding TodayTasks}">
            <ItemsRepeater.Layout>
              <StackLayout Spacing="12" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:TaskItem">
                <controls:TaskCard TaskItem="{x:Bind}" />
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </StackPanel>

        <!-- Progress Stats -->
        <StackPanel Spacing="16">
          <TextBlock Text="Today's Progress"
                     Style="{StaticResource SectionTitleStyle}" />

          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="20">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="3"
                           Style="{StaticResource StatValueSmallStyle}"
                           Foreground="{StaticResource AccentPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Completed"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{StaticResource BgCardBrush}"
                    BorderBrush="{StaticResource BorderColorBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="20">
              <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="2"
                           Style="{StaticResource StatValueSmallStyle}"
                           Foreground="{StaticResource AccentSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Remaining"
                           Style="{StaticResource CaptionStyle}"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>

        <!-- CSAT Score Card -->
        <controls:CSATScoreCard Score="4.8" />

        <!-- Chat Preview Card -->
        <controls:ChatPreviewCard UnreadCount="4" />

          <!-- Bottom spacing for nav bar -->
          <Border Height="100" />

        </utu:AutoLayout>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>

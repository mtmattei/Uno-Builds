<UserControl x:Class="FormaEspresso.Controls.BrewingCup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:FormaEspresso.Controls"
             Width="192" Height="192">

    <UserControl.Resources>
        <!-- Steam animation -->
        <Storyboard x:Key="SteamAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam1" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0.6" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam1Transform" Storyboard.TargetProperty="TranslateY">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="-12" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam1Transform" Storyboard.TargetProperty="ScaleY">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1.5" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam2" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.2">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0.6" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam2Transform" Storyboard.TargetProperty="TranslateY" BeginTime="0:0:0.2">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="-12" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam2Transform" Storyboard.TargetProperty="ScaleY" BeginTime="0:0:0.2">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1.5" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
            </DoubleAnimationUsingKeyFrames>

            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam3" Storyboard.TargetProperty="Opacity" BeginTime="0:0:0.4">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0.6" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam3Transform" Storyboard.TargetProperty="TranslateY" BeginTime="0:0:0.4">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="-12" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="0" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Steam3Transform" Storyboard.TargetProperty="ScaleY" BeginTime="0:0:0.4">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1.5" />
                <LinearDoubleKeyFrame KeyTime="0:0:1" Value="1" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <Canvas>
        <!-- Steam particles (visible when progress > 50%) -->
        <StackPanel x:Name="SteamContainer"
                    Orientation="Horizontal"
                    Spacing="8"
                    Canvas.Left="80"
                    Canvas.Top="20"
                    Opacity="{x:Bind local:BrewingCup.GetSteamOpacity(Progress), Mode=OneWay}">
            <Border x:Name="Steam1" Width="4" Height="24" CornerRadius="2" Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="Steam1Transform" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#80a8a29e" Offset="0" />
                        <GradientStop Color="#00a8a29e" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border x:Name="Steam2" Width="4" Height="24" CornerRadius="2" Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="Steam2Transform" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#80a8a29e" Offset="0" />
                        <GradientStop Color="#00a8a29e" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border x:Name="Steam3" Width="4" Height="24" CornerRadius="2" Opacity="0" RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <CompositeTransform x:Name="Steam3Transform" />
                </Border.RenderTransform>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                        <GradientStop Color="#80a8a29e" Offset="0" />
                        <GradientStop Color="#00a8a29e" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </StackPanel>

        <!-- Saucer -->
        <Ellipse Width="176" Height="12"
                 Canvas.Left="8"
                 Canvas.Top="156">
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#e7e5e3" Offset="0" />
                    <GradientStop Color="#d4d2d0" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Cup body -->
        <Border Width="128" Height="96"
                Canvas.Left="32"
                Canvas.Top="64"
                CornerRadius="0,0,40,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#f5f5f4" Offset="0" />
                    <GradientStop Color="#e7e5e3" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <!-- Coffee fill container -->
            <Grid VerticalAlignment="Bottom" Margin="4">
                <Border x:Name="CoffeeFill"
                        Height="{x:Bind local:BrewingCup.GetCoffeeHeight(Progress), Mode=OneWay}"
                        VerticalAlignment="Bottom"
                        CornerRadius="0,0,36,36">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                            <GradientStop Color="#451a03" Offset="0" />
                            <GradientStop Color="#78350f" Offset="0.5" />
                            <GradientStop Color="#b45309" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Crema layer -->
                <Border Height="12"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,{x:Bind local:BrewingCup.GetCremaOffset(Progress), Mode=OneWay}"
                        Opacity="{x:Bind local:BrewingCup.GetCremaOpacity(Progress), Mode=OneWay}"
                        CornerRadius="6">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#fde68a" Offset="0" />
                            <GradientStop Color="#fbbf24" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
            </Grid>
        </Border>

        <!-- Cup handle -->
        <Border Width="24" Height="48"
                Canvas.Left="156"
                Canvas.Top="88"
                BorderThickness="4,4,4,4"
                BorderBrush="#e7e5e3"
                CornerRadius="0,12,12,0"
                Background="Transparent" />

        <!-- Cup rim highlight -->
        <Border Width="136" Height="8"
                Canvas.Left="28"
                Canvas.Top="60"
                CornerRadius="4"
                Opacity="0.5">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFF" Offset="0" />
                    <GradientStop Color="#80FFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>
    </Canvas>
</UserControl>

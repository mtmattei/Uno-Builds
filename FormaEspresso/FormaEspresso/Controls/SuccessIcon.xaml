<UserControl x:Class="FormaEspresso.Controls.SuccessIcon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="96" Height="96">

    <UserControl.Resources>
        <!-- Pulse ring animation -->
        <Storyboard x:Key="PulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="PulseRingTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.5"
                             Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PulseRingTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.5"
                             Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PulseRing"
                             Storyboard.TargetProperty="Opacity"
                             From="0.5" To="0"
                             Duration="0:0:1.5">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Float animation -->
        <Storyboard x:Key="FloatAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="IconCircleTransform" Storyboard.TargetProperty="TranslateY">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0" />
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="-8">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
                <EasingDoubleKeyFrame KeyTime="0:0:3" Value="0">
                    <EasingDoubleKeyFrame.EasingFunction>
                        <SineEase EasingMode="EaseInOut" />
                    </EasingDoubleKeyFrame.EasingFunction>
                </EasingDoubleKeyFrame>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Checkmark draw animation -->
        <Storyboard x:Key="CheckmarkAnimation">
            <DoubleAnimation Storyboard.TargetName="Checkmark"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.4"
                             BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckmarkTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0" To="1"
                             Duration="0:0:0.4"
                             BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CheckmarkTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0" To="1"
                             Duration="0:0:0.4"
                             BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase EasingMode="EaseOut" Amplitude="0.3" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <Grid>
        <!-- Pulse ring background -->
        <Ellipse x:Name="PulseRing"
                 Width="96" Height="96"
                 Fill="#d1fae5"
                 Opacity="0.5"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <ScaleTransform x:Name="PulseRingTransform" ScaleX="1" ScaleY="1" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Icon circle -->
        <Ellipse Width="96" Height="96"
                 RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <CompositeTransform x:Name="IconCircleTransform" />
            </Ellipse.RenderTransform>
            <Ellipse.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#34d399" Offset="0" />
                    <GradientStop Color="#10b981" Offset="1" />
                </LinearGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Checkmark -->
        <FontIcon x:Name="Checkmark"
                  Glyph="&#xE73E;"
                  FontSize="40"
                  Foreground="White"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Opacity="0"
                  RenderTransformOrigin="0.5,0.5">
            <FontIcon.RenderTransform>
                <ScaleTransform x:Name="CheckmarkTransform" ScaleX="0" ScaleY="0" />
            </FontIcon.RenderTransform>
        </FontIcon>
    </Grid>
</UserControl>

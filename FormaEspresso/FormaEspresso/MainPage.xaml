<Page x:Class="FormaEspresso.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:FormaEspresso"
      xmlns:controls="using:FormaEspresso.Controls"
      xmlns:converters="using:FormaEspresso.Converters"
      xmlns:models="using:FormaEspresso.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{StaticResource Stone100Brush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:StageToVisibilityConverter x:Key="StageToVisibility" />
        <converters:QuantitySelectedConverter x:Key="QuantitySelected" />

        <!-- Floating Action Bar Animations -->
        <Storyboard x:Key="ShowFloatingBar">
            <DoubleAnimation Storyboard.TargetName="FloatingBarTransform"
                             Storyboard.TargetProperty="TranslateY"
                             From="100" To="0" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="FloatingActionBar"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" />
        </Storyboard>

        <!-- Page Fade In Animation -->
        <Storyboard x:Key="FadeInScale">
            <DoubleAnimation Storyboard.TargetName="ContentGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.95" To="1" Duration="0:0:0.5">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Quantity Button Style -->
        <Style x:Key="QuantityButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <!-- Ambient Background Layer -->
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="384" Height="384"
                     Canvas.Top="80" Canvas.Right="-128"
                     Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#fef3c7" Offset="0" />
                        <GradientStop Color="#00fef3c7" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="384" Height="384"
                     Canvas.Bottom="-128" Canvas.Left="-128"
                     Opacity="0.5">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#e7e5e3" Offset="0" />
                        <GradientStop Color="#00e7e5e3" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Grid utu:SafeArea.Insets="VisibleBounds">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Padding="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand Mark + Text -->
                <Button Grid.Column="0"
                        Command="{x:Bind ViewModel.GoHomeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <!-- Brand Mark -->
                        <Border Width="40" Height="40"
                                CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#fef3c7" Offset="0" />
                                    <GradientStop Color="#fde68a" Offset="0.5" />
                                    <GradientStop Color="#fcd34d" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Ellipse Width="12" Height="12"
                                     Fill="{StaticResource Amber800Brush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Border>

                        <!-- Brand Text -->
                        <StackPanel VerticalAlignment="Center" Spacing="0">
                            <TextBlock Text="FORMA"
                                       FontSize="11"
                                       CharacterSpacing="80"
                                       Foreground="{StaticResource Stone700Brush}" />
                            <TextBlock Text="Espresso Bar"
                                       FontSize="10"
                                       CharacterSpacing="40"
                                       Foreground="{StaticResource Stone400Brush}" />
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Status Badge (Menu Stage Only) -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind ViewModel.IsMenuStage, Mode=OneWay}">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource Emerald400Brush}" />
                    <TextBlock Text="Open until 6pm"
                               Style="{StaticResource BodySStyle}" />
                </StackPanel>

                <!-- Selection Badge (When Item Selected on Menu) -->
                <Border Grid.Column="2"
                        Background="White"
                        CornerRadius="9999"
                        Padding="12,8"
                        Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay}"
                                   Style="{StaticResource BodySStyle}" />
                        <TextBlock Text="{x:Bind ViewModel.SelectedItem.FormattedPrice, Mode=OneWay}"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource Stone900Brush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- MAIN CONTENT -->
            <Grid x:Name="ContentGrid"
                  Grid.Row="1"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="ContentScaleTransform" />
                </Grid.RenderTransform>

                <!-- MENU STAGE -->
                <ScrollViewer Visibility="{x:Bind ViewModel.CurrentStage, Mode=OneWay, Converter={StaticResource StageToVisibility}, ConverterParameter=Menu}">
                    <utu:AutoLayout Spacing="48"
                                    Padding="24,0,24,120"
                                    MaxWidth="800"
                                    HorizontalAlignment="Center">
                        <!-- Page Header -->
                        <StackPanel Spacing="8" HorizontalAlignment="Center">
                            <TextBlock Text="SELECT YOUR ESPRESSO"
                                       Style="{StaticResource LabelStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Four expressions"
                                       Style="{StaticResource DisplayLStyle}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>

                        <!-- Menu Grid -->
                        <ItemsRepeater x:Name="MenuRepeater" ItemsSource="{x:Bind ViewModel.MenuItems}">
                            <ItemsRepeater.Layout>
                                <UniformGridLayout MinItemWidth="280"
                                                   MaximumRowsOrColumns="2"
                                                   MinRowSpacing="16"
                                                   MinColumnSpacing="16"
                                                   ItemsStretch="Fill" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:EspressoItem">
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Click="OnEspressoCardClick"
                                            Tag="{x:Bind}">
                                        <controls:EspressoCard x:Name="Card" Item="{x:Bind}" />
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </utu:AutoLayout>
                </ScrollViewer>

                <!-- CUSTOMIZE STAGE -->
                <Grid Visibility="{x:Bind ViewModel.CurrentStage, Mode=OneWay, Converter={StaticResource StageToVisibility}, ConverterParameter=Customize}"
                      Padding="24">
                    <utu:AutoLayout Spacing="24"
                                    MaxWidth="512"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <!-- Back Button -->
                        <Button Command="{x:Bind ViewModel.BackToMenuCommand}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE76B;" FontSize="16" Foreground="{StaticResource Stone400Brush}" />
                                <TextBlock Text="Back to menu"
                                           Style="{StaticResource BodyMStyle}" />
                            </StackPanel>
                        </Button>

                        <!-- Customize Card -->
                        <Border Background="White"
                                CornerRadius="24"
                                Padding="32"
                                Translation="0,0,16">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>

                            <utu:AutoLayout Spacing="24" PrimaryAxisAlignment="Stretch">
                                <!-- Header -->
                                <StackPanel Spacing="12" HorizontalAlignment="Center">
                                    <Border Background="{StaticResource Stone100Brush}"
                                            CornerRadius="9999"
                                            Padding="12,6"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.SelectedItem.Volume, Mode=OneWay}"
                                                   Style="{StaticResource LabelStyle}" />
                                    </Border>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay}"
                                               Style="{StaticResource DisplayXLStyle}"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedItem.Description, Mode=OneWay}"
                                               Style="{StaticResource BodyLStyle}"
                                               TextAlignment="Center"
                                               MaxWidth="360"
                                               HorizontalAlignment="Center" />
                                </StackPanel>

                                <!-- Quantity Section -->
                                <StackPanel Spacing="12" Margin="0,16,0,0">
                                    <TextBlock Text="HOW MANY?"
                                               Style="{StaticResource LabelStyle}" />

                                    <!-- Quantity Selector -->
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <Button Style="{StaticResource QuantityButtonStyle}"
                                                Command="{x:Bind ViewModel.SetQuantityCommand}"
                                                CommandParameter="1"
                                                Background="{x:Bind local:MainPage.GetQuantityBackground(ViewModel.Quantity, 1), Mode=OneWay}">
                                            <TextBlock Text="1"
                                                       FontWeight="Medium"
                                                       Foreground="{x:Bind local:MainPage.GetQuantityForeground(ViewModel.Quantity, 1), Mode=OneWay}" />
                                        </Button>
                                        <Button Style="{StaticResource QuantityButtonStyle}"
                                                Command="{x:Bind ViewModel.SetQuantityCommand}"
                                                CommandParameter="2"
                                                Background="{x:Bind local:MainPage.GetQuantityBackground(ViewModel.Quantity, 2), Mode=OneWay}">
                                            <TextBlock Text="2"
                                                       FontWeight="Medium"
                                                       Foreground="{x:Bind local:MainPage.GetQuantityForeground(ViewModel.Quantity, 2), Mode=OneWay}" />
                                        </Button>
                                        <Button Style="{StaticResource QuantityButtonStyle}"
                                                Command="{x:Bind ViewModel.SetQuantityCommand}"
                                                CommandParameter="3"
                                                Background="{x:Bind local:MainPage.GetQuantityBackground(ViewModel.Quantity, 3), Mode=OneWay}">
                                            <TextBlock Text="3"
                                                       FontWeight="Medium"
                                                       Foreground="{x:Bind local:MainPage.GetQuantityForeground(ViewModel.Quantity, 3), Mode=OneWay}" />
                                        </Button>
                                        <Button Style="{StaticResource QuantityButtonStyle}"
                                                Command="{x:Bind ViewModel.SetQuantityCommand}"
                                                CommandParameter="4"
                                                Background="{x:Bind local:MainPage.GetQuantityBackground(ViewModel.Quantity, 4), Mode=OneWay}">
                                            <TextBlock Text="4"
                                                       FontWeight="Medium"
                                                       Foreground="{x:Bind local:MainPage.GetQuantityForeground(ViewModel.Quantity, 4), Mode=OneWay}" />
                                        </Button>
                                        <Button Style="{StaticResource QuantityButtonStyle}"
                                                Command="{x:Bind ViewModel.SetQuantityCommand}"
                                                CommandParameter="5"
                                                Background="{x:Bind local:MainPage.GetQuantityBackground(ViewModel.Quantity, 5), Mode=OneWay}">
                                            <TextBlock Text="5"
                                                       FontWeight="Medium"
                                                       Foreground="{x:Bind local:MainPage.GetQuantityForeground(ViewModel.Quantity, 5), Mode=OneWay}" />
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Divider -->
                                <Border Height="1" Background="{StaticResource Stone100Brush}" Margin="0,8,0,0" />

                                <!-- Order Summary -->
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{x:Bind ViewModel.OrderSummary, Mode=OneWay}"
                                                   Style="{StaticResource BodyMStyle}" />
                                        <TextBlock Text="{x:Bind ViewModel.FormattedTotalTime, Mode=OneWay}"
                                                   Style="{StaticResource BodySStyle}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1"
                                               Text="{x:Bind ViewModel.FormattedTotal, Mode=OneWay}"
                                               Style="{StaticResource PriceLargeStyle}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <!-- Place Order Button -->
                                <Button Command="{x:Bind ViewModel.PlaceOrderCommand}"
                                        HorizontalAlignment="Stretch"
                                        Background="{StaticResource Stone900Brush}"
                                        Foreground="White"
                                        Padding="20"
                                        CornerRadius="20"
                                        Margin="0,8,0,0">
                                    <TextBlock Text="PLACE ORDER"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               CharacterSpacing="60"
                                               Foreground="White" />
                                </Button>
                            </utu:AutoLayout>
                        </Border>
                    </utu:AutoLayout>
                </Grid>

                <!-- BREWING STAGE -->
                <Grid Visibility="{x:Bind ViewModel.CurrentStage, Mode=OneWay, Converter={StaticResource StageToVisibility}, ConverterParameter=Brewing}"
                      Padding="24">
                    <Border Background="White"
                            CornerRadius="24"
                            Padding="40"
                            MaxWidth="512"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Translation="0,0,16">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>

                        <utu:AutoLayout Spacing="32" HorizontalAlignment="Center">
                            <!-- Order Number -->
                            <TextBlock HorizontalAlignment="Center">
                                <Run Text="Order #"
                                     FontSize="11"
                                     CharacterSpacing="120"
                                     Foreground="{StaticResource Amber700Brush}" />
                                <Run Text="{x:Bind ViewModel.OrderNumber, Mode=OneWay}"
                                     FontSize="11"
                                     CharacterSpacing="120"
                                     Foreground="{StaticResource Amber700Brush}" />
                            </TextBlock>

                            <!-- Cup Visualization -->
                            <controls:BrewingCup Progress="{x:Bind ViewModel.BrewingProgress, Mode=OneWay}"
                                                 HorizontalAlignment="Center" />

                            <!-- Progress Bar -->
                            <Grid Width="192" Height="4" HorizontalAlignment="Center">
                                <Border Background="{StaticResource Stone200Brush}"
                                        CornerRadius="2" />
                                <Border HorizontalAlignment="Left"
                                        Width="{x:Bind local:MainPage.GetProgressWidth(ViewModel.BrewingProgress), Mode=OneWay}"
                                        CornerRadius="2">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#d97706" Offset="0" />
                                            <GradientStop Color="#fbbf24" Offset="1" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Grid>

                            <!-- Status Text -->
                            <StackPanel Spacing="4" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.BrewingStatus, Mode=OneWay}"
                                           Style="{StaticResource LabelStyle}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay}"
                                           Style="{StaticResource DisplayMStyle}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </utu:AutoLayout>
                    </Border>
                </Grid>

                <!-- READY STAGE -->
                <Grid Visibility="{x:Bind ViewModel.CurrentStage, Mode=OneWay, Converter={StaticResource StageToVisibility}, ConverterParameter=Ready}"
                      Padding="24">
                    <Border Background="White"
                            CornerRadius="24"
                            Padding="40"
                            MaxWidth="512"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Translation="0,0,16">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>

                        <utu:AutoLayout Spacing="24" HorizontalAlignment="Center">
                            <!-- Success Icon -->
                            <controls:SuccessIcon HorizontalAlignment="Center" />

                            <!-- Status Label -->
                            <TextBlock Text="READY FOR PICKUP"
                                       FontSize="11"
                                       CharacterSpacing="120"
                                       Foreground="{StaticResource Emerald600Brush}"
                                       HorizontalAlignment="Center" />

                            <!-- Order Details -->
                            <StackPanel Spacing="12" HorizontalAlignment="Center">
                                <TextBlock HorizontalAlignment="Center">
                                    <Run Text="Order #"
                                         FontFamily="Georgia"
                                         FontSize="48"
                                         Foreground="{StaticResource Stone900Brush}" />
                                    <Run Text="{x:Bind ViewModel.OrderNumber, Mode=OneWay}"
                                         FontFamily="Georgia"
                                         FontSize="48"
                                         Foreground="{StaticResource Stone900Brush}" />
                                </TextBlock>
                                <TextBlock Text="{x:Bind ViewModel.OrderSummary, Mode=OneWay}"
                                           Style="{StaticResource BodyLStyle}"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="Please collect at the counter"
                                           Style="{StaticResource BodyMStyle}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- New Order Button -->
                            <Button Command="{x:Bind ViewModel.NewOrderCommand}"
                                    Background="{StaticResource Stone900Brush}"
                                    Foreground="White"
                                    Padding="32,16"
                                    CornerRadius="9999"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">
                                <TextBlock Text="New Order"
                                           FontSize="14"
                                           CharacterSpacing="40"
                                           Foreground="White" />
                            </Button>
                        </utu:AutoLayout>
                    </Border>
                </Grid>
            </Grid>

            <!-- FLOATING ACTION BAR (Menu Stage) -->
            <Border x:Name="FloatingActionBar"
                    Grid.Row="1"
                    Background="{StaticResource Stone900Brush}"
                    CornerRadius="20"
                    Padding="20,20,20,20"
                    Margin="24,0,24,24"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    MaxWidth="500"
                    Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}"
                    Translation="0,0,24"
                    RenderTransformOrigin="0.5,1">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Border.RenderTransform>
                    <TranslateTransform x:Name="FloatingBarTransform" />
                </Border.RenderTransform>

                <Button Command="{x:Bind ViewModel.ContinueToCustomizeCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Section -->
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Text="Continue with"
                                       FontSize="12"
                                       Opacity="0.6"
                                       Foreground="White" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedItem.Name, Mode=OneWay}"
                                       FontFamily="Georgia"
                                       FontSize="20"
                                       Foreground="White" />
                        </StackPanel>

                        <!-- Price -->
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.SelectedItem.FormattedPrice, Mode=OneWay}"
                                   FontFamily="Georgia"
                                   FontSize="24"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="0,0,16,0" />

                        <!-- Arrow Button -->
                        <Border Grid.Column="2"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="#1AFFFFFF"
                                VerticalAlignment="Center">
                            <FontIcon Glyph="&#xE76C;"
                                      FontSize="20"
                                      Foreground="White" />
                        </Border>
                    </Grid>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Page>

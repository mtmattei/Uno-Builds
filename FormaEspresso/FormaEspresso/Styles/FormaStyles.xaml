<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Forma Stone Palette -->
    <Color x:Key="Stone900">#1c1917</Color>
    <Color x:Key="Stone800">#292524</Color>
    <Color x:Key="Stone700">#44403c</Color>
    <Color x:Key="Stone500">#78716c</Color>
    <Color x:Key="Stone400">#a8a29e</Color>
    <Color x:Key="Stone200">#e7e5e3</Color>
    <Color x:Key="Stone100">#f5f5f4</Color>
    <Color x:Key="Stone50">#fafaf9</Color>

    <!-- Forma Amber Palette -->
    <Color x:Key="Amber950">#451a03</Color>
    <Color x:Key="Amber900">#78350f</Color>
    <Color x:Key="Amber800">#92400e</Color>
    <Color x:Key="Amber700">#b45309</Color>
    <Color x:Key="Amber600">#d97706</Color>
    <Color x:Key="Amber400">#fbbf24</Color>
    <Color x:Key="Amber300">#fcd34d</Color>
    <Color x:Key="Amber200">#fde68a</Color>
    <Color x:Key="Amber100">#fef3c7</Color>

    <!-- Forma Emerald Palette -->
    <Color x:Key="Emerald600">#059669</Color>
    <Color x:Key="Emerald500">#10b981</Color>
    <Color x:Key="Emerald400">#34d399</Color>
    <Color x:Key="Emerald100">#d1fae5</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="Stone900Brush" Color="{StaticResource Stone900}" />
    <SolidColorBrush x:Key="Stone800Brush" Color="{StaticResource Stone800}" />
    <SolidColorBrush x:Key="Stone700Brush" Color="{StaticResource Stone700}" />
    <SolidColorBrush x:Key="Stone500Brush" Color="{StaticResource Stone500}" />
    <SolidColorBrush x:Key="Stone400Brush" Color="{StaticResource Stone400}" />
    <SolidColorBrush x:Key="Stone200Brush" Color="{StaticResource Stone200}" />
    <SolidColorBrush x:Key="Stone100Brush" Color="{StaticResource Stone100}" />
    <SolidColorBrush x:Key="Stone50Brush" Color="{StaticResource Stone50}" />

    <SolidColorBrush x:Key="Amber950Brush" Color="{StaticResource Amber950}" />
    <SolidColorBrush x:Key="Amber900Brush" Color="{StaticResource Amber900}" />
    <SolidColorBrush x:Key="Amber800Brush" Color="{StaticResource Amber800}" />
    <SolidColorBrush x:Key="Amber700Brush" Color="{StaticResource Amber700}" />
    <SolidColorBrush x:Key="Amber600Brush" Color="{StaticResource Amber600}" />
    <SolidColorBrush x:Key="Amber400Brush" Color="{StaticResource Amber400}" />
    <SolidColorBrush x:Key="Amber300Brush" Color="{StaticResource Amber300}" />
    <SolidColorBrush x:Key="Amber200Brush" Color="{StaticResource Amber200}" />
    <SolidColorBrush x:Key="Amber100Brush" Color="{StaticResource Amber100}" />

    <SolidColorBrush x:Key="Emerald600Brush" Color="{StaticResource Emerald600}" />
    <SolidColorBrush x:Key="Emerald500Brush" Color="{StaticResource Emerald500}" />
    <SolidColorBrush x:Key="Emerald400Brush" Color="{StaticResource Emerald400}" />
    <SolidColorBrush x:Key="Emerald100Brush" Color="{StaticResource Emerald100}" />

    <!-- Page Background -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{StaticResource Stone100}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />

    <!-- Spacing -->
    <x:Double x:Key="Space1">4</x:Double>
    <x:Double x:Key="Space2">8</x:Double>
    <x:Double x:Key="Space3">12</x:Double>
    <x:Double x:Key="Space4">16</x:Double>
    <x:Double x:Key="Space5">20</x:Double>
    <x:Double x:Key="Space6">24</x:Double>
    <x:Double x:Key="Space8">32</x:Double>
    <x:Double x:Key="Space10">40</x:Double>
    <x:Double x:Key="Space12">48</x:Double>
    <x:Double x:Key="Space16">64</x:Double>

    <!-- Border Radius -->
    <CornerRadius x:Key="RadiusSm">4</CornerRadius>
    <CornerRadius x:Key="RadiusMd">8</CornerRadius>
    <CornerRadius x:Key="RadiusLg">12</CornerRadius>
    <CornerRadius x:Key="RadiusXl">16</CornerRadius>
    <CornerRadius x:Key="Radius2Xl">20</CornerRadius>
    <CornerRadius x:Key="Radius3Xl">24</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

    <!-- Typography - Display Styles (Fraunces fallback to Georgia) -->
    <Style x:Key="DisplayXLStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="53" />
        <Setter Property="CharacterSpacing" Value="-40" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="DisplayLStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="40" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="46" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="DisplayMStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="38" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="DisplaySStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="31" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="PriceStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="24" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="PriceLargeStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Georgia" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="32" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <!-- Typography - Body Styles (Karla fallback to system-ui) -->
    <Style x:Key="HeadingStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="LineHeight" Value="28" />
        <Setter Property="Foreground" Value="{StaticResource Stone900Brush}" />
    </Style>

    <Style x:Key="BodyLStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="26" />
        <Setter Property="Foreground" Value="{StaticResource Stone500Brush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodyMStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="21" />
        <Setter Property="Foreground" Value="{StaticResource Stone500Brush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="BodySStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource Stone400Brush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="LineHeight" Value="15" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{StaticResource Stone400Brush}" />
    </Style>

    <!-- Button Styles -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Stone900Brush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius2Xl}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="PillButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource Stone900Brush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Padding" Value="16,16,32,16" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
    </Style>

    <!-- Card Styles -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius3Xl}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <!-- Badge Styles -->
    <Style x:Key="VolumeBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Stone100Brush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="8,4" />
    </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <!-- Forma Stone Palette mapped to Material -->
            <Color x:Key="PrimaryColor">#1c1917</Color>
            <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
            <Color x:Key="PrimaryContainerColor">#f5f5f4</Color>
            <Color x:Key="OnPrimaryContainerColor">#1c1917</Color>

            <Color x:Key="SecondaryColor">#44403c</Color>
            <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
            <Color x:Key="SecondaryContainerColor">#e7e5e3</Color>
            <Color x:Key="OnSecondaryContainerColor">#292524</Color>

            <!-- Amber accent as Tertiary -->
            <Color x:Key="TertiaryColor">#b45309</Color>
            <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
            <Color x:Key="TertiaryContainerColor">#fef3c7</Color>
            <Color x:Key="OnTertiaryContainerColor">#451a03</Color>

            <Color x:Key="ErrorColor">#B3261E</Color>
            <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
            <Color x:Key="OnErrorColor">#FFFFFF</Color>
            <Color x:Key="OnErrorContainerColor">#410E0B</Color>

            <Color x:Key="BackgroundColor">#f5f5f4</Color>
            <Color x:Key="OnBackgroundColor">#1c1917</Color>
            <Color x:Key="SurfaceColor">#FFFFFF</Color>
            <Color x:Key="OnSurfaceColor">#1c1917</Color>
            <Color x:Key="SurfaceVariantColor">#f5f5f4</Color>
            <Color x:Key="OnSurfaceVariantColor">#78716c</Color>
            <Color x:Key="OutlineColor">#a8a29e</Color>
            <Color x:Key="OnSurfaceInverseColor">#fafaf9</Color>
            <Color x:Key="SurfaceInverseColor">#1c1917</Color>
            <Color x:Key="PrimaryInverseColor">#fafaf9</Color>
            <Color x:Key="SurfaceTintColor">#b45309</Color>
            <Color x:Key="OutlineVariantColor">#e7e5e3</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <!-- Dark theme - inverted for dark mode -->
            <Color x:Key="PrimaryColor">#fafaf9</Color>
            <Color x:Key="OnPrimaryColor">#1c1917</Color>
            <Color x:Key="PrimaryContainerColor">#292524</Color>
            <Color x:Key="OnPrimaryContainerColor">#f5f5f4</Color>

            <Color x:Key="SecondaryColor">#a8a29e</Color>
            <Color x:Key="OnSecondaryColor">#1c1917</Color>
            <Color x:Key="SecondaryContainerColor">#44403c</Color>
            <Color x:Key="OnSecondaryContainerColor">#e7e5e3</Color>

            <Color x:Key="TertiaryColor">#fbbf24</Color>
            <Color x:Key="OnTertiaryColor">#451a03</Color>
            <Color x:Key="TertiaryContainerColor">#78350f</Color>
            <Color x:Key="OnTertiaryContainerColor">#fef3c7</Color>

            <Color x:Key="ErrorColor">#FFB4AB</Color>
            <Color x:Key="ErrorContainerColor">#93000A</Color>
            <Color x:Key="OnErrorColor">#690005</Color>
            <Color x:Key="OnErrorContainerColor">#FFDAD6</Color>

            <Color x:Key="BackgroundColor">#1c1917</Color>
            <Color x:Key="OnBackgroundColor">#f5f5f4</Color>
            <Color x:Key="SurfaceColor">#292524</Color>
            <Color x:Key="OnSurfaceColor">#f5f5f4</Color>
            <Color x:Key="SurfaceVariantColor">#44403c</Color>
            <Color x:Key="OnSurfaceVariantColor">#a8a29e</Color>
            <Color x:Key="OutlineColor">#78716c</Color>
            <Color x:Key="OnSurfaceInverseColor">#1c1917</Color>
            <Color x:Key="SurfaceInverseColor">#f5f5f4</Color>
            <Color x:Key="PrimaryInverseColor">#1c1917</Color>
            <Color x:Key="SurfaceTintColor">#fbbf24</Color>
            <Color x:Key="OutlineVariantColor">#44403c</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

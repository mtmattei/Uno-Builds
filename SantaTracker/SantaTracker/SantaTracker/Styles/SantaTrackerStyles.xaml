<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== DESIGN TOKENS ==================== -->

    <!-- Spacing Scale -->
    <x:Double x:Key="Space2Xs">4</x:Double>
    <x:Double x:Key="SpaceXs">8</x:Double>
    <x:Double x:Key="SpaceSm">12</x:Double>
    <x:Double x:Key="SpaceMd">16</x:Double>
    <x:Double x:Key="SpaceLg">20</x:Double>
    <x:Double x:Key="SpaceXl">24</x:Double>
    <x:Double x:Key="Space2Xl">32</x:Double>
    <x:Double x:Key="Space3Xl">40</x:Double>

    <!-- Border Radius Scale -->
    <CornerRadius x:Key="RadiusSm">8</CornerRadius>
    <CornerRadius x:Key="RadiusMd">12</CornerRadius>
    <CornerRadius x:Key="RadiusLg">16</CornerRadius>
    <CornerRadius x:Key="RadiusXl">20</CornerRadius>
    <CornerRadius x:Key="RadiusFull">9999</CornerRadius>

    <!-- ==================== GRADIENT BRUSHES ==================== -->

    <!-- Card Gradients -->
    <LinearGradientBrush x:Key="CardDarkGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1E352C" Offset="0"/>
        <GradientStop Color="#FF162821" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardMediumGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF2A4438" Offset="0"/>
        <GradientStop Color="#FF223A30" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="StatCardGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3A5548" Offset="0"/>
        <GradientStop Color="#FF324B40" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="StatusBadgeGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3A5548" Offset="0"/>
        <GradientStop Color="#FF2D4A3D" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CheerScannerGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF7F3E8" Offset="0"/>
        <GradientStop Color="#FFF0EBD8" Offset="1"/>
    </LinearGradientBrush>

    <!-- ==================== NAUGHTY/NICE SCANNER DESIGN SYSTEM ==================== -->

    <!-- Scanner Color Palette -->
    <Color x:Key="ScannerDeepPineColor">#FF1a2e1f</Color>
    <Color x:Key="ScannerForestColor">#FF2d4a3e</Color>
    <Color x:Key="ScannerGoldColor">#FFd4a853</Color>
    <Color x:Key="ScannerGoldBrightColor">#FFf0c75e</Color>
    <Color x:Key="ScannerCrimsonColor">#FFc41e3a</Color>
    <Color x:Key="ScannerCrimsonGlowColor">#FFff2d55</Color>
    <Color x:Key="ScannerSnowColor">#FFf8f9fa</Color>
    <Color x:Key="ScannerFrostColor">#FFe8f0f2</Color>
    <Color x:Key="ScannerIceBlueColor">#FFa8d4e6</Color>
    <Color x:Key="ScannerNiceGreenColor">#FF4ade80</Color>
    <Color x:Key="ScannerNaughtyRedColor">#FFef4444</Color>

    <SolidColorBrush x:Key="ScannerDeepPineBrush" Color="{StaticResource ScannerDeepPineColor}" />
    <SolidColorBrush x:Key="ScannerForestBrush" Color="{StaticResource ScannerForestColor}" />
    <SolidColorBrush x:Key="ScannerGoldBrush" Color="{StaticResource ScannerGoldColor}" />
    <SolidColorBrush x:Key="ScannerGoldBrightBrush" Color="{StaticResource ScannerGoldBrightColor}" />
    <SolidColorBrush x:Key="ScannerCrimsonBrush" Color="{StaticResource ScannerCrimsonColor}" />
    <SolidColorBrush x:Key="ScannerCrimsonGlowBrush" Color="{StaticResource ScannerCrimsonGlowColor}" />
    <SolidColorBrush x:Key="ScannerSnowBrush" Color="{StaticResource ScannerSnowColor}" />
    <SolidColorBrush x:Key="ScannerFrostBrush" Color="{StaticResource ScannerFrostColor}" />
    <SolidColorBrush x:Key="ScannerIceBlueBrush" Color="{StaticResource ScannerIceBlueColor}" />
    <SolidColorBrush x:Key="ScannerNiceGreenBrush" Color="{StaticResource ScannerNiceGreenColor}" />
    <SolidColorBrush x:Key="ScannerNaughtyRedBrush" Color="{StaticResource ScannerNaughtyRedColor}" />

    <!-- ==================== MAGIC-O-METER DESIGN SYSTEM ==================== -->

    <!-- Magic Meter Color Palette -->
    <Color x:Key="MagicPurpleColor">#FFa855f7</Color>
    <Color x:Key="MagicPinkColor">#FFec4899</Color>

    <SolidColorBrush x:Key="MagicPurpleBrush" Color="{StaticResource MagicPurpleColor}" />
    <SolidColorBrush x:Key="MagicPinkBrush" Color="{StaticResource MagicPinkColor}" />

    <!-- Magic Meter Gradients -->
    <LinearGradientBrush x:Key="MagicLogoGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource MagicPurpleColor}" Offset="0" />
        <GradientStop Color="{StaticResource MagicPinkColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MagicNeedleGradient" StartPoint="0.5,1" EndPoint="0.5,0">
        <GradientStop Color="{StaticResource ScannerCrimsonColor}" Offset="0" />
        <GradientStop Color="{StaticResource ScannerGoldColor}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="MagicTextGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource MagicPurpleColor}" Offset="0" />
        <GradientStop Color="{StaticResource MagicPinkColor}" Offset="0.5" />
        <GradientStop Color="{StaticResource ScannerGoldColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- ==================== NORTH POLE FM DESIGN SYSTEM ==================== -->

    <!-- Vinyl Record Color Palette -->
    <Color x:Key="VinylDarkColor">#FF1a1a2e</Color>
    <Color x:Key="VinylMidColor">#FF16213e</Color>
    <Color x:Key="VinylHighlightColor">#FF0f3460</Color>
    <Color x:Key="RadioCrimsonColor">#FFc41e3a</Color>
    <Color x:Key="RadioCrimsonGlowColor">#FFff2d55</Color>

    <SolidColorBrush x:Key="VinylDarkBrush" Color="{StaticResource VinylDarkColor}" />
    <SolidColorBrush x:Key="VinylMidBrush" Color="{StaticResource VinylMidColor}" />
    <SolidColorBrush x:Key="VinylHighlightBrush" Color="{StaticResource VinylHighlightColor}" />
    <SolidColorBrush x:Key="RadioCrimsonBrush" Color="{StaticResource RadioCrimsonColor}" />
    <SolidColorBrush x:Key="RadioCrimsonGlowBrush" Color="{StaticResource RadioCrimsonGlowColor}" />

    <!-- Vinyl Record Gradient -->
    <LinearGradientBrush x:Key="VinylRecordGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource VinylDarkColor}" Offset="0" />
        <GradientStop Color="{StaticResource VinylMidColor}" Offset="0.5" />
        <GradientStop Color="{StaticResource VinylHighlightColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Vinyl Label Gradient -->
    <RadialGradientBrush x:Key="VinylLabelGradient" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#FFd4304a" Offset="0" />
        <GradientStop Color="{StaticResource RadioCrimsonColor}" Offset="1" />
    </RadialGradientBrush>

    <!-- Radio Logo Gradient -->
    <LinearGradientBrush x:Key="RadioLogoGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource RadioCrimsonColor}" Offset="0" />
        <GradientStop Color="{StaticResource ScannerGoldColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Play Button Gradient -->
    <LinearGradientBrush x:Key="PlayButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource RadioCrimsonColor}" Offset="0" />
        <GradientStop Color="#FFd4304a" Offset="1" />
    </LinearGradientBrush>

    <!-- Visualizer Bar Gradient -->
    <LinearGradientBrush x:Key="VisualizerBarGradient" StartPoint="0.5,1" EndPoint="0.5,0">
        <GradientStop Color="{StaticResource RadioCrimsonColor}" Offset="0" />
        <GradientStop Color="{StaticResource ScannerGoldColor}" Offset="1" />
    </LinearGradientBrush>

    <!-- Scanner Background Gradient -->
    <LinearGradientBrush x:Key="ScannerBackgroundGradient" StartPoint="0,0" EndPoint="0.3,1">
        <GradientStop Color="#FF0f1a14" Offset="0"/>
        <GradientStop Color="#FF1a2e1f" Offset="0.4"/>
        <GradientStop Color="#FF234034" Offset="1"/>
    </LinearGradientBrush>

    <!-- Scanner Card Glass Effect -->
    <LinearGradientBrush x:Key="ScannerCardGlassBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1FFFFFFF" Offset="0"/>
        <GradientStop Color="#0DFFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- Scanner Button Gradient -->
    <LinearGradientBrush x:Key="ScannerButtonGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFc41e3a" Offset="0"/>
        <GradientStop Color="#FFd4304a" Offset="1"/>
    </LinearGradientBrush>

    <!-- Scanner Logo Gradient -->
    <LinearGradientBrush x:Key="ScannerLogoGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFc41e3a" Offset="0"/>
        <GradientStop Color="#FFff2d55" Offset="1"/>
    </LinearGradientBrush>

    <!-- Radar Radial Gradient -->
    <RadialGradientBrush x:Key="ScannerRadarGradient" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#1Aa8d4e6" Offset="0"/>
        <GradientStop Color="#00a8d4e6" Offset="1"/>
    </RadialGradientBrush>

    <!-- ==================== AEGIS HUD DESIGN SYSTEM ==================== -->

    <!-- Aegis Color Palette -->
    <Color x:Key="AegisVoidColor">#FF08110d</Color>
    <Color x:Key="AegisTerminalColor">#FF101f18</Color>
    <Color x:Key="AegisAlertRedColor">#FFc6433e</Color>
    <Color x:Key="AegisTelemetryGoldColor">#FFfcc244</Color>

    <SolidColorBrush x:Key="AegisVoidBrush" Color="{StaticResource AegisVoidColor}" />
    <SolidColorBrush x:Key="AegisTerminalBrush" Color="{StaticResource AegisTerminalColor}" />
    <SolidColorBrush x:Key="AegisAlertRedBrush" Color="{StaticResource AegisAlertRedColor}" />
    <SolidColorBrush x:Key="AegisTelemetryGoldBrush" Color="{StaticResource AegisTelemetryGoldColor}" />
    <SolidColorBrush x:Key="AegisGlassBorderBrush" Color="#19FFFFFF" />
    <SolidColorBrush x:Key="AegisTextMutedBrush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="AegisTextDimBrush" Color="#40FFFFFF" />

    <!-- Aegis Timeline Gradients -->
    <LinearGradientBrush x:Key="AegisCurrentLineGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFc6433e" Offset="0"/>
        <GradientStop Color="#00c6433e" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AegisTerminalGlassGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D9101f18" Offset="0"/>
        <GradientStop Color="#D9080f0c" Offset="1"/>
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="AegisGlowRedBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#30c6433e" Offset="0"/>
        <GradientStop Color="#00c6433e" Offset="1"/>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AegisGlowGoldBrush" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
        <GradientStop Color="#30fcc244" Offset="0"/>
        <GradientStop Color="#00fcc244" Offset="1"/>
    </RadialGradientBrush>

    <!-- Aegis Terminal Card Style (matches StatCardGradient) -->
    <Style x:Key="AegisTerminalCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatCardGradient}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="Padding" Value="20,18" />
    </Style>

    <!-- Aegis HUD Label Style (Headers - Berkshire Swash) -->
    <Style x:Key="AegisHudLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/Berkshire_Swash/BerkshireSwash-Regular.ttf#Berkshire Swash" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AegisTextMutedBrush}" />
    </Style>

    <!-- Aegis City Name Style -->
    <Style x:Key="AegisCityNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="-20" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Aegis Monospace Data Style -->
    <Style x:Key="AegisMonoDataStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AegisTelemetryGoldBrush}" />
    </Style>

    <!-- Aegis Telemetry Stat Value -->
    <Style x:Key="AegisTelemetryValueStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Aegis Telemetry Stat Label -->
    <Style x:Key="AegisTelemetryLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="Black" />
        <Setter Property="CharacterSpacing" Value="300" />
        <Setter Property="Foreground" Value="{StaticResource AegisTextMutedBrush}" />
    </Style>

    <!-- Aegis Historical Item Style (40% opacity) -->
    <Style x:Key="AegisHistoricalTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource AegisTextDimBrush}" />
    </Style>

    <!-- Accent Gradients -->
    <LinearGradientBrush x:Key="AccentRedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFC94643" Offset="0"/>
        <GradientStop Color="#FFB53D3A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LogoUnderlineGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FFC94643" Offset="0"/>
        <GradientStop Color="#FFE8894A" Offset="0.5"/>
        <GradientStop Color="#FFE5C54B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="DestinationTimelineGradient" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#FFC94643" Offset="0"/>
        <GradientStop Color="#FFD65A4A" Offset="0.25"/>
        <GradientStop Color="#FFE57A4B" Offset="0.5"/>
        <GradientStop Color="#FFE9A54C" Offset="0.75"/>
        <GradientStop Color="#FFE5C54B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ProgressBarGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FFC94643" Offset="0"/>
        <GradientStop Color="#FFD4574A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Avatar Gradient -->
    <LinearGradientBrush x:Key="AvatarGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF3A5548" Offset="0"/>
        <GradientStop Color="#FF2D4A3D" Offset="1"/>
    </LinearGradientBrush>

    <!-- ==================== SOLID COLOR BRUSHES ==================== -->

    <!-- Surface Colors -->
    <SolidColorBrush x:Key="SurfaceBackgroundBaseBrush" Color="#FF2D4A3D" />
    <SolidColorBrush x:Key="SurfaceBackgroundDarkBrush" Color="#FF1C332A" />
    <SolidColorBrush x:Key="SurfaceBackgroundMediumBrush" Color="#FF3A5548" />
    <SolidColorBrush x:Key="SurfaceCardCreamBrush" Color="#FFF7F3E8" />
    <SolidColorBrush x:Key="SurfaceCardFleetBrush" Color="#FFF5F5F0" />

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="AccentRedBrush" Color="#FFC94643" />
    <SolidColorBrush x:Key="AccentRedHoverBrush" Color="#FFB53D3A" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#FFE8894A" />
    <SolidColorBrush x:Key="AccentYellowBrush" Color="#FFE5C54B" />
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#FF4A90B8" />
    <SolidColorBrush x:Key="StatusGreenBrush" Color="#FF5FAD56" />
    <SolidColorBrush x:Key="AccentPinkBrush" Color="#FFD65A9A" />
    <SolidColorBrush x:Key="AccentBrightRedBrush" Color="#FFE85A6B" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#99FFFFFF" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#66FFFFFF" />
    <SolidColorBrush x:Key="TextOnCreamBrush" Color="#FF6B6B5A" />
    <SolidColorBrush x:Key="TextOnCreamMutedBrush" Color="#FF9A9A8A" />
    <SolidColorBrush x:Key="LogoTextBrush" Color="#FFF5EDE0" />

    <!-- Border Colors -->
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="#19FFFFFF" />
    <SolidColorBrush x:Key="BorderFaintBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="BorderOnCreamBrush" Color="#1A000000" />

    <!-- ==================== CARD STYLES ==================== -->

    <!-- Dark Card - Level 2 shadow (Z=12) -->
    <Style x:Key="CardDarkStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardDarkGradient}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderFaintBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- Medium Card - Level 2 shadow -->
    <Style x:Key="CardMediumStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardMediumGradient}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderFaintBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <!-- Stat Card - Level 1 shadow (Z=6) -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatCardGradient}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="16,16,20,16" />
        <Setter Property="MinWidth" Value="180" />
        <Setter Property="Height" Value="90" />
    </Style>

    <!-- Cheer Scanner Card - Level 3 shadow (Z=24) -->
    <Style x:Key="CheerScannerCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CheerScannerGradient}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusXl}" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <!-- Status Badge - Pill style -->
    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource StatusBadgeGradient}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
    </Style>

    <!-- User Profile Card -->
    <Style x:Key="UserProfileCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Avatar Container -->
    <Style x:Key="AvatarContainerStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AvatarGradient}" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
    </Style>

    <!-- Tag/Pill Style -->
    <Style x:Key="TagStyle" TargetType="Border">
        <Setter Property="Background" Value="#19FFFFFF" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <!-- Fleet Card Style -->
    <Style x:Key="FleetCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceCardFleetBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinHeight" Value="110" />
    </Style>

    <!-- Inner Card (nested) - Level 0 -->
    <Style x:Key="InnerCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#40000000" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="14,14,16,14" />
        <Setter Property="BorderThickness" Value="3,0,0,0" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}" />
    </Style>

    <!-- ==================== TYPOGRAPHY STYLES ==================== -->

    <!-- Logo Title (48px - Berkshire Swash) -->
    <Style x:Key="LogoTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/Berkshire_Swash/BerkshireSwash-Regular.ttf#Berkshire Swash" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource LogoTextBrush}" />
    </Style>

    <!-- Section Header (12px SemiBold Uppercase - Berkshire Swash) -->
    <Style x:Key="CardHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/Berkshire_Swash/BerkshireSwash-Regular.ttf#Berkshire Swash" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <!-- Stat Number (28px Bold) -->
    <Style x:Key="StatNumberStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Stat Label (10px Medium Uppercase) -->
    <Style x:Key="StatLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <!-- Body Text (14px Regular) -->
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Body Text SemiBold -->
    <Style x:Key="BodyTextSemiBoldStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Subtitle Text -->
    <Style x:Key="SubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <!-- Tag Text -->
    <Style x:Key="TagTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <!-- Destination City Style -->
    <Style x:Key="DestinationCityStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Destination Coordinates Style -->
    <Style x:Key="DestinationCoordsStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <!-- Alert Title Style -->
    <Style x:Key="AlertTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="LineHeight" Value="20" />
    </Style>

    <!-- Reindeer Name Style -->
    <Style x:Key="ReindeerNameStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="50" />
        <Setter Property="Foreground" Value="#FF3A3A3A" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Text on Cream Style -->
    <Style x:Key="TextOnCreamStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Foreground" Value="{StaticResource TextOnCreamBrush}" />
    </Style>

    <!-- Authorization Label -->
    <Style x:Key="AuthLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CharacterSpacing" Value="100" />

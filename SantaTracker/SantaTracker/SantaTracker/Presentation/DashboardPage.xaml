<Page x:Class="SantaTracker.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:local="using:SantaTracker.Controls"
      xmlns:models="using:SantaTracker.Models"
      Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <!-- Background gradient layer -->
        <Border>
            <Border.Background>
                <RadialGradientBrush Center="0.5,0.15" RadiusX="1" RadiusY="1">
                    <GradientStop Color="#FF3A5548" Offset="0" />
                    <GradientStop Color="#FF2D4A3D" Offset="0.5" />
                    <GradientStop Color="#FF1C332A" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>

        <!-- Floating emoji background layer (behind content) -->
        <local:FloatingGlyphs HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch" />

        <!-- Main content layer -->
        <ScrollViewer>
            <utu:AutoLayout Orientation="Vertical"
                        Spacing="16"
                        Padding="24,32,24,24"
                        MaxWidth="1200"
                        HorizontalAlignment="Center">

            <!-- ==================== GLOBAL HQ STATUS (Above Header) ==================== -->
            <Border CornerRadius="18"
                    Style="{StaticResource StatusBadgeStyle}"
                    HorizontalAlignment="Left"
                    Translation="0,0,6"
                    Margin="0,0,0,12">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <utu:AutoLayout Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <!-- Pulsing indicator dot -->
                    <Grid Width="8" Height="8">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource StatusGreenBrush}" />
                    </Grid>
                    <TextBlock Text="GLOBAL HQ STATUS: OPERATIONAL"
                               Style="{StaticResource TagTextStyle}" />
                </utu:AutoLayout>
            </Border>

            <!-- ==================== HEADER (70px height) ==================== -->
            <Grid Height="70">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo Section -->
                <utu:AutoLayout Orientation="Vertical"
                                Spacing="6"
                                VerticalAlignment="Center">
                    <utu:AutoLayout Orientation="Horizontal" Spacing="0">
                        <TextBlock Text="Santa" Style="{StaticResource LogoTitleStyle}" />
                        <TextBlock Text="Tracker" Style="{StaticResource LogoTitleStyle}"
                                   Foreground="{StaticResource AccentRedBrush}" />
                    </utu:AutoLayout>
                    <!-- Gradient underline -->
                    <Border Background="{StaticResource LogoUnderlineGradient}"
                            Height="3"
                            Width="180"
                            CornerRadius="2"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0" />
                    <TextBlock Text="FLIGHT TELEMETRY &amp; CHEER MONITORING"
                               Style="{StaticResource SubtitleStyle}"
                               Margin="0,4,0,0" />
                </utu:AutoLayout>

                <!-- User Profile Section -->
                <utu:AutoLayout Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="12"
                                VerticalAlignment="Center">
                    <!-- Text Stack (right-aligned) -->
                    <utu:AutoLayout Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="AUTHORIZATION"
                                   Style="{StaticResource AuthLabelStyle}"
                                   HorizontalAlignment="Right" />
                        <TextBlock Text="Kris Kringle"
                                   Style="{StaticResource UserNameStyle}"
                                   HorizontalAlignment="Right" />
                    </utu:AutoLayout>
                    <!-- Avatar -->
                    <Border Style="{StaticResource AvatarContainerStyle}">
                        <TextBlock Text="🎅"
                                   FontSize="28"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                </utu:AutoLayout>
            </Grid>

            <!-- ==================== ROW 2: MAP (6 cols) + DESTINATIONS (6 cols) - 322px ==================== -->
            <Grid ColumnSpacing="16" Height="322">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Live Sleigh Vector Card with MapsUI -->
                <Border Style="{StaticResource CardDarkStyle}"
                        Padding="0"
                        Translation="0,0,12">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <mvux:FeedView Source="{Binding CurrentDestination}">
                        <mvux:FeedView.ValueTemplate>
                            <DataTemplate>
                                <local:SantaMapView
                                    Latitude="{Binding Data.Latitude}"
                                    Longitude="{Binding Data.Longitude}" />
                            </DataTemplate>
                        </mvux:FeedView.ValueTemplate>
                        <mvux:FeedView.NoneTemplate>
                            <DataTemplate>
                                <local:SantaMapView />
                            </DataTemplate>
                        </mvux:FeedView.NoneTemplate>
                    </mvux:FeedView>
                </Border>

                <!-- Mission Log / Timeline - Aegis-Class Logistics Command Interface -->
                <Border Grid.Column="1"
                        Style="{StaticResource AegisTerminalCardStyle}"
                        Padding="0"
                        Translation="0,0,16">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>

                    <!-- Z-Level 1: Terminal Frame -->
                    <Grid RowDefinitions="55*,65*">

                        <!-- ========== HEADER ZONE (35%) - Static ========== -->
                        <Grid Padding="40,40,40,20">
                            <utu:AutoLayout Orientation="Vertical" Spacing="16">
                                <!-- Identity Badge -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Glowing Live Indicator -->
                                    <Grid Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <Ellipse Width="14" Height="14" Fill="{StaticResource AegisGlowRedBrush}" />
                                        <Ellipse Width="7" Height="7" Fill="{StaticResource AegisAlertRedBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Grid>

                                    <TextBlock Grid.Column="1"
                                               Text="MISSION LOG"
                                               Style="{StaticResource AegisHudLabelStyle}"
                                               VerticalAlignment="Center" />

                                    <Border Grid.Column="2"
                                            Background="#20c6433e"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock Text="LIVE"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource AegisAlertRedBrush}"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>

                                <!-- Telemetry Bar - bound to MissionStats for live updates -->
                                <mvux:FeedView Source="{Binding MissionStats}">
                                    <mvux:FeedView.ValueTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource DataBarBackgroundBrush}"
                                                    CornerRadius="8"
                                                    BorderBrush="{StaticResource AegisGlassBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid Height="52">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Stops -->
                                                    <utu:AutoLayout Orientation="Vertical" Spacing="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Data.TotalStops}"
                                                                   Style="{StaticResource AegisTelemetryValueStyle}"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="STOPS"
                                                                   Style="{StaticResource AegisTelemetryLabelStyle}"
                                                                   HorizontalAlignment="Center" />
                                                    </utu:AutoLayout>

                                                    <Border Grid.Column="1" Width="1" Height="28"
                                                            Background="{StaticResource BorderSubtleBrush}" VerticalAlignment="Center" />

                                                    <!-- Cities -->
                                                    <utu:AutoLayout Grid.Column="2" Orientation="Vertical" Spacing="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Data.TotalCities}"
                                                                   Style="{StaticResource AegisTelemetryValueStyle}"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="CITIES"
                                                                   Style="{StaticResource AegisTelemetryLabelStyle}"
                                                                   HorizontalAlignment="Center" />
                                                    </utu:AutoLayout>

                                                    <Border Grid.Column="3" Width="1" Height="28"
                                                            Background="{StaticResource BorderSubtleBrush}" VerticalAlignment="Center" />

                                                    <!-- Distance -->
                                                    <utu:AutoLayout Grid.Column="4" Orientation="Vertical" Spacing="2"
                                                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Data.FormattedDistance}"
                                                                   Style="{StaticResource AegisTelemetryValueStyle}"
                                                                   HorizontalAlignment="Center" />
                                                        <TextBlock Text="MILES"
                                                                   Style="{StaticResource AegisTelemetryLabelStyle}"
                                                                   HorizontalAlignment="Center" />
                                                    </utu:AutoLayout>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </mvux:FeedView.ValueTemplate>
                                </mvux:FeedView>

                                <!-- Primary Action Button -->
                                <Button Content="VIEW FULL ROUTE"
                                        HorizontalAlignment="Stretch"
                                        Height="40"
                                        Background="{StaticResource TimelineFutureLineBrush}"
                                        BorderBrush="{StaticResource AegisGlassBorderBrush}"
                                        BorderThickness="1"
                                        Foreground="{StaticResource AegisTextMutedBrush}"
                                        CornerRadius="8" />
                            </utu:AutoLayout>
                        </Grid>

                        <!-- ========== DATA STREAM ZONE (65%) - Fluid/Scrollable ========== -->
                        <Grid Grid.Row="1">
                            <!-- Scroll container -->
                            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                          Padding="40,0,40,20">
                                <mvux:FeedView Source="{Binding MissionLog}">
                                    <mvux:FeedView.ValueTemplate>
                                        <DataTemplate>
                                            <ItemsRepeater ItemsSource="{Binding Data}">
                                                <ItemsRepeater.Layout>
                                                    <StackLayout Spacing="0" />
                                                </ItemsRepeater.Layout>
                                                <ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="models:MissionLogEntry">
                                                        <local:TimelineEntryItem
                                                            City="{x:Bind City}"
                                                            CountryFlag="{x:Bind CountryFlag}"
                                                            ArrivalTime="{x:Bind ArrivalTime}"
                                                            FormattedPresents="{x:Bind FormattedPresents}"
                                                            IsCurrent="{x:Bind IsCurrent}"
                                                            IsVisited="{x:Bind IsVisited}"
                                                            IsNotVisited="{x:Bind IsNotVisited}"
                                                            ContentOpacity="{x:Bind ContentOpacity}" />
                                                    </DataTemplate>
                                                </ItemsRepeater.ItemTemplate>
                                            </ItemsRepeater>
                                        </DataTemplate>
                                    </mvux:FeedView.ValueTemplate>
                                </mvux:FeedView>
                            </ScrollViewer>

                            <!-- Top Edge Mask (32px gradient: transparent->card) -->
                            <Border Height="32" VerticalAlignment="Top" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF3A5548" Offset="0" />
                                        <GradientStop Color="#003A5548" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Bottom Edge Mask (32px gradient: transparent->card) -->
                            <Border Height="32" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#003A5548" Offset="0" />
                                        <GradientStop Color="#FF3A5548" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- Z-Level 3: Floating Scanline Animation -->
                        <Border Grid.RowSpan="2"
                                Height="1"
                                VerticalAlignment="Top"
                                IsHitTestVisible="False"
                                Opacity="0.3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Color="#00c6433e" Offset="0" />
                                    <GradientStop Color="#80c6433e" Offset="0.5" />
                                    <GradientStop Color="#00c6433e" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ScanlineTransform" Y="0" />
                            </Border.RenderTransform>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- ==================== ROW 3: STATISTICS (4 x 3 cols each) - 90px ==================== -->
            <mvux:FeedView Source="{Binding Telemetry}">
                <mvux:FeedView.ValueTemplate>
                    <DataTemplate>
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- PRESENTS -->
                            <Border Style="{StaticResource StatCardStyle}" Translation="0,0,6">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <utu:AutoLayout Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatIconContainerStyle}">
                                        <!-- Christmas Gift Box Icon -->
                                        <Viewbox Width="26" Height="26">
                                            <Canvas Width="24" Height="24">
                                                <!-- Ribbon vertical -->
                                                <Rectangle Canvas.Left="10.5" Canvas.Top="2" Width="3" Height="20" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Ribbon horizontal -->
                                                <Rectangle Canvas.Left="2" Canvas.Top="9" Width="20" Height="3" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Box bottom -->
                                                <Rectangle Canvas.Left="2" Canvas.Top="12" Width="20" Height="10" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentRedBrush}" />
                                                <!-- Box lid -->
                                                <Rectangle Canvas.Left="1" Canvas.Top="8" Width="22" Height="5" RadiusX="2" RadiusY="2" Fill="{StaticResource AccentBrightRedBrush}" />
                                                <!-- Bow left -->
                                                <Ellipse Canvas.Left="5" Canvas.Top="2" Width="6" Height="5" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Bow right -->
                                                <Ellipse Canvas.Left="13" Canvas.Top="2" Width="6" Height="5" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Bow center -->
                                                <Ellipse Canvas.Left="10" Canvas.Top="3" Width="4" Height="4" Fill="{StaticResource AccentOrangeBrush}" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <utu:AutoLayout Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="PRESENTS" Style="{StaticResource StatLabelStyle}" />
                                        <local:AnimatedNumber Value="{Binding Data.ToysDelivered}"
                                                              Format="N0"
                                                              TextStyle="{StaticResource StatNumberStyle}" />
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- SNACKS -->
                            <Border Grid.Column="1" Style="{StaticResource StatCardStyle}" Translation="0,0,6">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <utu:AutoLayout Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatIconContainerStyle}">
                                        <!-- Christmas Cookie Icon -->
                                        <Viewbox Width="26" Height="26">
                                            <Canvas Width="24" Height="24">
                                                <!-- Cookie base (round) -->
                                                <Ellipse Canvas.Left="2" Canvas.Top="2" Width="20" Height="20" Fill="{StaticResource AccentOrangeBrush}" />
                                                <!-- Cookie inner shadow -->
                                                <Ellipse Canvas.Left="4" Canvas.Top="4" Width="16" Height="16" Fill="#FFD4854A" />
                                                <!-- Chocolate chips -->
                                                <Ellipse Canvas.Left="6" Canvas.Top="6" Width="3" Height="3" Fill="#FF6B4423" />
                                                <Ellipse Canvas.Left="12" Canvas.Top="5" Width="3" Height="3" Fill="#FF6B4423" />
                                                <Ellipse Canvas.Left="15" Canvas.Top="10" Width="3" Height="3" Fill="#FF6B4423" />
                                                <Ellipse Canvas.Left="8" Canvas.Top="12" Width="3" Height="3" Fill="#FF6B4423" />
                                                <Ellipse Canvas.Left="11" Canvas.Top="15" Width="3" Height="3" Fill="#FF6B4423" />
                                                <Ellipse Canvas.Left="5" Canvas.Top="15" Width="2.5" Height="2.5" Fill="#FF6B4423" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <utu:AutoLayout Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="COOKIES" Style="{StaticResource StatLabelStyle}" />
                                        <local:AnimatedNumber Value="{Binding Data.CookiesEaten}"
                                                              Format="N0"
                                                              TextStyle="{StaticResource StatNumberStyle}" />
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- VISITS -->
                            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}" Translation="0,0,6">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <utu:AutoLayout Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatIconContainerStyle}">
                                        <!-- Christmas House Icon -->
                                        <Viewbox Width="26" Height="26">
                                            <Canvas Width="24" Height="24">
                                                <!-- Roof -->
                                                <Path Fill="{StaticResource AccentRedBrush}" Data="M 12,1 L 2,10 L 22,10 Z" />
                                                <!-- House body -->
                                                <Rectangle Canvas.Left="4" Canvas.Top="10" Width="16" Height="12" Fill="{StaticResource AccentOrangeBrush}" />
                                                <!-- Chimney -->
                                                <Rectangle Canvas.Left="16" Canvas.Top="3" Width="4" Height="7" Fill="{StaticResource AccentBrightRedBrush}" />
                                                <!-- Door -->
                                                <Rectangle Canvas.Left="10" Canvas.Top="14" Width="5" Height="8" RadiusX="2" RadiusY="2" Fill="#FF6B4423" />
                                                <!-- Window left -->
                                                <Rectangle Canvas.Left="5" Canvas.Top="12" Width="4" Height="4" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Window cross left -->
                                                <Rectangle Canvas.Left="6.75" Canvas.Top="12" Width="0.5" Height="4" Fill="#FF6B4423" />
                                                <Rectangle Canvas.Left="5" Canvas.Top="13.75" Width="4" Height="0.5" Fill="#FF6B4423" />
                                                <!-- Snow on roof -->
                                                <Path Fill="White" Data="M 12,0 L 3,9 L 4,9 L 12,2 L 20,9 L 21,9 Z" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <utu:AutoLayout Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="VISITS" Style="{StaticResource StatLabelStyle}" />
                                        <local:AnimatedNumber Value="{Binding Data.ToysDelivered, Converter={StaticResource VisitsMultiplierConverter}}"
                                                              Format="N0"
                                                              TextStyle="{StaticResource StatNumberStyle}" />
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- TRAVEL -->
                            <Border Grid.Column="3" Style="{StaticResource StatCardStyle}" Translation="0,0,6">
                                <Border.Shadow>
                                    <ThemeShadow />
                                </Border.Shadow>
                                <utu:AutoLayout Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                                    <Border Style="{StaticResource StatIconContainerStyle}">
                                        <!-- Christmas Sleigh Icon -->
                                        <Viewbox Width="26" Height="26">
                                            <Canvas Width="24" Height="24">
                                                <!-- Sleigh body -->
                                                <Path Fill="{StaticResource AccentRedBrush}" Data="M 3,10 L 5,8 L 20,8 L 22,10 L 22,14 L 3,14 Z" />
                                                <!-- Sleigh front curve -->
                                                <Path Fill="{StaticResource AccentBrightRedBrush}" Data="M 3,10 Q 1,12 2,16 L 4,16 L 4,14 L 3,14 Z" />
                                                <!-- Sleigh runner -->
                                                <Path Fill="{StaticResource AccentYellowBrush}" Data="M 2,17 Q 1,19 3,20 L 21,20 Q 23,19 22,17 L 4,17 Z" />
                                                <!-- Runner curve front -->
                                                <Path Fill="{StaticResource AccentYellowBrush}" Data="M 2,16 Q 0,18 2,20 L 4,20 Q 2,18 3,16 Z" />
                                                <!-- Gift 1 on sleigh -->
                                                <Rectangle Canvas.Left="6" Canvas.Top="4" Width="5" Height="5" RadiusX="1" RadiusY="1" Fill="{StaticResource StatusGreenBrush}" />
                                                <!-- Gift 2 on sleigh -->
                                                <Rectangle Canvas.Left="12" Canvas.Top="5" Width="4" Height="4" RadiusX="1" RadiusY="1" Fill="{StaticResource AccentYellowBrush}" />
                                                <!-- Gift 3 on sleigh -->
                                                <Rectangle Canvas.Left="17" Canvas.Top="4" Width="4" Height="5" RadiusX="1" RadiusY="1" Fill="{StaticResource AccentPinkBrush}" />
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                    <utu:AutoLayout Orientation="Vertical" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="TRAVEL" Style="{StaticResource StatLabelStyle}" />
                                        <utu:AutoLayout Orientation="Horizontal" Spacing="4">
                                            <local:AnimatedNumber Value="{Binding Data.DistanceTraveled}"
                                                                  Format="N0"
                                                                  TextStyle="{StaticResource StatNumberStyle}" />
                                            <TextBlock Text="KM"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Bottom"
                                                       Margin="0,0,0,4" />
                                        </utu:AutoLayout>
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </mvux:FeedView.ValueTemplate>
            </mvux:FeedView>

            <!-- ==================== ROW 4: AIR TRAFFIC + MAGIC-O-METER + CHEER SCANNER ==================== -->
            <Grid ColumnSpacing="16" MinHeight="220">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="4*" />
                </Grid.ColumnDefinitions>

                <!-- Air Traffic Card (Burgundy Theme) -->
                <Border Style="{StaticResource AirTrafficCardStyle}" Translation="0,0,12">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <utu:AutoLayout Orientation="Vertical" Spacing="14">
                        <!-- Header -->
                        <utu:AutoLayout Orientation="Horizontal" Spacing="10" Padding="0,0,0,0">
                            <TextBlock Text="✈️"
                                       FontSize="18"
                                       Foreground="{StaticResource AirTrafficIconBrush}"
                                       Opacity="0.9" />
                            <TextBlock Text="WEATHER ALERTS"
                                       Style="{StaticResource AirTrafficHeaderStyle}"
                                       VerticalAlignment="Center" />
                        </utu:AutoLayout>

                        <!-- Feed Items Container -->
                        <utu:AutoLayout Orientation="Vertical" Spacing="8">
                            <!-- Emergency Feed 1 -->
                            <Border Style="{StaticResource AirTrafficFeedStyle}">
                                <utu:AutoLayout Orientation="Vertical" Spacing="4">
                                    <TextBlock Text="WEATHER ADVISORY"
                                               Style="{StaticResource AirTrafficFeedLabelStyle}" />
                                    <TextBlock Text="Strong tailwinds over the Atlantic!"
                                               Style="{StaticResource AirTrafficFeedMessageStyle}" />
                                    <utu:AutoLayout Orientation="Horizontal" Spacing="6">
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="ATLANTIC"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="FAVORABLE"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- Emergency Feed 2 -->
                            <Border Style="{StaticResource AirTrafficFeedStyle}">
                                <utu:AutoLayout Orientation="Vertical" Spacing="4">
                                    <TextBlock Text="STORM WARNING"
                                               Style="{StaticResource AirTrafficFeedLabelStyle}" />
                                    <TextBlock Text="Heavy gingerbread snowfall ahead."
                                               Style="{StaticResource AirTrafficFeedMessageStyle}" />
                                    <utu:AutoLayout Orientation="Horizontal" Spacing="6">
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="SIBERIA"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="CAUTION"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- Emergency Feed 3 -->
                            <Border Style="{StaticResource AirTrafficFeedStyle}">
                                <utu:AutoLayout Orientation="Vertical" Spacing="4">
                                    <TextBlock Text="CLEAR SKIES"
                                               Style="{StaticResource AirTrafficFeedLabelStyle}" />
                                    <TextBlock Text="Perfect flying conditions detected."
                                               Style="{StaticResource AirTrafficFeedMessageStyle}" />
                                    <utu:AutoLayout Orientation="Horizontal" Spacing="6">
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="PACIFIC"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="OPTIMAL"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>

                            <!-- Emergency Feed 4 -->
                            <Border Style="{StaticResource AirTrafficFeedStyle}">
                                <utu:AutoLayout Orientation="Vertical" Spacing="4">
                                    <TextBlock Text="AURORA ALERT"
                                               Style="{StaticResource AirTrafficFeedLabelStyle}" />
                                    <TextBlock Text="Northern lights may affect nav systems."
                                               Style="{StaticResource AirTrafficFeedMessageStyle}" />
                                    <utu:AutoLayout Orientation="Horizontal" Spacing="6">
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="ARCTIC"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                        <Border Style="{StaticResource AirTrafficTagStyle}">
                                            <TextBlock Text="MONITOR"
                                                       Style="{StaticResource AirTrafficTagTextStyle}" />
                                        </Border>
                                    </utu:AutoLayout>
                                </utu:AutoLayout>
                            </Border>
                        </utu:AutoLayout>
                    </utu:AutoLayout>
                </Border>

                <!-- Magic-O-Meter - Christmas Magic Levels -->
                <local:MagicOMeter Grid.Column="1" Translation="0,0,16">
                    <local:MagicOMeter.Shadow>
                        <ThemeShadow />
                    </local:MagicOMeter.Shadow>
                </local:MagicOMeter>

                <!-- Naughty or Nice Scanner - North Pole Command Center Style -->
                <local:NaughtyNiceScanner Grid.Column="2" Translation="0,0,24">
                    <local:NaughtyNiceScanner.Shadow>
                        <ThemeShadow />
                    </local:NaughtyNiceScanner.Shadow>
                </local:NaughtyNiceScanner>
            </Grid>

            <!-- ==================== ROW 5: NORTH POLE FM + FLEET STATUS ==================== -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*" />
                    <ColumnDefinition Width="6*" />
                </Grid.ColumnDefinitions>

                <!-- North Pole FM Radio Station (Horizontal Layout) -->
                <local:NorthPoleFM Translation="0,0,16">
                    <local:NorthPoleFM.Shadow>
                        <ThemeShadow />
                    </local:NorthPoleFM.Shadow>
                </local:NorthPoleFM>

                <!-- Fleet Status -->
                <Border Grid.Column="1" Style="{StaticResource FleetContainerStyle}" Translation="0,0,12">
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    <utu:AutoLayout Orientation="Vertical" Spacing="16">
                        <!-- Header -->
                        <utu:AutoLayout Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🦌"
                                       FontSize="20"
                                       Foreground="{StaticResource AccentOrangeBrush}"
                                       Opacity="0.9" />
                            <TextBlock Text="FLEET STATUS"
                                       Style="{StaticResource FleetHeaderTextStyle}"
                                       VerticalAlignment="Center" />
                        </utu:AutoLayout>

                        <!-- Reindeer Grid (3 columns for compact layout) -->
                        <mvux:FeedView Source="{Binding ReindeerVitals}" HorizontalAlignment="Center">
                            <mvux:FeedView.ValueTemplate>
                                <DataTemplate>
                                    <ItemsRepeater HorizontalAlignment="Center" ItemsSource="{Binding Data}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout MinItemWidth="90"
                                                               MinItemHeight="85"
                                                               MinColumnSpacing="8"
                                                               MinRowSpacing="8"
                                                               MaximumRowsOrColumns="3"
                                                               ItemsJustification="Center" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:ReindeerStatus">
                                                <local:ReindeerCard ReindeerName="{x:Bind Name}"
                                                                    Emoji="{x:Bind Emoji}"
                                                                    EnergyLevel="{x:Bind EnergyLevel}"
                                                                    State="{x:Bind State}"
                                                                    IsLeader="{x:Bind IsLeader}" />
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                </DataTemplate>
                            </mvux:FeedView.ValueTemplate>
                        </mvux:FeedView>
                    </utu:AutoLayout>
                </Border>
            </Grid>

            <!-- Footer spacing -->
            <Border Height="20" />

        </utu:AutoLayout>
        </ScrollViewer>
    </Grid>

</Page>
<UserControl x:Class="SantaTracker.Controls.ReindeerCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:local="using:SantaTracker.Controls">

    <Border Style="{StaticResource FleetReindeerCardStyle}" Padding="8,6">
        <utu:AutoLayout Orientation="Vertical"
                        Spacing="0"
                        HorizontalAlignment="Stretch">

            <!-- Icon Container -->
            <Grid Height="32" HorizontalAlignment="Center" Margin="0,0,0,4">
                <!-- Icon based on reindeer type -->
                <TextBlock Text="&#x1F98C;"
                           FontSize="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Rudolph's red nose glow effect -->
                <Ellipse Width="22"
                         Height="22"
                         Fill="{StaticResource RudolphIconGradient}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         Visibility="{x:Bind IsRudolphVisibility, Mode=OneWay}" />
            </Grid>

            <!-- Name -->
            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                       Style="{StaticResource FleetReindeerNameStyle}"
                       FontSize="10"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />

            <!-- Energy Progress Bar (Border-based for reliable rendering) -->
            <Grid Width="60" Height="4" HorizontalAlignment="Center" Margin="0,0,0,4">
                <!-- Track background -->
                <Border Background="#30FFFFFF"
                        CornerRadius="2" />
                <!-- Fill (uses clip to show percentage) -->
                <Border Background="{StaticResource FleetProgressFillBrush}"
                        CornerRadius="2"
                        HorizontalAlignment="Left"
                        Width="{x:Bind ProgressWidthSmall, Mode=OneWay}" />
            </Grid>

            <!-- Bottom row: Percentage + Status -->
            <Grid Width="60" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Energy Percentage -->
                <TextBlock Text="{x:Bind EnergyText, Mode=OneWay}"
                           FontSize="9"
                           Foreground="#80FFFFFF"
                           VerticalAlignment="Center" />

                <!-- Status Text -->
                <TextBlock Grid.Column="1"
                           Text="{x:Bind StatusText, Mode=OneWay}"
                           FontSize="8"
                           Foreground="{x:Bind StatusColor, Mode=OneWay}"
                           VerticalAlignment="Center" />
            </Grid>

        </utu:AutoLayout>
    </Border>

</UserControl>
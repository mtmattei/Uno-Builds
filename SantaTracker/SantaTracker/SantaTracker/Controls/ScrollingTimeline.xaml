<UserControl x:Class="SantaTracker.Controls.ScrollingTimeline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <Grid>
        <!-- Timeline Track -->
        <Border Width="2"
                Background="{ThemeResource DestinationTimelineGradient}"
                HorizontalAlignment="Left"
                Margin="9,12,0,12" />

        <!-- Scrolling Items Container with clip -->
        <Border x:Name="ItemsContainer">
            <StackPanel x:Name="ItemsPanel" Spacing="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="ScrollTransform" Y="0" />
                </StackPanel.RenderTransform>
            </StackPanel>
        </Border>
    </Grid>

</UserControl>

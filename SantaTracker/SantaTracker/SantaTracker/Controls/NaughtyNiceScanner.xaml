<UserControl x:Class="SantaTracker.Controls.NaughtyNiceScanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <UserControl.Resources>
        <!-- Radar Sweep Animation -->
        <Storyboard x:Key="RadarSweepAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="RadarSweepRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360"
                             Duration="0:0:3" />
        </Storyboard>

        <!-- Center Pulse Animation -->
        <Storyboard x:Key="CenterPulseAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CenterPulseScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.3" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CenterPulseScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.3" Duration="0:0:1">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <!-- Main Container with Background -->
    <Border Background="{StaticResource ScannerBackgroundGradient}"
            CornerRadius="24"
            Padding="0">

        <!-- Glass Card -->
        <Border Background="{StaticResource ScannerCardGlassBrush}"
                BorderBrush="#26FFFFFF"
                BorderThickness="1"
                CornerRadius="24"
                Padding="24,20">

            <Grid>
                <!-- Corner Decorations -->
                <Canvas HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-12,-8,0,0">
                    <Border Width="20" Height="2" Background="{StaticResource ScannerGoldBrush}" Opacity="0.4" />
                    <Border Width="2" Height="20" Background="{StaticResource ScannerGoldBrush}" Opacity="0.4" />
                </Canvas>
                <Canvas HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-12,-8">
                    <Border Width="20" Height="2" Background="{StaticResource ScannerGoldBrush}" Opacity="0.4" Canvas.Left="-20" Canvas.Top="18" />
                    <Border Width="2" Height="20" Background="{StaticResource ScannerGoldBrush}" Opacity="0.4" Canvas.Left="-2" />
                </Canvas>

                <!-- Single Column Layout -->
                <utu:AutoLayout Orientation="Vertical" Spacing="16">

                    <!-- Header -->
                    <utu:AutoLayout Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Border Width="36" Height="36"
                                Background="{StaticResource ScannerLogoGradient}"
                                CornerRadius="8">
                            <TextBlock Text="🎅"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <utu:AutoLayout Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="Naughty or Nice"
                                       FontFamily="ms-appx:///Assets/Fonts/Berkshire_Swash/BerkshireSwash-Regular.ttf#Berkshire Swash"
                                       FontSize="16"
                                       Foreground="{StaticResource ScannerSnowBrush}" />
                            <TextBlock Text="Global List Scanner"
                                       FontSize="10"
                                       Foreground="{StaticResource ScannerSnowBrush}"
                                       Opacity="0.5" />
                        </utu:AutoLayout>
                    </utu:AutoLayout>

                    <!-- Radar Visualization (centered in container) -->
                    <Grid HorizontalAlignment="Stretch" Height="140">
                        <Grid Width="140" Height="140" HorizontalAlignment="Center">
                            <!-- Outer Ring -->
                        <Ellipse Width="140" Height="140"
                                 Stroke="{StaticResource ScannerIceBlueBrush}"
                                 StrokeThickness="2"
                                 Opacity="0.25"
                                 Fill="{StaticResource ScannerRadarGradient}" />

                        <!-- Middle Ring -->
                        <Ellipse Width="95" Height="95"
                                 Stroke="{StaticResource ScannerIceBlueBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />

                        <!-- Inner Ring -->
                        <Ellipse Width="50" Height="50"
                                 Stroke="{StaticResource ScannerIceBlueBrush}"
                                 StrokeThickness="1"
                                 Opacity="0.15"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />

                        <!-- Crosshairs -->
                        <Border Width="140" Height="1"
                                Background="{StaticResource ScannerIceBlueBrush}"
                                Opacity="0.1"
                                VerticalAlignment="Center" />
                        <Border Width="1" Height="140"
                                Background="{StaticResource ScannerIceBlueBrush}"
                                Opacity="0.1"
                                HorizontalAlignment="Center" />

                        <!-- Radar Sweep -->
                        <Border Width="140" Height="140"
                                CornerRadius="70"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border.RenderTransform>
                                <RotateTransform x:Name="RadarSweepRotation" Angle="0" CenterX="70" CenterY="70" />
                            </Border.RenderTransform>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0.5" EndPoint="0.5,0">
                                    <GradientStop Color="#00c41e3a" Offset="0" />
                                    <GradientStop Color="#66c41e3a" Offset="0.3" />
                                    <GradientStop Color="#00c41e3a" Offset="0.35" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>

                        <!-- Center Dot with Pulse -->
                        <Grid Width="18" Height="18"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                            <Ellipse Width="18" Height="18"
                                     Fill="{StaticResource ScannerCrimsonBrush}"
                                     Opacity="0.4">
                                <Ellipse.RenderTransform>
                                    <ScaleTransform x:Name="CenterPulseScale" ScaleX="1" ScaleY="1" CenterX="9" CenterY="9" />
                                </Ellipse.RenderTransform>
                            </Ellipse>
                            <Ellipse Width="10" Height="10"
                                     Fill="{StaticResource ScannerCrimsonBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <!-- Radar Blips -->
                        <Ellipse Width="5" Height="5"
                                 Fill="{StaticResource ScannerGoldBrush}"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Margin="38,30,0,0"
                                 Opacity="0.7" />
                        <Ellipse Width="4" Height="4"
                                 Fill="{StaticResource ScannerGoldBrush}"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="0,0,25,15"
                                 Opacity="0.5" />
                            <Ellipse Width="3" Height="3"
                                     Fill="{StaticResource ScannerGoldBrush}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Bottom"
                                     Margin="20,0,0,35"
                                     Opacity="0.6" />
                        </Grid>
                    </Grid>

                    <!-- Input Field -->
                    <TextBox x:Name="NameInput"
                             PlaceholderText="Enter child's name..."
                             Text="{x:Bind ChildName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             HorizontalAlignment="Stretch"
                             Padding="14,12"
                             FontSize="14"
                             Background="#14FFFFFF"
                             BorderBrush="#26FFFFFF"
                             BorderThickness="1"
                             CornerRadius="10"
                             Foreground="{StaticResource ScannerSnowBrush}"
                             PlaceholderForeground="#66FFFFFF" />

                    <!-- Scan Button -->
                    <Button x:Name="ScanButton"
                            Content="SCAN THE LIST"
                            HorizontalAlignment="Stretch"
                            Height="44"
                            Background="{StaticResource ScannerButtonGradient}"
                            Foreground="{StaticResource ScannerSnowBrush}"
                            FontWeight="SemiBold"
                            FontSize="13"
                            CornerRadius="10"
                            BorderThickness="0"
                            Click="OnScanClick" />

                    <!-- Status/Result Display -->
                    <Border x:Name="StatusContainer"
                            Background="#33000000"
                            BorderBrush="#14FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            MinHeight="60"
                            HorizontalAlignment="Stretch">
                        <TextBlock x:Name="IdleText"
                                   Text="Awaiting scan..."
                                   FontSize="13"
                                   Foreground="{StaticResource ScannerSnowBrush}"
                                   Opacity="0.4"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Result Display (hidden initially) -->
                    <Border x:Name="ResultContainer"
                            Background="#33000000"
                            BorderBrush="#14FFFFFF"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16"
                            Visibility="Collapsed"
                            HorizontalAlignment="Stretch">
                        <utu:AutoLayout Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <TextBlock x:Name="ResultIcon"
                                       Text="✨"
                                       FontSize="28"
                                       VerticalAlignment="Center" />
                            <utu:AutoLayout Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Name="ResultLabel"
                                           Text="NICE LIST"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource ScannerNiceGreenBrush}" />
                                <TextBlock x:Name="ResultMessage"
                                           Text="Outstanding kindness detected!"
                                           FontSize="11"
                                           Foreground="{StaticResource ScannerSnowBrush}"
                                           Opacity="0.6"
                                           TextWrapping="Wrap"
                                           MaxWidth="200" />
                            </utu:AutoLayout>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Footer -->
                    <Border BorderBrush="#14FFFFFF"
                            BorderThickness="0,1,0,0"
                            Padding="0,12,0,0">
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="10">
                            <Run Text="Powered by " Foreground="#4DFFFFFF" />
                            <Run Text="North Pole Analytics" Foreground="{StaticResource ScannerGoldBrush}" />
                            <Run Text="™" Foreground="#4DFFFFFF" />
                        </TextBlock>
                    </Border>

                </utu:AutoLayout>
            </Grid>
        </Border>
    </Border>

</UserControl>
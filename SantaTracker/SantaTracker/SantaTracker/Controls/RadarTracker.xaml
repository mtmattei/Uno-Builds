<UserControl x:Class="SantaTracker.Controls.RadarTracker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Width="280" Height="280">
        <!-- Outer glow -->
        <Ellipse Width="280" Height="280"
                 Fill="{ThemeResource SurfaceVariantBrush}"
                 Opacity="0.3" />

        <!-- Concentric rings -->
        <Ellipse Width="240" Height="240"
                 Stroke="{ThemeResource OutlineBrush}"
                 StrokeThickness="1"
                 Opacity="0.4"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <Ellipse Width="180" Height="180"
                 Stroke="{ThemeResource OutlineBrush}"
                 StrokeThickness="1"
                 Opacity="0.3"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <Ellipse Width="120" Height="120"
                 Stroke="{ThemeResource OutlineBrush}"
                 StrokeThickness="1"
                 Opacity="0.2"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <Ellipse Width="60" Height="60"
                 Stroke="{ThemeResource OutlineBrush}"
                 StrokeThickness="1"
                 Opacity="0.15"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <!-- Crosshairs -->
        <Line X1="0" Y1="140" X2="280" Y2="140"
              Stroke="{ThemeResource OutlineBrush}"
              StrokeThickness="1"
              Opacity="0.2" />

        <Line X1="140" Y1="0" X2="140" Y2="280"
              Stroke="{ThemeResource OutlineBrush}"
              StrokeThickness="1"
              Opacity="0.2" />

        <!-- Sweep line (animated) -->
        <Line x:Name="SweepLine"
              X1="140" Y1="140" X2="140" Y2="20"
              Stroke="{ThemeResource PrimaryBrush}"
              StrokeThickness="2"
              Opacity="0.6"
              RenderTransformOrigin="0.5,1">
            <Line.RenderTransform>
                <RotateTransform x:Name="SweepRotation" CenterX="0" CenterY="120" />
            </Line.RenderTransform>
        </Line>

        <!-- Santa position dot -->
        <Grid x:Name="SantaDotContainer"
              Width="24" Height="24"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <!-- Outer pulse ring -->
            <Ellipse x:Name="PulseRing"
                     Width="24" Height="24"
                     Fill="{ThemeResource SecondaryBrush}"
                     Opacity="0.3">
                <Ellipse.RenderTransform>
                    <CompositeTransform x:Name="PulseTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Inner dot -->
            <Ellipse Width="12" Height="12"
                     Fill="{ThemeResource SecondaryBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />

        </Grid>

        <!-- Coordinate display -->
        <Border Background="{ThemeResource SurfaceBrush}"
                CornerRadius="8"
                Padding="8,4"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                Opacity="0.9">
            <TextBlock x:Name="CoordinateText"
                       FontSize="10"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       FontFamily="Consolas"
                       Text="{x:Bind CoordinateDisplay, Mode=OneWay}" />
        </Border>

        <!-- Animations -->
        <Grid.Resources>
            <Storyboard x:Name="SweepAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="SweepRotation"
                                 Storyboard.TargetProperty="Angle"
                                 From="0" To="360"
                                 Duration="0:0:4" />
            </Storyboard>

            <Storyboard x:Name="PulseAnimation" RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetName="PulseTransform"
                                 Storyboard.TargetProperty="ScaleX"
                                 From="1" To="1.5"
                                 Duration="0:0:1"
                                 AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PulseTransform"
                                 Storyboard.TargetProperty="ScaleY"
                                 From="1" To="1.5"
                                 Duration="0:0:1"
                                 AutoReverse="True">
                    <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseInOut" />
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="PulseRing"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0.4" To="0.1"
                                 Duration="0:0:1"
                                 AutoReverse="True" />
            </Storyboard>
        </Grid.Resources>

    </Grid>

</UserControl>

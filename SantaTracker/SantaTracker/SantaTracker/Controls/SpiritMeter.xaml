<UserControl x:Class="SantaTracker.Controls.SpiritMeter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <utu:AutoLayout Orientation="Vertical" Spacing="12">

        <!-- Header -->
        <TextBlock Text="MAGIC SPIRIT"
                   Style="{StaticResource ChipLabelStyle}"
                   HorizontalAlignment="Center" />

        <!-- Circular gauge representation -->
        <Grid Width="120" Height="120" HorizontalAlignment="Center">

            <!-- Background ring -->
            <Ellipse Width="120" Height="120"
                     Stroke="{ThemeResource SurfaceVariantBrush}"
                     StrokeThickness="12"
                     Fill="Transparent" />

            <!-- Progress ring (simulated with arc) -->
            <Ellipse Width="120" Height="120"
                     Stroke="{ThemeResource TertiaryBrush}"
                     StrokeThickness="12"
                     Fill="Transparent"
                     StrokeDashArray="{x:Bind DashArray, Mode=OneWay}"
                     StrokeDashOffset="0"
                     RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                    <RotateTransform Angle="-90" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Center display -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Value, Mode=OneWay}"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="%"
                           FontSize="14"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,-4,0,0" />
            </StackPanel>

            <!-- Sparkle icon at top -->
            <FontIcon Glyph="&#xE734;"
                      FontSize="20"
                      Foreground="{ThemeResource TertiaryBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Top"
                      Margin="0,-4,0,0" />

        </Grid>

        <!-- Status text -->
        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                   Style="{StaticResource BodySmallTextBlockStyle}"
                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center" />

    </utu:AutoLayout>

</UserControl>

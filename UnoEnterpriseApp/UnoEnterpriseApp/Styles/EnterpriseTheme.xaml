<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Definitions -->
    <Color x:Key="PrimaryColor">#667EEA</Color>
    <Color x:Key="SecondaryColor">#764BA2</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="BackgroundColor">#F8F9FA</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="HeaderBackgroundColor">#F8FAFC</Color>
    <Color x:Key="BorderColor">#E2E8F0</Color>
    <Color x:Key="TextPrimaryColor">#1E293B</Color>
    <Color x:Key="TextSecondaryColor">#475569</Color>
    <Color x:Key="TextMutedColor">#64748B</Color>
    <Color x:Key="TextOnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="SuccessBackgroundColor">#DCFCE7</Color>
    <Color x:Key="SuccessTextColor">#16A34A</Color>
    <Color x:Key="WarningBackgroundColor">#FEF3C7</Color>
    <Color x:Key="WarningTextColor">#D97706</Color>
    <Color x:Key="ErrorBackgroundColor">#FEE2E2</Color>
    <Color x:Key="ErrorTextColor">#DC2626</Color>
    <Color x:Key="InactiveBackgroundColor">#F3F4F6</Color>
    <Color x:Key="InactiveTextColor">#6B7280</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackgroundColor}"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>

    <!-- Status-specific brushes -->
    <SolidColorBrush x:Key="SuccessBackgroundBrush" Color="{StaticResource SuccessBackgroundColor}"/>
    <SolidColorBrush x:Key="SuccessTextBrush" Color="{StaticResource SuccessTextColor}"/>
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="{StaticResource WarningBackgroundColor}"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="{StaticResource WarningTextColor}"/>
    <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="{StaticResource ErrorBackgroundColor}"/>
    <SolidColorBrush x:Key="ErrorTextBrush" Color="{StaticResource ErrorTextColor}"/>
    <SolidColorBrush x:Key="InactiveBackgroundBrush" Color="{StaticResource InactiveBackgroundColor}"/>
    <SolidColorBrush x:Key="InactiveTextBrush" Color="{StaticResource InactiveTextColor}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PrimaryColor}" Offset="0"/>
        <GradientStop Color="{StaticResource SecondaryColor}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Typography -->
    <x:Double x:Key="TitleFontSize">24</x:Double>
    <x:Double x:Key="SubtitleFontSize">18</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>
    <x:Double x:Key="CaptionFontSize">12</x:Double>
    <x:Double x:Key="SmallFontSize">11</x:Double>

    <!-- Spacing -->
    <x:Double x:Key="SmallSpacing">4</x:Double>
    <x:Double x:Key="MediumSpacing">8</x:Double>
    <x:Double x:Key="LargeSpacing">16</x:Double>
    <x:Double x:Key="XLargeSpacing">24</x:Double>

    <!-- Corner Radius -->
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="MediumCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="LargeCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="TopCornerRadius">12,12,0,0</CornerRadius>

    <!-- Window Control Button Style -->
    <Style x:Key="WindowControlButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
    </Style>

    <!-- Navigation Item Style -->
    <Style x:Key="NavigationItemStyle" TargetType="ListViewItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Margin" Value="8,2"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- Filter CheckBox Style -->
    <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0,4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- Tab RadioButton Style -->
    <Style x:Key="TabRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CheckStates">
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BottomBorder"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="#667EEA" Duration="0:0:0.2"/>
                                        <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                        Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)"
                                                        To="#667EEA" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BottomBorder"
                                                         Storyboard.TargetProperty="(Border.BorderThickness).(Thickness.Bottom)"
                                                         To="3" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Unchecked">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BottomBorder"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BackgroundBorder"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#F8F9FA" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Border x:Name="BackgroundBorder"
                                Background="{TemplateBinding Background}"/>

                        <Border x:Name="BottomBorder"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,0"
                                VerticalAlignment="Bottom"/>

                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TabView Style -->
    <Style x:Key="EnterpriseTabViewStyle" TargetType="TabView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsAddTabButtonVisible" Value="False"/>
        <Setter Property="TabWidthMode" Value="SizeToContent"/>
    </Style>

    <!-- TabViewItem Style -->
    <Style x:Key="EnterpriseTabViewItemStyle" TargetType="TabViewItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="IsClosable" Value="False"/>
    </Style>

    <!-- Primary Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource HeaderGradientBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- Secondary Button Style -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#F1F5F9"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource LargeCornerRadius}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="{StaticResource XLargeSpacing}"/>
    </Style>

    <!-- TextBox Style -->
    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- ComboBox Style -->
    <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Data Grid Header Style -->
    <Style x:Key="DataGridHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="16,12"/>
    </Style>

    <!-- Data Grid Cell Text Style -->
    <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource BodyFontSize}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Status Badge Style -->
    <Style x:Key="StatusBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
    </Style>

    <!-- Section Header Style -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource CaptionFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="CharacterSpacing" Value="50"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- Form Label Style -->
    <Style x:Key="FormLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- Menu Bar Item Style -->
    <Style x:Key="MenuBarItemStyle" TargetType="MenuBarItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Menu Flyout Item Style -->
    <Style x:Key="MenuFlyoutItemStyle" TargetType="MenuFlyoutItem">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="Padding" Value="16,8"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- Enhanced Toolbar Style -->
    <Style x:Key="EnhancedToolbarStyle" TargetType="CommandBar">
        <Setter Property="Background" Value="#FAFBFC"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="MinHeight" Value="60"/>
        <Setter Property="DefaultLabelPosition" Value="Right"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>

    <!-- Enhanced AppBar Button Style -->
    <Style x:Key="EnhancedAppBarButtonStyle" TargetType="AppBarButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="MinWidth" Value="80"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- App Bar Button Style -->
    <Style x:Key="ModernAppBarButtonStyle" TargetType="AppBarButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="4,0"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="MinWidth" Value="60"/>
        <Setter Property="MinHeight" Value="48"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="CornerRadius" Value="{StaticResource MediumCornerRadius}"/>
    </Style>

    <!-- App Bar Separator Style -->
    <Style x:Key="ModernAppBarSeparatorStyle" TargetType="AppBarSeparator">
        <Setter Property="Foreground" Value="{StaticResource BorderBrush}"/>
        <Setter Property="Margin" Value="8,8"/>
    </Style>

    <!-- ============================================ -->
    <!-- Modern Toolbar Styles - Colorful Icons -->
    <!-- ============================================ -->

    <!-- Toolbar Icon Colors -->
    <Color x:Key="ToolbarBackgroundColor">#FAFBFC</Color>
    <Color x:Key="ToolbarBorderColor">#E1E4E8</Color>
    <Color x:Key="ToolbarSeparatorColor">#D0D7DE</Color>
    <Color x:Key="NewIconColor">#5B47D9</Color>
    <Color x:Key="OpenIconColor">#F5A623</Color>
    <Color x:Key="SaveIconColor">#7B68EE</Color>
    <Color x:Key="CutIconColor">#E74C3C</Color>
    <Color x:Key="CopyIconColor">#9B59B6</Color>
    <Color x:Key="PasteIconColor">#E91E63</Color>
    <Color x:Key="UndoIconColor">#3498DB</Color>
    <Color x:Key="RedoIconColor">#2196F3</Color>
    <Color x:Key="FindIconColor">#16A085</Color>
    <Color x:Key="ExportIconColor">#00BCD4</Color>
    <Color x:Key="PrintIconColor">#795548</Color>
    <Color x:Key="FilterIconColor">#9333EA</Color>

    <!-- Toolbar Brushes -->
    <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="{StaticResource ToolbarBackgroundColor}"/>
    <SolidColorBrush x:Key="ToolbarBorderBrush" Color="{StaticResource ToolbarBorderColor}"/>
    <SolidColorBrush x:Key="ToolbarSeparatorBrush" Color="{StaticResource ToolbarSeparatorColor}"/>

    <!-- Modern Toolbar Style -->
    <Style x:Key="ModernToolbarStyle" TargetType="CommandBar">
        <Setter Property="Background" Value="{StaticResource ToolbarBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ToolbarBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="DefaultLabelPosition" Value="Right"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="OverflowButtonVisibility" Value="Auto"/>
        <Setter Property="IsDynamicOverflowEnabled" Value="True"/>
    </Style>

    <!-- Modern Toolbar Separator Style -->
    <Style x:Key="ModernToolbarSeparatorStyle" TargetType="AppBarSeparator">
        <Setter Property="Background" Value="{StaticResource ToolbarSeparatorBrush}"/>
        <Setter Property="Width" Value="1"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Margin" Value="8,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>


<Page x:Class="SpaceXhistory.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SpaceXhistory.Views"
      Background="#000000">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="24">

            <!-- Logo -->
            <Image Source="https://upload.wikimedia.org/wikipedia/commons/thumb/d/de/SpaceX-Logo.svg/1280px-SpaceX-Logo.svg.png"
                   Height="50"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,20" />

            <!-- Next Launch Section -->
            <Border Background="#1a1a1a"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="NEXT LAUNCH"
                               Foreground="#adb5bd"
                               FontSize="12"
                               FontWeight="SemiBold" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="8"
                                Background="#2a2a2a"
                                Width="100"
                                Height="100">
                            <Image Source="{Binding NextLaunch.links.patch.small, FallbackValue='https://i.imgur.com/8pgWyf4.png', TargetNullValue='https://i.imgur.com/8pgWyf4.png'}"
                                   Stretch="Uniform"
                                   Margin="8" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="{Binding NextLaunch.name}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />

                            <TextBlock Foreground="#adb5bd"
                                       FontSize="14">
                                <Run Text="{Binding NextLaunch.date_local}" />
                            </TextBlock>

                            <Border Background="{Binding NextLaunch.StatusColor}"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding NextLaunch.Status}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Button Content="Watch the launch"
                            HorizontalAlignment="Stretch"
                            Click="OnNextLaunchTapped"
                            Background="#3498db"
                            Foreground="White"
                            Padding="16,12"
                            CornerRadius="8" />
                </StackPanel>
            </Border>

            <!-- Latest Launch Section -->
            <Border Background="#1a1a1a"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="LATEST LAUNCH"
                               Foreground="#adb5bd"
                               FontSize="12"
                               FontWeight="SemiBold" />

                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border CornerRadius="8"
                                Background="#2a2a2a"
                                Width="100"
                                Height="100">
                            <Image Source="{Binding LatestLaunch.links.patch.small, FallbackValue='https://i.imgur.com/8pgWyf4.png', TargetNullValue='https://i.imgur.com/8pgWyf4.png'}"
                                   Stretch="Uniform"
                                   Margin="8" />
                        </Border>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <TextBlock Text="{Binding LatestLaunch.name}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap" />

                            <TextBlock Foreground="#adb5bd"
                                       FontSize="14">
                                <Run Text="{Binding LatestLaunch.date_local}" />
                            </TextBlock>

                            <Border Background="{Binding LatestLaunch.StatusColor}"
                                    CornerRadius="4"
                                    Padding="8,4"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding LatestLaunch.Status}"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Button Content="Watch the launch"
                            HorizontalAlignment="Stretch"
                            Click="OnLatestLaunchTapped"
                            Background="#3498db"
                            Foreground="White"
                            Padding="16,12"
                            CornerRadius="8" />
                </StackPanel>
            </Border>

            <!-- Tesla Roadster Section -->
            <Border Background="#1a1a1a"
                    CornerRadius="16"
                    Padding="20">
                <StackPanel Spacing="16">
                    <TextBlock Text="TESLA ROADSTER STATUS"
                               Foreground="#adb5bd"
                               FontSize="12"
                               FontWeight="SemiBold" />

                    <Grid ColumnSpacing="8"
                          RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Earth Distance -->
                        <Border Grid.Column="0"
                                Background="#2a2a2a"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Earth distance"
                                           Foreground="#adb5bd"
                                           FontSize="10"
                                           TextAlignment="Center" />
                                <TextBlock Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding RoadsterInfo.earth_distance_km}" />
                                    <Run Text=" km" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Mars Distance -->
                        <Border Grid.Column="1"
                                Background="#2a2a2a"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Mars distance"
                                           Foreground="#adb5bd"
                                           FontSize="10"
                                           TextAlignment="Center" />
                                <TextBlock Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding RoadsterInfo.mars_distance_km}" />
                                    <Run Text=" km" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Speed -->
                        <Border Grid.Column="2"
                                Background="#2a2a2a"
                                CornerRadius="8"
                                Padding="12">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Speed"
                                           Foreground="#adb5bd"
                                           FontSize="10"
                                           TextAlignment="Center" />
                                <TextBlock Foreground="White"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap">
                                    <Run Text="{Binding RoadsterInfo.speed_kph}" />
                                    <Run Text=" km/h" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Links -->
                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="16"
                                    Margin="0,8,0,0">
                            <Button Content="Video"
                                    Click="OnRoadsterVideoTapped"
                                    Background="#e74c3c"
                                    Foreground="White"
                                    Padding="24,10"
                                    CornerRadius="8" />
                            <Button Content="Wikipedia"
                                    Click="OnRoadsterWikiTapped"
                                    Background="#3498db"
                                    Foreground="White"
                                    Padding="24,10"
                                    CornerRadius="8" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>

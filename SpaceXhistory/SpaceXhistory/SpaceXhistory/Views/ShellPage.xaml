<Page x:Class="SpaceXhistory.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SpaceXhistory.Views"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="#000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Content Area -->
        <Frame x:Name="ContentFrame" />

        <!-- Bottom TabBar -->
        <utu:TabBar Grid.Row="1"
                    x:Name="BottomTabBar"
                    SelectedIndex="0"
                    SelectionChanged="OnTabSelectionChanged"
                    Background="#1a1a1a">
            <utu:TabBarItem Content="Home">
                <utu:TabBarItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem Content="Upcoming">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE8F4;" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
            <utu:TabBarItem Content="Past">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE81C;" />
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>
        </utu:TabBar>
    </Grid>
</Page>

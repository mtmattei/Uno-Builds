<Page x:Class="SpaceXhistory.Views.UpcomingLaunchesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SpaceXhistory.Views"
      Background="#000000">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Padding="20" Spacing="16">
            <Image Source="https://upload.wikimedia.org/wikipedia/commons/thumb/d/de/SpaceX-Logo.svg/1280px-SpaceX-Logo.svg.png"
                   Height="40"
                   Stretch="Uniform"
                   HorizontalAlignment="Center" />
            <TextBlock Text="UPCOMING LAUNCHES"
                       Foreground="#adb5bd"
                       FontSize="14"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Launch List -->
        <ListView Grid.Row="1"
                  x:Name="LaunchList"
                  ItemsSource="{Binding NextLaunches}"
                  SelectionMode="Single"
                  Background="Transparent"
                  Padding="16,0"
                  ItemClick="OnLaunchItemClick"
                  IsItemClickEnabled="True">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Margin" Value="0,0,0,12" />
                    <Setter Property="Padding" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#1a1a1a"
                            CornerRadius="12"
                            Padding="16">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border CornerRadius="8"
                                    Background="#2a2a2a"
                                    Width="80"
                                    Height="80">
                                <Image Source="{Binding links.patch.small, FallbackValue='https://i.imgur.com/8pgWyf4.png', TargetNullValue='https://i.imgur.com/8pgWyf4.png'}"
                                       Stretch="Uniform"
                                       Margin="8" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                <TextBlock Text="{Binding name}"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           MaxLines="2" />

                                <TextBlock Foreground="#adb5bd"
                                           FontSize="13">
                                    <Run Text="{Binding date_local}" />
                                </TextBlock>

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Border Background="{Binding StatusColor}"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="SemiBold" />
                                    </Border>

                                    <Border Background="#3498db"
                                            CornerRadius="4"
                                            Padding="8,4">
                                        <TextBlock Text="Watch"
                                                   Foreground="White"
                                                   FontSize="11" />
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>

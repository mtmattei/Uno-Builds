<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark space theme - Material color token overrides -->

    <!-- Surface colors -->
    <Color x:Key="SurfaceDark">#000000</Color>
    <Color x:Key="SurfaceLight">#121212</Color>
    <Color x:Key="OnSurfaceDark">#FFFFFF</Color>
    <Color x:Key="OnSurfaceLight">#1C1B1F</Color>
    <Color x:Key="SurfaceVariantDark">#1A1A2E</Color>
    <Color x:Key="SurfaceVariantLight">#E7E0EC</Color>
    <Color x:Key="OnSurfaceVariantDark">#CAC4D0</Color>
    <Color x:Key="OnSurfaceVariantLight">#49454F</Color>

    <!-- Background colors -->
    <Color x:Key="BackgroundDark">#000000</Color>
    <Color x:Key="BackgroundLight">#FFFBFE</Color>
    <Color x:Key="OnBackgroundDark">#FFFFFF</Color>
    <Color x:Key="OnBackgroundLight">#1C1B1F</Color>

    <!-- Primary (SpaceX blue-accent) -->
    <Color x:Key="PrimaryDark">#3498DB</Color>
    <Color x:Key="PrimaryLight">#2980B9</Color>
    <Color x:Key="OnPrimaryDark">#FFFFFF</Color>
    <Color x:Key="OnPrimaryLight">#FFFFFF</Color>
    <Color x:Key="PrimaryContainerDark">#1A3A5C</Color>
    <Color x:Key="PrimaryContainerLight">#D4E4F7</Color>
    <Color x:Key="OnPrimaryContainerDark">#D4E4F7</Color>
    <Color x:Key="OnPrimaryContainerLight">#0D1F30</Color>

    <!-- Secondary -->
    <Color x:Key="SecondaryDark">#9B9B9B</Color>
    <Color x:Key="SecondaryLight">#625B71</Color>
    <Color x:Key="OnSecondaryDark">#FFFFFF</Color>
    <Color x:Key="OnSecondaryLight">#FFFFFF</Color>
    <Color x:Key="SecondaryContainerDark">#2A2A2A</Color>
    <Color x:Key="SecondaryContainerLight">#E8DEF8</Color>
    <Color x:Key="OnSecondaryContainerDark">#E8DEF8</Color>
    <Color x:Key="OnSecondaryContainerLight">#1D192B</Color>

    <!-- Tertiary -->
    <Color x:Key="TertiaryDark">#2ECC71</Color>
    <Color x:Key="TertiaryLight">#7D5260</Color>
    <Color x:Key="OnTertiaryDark">#FFFFFF</Color>
    <Color x:Key="OnTertiaryLight">#FFFFFF</Color>

    <!-- Error -->
    <Color x:Key="ErrorDark">#E74C3C</Color>
    <Color x:Key="ErrorLight">#B3261E</Color>
    <Color x:Key="OnErrorDark">#FFFFFF</Color>
    <Color x:Key="OnErrorLight">#FFFFFF</Color>

    <!-- Outline -->
    <Color x:Key="OutlineDark">#3A3A3A</Color>
    <Color x:Key="OutlineLight">#79747E</Color>
    <Color x:Key="OutlineVariantDark">#2A2A2A</Color>
    <Color x:Key="OutlineVariantLight">#CAC4D0</Color>

    <!-- Override application page background -->
    <StaticResource x:Key="ApplicationPageBackgroundThemeBrush" ResourceKey="SurfaceDark" />

</ResourceDictionary>

<UserControl x:Class="Olea.Presentation.Shell"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Olea.Presentation"
             xmlns:uen="using:Uno.Extensions.Navigation.UI"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:um="using:Uno.Material">

  <Grid Background="{StaticResource OleaBackgroundBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Top Navigation Bar -->
    <Border Background="{StaticResource OleaSurfaceBrush}"
            BorderBrush="{StaticResource OleaBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- OLEA. Logo -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="OLEA"
                     Style="{StaticResource OleaLogoStyle}" />
          <TextBlock Text="."
                     FontFamily="{StaticResource OleaHeadingFont}"
                     FontSize="22"
                     FontWeight="Bold"
                     FontStyle="Italic"
                     Foreground="{StaticResource OleaAccentBrush}"
                     Margin="-2,0,0,0" />
        </StackPanel>

        <!-- Nav Links -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="24"
                    VerticalAlignment="Center">
          <TextBlock x:Name="NavNewTasting"
                     Text="New Tasting"
                     Style="{StaticResource OleaNavLinkStyle}"
                     Foreground="{StaticResource OleaPrimaryBrush}"
                     Tapped="OnNavNewTastingTapped" />
          <TextBlock x:Name="NavJournal"
                     Text="Journal"
                     Style="{StaticResource OleaNavLinkStyle}"
                     Tapped="OnNavJournalTapped" />
          <TextBlock x:Name="NavExplore"
                     Text="Explore"
                     Style="{StaticResource OleaNavLinkStyle}"
                     Tapped="OnNavExploreTapped" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- Main Content -->
    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Padding="24,32" Spacing="24" MaxWidth="480" HorizontalAlignment="Center">

        <!-- Page Header -->
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <TextBlock x:Name="PageTitle"
                     Text="Record a Tasting"
                     Style="{StaticResource OleaPageTitleStyle}" />
          <TextBlock x:Name="PageSubtitle"
                     Text="Capture every nuance of your olive oil experience"
                     Style="{StaticResource OleaPageSubtitleStyle}" />
        </StackPanel>

        <!-- Tab Pills -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="8">
          <Button x:Name="TabNewTasting"
                  Content="New Tasting"
                  Click="OnTabNewTastingClick"
                  Background="{StaticResource OleaPrimaryBrush}"
                  Foreground="{StaticResource OleaBackgroundBrush}"
                  FontFamily="{StaticResource OleaBodyFont}"
                  FontSize="10"
                  CornerRadius="100"
                  Padding="20,10"
                  BorderThickness="1.5"
                  BorderBrush="{StaticResource OleaPrimaryBrush}" />
          <Button x:Name="TabJournal"
                  Content="My Journal"
                  Click="OnTabJournalClick"
                  Background="Transparent"
                  Foreground="{StaticResource OleaTextMutedBrush}"
                  FontFamily="{StaticResource OleaBodyFont}"
                  FontSize="10"
                  CornerRadius="100"
                  Padding="20,10"
                  BorderThickness="1.5"
                  BorderBrush="{StaticResource OleaBorderBrush}" />
          <Button x:Name="TabExplore"
                  Content="Explore Regions"
                  Click="OnTabExploreClick"
                  Background="Transparent"
                  Foreground="{StaticResource OleaTextMutedBrush}"
                  FontFamily="{StaticResource OleaBodyFont}"
                  FontSize="10"
                  CornerRadius="100"
                  Padding="20,10"
                  BorderThickness="1.5"
                  BorderBrush="{StaticResource OleaBorderBrush}" />
        </StackPanel>

        <!-- Tab Content Panels -->
        <Grid>
          <!-- New Tasting Content -->
          <StackPanel x:Name="NewTastingPanel" Visibility="Visible" Spacing="24">
            <local:NewTastingView />
            <local:FlavorWheelView />
          </StackPanel>

          <!-- Journal Content -->
          <StackPanel x:Name="JournalPanel" Visibility="Collapsed">
            <local:JournalView />
          </StackPanel>

          <!-- Explore Content -->
          <StackPanel x:Name="ExplorePanel" Visibility="Collapsed">
            <local:ExploreView />
          </StackPanel>
        </Grid>

      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>

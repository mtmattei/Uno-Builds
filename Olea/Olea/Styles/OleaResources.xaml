<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- OLEA CUSTOM COLORS & BRUSHES                          -->
  <!-- ══════════════════════════════════════════════════════ -->

  <!-- Core Palette -->
  <Color x:Key="OleaPrimaryColor">#2D3B2D</Color>
  <Color x:Key="OleaPrimaryVariantColor">#4A5D3A</Color>
  <Color x:Key="OleaAccentColor">#C4A44A</Color>
  <Color x:Key="OleaAccentLightColor">#D4BC6A</Color>
  <Color x:Key="OleaAccentMutedColor">#B89B3E</Color>
  <Color x:Key="OleaBackgroundColor">#FAF6EE</Color>
  <Color x:Key="OleaSurfaceColor">#FDFCF9</Color>
  <Color x:Key="OleaCreamDarkColor">#F0E8D8</Color>

  <!-- Text -->
  <Color x:Key="OleaCharcoalColor">#1A1A18</Color>
  <Color x:Key="OleaTextMutedColor">#6B6560</Color>
  <Color x:Key="OleaLabelColor">#8B7355</Color>
  <Color x:Key="OleaBrownColor">#5C4A2A</Color>
  <Color x:Key="OleaPlaceholderColor">#B0A898</Color>

  <!-- Border -->
  <Color x:Key="OleaBorderColor">#E5DDD0</Color>

  <!-- Semantic / Intensity -->
  <Color x:Key="OleaFruityColor">#6B9B4A</Color>
  <Color x:Key="OleaBitterColor">#C49B3A</Color>
  <Color x:Key="OleaPungentColor">#B85A4A</Color>

  <!-- Flavor Wheel Categories -->
  <Color x:Key="OleaFlavorFruityColor">#6B9B4A</Color>
  <Color x:Key="OleaFlavorFloralColor">#9B7BB5</Color>
  <Color x:Key="OleaFlavorHerbalColor">#5A8B6A</Color>
  <Color x:Key="OleaFlavorNuttyColor">#A67B5B</Color>
  <Color x:Key="OleaFlavorPepperyColor">#B85A4A</Color>
  <Color x:Key="OleaFlavorBitterColor">#C49B3A</Color>
  <Color x:Key="OleaFlavorButteryColor">#D4A85A</Color>
  <Color x:Key="OleaFlavorWoodyColor">#7A6B5A</Color>

  <!-- Brushes -->
  <SolidColorBrush x:Key="OleaPrimaryBrush" Color="{StaticResource OleaPrimaryColor}" />
  <SolidColorBrush x:Key="OleaPrimaryVariantBrush" Color="{StaticResource OleaPrimaryVariantColor}" />
  <SolidColorBrush x:Key="OleaAccentBrush" Color="{StaticResource OleaAccentColor}" />
  <SolidColorBrush x:Key="OleaAccentLightBrush" Color="{StaticResource OleaAccentLightColor}" />
  <SolidColorBrush x:Key="OleaAccentMutedBrush" Color="{StaticResource OleaAccentMutedColor}" />
  <SolidColorBrush x:Key="OleaBackgroundBrush" Color="{StaticResource OleaBackgroundColor}" />
  <SolidColorBrush x:Key="OleaSurfaceBrush" Color="{StaticResource OleaSurfaceColor}" />
  <SolidColorBrush x:Key="OleaCreamDarkBrush" Color="{StaticResource OleaCreamDarkColor}" />
  <SolidColorBrush x:Key="OleaOnBackgroundBrush" Color="{StaticResource OleaCharcoalColor}" />
  <SolidColorBrush x:Key="OleaTextMutedBrush" Color="{StaticResource OleaTextMutedColor}" />
  <SolidColorBrush x:Key="OleaLabelBrush" Color="{StaticResource OleaLabelColor}" />
  <SolidColorBrush x:Key="OleaPlaceholderBrush" Color="{StaticResource OleaPlaceholderColor}" />
  <SolidColorBrush x:Key="OleaBorderBrush" Color="{StaticResource OleaBorderColor}" />
  <SolidColorBrush x:Key="OleaFruityBrush" Color="{StaticResource OleaFruityColor}" />
  <SolidColorBrush x:Key="OleaBitterBrush" Color="{StaticResource OleaBitterColor}" />
  <SolidColorBrush x:Key="OleaPungentBrush" Color="{StaticResource OleaPungentColor}" />
  <SolidColorBrush x:Key="OleaStarActiveBrush" Color="{StaticResource OleaAccentColor}" />
  <SolidColorBrush x:Key="OleaStarInactiveBrush" Color="{StaticResource OleaBorderColor}" />

  <!-- Card gradient: olive → gold (used as start/end for LinearGradientBrush in code) -->
  <Color x:Key="OleaCardGradientStartColor">#4A5D3A</Color>
  <Color x:Key="OleaCardGradientEndColor">#C4A44A</Color>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- TYPOGRAPHY                                             -->
  <!-- ══════════════════════════════════════════════════════ -->

  <!-- Font Families (Figma: Cormorant Garamond, Playfair Display, DM Sans) -->
  <!-- Using system serif/sans-serif fallbacks for v1; embed custom fonts in v2 -->
  <FontFamily x:Key="OleaDisplayFont">Georgia</FontFamily>
  <FontFamily x:Key="OleaHeadingFont">Georgia</FontFamily>
  <FontFamily x:Key="OleaBodyFont">Segoe UI</FontFamily>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- SPACING SCALE (base unit 4px)                          -->
  <!-- ══════════════════════════════════════════════════════ -->

  <x:Double x:Key="OleaSpacing4">4</x:Double>
  <x:Double x:Key="OleaSpacing8">8</x:Double>
  <x:Double x:Key="OleaSpacing12">12</x:Double>
  <x:Double x:Key="OleaSpacing16">16</x:Double>
  <x:Double x:Key="OleaSpacing20">20</x:Double>
  <x:Double x:Key="OleaSpacing24">24</x:Double>
  <x:Double x:Key="OleaSpacing28">28</x:Double>
  <x:Double x:Key="OleaSpacing32">32</x:Double>
  <x:Double x:Key="OleaSpacing36">36</x:Double>
  <x:Double x:Key="OleaSpacing40">40</x:Double>
  <x:Double x:Key="OleaSpacing48">48</x:Double>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- CORNER RADII                                           -->
  <!-- ══════════════════════════════════════════════════════ -->

  <CornerRadius x:Key="OleaCardRadius">16</CornerRadius>
  <CornerRadius x:Key="OleaInputRadius">10</CornerRadius>
  <CornerRadius x:Key="OleaPillRadius">100</CornerRadius>

  <!-- ══════════════════════════════════════════════════════ -->
  <!-- REUSABLE STYLES                                        -->
  <!-- ══════════════════════════════════════════════════════ -->

  <!-- Page Title: Cormorant Garamond Regular 28px (mapped to Georgia) -->
  <Style x:Key="OleaPageTitleStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaDisplayFont}" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <!-- Page Subtitle -->
  <Style x:Key="OleaPageSubtitleStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaTextMutedBrush}" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <!-- Section Heading: Playfair Display 18px (mapped to Georgia) -->
  <Style x:Key="OleaSectionHeadingStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaHeadingFont}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
  </Style>

  <!-- Section Sub-Heading: Playfair Display 15px -->
  <Style x:Key="OleaSectionSubHeadingStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaHeadingFont}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
  </Style>

  <!-- Card Name: Playfair Display 17px -->
  <Style x:Key="OleaCardNameStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaHeadingFont}" />
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
  </Style>

  <!-- Form Label: DM Sans Bold 9px uppercase -->
  <Style x:Key="OleaFormLabelStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource OleaLabelBrush}" />
    <Setter Property="CharacterSpacing" Value="150" />
  </Style>

  <!-- Card Date: DM Sans 9px uppercase -->
  <Style x:Key="OleaCardDateStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaLabelBrush}" />
    <Setter Property="CharacterSpacing" Value="100" />
  </Style>

  <!-- Card Origin subtitle -->
  <Style x:Key="OleaCardOriginStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="Foreground" Value="{StaticResource OleaTextMutedBrush}" />
  </Style>

  <!-- Intensity Label: 7px bold uppercase -->
  <Style x:Key="OleaIntensityLabelStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="7" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource OleaLabelBrush}" />
    <Setter Property="CharacterSpacing" Value="100" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <!-- Flavor Tag (card): 7px bold uppercase white -->
  <Style x:Key="OleaFlavorTagTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="7" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CharacterSpacing" Value="50" />
  </Style>

  <!-- Cultivar Tag text: 7px bold olive -->
  <Style x:Key="OleaCultivarTagTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="7" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryVariantBrush}" />
    <Setter Property="CharacterSpacing" Value="50" />
  </Style>

  <!-- Region Name: Playfair 17px -->
  <Style x:Key="OleaRegionNameStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaHeadingFont}" />
    <Setter Property="FontSize" Value="17" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
  </Style>

  <!-- Region Area: 11px gold-muted -->
  <Style x:Key="OleaRegionAreaStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{StaticResource OleaAccentMutedBrush}" />
  </Style>

  <!-- Region Description: 10px muted -->
  <Style x:Key="OleaRegionDescriptionStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaTextMutedBrush}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <!-- Nav Link (inactive): 10px muted -->
  <Style x:Key="OleaNavLinkStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{StaticResource OleaTextMutedBrush}" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <!-- Logo: Playfair Display Bold 22px -->
  <Style x:Key="OleaLogoStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OleaHeadingFont}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="{StaticResource OleaPrimaryBrush}" />
    <Setter Property="CharacterSpacing" Value="200" />
  </Style>

  <!-- Input Style overrides -->
  <Style x:Key="OleaTextBoxStyle" TargetType="TextBox">
    <Setter Property="Background" Value="{StaticResource OleaSurfaceBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource OleaBorderBrush}" />
    <Setter Property="BorderThickness" Value="1.5" />
    <Setter Property="CornerRadius" Value="{StaticResource OleaInputRadius}" />
    <Setter Property="Padding" Value="16,12" />
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource OleaOnBackgroundBrush}" />
    <Setter Property="PlaceholderForeground" Value="{StaticResource OleaPlaceholderBrush}" />
  </Style>

  <!-- Save Button -->
  <Style x:Key="OleaPrimaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource OleaPrimaryBrush}" />
    <Setter Property="Foreground" Value="{StaticResource OleaBackgroundBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource OleaBodyFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CornerRadius" Value="{StaticResource OleaInputRadius}" />
    <Setter Property="Padding" Value="24,16" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

</ResourceDictionary>

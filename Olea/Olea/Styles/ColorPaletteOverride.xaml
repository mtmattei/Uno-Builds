<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Primary: olive-dark -->
      <Color x:Key="PrimaryColor">#2D3B2D</Color>
      <Color x:Key="OnPrimaryColor">#FAF6EE</Color>
      <Color x:Key="PrimaryContainerColor">#E8E4D8</Color>
      <Color x:Key="OnPrimaryContainerColor">#2D3B2D</Color>
      <!-- Secondary: gold -->
      <Color x:Key="SecondaryColor">#C4A44A</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#F0E8D8</Color>
      <Color x:Key="OnSecondaryContainerColor">#5C4A2A</Color>
      <!-- Tertiary: olive -->
      <Color x:Key="TertiaryColor">#4A5D3A</Color>
      <Color x:Key="OnTertiaryColor">#FAF6EE</Color>
      <Color x:Key="TertiaryContainerColor">#D8E8D0</Color>
      <Color x:Key="OnTertiaryContainerColor">#2D3B2D</Color>
      <!-- Error -->
      <Color x:Key="ErrorColor">#B3261E</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <!-- Background / Surface -->
      <Color x:Key="BackgroundColor">#FAF6EE</Color>
      <Color x:Key="OnBackgroundColor">#1A1A18</Color>
      <Color x:Key="SurfaceColor">#FDFCF9</Color>
      <Color x:Key="OnSurfaceColor">#1A1A18</Color>
      <Color x:Key="SurfaceVariantColor">#F0E8D8</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B6560</Color>
      <!-- Outline / Borders -->
      <Color x:Key="OutlineColor">#E5DDD0</Color>
      <Color x:Key="OutlineVariantColor">#D5CCBD</Color>
      <!-- Inverse -->
      <Color x:Key="OnSurfaceInverseColor">#FAF6EE</Color>
      <Color x:Key="SurfaceInverseColor">#2D3B2D</Color>
      <Color x:Key="PrimaryInverseColor">#6B7F5A</Color>
      <Color x:Key="SurfaceTintColor">#2D3B2D</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <!-- Dark theme: keep light for this app (no dark mode per design brief) -->
      <Color x:Key="PrimaryColor">#2D3B2D</Color>
      <Color x:Key="OnPrimaryColor">#FAF6EE</Color>
      <Color x:Key="PrimaryContainerColor">#E8E4D8</Color>
      <Color x:Key="OnPrimaryContainerColor">#2D3B2D</Color>
      <Color x:Key="SecondaryColor">#C4A44A</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#F0E8D8</Color>
      <Color x:Key="OnSecondaryContainerColor">#5C4A2A</Color>
      <Color x:Key="TertiaryColor">#4A5D3A</Color>
      <Color x:Key="OnTertiaryColor">#FAF6EE</Color>
      <Color x:Key="TertiaryContainerColor">#D8E8D0</Color>
      <Color x:Key="OnTertiaryContainerColor">#2D3B2D</Color>
      <Color x:Key="ErrorColor">#B3261E</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#FAF6EE</Color>
      <Color x:Key="OnBackgroundColor">#1A1A18</Color>
      <Color x:Key="SurfaceColor">#FDFCF9</Color>
      <Color x:Key="OnSurfaceColor">#1A1A18</Color>
      <Color x:Key="SurfaceVariantColor">#F0E8D8</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B6560</Color>
      <Color x:Key="OutlineColor">#E5DDD0</Color>
      <Color x:Key="OutlineVariantColor">#D5CCBD</Color>
      <Color x:Key="OnSurfaceInverseColor">#FAF6EE</Color>
      <Color x:Key="SurfaceInverseColor">#2D3B2D</Color>
      <Color x:Key="PrimaryInverseColor">#6B7F5A</Color>
      <Color x:Key="SurfaceTintColor">#2D3B2D</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

{
  "AppConfig": {
    "Environment": "Production"
  },
  "ApiClient": {
    "UseNativeHandler": true
  },
  "LocalizationConfiguration": {
    "Cultures": [
      "es",
      "fr",
      "pt-BR",
      "en"
    ]
  },
  "Roboflow": {
    "ApiKey": "YOUR_API_KEY_HERE",
    "ModelEndpoint": "hand-gesture-recognition-9ldly/1",
    "BaseUrl": "https://detect.roboflow.com",
    "MinConfidence": 0.4,
    "ThrottleIntervalMs": 300,
    "TimeoutMs": 5000,
    "MaxImageSize": 640,
    "JpegQuality": 75,
    "ValidateOnStartup": false
  },
  "HandTracking": {
    "TargetFps": 30,
    "HandProcessingIntervalMs": 16,
    "MinInvalidateIntervalMs": 33,
    "PalmDetectionInterval": 10,
    "PalmConfidenceThreshold": 0.3,
    "PalmNmsThreshold": 0.25,
    "PalmBoxPadding": 0.3,
    "PalmInputSize": 192,
    "LandmarkInputSize": 224,
    "MinHandAreaPixels": 3500,
    "MaxHandAreaPixels": 80000,
    "MinMotionPixels": 10,
    "HandConfirmationFrames": 3,
    "HandTrackingDistancePixels": 100,
    "BasePinchThreshold": 0.45,
    "FingerExtensionRatio": 1.3,
    "MinGestureConfidenceThreshold": 1.25,
    "GestureConfidenceThreshold": 0.60,
    "GestureHysteresisThreshold": 0.45,
    "GestureWeakContinuationThreshold": 0.30,
    "GestureConfirmationFrames": 1,
    "LandmarkProcessNoise": 0.03,
    "LandmarkMeasurementNoise": 0.06,
    "MapperProcessNoise": 0.03,
    "MapperMeasurementNoise": 0.08
  },
  "Webcam": {
    "DefaultWidth": 640,
    "DefaultHeight": 480,
    "DefaultFps": 30,
    "FrameReadTimeoutMs": 33,
    "MaxConsecutiveFailures": 30,
    "MaxCameraProbeIndex": 3,
    "CaptureThreadSleepMs": 33,
    "InitializationWarmupFrames": 3,
    "CameraProbeTimeoutMs": 500
  },
  "VoxelEditor": {
    "GridSize": 32,
    "DefaultVoxelSize": 8,
    "MinVoxelSize": 4,
    "MaxVoxelSize": 24,
    "ArPlaneDepth": 16.0,
    "TwoHandPanSensitivity": 800.0,
    "TwoHandZoomSensitivity": 200.0,
    "TwoHandMinDistanceDelta": 0.005
  }
}

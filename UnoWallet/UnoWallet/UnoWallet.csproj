<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net9.0-android;net9.0-desktop</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>UnoWallet</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>com.companyname.UnoWallet</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>Platform006</ApplicationPublisher>
    <!-- Package Description -->
    <Description>UnoWallet powered by Uno Platform.</Description>

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <UnoFeatures>
      Material;
      Hosting;
      Toolkit;
      Logging;
      Mvvm;
      Configuration;
      HttpKiota;
      Serialization;
      Localization;
      Navigation;
      ThemeService;
      SkiaRenderer;
    </UnoFeatures>
  </PropertyGroup>

  <ItemGroup>
    <UnoImage Include="Assets\Images\avatar.svg" />
    <UnoImage Include="Assets\Images\amazon.svg" />
    <UnoImage Include="Assets\Images\temu.svg" />
    <UnoImage Include="Assets\Images\ps5.svg" />
    <UnoImage Include="Assets\Images\nikon.svg" />
    <UnoImage Include="Assets\Images\laptop.svg" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="LiveChartsCore.SkiaSharpView.Uno.WinUI" />
  </ItemGroup>

</Project>

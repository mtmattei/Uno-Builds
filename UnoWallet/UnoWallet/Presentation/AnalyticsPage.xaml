<Page x:Class="UnoWallet.Presentation.AnalyticsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoWallet.Presentation"
      xmlns:models="using:UnoWallet.Models"
      xmlns:converters="using:UnoWallet.Converters"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      Background="#F2F2F7">

    <Page.Resources>
        <converters:BoolToTabIndicatorConverter x:Key="BoolToTabIndicatorConverter" />
        <converters:InverseBoolToTabIndicatorConverter x:Key="InverseBoolToTabIndicatorConverter" />
        <converters:BoolToForegroundConverter x:Key="BoolToForegroundConverter" />
        <converters:InverseBoolToForegroundConverter x:Key="InverseBoolToForegroundConverter" />
    </Page.Resources>

    <Grid utu:SafeArea.Insets="Top,Bottom">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel Padding="16"
                        Spacing="16">

                <!-- ===== HEADER SECTION (on gray background) ===== -->
                <Grid Height="48"
                      Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Back Button -->
                    <Button Grid.Column="0"
                            Width="44"
                            Height="44"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="22"
                            uen:Navigation.Request="-">
                        <FontIcon Glyph="&#xE72B;"
                                  FontSize="20"
                                  Foreground="#1C1C1E" />
                    </Button>

                    <!-- Title -->
                    <TextBlock Grid.Column="1"
                               Text="Analytics"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Foreground="#1C1C1E" />

                    <!-- Menu Button -->
                    <Button Grid.Column="2"
                            Width="44"
                            Height="44"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="22">
                        <FontIcon Glyph="&#xE712;"
                                  FontSize="20"
                                  Foreground="#1C1C1E" />
                    </Button>
                </Grid>

                <!-- ===== TOTAL SPENDING (on gray background) ===== -->
                <StackPanel Spacing="4"
                            Margin="4,0">
                    <TextBlock Text="Total Spending"
                               FontSize="14"
                               Foreground="#8E8E93" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="$"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Top"
                                   Margin="0,4,2,0"
                                   Foreground="#1C1C1E" />
                        <TextBlock Text="{Binding TotalSpendingFormatted}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#1C1C1E" />
                    </StackPanel>
                </StackPanel>

                <!-- ===== LINE CHART (on gray background) ===== -->
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Line Chart (LiveCharts2) -->
                    <lvc:CartesianChart Grid.Row="0"
                                        Height="180"
                                        Series="{Binding Series}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        TooltipPosition="Top"
                                        ZoomMode="None" />

                    <!-- Powered by LiveCharts2 label -->
                    <TextBlock Grid.Row="1"
                               Text="Powered by LiveCharts2"
                               FontSize="9"
                               Foreground="#C7C7CC"
                               HorizontalAlignment="Right"
                               Margin="0,4,4,0" />
                </Grid>

                <!-- ===== SUMMARY STATS ROW (each in own white container) ===== -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- On Progress -->
                    <Border Grid.Column="0"
                            Background="White"
                            CornerRadius="16"
                            Padding="12,16">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="4">
                            <TextBlock Text="On Progress"
                                       FontSize="13"
                                       Foreground="#8E8E93"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="$"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Margin="0,2,1,0"
                                           Foreground="#1C1C1E" />
                                <TextBlock Text="{Binding OnProgressFormatted}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#1C1C1E" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Overdue -->
                    <Border Grid.Column="1"
                            Background="White"
                            CornerRadius="16"
                            Padding="12,16">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="4">
                            <TextBlock Text="Overdue"
                                       FontSize="13"
                                       Foreground="#8E8E93"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="$"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Margin="0,2,1,0"
                                           Foreground="#1C1C1E" />
                                <TextBlock Text="{Binding OverdueFormatted}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#1C1C1E" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Total -->
                    <Border Grid.Column="2"
                            Background="White"
                            CornerRadius="16"
                            Padding="12,16">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="4">
                            <TextBlock Text="Total"
                                       FontSize="13"
                                       Foreground="#8E8E93"
                                       HorizontalAlignment="Center" />
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="$"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Top"
                                           Margin="0,2,1,0"
                                           Foreground="#1C1C1E" />
                                <TextBlock Text="{Binding TotalInstallmentsFormatted}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#1C1C1E" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ===== INSTALLMENTS CARD ===== -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20,16">
                    <StackPanel Spacing="0">
                        <!-- Installment Tabs -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- 4 Installment Tab -->
                            <Button Grid.Column="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Padding="0,12"
                                    Command="{Binding SelectFourInstallmentCommand}">
                                <StackPanel>
                                    <TextBlock Text="4 Installment"
                                               FontSize="15"
                                               FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               Foreground="{Binding IsFourInstallmentSelected, Converter={StaticResource BoolToForegroundConverter}}" />
                                    <Border Height="2"
                                            Margin="0,8,0,0"
                                            CornerRadius="1"
                                            Background="{Binding IsFourInstallmentSelected, Converter={StaticResource BoolToTabIndicatorConverter}}" />
                                </StackPanel>
                            </Button>

                            <!-- 6 Installment Tab -->
                            <Button Grid.Column="1"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Padding="0,12"
                                    Command="{Binding SelectSixInstallmentCommand}">
                                <StackPanel>
                                    <TextBlock Text="6 Installment"
                                               FontSize="15"
                                               FontWeight="Medium"
                                               HorizontalAlignment="Center"
                                               Foreground="{Binding IsFourInstallmentSelected, Converter={StaticResource InverseBoolToForegroundConverter}}" />
                                    <Border Height="2"
                                            Margin="0,8,0,0"
                                            CornerRadius="1"
                                            Background="{Binding IsFourInstallmentSelected, Converter={StaticResource InverseBoolToTabIndicatorConverter}}" />
                                </StackPanel>
                            </Button>

                            <!-- Bottom border line -->
                            <Border Grid.ColumnSpan="2"
                                    Height="1"
                                    VerticalAlignment="Bottom"
                                    Background="#E5E5EA" />
                        </Grid>

                        <!-- Installment List -->
                        <ItemsRepeater ItemsSource="{Binding CurrentInstallments}"
                                       Margin="0,12,0,0">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:Installment">
                                    <StackPanel Margin="0,0,0,12">
                                        <!-- White card for product info -->
                                        <Border Background="White"
                                                BorderBrush="#E5E5EA"
                                                BorderThickness="1"
                                                CornerRadius="12,12,0,0"
                                                Padding="12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Product Image -->
                                                <Border Grid.Column="0"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="24">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{x:Bind ImageSource}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>

                                                <!-- Product Name and Merchant -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind ProductName}"
                                                               FontSize="15"
                                                               FontWeight="Medium"
                                                               Foreground="#1C1C1E" />
                                                    <TextBlock Text="{x:Bind MerchantName}"
                                                               FontSize="13"
                                                               Foreground="#8E8E93" />
                                                </StackPanel>

                                                <!-- Price and Due Date -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind FormattedPrice}"
                                                               FontSize="15"
                                                               FontWeight="Medium"
                                                               HorizontalAlignment="Right"
                                                               Foreground="#1C1C1E" />
                                                    <TextBlock Text="{x:Bind DueDateText}"
                                                               FontSize="13"
                                                               HorizontalAlignment="Right"
                                                               Foreground="#8E8E93" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Gray pulled-out section for installment progress -->
                                        <Border Background="#F2F2F7"
                                                CornerRadius="0,0,12,12"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Progress indicator icon -->
                                                <FontIcon Grid.Column="0"
                                                          Glyph="&#xE916;"
                                                          FontSize="14"
                                                          Foreground="#8E8E93"
                                                          Margin="0,0,6,0" />

                                                <!-- Progress text -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind ProgressText}"
                                                           FontSize="13"
                                                           Foreground="#8E8E93"
                                                           VerticalAlignment="Center" />

                                                <!-- Pay Now button -->
                                                <Button Grid.Column="2"
                                                        Content="Pay Now"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#00BCD4"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Padding="0" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Bottom spacing for tab bar -->
                <Border Height="8" />

            </StackPanel>
        </ScrollViewer>

        <!-- ===== BOTTOM TAB BAR ===== -->
        <Border Grid.Row="1"
                Background="#F2F2F7"
                Padding="8,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Home Tab -->
                <Button Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12"
                        uen:Navigation.Request="/Dashboard">
                    <FontIcon Glyph="&#xE80F;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Card Tab -->
                <Button Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12"
                        uen:Navigation.Request="Card">
                    <FontIcon Glyph="&#xE8C7;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Wallet Tab -->
                <Button Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12">
                    <FontIcon Glyph="&#xE786;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Progress Tab (Selected) -->
                <Border Grid.Column="3"
                        Background="#3C3C3C"
                        CornerRadius="20"
                        HorizontalAlignment="Center"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE9D2;"
                                  FontSize="18"
                                  Foreground="White" />
                        <TextBlock Text="Progress"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Profile Tab -->
                <Button Grid.Column="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12">
                    <FontIcon Glyph="&#xE77B;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>
            </Grid>
        </Border>

    </Grid>
</Page>

<Page x:Class="UnoWallet.Presentation.CardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoWallet.Presentation"
      xmlns:models="using:UnoWallet.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      Background="#F2F2F7">

    <Grid utu:SafeArea.Insets="Top,Bottom">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Hidden">
            <StackPanel Padding="16"
                        Spacing="16">

                <!-- ===== HEADER SECTION ===== -->
                <Grid Height="48"
                      Margin="4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            Width="48"
                            Height="48"
                            CornerRadius="24">
                        <Border.Background>
                            <ImageBrush ImageSource="ms-appx:///Assets/Images/avatar.png"
                                        Stretch="UniformToFill" />
                        </Border.Background>
                    </Border>

                    <!-- Support Button -->
                    <Button Grid.Column="2"
                            Width="44"
                            Height="44"
                            Padding="0"
                            Background="White"
                            BorderThickness="0"
                            CornerRadius="22"
                            Margin="0,0,8,0">
                        <FontIcon Glyph="&#xE95B;"
                                  FontSize="20"
                                  Foreground="#1C1C1E" />
                    </Button>

                    <!-- Notification Button with Badge -->
                    <Grid Grid.Column="3"
                          Width="44"
                          Height="44">
                        <Button Width="44"
                                Height="44"
                                Padding="0"
                                Background="White"
                                BorderThickness="0"
                                CornerRadius="22">
                            <FontIcon Glyph="&#xE7E7;"
                                      FontSize="20"
                                      Foreground="#1C1C1E" />
                        </Button>
                        <!-- Badge -->
                        <Border HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Background="#FF3B30"
                                CornerRadius="9"
                                MinWidth="18"
                                Height="18"
                                Padding="4,0"
                                Margin="0,2,2,0">
                            <TextBlock Text="{Binding NotificationCount}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- ===== CREDIT CARD VISUAL ===== -->
                <Border Background="#3A3D40"
                        CornerRadius="20"
                        Height="220">
                    <Grid>
                        <!-- Top pocket/wallet overlay -->
                        <Border Background="#2C2C2E"
                                CornerRadius="20,20,100,100"
                                Height="100"
                                VerticalAlignment="Top"
                                Opacity="0.85" />

                        <!-- Card Content -->
                        <Grid Padding="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Card Header: Logo + Card Number -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- MasterCard Logo + Text -->
                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <!-- Overlapping circles for MasterCard logo -->
                                    <Grid Width="36" Height="24">
                                        <Ellipse Width="24"
                                                 Height="24"
                                                 Fill="#EB001B"
                                                 HorizontalAlignment="Left" />
                                        <Ellipse Width="24"
                                                 Height="24"
                                                 Fill="#F79E1B"
                                                 HorizontalAlignment="Right"
                                                 Opacity="0.9" />
                                    </Grid>
                                    <TextBlock Text="{Binding CardType}"
                                               FontSize="14"
                                               FontWeight="Medium"
                                               Foreground="White"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Card Number -->
                                <TextBlock Grid.Column="2"
                                           Text="{Binding CardNumber}"
                                           FontSize="13"
                                           Foreground="#B0B0B0"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <!-- Decorative stitching dots (arc pattern) -->
                            <Canvas Grid.Row="1"
                                    VerticalAlignment="Top"
                                    Margin="0,20,0,0">
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="20" Canvas.Top="0"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="40" Canvas.Top="4"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="60" Canvas.Top="6"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="80" Canvas.Top="8"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="100" Canvas.Top="8"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="120" Canvas.Top="8"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="140" Canvas.Top="8"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="160" Canvas.Top="8"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="180" Canvas.Top="6"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="200" Canvas.Top="4"/>
                                <Ellipse Width="4" Height="4" Fill="#FFFFFF30" Canvas.Left="220" Canvas.Top="0"/>
                            </Canvas>

                            <!-- Limit Info -->
                            <StackPanel Grid.Row="2"
                                        Spacing="4">
                                <TextBlock Text="{Binding LimitLabel}"
                                           FontSize="13"
                                           Foreground="#B0B0B0" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0"
                                                Orientation="Horizontal">
                                        <TextBlock Text="$"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   VerticalAlignment="Top"
                                                   Margin="0,4,2,0" />
                                        <TextBlock Text="{Binding CardLimitFormatted}"
                                                   FontSize="28"
                                                   FontWeight="Bold"
                                                   Foreground="White" />
                                    </StackPanel>

                                    <!-- Eye toggle button -->
                                    <Button Grid.Column="2"
                                            Width="36"
                                            Height="36"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding ToggleAmountVisibilityCommand}"
                                            VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7B3;"
                                                  FontSize="18"
                                                  Foreground="#B0B0B0" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ===== QUICK ACTIONS ROW ===== -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Card Details Button -->
                    <Button Grid.Column="0"
                            Background="White"
                            BorderBrush="#E5E5EA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <StackPanel Spacing="8"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE8C7;"
                                      FontSize="24"
                                      Foreground="#1C1C1E" />
                            <TextBlock Text="Card Details"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Freeze Card Button -->
                    <Button Grid.Column="1"
                            Background="White"
                            BorderBrush="#E5E5EA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Command="{Binding ToggleFreezeCardCommand}">
                        <StackPanel Spacing="8"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE9CA;"
                                      FontSize="24"
                                      Foreground="#1C1C1E" />
                            <TextBlock Text="Freeze Card"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- More Button -->
                    <Button Grid.Column="2"
                            Background="White"
                            BorderBrush="#E5E5EA"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12,16"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <StackPanel Spacing="8"
                                    HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE712;"
                                      FontSize="24"
                                      Foreground="#1C1C1E" />
                            <TextBlock Text="More"
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- ===== PAYMENT NEXT CARD ===== -->
                <Border Background="White"
                        CornerRadius="16"
                        Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Payment Next"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#1C1C1E" />

                        <!-- Payment List -->
                        <ItemsRepeater ItemsSource="{Binding UpcomingPayments}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:Installment">
                                    <StackPanel Margin="0,0,0,8">
                                        <!-- White card for product info -->
                                        <Border Background="White"
                                                BorderBrush="#E5E5EA"
                                                BorderThickness="1"
                                                CornerRadius="12,12,0,0"
                                                Padding="12">
                                            <Grid ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="48" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Product Image -->
                                                <Border Grid.Column="0"
                                                        Width="48"
                                                        Height="48"
                                                        CornerRadius="24">
                                                    <Border.Background>
                                                        <ImageBrush ImageSource="{x:Bind ImageSource}"
                                                                    Stretch="UniformToFill" />
                                                    </Border.Background>
                                                </Border>

                                                <!-- Product Name and Merchant -->
                                                <StackPanel Grid.Column="1"
                                                            VerticalAlignment="Center"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind ProductName}"
                                                               FontSize="15"
                                                               FontWeight="Medium"
                                                               Foreground="#1C1C1E" />
                                                    <TextBlock Text="{x:Bind MerchantName}"
                                                               FontSize="13"
                                                               Foreground="#8E8E93" />
                                                </StackPanel>

                                                <!-- Price and Due Date -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Right"
                                                            Spacing="2">
                                                    <TextBlock Text="{x:Bind FormattedPrice}"
                                                               FontSize="15"
                                                               FontWeight="Medium"
                                                               HorizontalAlignment="Right"
                                                               Foreground="#1C1C1E" />
                                                    <TextBlock Text="{x:Bind DueDateText}"
                                                               FontSize="13"
                                                               HorizontalAlignment="Right"
                                                               Foreground="#8E8E93" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- Gray pulled-out section for installment progress -->
                                        <Border Background="#F2F2F7"
                                                CornerRadius="0,0,12,12"
                                                Padding="12,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Progress indicator icon -->
                                                <FontIcon Grid.Column="0"
                                                          Glyph="&#xE916;"
                                                          FontSize="14"
                                                          Foreground="#8E8E93"
                                                          Margin="0,0,6,0" />

                                                <!-- Progress text -->
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind ProgressText}"
                                                           FontSize="13"
                                                           Foreground="#8E8E93"
                                                           VerticalAlignment="Center" />

                                                <!-- Pay Now button -->
                                                <Button Grid.Column="2"
                                                        Content="Pay Now"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="#00BCD4"
                                                        FontSize="13"
                                                        FontWeight="SemiBold"
                                                        Padding="0" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>

                <!-- Bottom spacing for tab bar -->
                <Border Height="8" />

            </StackPanel>
        </ScrollViewer>

        <!-- ===== BOTTOM TAB BAR ===== -->
        <Border Grid.Row="1"
                Background="#F2F2F7"
                Padding="8,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Home Tab -->
                <Button Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12"
                        uen:Navigation.Request="/Dashboard">
                    <FontIcon Glyph="&#xE80F;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Card Tab (Selected) -->
                <Border Grid.Column="1"
                        Background="#3C3C3C"
                        CornerRadius="20"
                        HorizontalAlignment="Center"
                        Padding="16,10">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <FontIcon Glyph="&#xE8C7;"
                                  FontSize="18"
                                  Foreground="White" />
                        <TextBlock Text="Card"
                                   FontSize="14"
                                   FontWeight="Medium"
                                   Foreground="White"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Wallet Tab -->
                <Button Grid.Column="2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12">
                    <FontIcon Glyph="&#xE786;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Progress Tab -->
                <Button Grid.Column="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12"
                        uen:Navigation.Request="Analytics">
                    <FontIcon Glyph="&#xE9D2;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>

                <!-- Profile Tab -->
                <Button Grid.Column="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="48"
                        Height="48"
                        CornerRadius="12">
                    <FontIcon Glyph="&#xE77B;"
                              FontSize="22"
                              Foreground="#8E8E93" />
                </Button>
            </Grid>
        </Border>

    </Grid>
</Page>

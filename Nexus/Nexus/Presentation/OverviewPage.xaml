<Page x:Class="Nexus.Presentation.OverviewPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      Background="{ThemeResource NexusBackgroundPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Padding="24" MinWidth="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Metrics Row -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- THROUGHPUT Card -->
                <Border Grid.Column="0" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="THROUGHPUT" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="847.2" Style="{ThemeResource NexusDisplayStyle}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Text="units/hr" Style="{ThemeResource NexusLabelMonoStyle}" Margin="0,4,0,0"/>
                        <lvc:CartesianChart Grid.Row="3"
                                            Series="{x:Bind ViewModel.ThroughputSeries}"
                                            XAxes="{x:Bind ViewModel.SparklineXAxis}"
                                            YAxes="{x:Bind ViewModel.SparklineYAxis}"
                                            TooltipPosition="Hidden"
                                            ZoomMode="None"
                                            Margin="0,8,0,0"/>
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="+2.4%" Style="{ThemeResource NexusStatusLabelStyle}"
                                       Foreground="{ThemeResource NexusSuccessBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="NOMINAL" Style="{ThemeResource NexusStatusLabelStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- EFFICIENCY Card -->
                <Border Grid.Column="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="EFFICIENCY" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="94.7" Style="{ThemeResource NexusDisplayStyle}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Text="%" Style="{ThemeResource NexusLabelMonoStyle}" Margin="0,4,0,0"/>
                        <lvc:CartesianChart Grid.Row="3"
                                            Series="{x:Bind ViewModel.EfficiencySeries}"
                                            XAxes="{x:Bind ViewModel.SparklineXAxis}"
                                            YAxes="{x:Bind ViewModel.SparklineYAxis}"
                                            TooltipPosition="Hidden"
                                            ZoomMode="None"
                                            Margin="0,8,0,0"/>
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="+0.8%" Style="{ThemeResource NexusStatusLabelStyle}"
                                       Foreground="{ThemeResource NexusSuccessBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="NOMINAL" Style="{ThemeResource NexusStatusLabelStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- UPTIME Card -->
                <Border Grid.Column="4" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="UPTIME" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="99.2" Style="{ThemeResource NexusDisplayStyle}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Text="%" Style="{ThemeResource NexusLabelMonoStyle}" Margin="0,4,0,0"/>
                        <lvc:CartesianChart Grid.Row="3"
                                            Series="{x:Bind ViewModel.UptimeSeries}"
                                            XAxes="{x:Bind ViewModel.SparklineXAxis}"
                                            YAxes="{x:Bind ViewModel.SparklineYAxis}"
                                            TooltipPosition="Hidden"
                                            ZoomMode="None"
                                            Margin="0,8,0,0"/>
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="-0.1%" Style="{ThemeResource NexusStatusLabelStyle}"
                                       Foreground="{ThemeResource NexusDangerBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="NOMINAL" Style="{ThemeResource NexusStatusLabelStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ENERGY Card -->
                <Border Grid.Column="6" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="48"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="ENERGY" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        <TextBlock Grid.Row="1" Text="1.24" Style="{ThemeResource NexusDisplayStyle}" Margin="0,8,0,0"/>
                        <TextBlock Grid.Row="2" Text="MW" Style="{ThemeResource NexusLabelMonoStyle}" Margin="0,4,0,0"/>
                        <lvc:CartesianChart Grid.Row="3"
                                            Series="{x:Bind ViewModel.EnergySeries}"
                                            XAxes="{x:Bind ViewModel.SparklineXAxis}"
                                            YAxes="{x:Bind ViewModel.SparklineYAxis}"
                                            TooltipPosition="Hidden"
                                            ZoomMode="None"
                                            Margin="0,8,0,0"/>
                        <Grid Grid.Row="4" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="-3.2%" Style="{ThemeResource NexusStatusLabelStyle}"
                                       Foreground="{ThemeResource NexusSuccessBrush}"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="OPTIMAL" Style="{ThemeResource NexusStatusLabelStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Middle Row: Production Lines + Network Topology -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- PRODUCTION LINES Panel -->
                <Border Grid.Column="0" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="PRODUCTION LINES" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="VIEW ALL" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <!-- Table Header -->
                        <Grid Grid.Row="1" Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" MinWidth="120"/>
                                <ColumnDefinition Width="*" MinWidth="80"/>
                                <ColumnDefinition Width="*" MinWidth="70"/>
                                <ColumnDefinition Width="*" MinWidth="60"/>
                                <ColumnDefinition Width="*" MinWidth="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="UNIT" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="STATUS" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="OUTPUT" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="TEMP °C" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="PRESSURE" Style="{ThemeResource NexusTableHeaderStyle}"/>
                        </Grid>

                        <!-- Table Rows -->
                        <StackPanel Grid.Row="2" Spacing="0">
                            <!-- Row 1 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="8,4">
                                            <TextBlock Text="A1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                        </Border>
                                        <TextBlock Text="Assembly Line A1" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Column="2" Value="87" MaxWidth="80" Style="{ThemeResource NexusProgressBarStyle}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="3" Text="42.3" Style="{ThemeResource NexusTableCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="2.4 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Row 2 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="8,4">
                                            <TextBlock Text="A2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                        </Border>
                                        <TextBlock Text="Assembly Line A2" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Column="2" Value="92" MaxWidth="80" Style="{ThemeResource NexusProgressBarStyle}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="3" Text="41.8" Style="{ThemeResource NexusTableCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="2.3 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Row 3 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="8,4">
                                            <TextBlock Text="B1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                        </Border>
                                        <TextBlock Text="Processing Unit B1" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="STANDBY" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Column="2" Value="0" MaxWidth="80" Style="{ThemeResource NexusProgressBarStyle}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="3" Text="22.1" Style="{ThemeResource NexusTableCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="1 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Row 4 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="8,4">
                                            <TextBlock Text="C1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                        </Border>
                                        <TextBlock Text="Packaging Line C1" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Column="2" Value="78" MaxWidth="80" Style="{ThemeResource NexusProgressBarStyle}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="3" Text="38.5" Style="{ThemeResource NexusTableCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="1.8 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                </Grid>
                            </Border>

                            <!-- Row 5 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="80"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                        <ColumnDefinition Width="*" MinWidth="60"/>
                                        <ColumnDefinition Width="*" MinWidth="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="8,4">
                                            <TextBlock Text="C2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                        </Border>
                                        <TextBlock Text="Packaging Line C2" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusDangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="MAINT" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                    </StackPanel>
                                    <ProgressBar Grid.Column="2" Value="0" MaxWidth="80" Style="{ThemeResource NexusProgressBarStyle}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Column="3" Text="21" Style="{ThemeResource NexusTableCellStyle}"/>
                                    <TextBlock Grid.Column="4" Text="0 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- NETWORK TOPOLOGY Panel -->
                <Border Grid.Column="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="NETWORK TOPOLOGY" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        </StackPanel>

                        <!-- Network Diagram - Grid-based responsive layout -->
                        <Grid Grid.Row="1" Margin="0,20,0,0" MinHeight="200">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- HMI-A Node (Top Center) -->
                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="HMI-A" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- PLC-01 Node (Row 1, Left) -->
                            <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="PLC-01" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- SERVER Node (Row 1, Right) -->
                            <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="SERVER" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- SCADA Node (Row 2, Center) -->
                            <StackPanel Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="SCADA" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- DB-01 Node (Row 3, Left) -->
                            <StackPanel Grid.Row="3" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="DB-01" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- CLOUD Node (Row 3, Right) -->
                            <StackPanel Grid.Row="3" Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="4">
                                <Ellipse Width="12" Height="12" Fill="{ThemeResource NexusTextTertiaryBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="CLOUD" Style="{ThemeResource NexusCaptionMonoStyle}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom Row: System Log -->
            <Border Grid.Row="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="SYSTEM LOG" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="EXPORT" Style="{ThemeResource NexusGhostButtonStyle}"/>
                    </Grid>

                    <!-- Log Entries -->
                    <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="0">
                        <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="14:32:08" Style="{ThemeResource NexusBodyMonoStyle}" MinWidth="70"/>
                                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                <TextBlock Grid.Column="2" Text="Batch #4892 completed successfully" Style="{ThemeResource NexusTableCellStyle}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="14:28:41" Style="{ThemeResource NexusBodyMonoStyle}" MinWidth="70"/>
                                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                <TextBlock Grid.Column="2" Text="Line C2 scheduled maintenance in progress" Style="{ThemeResource NexusTableCellStyle}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="14:15:22" Style="{ThemeResource NexusBodyMonoStyle}" MinWidth="70"/>
                                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                <TextBlock Grid.Column="2" Text="Energy optimization mode activated" Style="{ThemeResource NexusTableCellStyle}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                        <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="13:58:03" Style="{ThemeResource NexusBodyMonoStyle}" MinWidth="70"/>
                                <Ellipse Grid.Column="1" Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center" Margin="16,0"/>
                                <TextBlock Grid.Column="2" Text="System backup completed" Style="{ThemeResource NexusTableCellStyle}" TextTrimming="CharacterEllipsis"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

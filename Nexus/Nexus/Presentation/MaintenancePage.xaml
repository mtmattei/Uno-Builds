<Page x:Class="Nexus.Presentation.MaintenancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource NexusBackgroundPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Padding="24" MinWidth="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Row: Work Orders + Spare Parts -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- WORK ORDERS Panel -->
                <Border Grid.Column="0" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="WORK ORDERS" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="+ NEW ORDER" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="0">
                            <!-- Table Header -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="65"/>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    <ColumnDefinition Width="Auto" MinWidth="70"/>
                                    <ColumnDefinition Width="Auto" MinWidth="80"/>
                                    <ColumnDefinition Width="Auto" MinWidth="90"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="ORDER" Style="{ThemeResource NexusTableHeaderStyle}"/>
                                <TextBlock Grid.Column="1" Text="EQUIPMENT" Style="{ThemeResource NexusTableHeaderStyle}"/>
                                <TextBlock Grid.Column="2" Text="TYPE" Style="{ThemeResource NexusTableHeaderStyle}"/>
                                <TextBlock Grid.Column="3" Text="DATE" Style="{ThemeResource NexusTableHeaderStyle}"/>
                                <TextBlock Grid.Column="4" Text="TECH" Style="{ThemeResource NexusTableHeaderStyle}"/>
                                <TextBlock Grid.Column="5" Text="STATUS" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            </Grid>

                            <!-- Row 1 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="WO-1247" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Packaging C2 - Motor" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusDangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="EMERGENCY" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="TODAY" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="J. Martinez" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="IN PROGRESS" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Row 2 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="WO-1248" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Assembly A1 - Conveyor" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="PREVENTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusInfoBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="DEC 03" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="R. Thompson" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="SCHEDULED" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusInfoBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Row 3 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="WO-1249" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Processing B1 - Hydraulic" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="PREVENTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusInfoBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="DEC 05" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="S. Kim" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="SCHEDULED" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusInfoBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Row 4 -->
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                                        <ColumnDefinition Width="Auto" MinWidth="90"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="WO-1246" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Assembly A2 - Sensor" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="CORRECTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="3" Text="NOV 30" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="J. Martinez" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="COMPLETED" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SPARE PARTS INVENTORY Panel -->
                <Border Grid.Column="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <StackPanel Spacing="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="SPARE PARTS" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="ORDER" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <StackPanel Spacing="0">
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Bearing SKF 6205" Style="{ThemeResource NexusBodyStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="QTY: 24" Style="{ThemeResource NexusStatusLabelStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Motor Drive Belt V-42" Style="{ThemeResource NexusBodyStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="QTY: 3" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="LOW STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Hydraulic Seal Kit HS-100" Style="{ThemeResource NexusBodyStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="QTY: 12" Style="{ThemeResource NexusStatusLabelStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Proximity Sensor PS-24V" Style="{ThemeResource NexusBodyStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="QTY: 0" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="OUT OF STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="PLC Module PM-500" Style="{ThemeResource NexusBodyStyle}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="QTY: 2" Style="{ThemeResource NexusStatusLabelStyle}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Row: Equipment Health -->
            <Border Grid.Row="1" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="EQUIPMENT HEALTH MONITORING" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="2" Content="SCHEDULE SERVICE" Style="{ThemeResource NexusGhostButtonStyle}"/>
                    </Grid>

                    <!-- Equipment Cards -->
                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Equipment A1 -->
                        <Border Grid.Column="0" Style="{ThemeResource NexusCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="A1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="94%" Style="{ThemeResource NexusDisplayMediumStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                </Grid>
                                <TextBlock Text="Assembly Line A1" Style="{ThemeResource NexusCaptionStyle}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Value="94" Style="{ThemeResource NexusProgressBarStyle}"/>
                                <StackPanel Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RUNTIME" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="4,892 hrs" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="NEXT SERVICE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="DEC 15" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Equipment A2 -->
                        <Border Grid.Column="2" Style="{ThemeResource NexusCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="A2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="87%" Style="{ThemeResource NexusDisplayMediumStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                </Grid>
                                <TextBlock Text="Assembly Line A2" Style="{ThemeResource NexusCaptionStyle}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Value="87" Style="{ThemeResource NexusProgressBarStyle}"/>
                                <StackPanel Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RUNTIME" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="5,124 hrs" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="NEXT SERVICE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="DEC 10" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Equipment B1 -->
                        <Border Grid.Column="4" Style="{ThemeResource NexusCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="B1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="72%" Style="{ThemeResource NexusDisplayMediumStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                </Grid>
                                <TextBlock Text="Processing Unit B1" Style="{ThemeResource NexusCaptionStyle}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Value="72" Style="{ThemeResource NexusProgressBarStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                <StackPanel Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RUNTIME" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="6,847 hrs" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="NEXT SERVICE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="DEC 05" Style="{ThemeResource NexusTableCellStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Equipment C1 -->
                        <Border Grid.Column="6" Style="{ThemeResource NexusCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="C1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="91%" Style="{ThemeResource NexusDisplayMediumStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                </Grid>
                                <TextBlock Text="Packaging Line C1" Style="{ThemeResource NexusCaptionStyle}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Value="91" Style="{ThemeResource NexusProgressBarStyle}"/>
                                <StackPanel Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RUNTIME" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="3,456 hrs" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="NEXT SERVICE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="DEC 20" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Equipment C2 -->
                        <Border Grid.Column="8" Style="{ThemeResource NexusCardBorderStyle}">
                            <StackPanel Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="C2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="45%" Style="{ThemeResource NexusDisplayMediumStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                </Grid>
                                <TextBlock Text="Packaging Line C2" Style="{ThemeResource NexusCaptionStyle}" TextTrimming="CharacterEllipsis"/>
                                <ProgressBar Value="45" Style="{ThemeResource NexusProgressBarStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                <StackPanel Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="RUNTIME" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="7,234 hrs" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="STATUS" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="REPAIRING" Style="{ThemeResource NexusTableCellStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

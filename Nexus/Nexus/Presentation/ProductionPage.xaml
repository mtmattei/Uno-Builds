<Page x:Class="Nexus.Presentation.ProductionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource NexusBackgroundPrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid Padding="24" MinWidth="800">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Top Row: Batch Queue, Shift Info, Material Inventory -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- BATCH QUEUE Panel -->
                <Border Grid.Column="0" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="BATCH QUEUE" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="+ NEW BATCH" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="70"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="45"/>
                                <ColumnDefinition Width="Auto" MinWidth="65"/>
                                <ColumnDefinition Width="Auto" MinWidth="45"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="BATCH ID" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="1" Text="PRODUCT" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="2" Text="QTY" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="3" Text="PRIORITY" Style="{ThemeResource NexusTableHeaderStyle}"/>
                            <TextBlock Grid.Column="4" Text="ETA" Style="{ThemeResource NexusTableHeaderStyle}"/>
                        </Grid>

                        <StackPanel Grid.Row="2" Spacing="0">
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="B-4893" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Component Alpha-7" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="2,500" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusDangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="HIGH" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="16:45" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="B-4894" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Assembly Beta-2" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="1,200" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="NORMAL" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="18:20" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="B-4895" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Module Gamma-X" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="800" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="NORMAL" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="20:15" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                        <ColumnDefinition Width="Auto" MinWidth="65"/>
                                        <ColumnDefinition Width="Auto" MinWidth="45"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="4,2" HorizontalAlignment="Left">
                                        <TextBlock Text="B-4896" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Component Alpha-7" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="3,000" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="LOW" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4" Text="22:30" Style="{ThemeResource NexusTableCellStyle}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- SHIFT INFORMATION Panel -->
                <Border Grid.Column="2" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusInfoBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="SHIFT INFORMATION" Style="{ThemeResource NexusPanelTitleStyle}"/>
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="12,8">
                                <TextBlock Text="SHIFT B" Style="{ThemeResource NexusBodyStyle}" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Grid.Column="2" Text="06:00 - 14:00" Style="{ThemeResource NexusBodyMonoStyle}" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="SUPERVISOR" Style="{ThemeResource NexusStatusLabelStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="M. Chen" Style="{ThemeResource NexusBodyStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="OPERATORS" Style="{ThemeResource NexusStatusLabelStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="12" Style="{ThemeResource NexusDisplayMediumStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="BREAKS TAKEN" Style="{ThemeResource NexusStatusLabelStyle}" HorizontalAlignment="Center"/>
                                <TextBlock Text="2/3" Style="{ThemeResource NexusDisplayMediumStyle}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="3" Margin="0,20,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SHIFT PROGRESS" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                <TextBlock Grid.Column="1" Text="67%" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusTextSecondaryBrush}"/>
                            </Grid>
                            <ProgressBar Value="67" Style="{ThemeResource NexusProgressBarStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- MATERIAL INVENTORY Panel -->
                <Border Grid.Column="4" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="MATERIAL INVENTORY" Style="{ThemeResource NexusPanelTitleStyle}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="REORDER" Style="{ThemeResource NexusGhostButtonStyle}"/>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,16,0,0" Spacing="0">
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Steel Alloy 304" Style="{ThemeResource NexusBodyStyle}"/>
                                        <ProgressBar Value="85" Style="{ThemeResource NexusProgressBarStyle}" Margin="0,8,0,0" MaxWidth="150" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="82 tons" Style="{ThemeResource NexusLabelMonoStyle}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Polymer Compound B" Style="{ThemeResource NexusBodyStyle}"/>
                                        <ProgressBar Value="25" Style="{ThemeResource NexusProgressBarStyle}" Foreground="{ThemeResource NexusWarningBrush}" Margin="0,8,0,0" MaxWidth="150" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="LOW STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="45 kg" Style="{ThemeResource NexusLabelMonoStyle}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Copper Wire 2.5mm" Style="{ThemeResource NexusBodyStyle}"/>
                                        <ProgressBar Value="72" Style="{ThemeResource NexusProgressBarStyle}" Margin="0,8,0,0" MaxWidth="150" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="1250 m" Style="{ThemeResource NexusLabelMonoStyle}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border BorderBrush="{ThemeResource NexusBorderPrimaryBrush}" BorderThickness="0,1,0,0" Padding="0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Lubricant ISO VG 46" Style="{ThemeResource NexusBodyStyle}"/>
                                        <ProgressBar Value="60" Style="{ThemeResource NexusProgressBarStyle}" Margin="0,8,0,0" MaxWidth="150" HorizontalAlignment="Left"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock Text="IN STOCK" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}" HorizontalAlignment="Right"/>
                                        <TextBlock Text="28 L" Style="{ThemeResource NexusLabelMonoStyle}" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom Row: Line Status Detail -->
            <Border Grid.Row="1" Style="{ThemeResource NexusPanelBorderStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="LINE STATUS DETAIL" Style="{ThemeResource NexusPanelTitleStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- A1 Card -->
                        <Border Grid.Column="0" Style="{ThemeResource NexusCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="A1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="Assembly Line A1" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="89%" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="42.3°C" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="2.4 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- A2 Card -->
                        <Border Grid.Column="2" Style="{ThemeResource NexusCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="A2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="Assembly Line A2" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="94%" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="41.8°C" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="2.3 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- B1 Card -->
                        <Border Grid.Column="4" Style="{ThemeResource NexusCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="B1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusWarningBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="STANDBY" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusWarningBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="Processing Unit B1" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="0%" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="22.1°C" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="1 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- C1 Card -->
                        <Border Grid.Column="6" Style="{ThemeResource NexusCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="C1" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusSuccessBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="ACTIVE" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusSuccessBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="Packaging Line C1" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="78%" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="38.5°C" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="1.8 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- C2 Card -->
                        <Border Grid.Column="8" Style="{ThemeResource NexusCardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{ThemeResource NexusBorderSecondaryBrush}" BorderThickness="1" Padding="6,4">
                                        <TextBlock Text="C2" Style="{ThemeResource NexusLabelMonoStyle}"/>
                                    </Border>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
                                        <Ellipse Width="6" Height="6" Fill="{ThemeResource NexusDangerBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="MAINT" Style="{ThemeResource NexusStatusLabelStyle}" Foreground="{ThemeResource NexusDangerBrush}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Grid.Row="1" Text="Packaging Line C2" Style="{ThemeResource NexusCaptionStyle}" Margin="0,8,0,0" TextTrimming="CharacterEllipsis"/>
                                <StackPanel Grid.Row="2" Margin="0,12,0,0" Spacing="4">
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="OUTPUT" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="0%" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="TEMP" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="21°C" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="PRESSURE" Style="{ThemeResource NexusStatusLabelStyle}"/>
                                        <TextBlock Grid.Column="1" Text="0 bar" Style="{ThemeResource NexusTableCellStyle}"/>
                                    </Grid>
                                </StackPanel>
                                <Grid Grid.Row="3" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Button Content="DETAILS" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                    <Button Grid.Column="2" Content="CONTROL" Style="{ThemeResource NexusGhostButtonStyle}" HorizontalAlignment="Stretch"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

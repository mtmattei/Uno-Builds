<UserControl
    x:Class="Unoblueprint.Controls.PluginCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Unoblueprint.Controls"
    mc:Ignorable="d">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="White" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666" />
        <SolidColorBrush x:Key="BrandYellowBrush" Color="#C4FF0D" />
        <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#F5F5F5" />
        <SolidColorBrush x:Key="IsometricShape1Brush" Color="#FFE5CC" />
        <SolidColorBrush x:Key="IsometricShape2Brush" Color="#FFD4B3" />
        <SolidColorBrush x:Key="IsometricShape3Brush" Color="#FFC299" />
    </UserControl.Resources>

    <Border
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        CornerRadius="16"
        Width="350"
        Height="420">

        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Isometric illustration area with logo -->
            <Grid Grid.Row="0" Height="140" Margin="0,0,0,20">
                <!-- Placeholder for isometric shapes background image -->
                <Border
                    Background="#F5F5F5"
                    CornerRadius="12">
                    <TextBlock
                        Text="[Isometric Shapes]"
                        FontSize="12"
                        Foreground="#CCCCCC"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>

                <!-- Logo container -->
                <Border
                    Background="{StaticResource BrandYellowBrush}"
                    Width="64"
                    Height="64"
                    CornerRadius="16"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom">
                    <TextBlock
                        x:Name="LogoText"
                        Text="P"
                        FontSize="32"
                        FontWeight="Bold"
                        Foreground="{StaticResource PrimaryTextBrush}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- Plugin name with category badge inline -->
            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    x:Name="PluginNameText"
                    Text="Wordsometric"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="{StaticResource PrimaryTextBrush}"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0" />

                <Border
                    Grid.Column="1"
                    Background="{StaticResource BadgeBackgroundBrush}"
                    CornerRadius="12"
                    Padding="10,4"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <TextBlock
                        x:Name="CategoryText"
                        Text="Third-party payment"
                        FontSize="11"
                        Foreground="{StaticResource SecondaryTextBrush}" />
                </Border>
            </Grid>

            <!-- Plugin description -->
            <TextBlock
                Grid.Row="2"
                x:Name="DescriptionText"
                Text="Wordsometric allows you to create isometric layers without manually having to set them up."
                FontSize="13"
                Foreground="{StaticResource SecondaryTextBrush}"
                TextWrapping="Wrap"
                LineHeight="20"
                Margin="0,0,0,20" />

            <!-- Divider -->
            <Border
                Grid.Row="3"
                Height="1"
                Background="#E5E5E5"
                Margin="0,0,0,20" />

            <!-- Install button -->
            <local:InstallButton
                Grid.Row="4"
                x:Name="InstallBtn"
                HorizontalAlignment="Left"
                Margin="0,0,0,16" />

            <!-- Installation stats -->
            <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="6">
                <FontIcon
                    FontFamily="Segoe Fluent Icons"
                    Glyph="&#xE8A7;"
                    FontSize="14"
                    Foreground="{StaticResource SecondaryTextBrush}" />
                <TextBlock
                    x:Name="InstallationsText"
                    Text="300,00 active installations"
                    FontSize="12"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    VerticalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>

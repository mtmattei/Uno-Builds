<Page
    x:Class="ZaraApp.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ZaraApp.Controls"
    Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="45"/>   <!-- Tabs -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Fixed Header -->
        <Grid Grid.Row="0"
              Background="White"
              BorderBrush="#E5E5E5"
              BorderThickness="0,0,0,1">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Hamburger Menu -->
            <Button Grid.Column="0"
                    Width="56"
                    Height="60"
                    Background="Transparent"
                    BorderThickness="0">
                <FontIcon Glyph="&#xE700;"
                          FontSize="20"
                          Foreground="#333333"/>
            </Button>

            <!-- Right Icons -->
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        Spacing="0"
                        Margin="0,0,16,0">

                <Button Width="48" Height="60"
                        Background="Transparent"
                        BorderThickness="0">
                    <StackPanel Spacing="2">
                        <FontIcon Glyph="&#xE71C;" FontSize="20"/>
                        <TextBlock Text="FILTERS"
                                   FontSize="9"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Width="48" Height="60"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE721;" FontSize="20"/>
                </Button>

                <Button Width="48" Height="60"
                        Background="Transparent"
                        BorderThickness="0">
                    <FontIcon Glyph="&#xE7BF;" FontSize="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Category Tabs -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1">

            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollMode="Enabled">
                <StackPanel Orientation="Horizontal"
                            Padding="16,0">

                    <Button Content="VIEW ALL" Style="{StaticResource SelectedTabStyle}"/>
                    <Button Content="RAW DENIM" Style="{StaticResource CategoryTabStyle}"/>
                    <Button Content="FLARE" Style="{StaticResource CategoryTabStyle}"/>
                    <Button Content="BAGGY" Style="{StaticResource CategoryTabStyle}"/>
                    <Button Content="BALLOON" Style="{StaticResource CategoryTabStyle}"/>
                    <Button Content="SLIM" Style="{StaticResource CategoryTabStyle}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Scrollable Content -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,24,16,24">

            <StackPanel Spacing="32">

                <!-- Section 1: The Fits Grid -->
                <StackPanel>
                    <TextBlock Text="THE FITS - ZARA MAN JEANS"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Row 1 -->
                        <controls:ProductGridItem Grid.Row="0" Grid.Column="0"
                                                  FitName="BAGGY FIT"
                                                  ImageSource="ms-appx:///Assets/Images/hero1.jpg"/>
                        <controls:ProductGridItem Grid.Row="0" Grid.Column="2"
                                                  FitName="FLARE FIT"
                                                  ImageSource="ms-appx:///Assets/Images/hero2.jpg"/>

                        <!-- Row 2 -->
                        <controls:ProductGridItem Grid.Row="1" Grid.Column="0"
                                                  FitName="SLIM FIT"
                                                  ImageSource="ms-appx:///Assets/Images/hero3.jpg"
                                                  Margin="0,12,0,0"/>
                        <controls:ProductGridItem Grid.Row="1" Grid.Column="2"
                                                  FitName="STRAIGHT FIT"
                                                  ImageSource="ms-appx:///Assets/Images/hero4.jpg"
                                                  Margin="0,12,0,0"/>
                    </Grid>
                </StackPanel>

                <!-- Section 2: Straight // Basic -->
                <StackPanel>
                    <TextBlock Text="FIT: STRAIGHT // BASIC"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.StraightProducts}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <controls:ProductCard/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

                <!-- Section 3: Flare // Boot Cut -->
                <StackPanel>
                    <TextBlock Text="FIT: FLARE // BOOT CUT"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.FlareProducts}">
                            <ItemsRepeater.Layout>
                                <StackLayout Orientation="Horizontal" Spacing="12"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <controls:ProductCard/>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>

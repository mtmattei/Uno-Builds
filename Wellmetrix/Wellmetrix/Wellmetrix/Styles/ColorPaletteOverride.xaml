<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Background Colors -->
    <Color x:Key="DeepSpaceColor">#0C1222</Color>
    <Color x:Key="DarkNavyColor">#1A1F3C</Color>
    <Color x:Key="ElevatedSurfaceColor">#252B4A</Color>
    <Color x:Key="MidnightBlueColor">#1E293B</Color>

    <!-- Organ-Specific Accent Colors -->
    <Color x:Key="HeartAccentColor">#F43F5E</Color>
    <Color x:Key="HeartLightColor">#FFF1F2</Color>
    <Color x:Key="BrainAccentColor">#8B5CF6</Color>
    <Color x:Key="BrainLightColor">#F5F3FF</Color>
    <Color x:Key="LungsAccentColor">#06B6D4</Color>
    <Color x:Key="LungsLightColor">#ECFEFF</Color>
    <Color x:Key="LiverAccentColor">#F59E0B</Color>
    <Color x:Key="LiverLightColor">#FFFBEB</Color>
    <Color x:Key="KidneysAccentColor">#10B981</Color>
    <Color x:Key="KidneysLightColor">#ECFDF5</Color>
    <Color x:Key="PancreasAccentColor">#EC4899</Color>
    <Color x:Key="PancreasLightColor">#FDF2F8</Color>

    <!-- Semantic Colors -->
    <Color x:Key="SuccessColor">#10B981</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="InfoColor">#06B6D4</Color>
    <Color x:Key="DangerColor">#EF4444</Color>

    <!-- Text Colors -->
    <Color x:Key="TextPrimaryColor">#FFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#B3FFFFFF</Color>
    <Color x:Key="TextTertiaryColor">#80FFFFFF</Color>
    <Color x:Key="TextMutedColor">#59FFFFFF</Color>

    <!-- Background Brushes -->
    <SolidColorBrush x:Key="DeepSpaceBrush" Color="{StaticResource DeepSpaceColor}" />
    <SolidColorBrush x:Key="DarkNavyBrush" Color="{StaticResource DarkNavyColor}" />
    <SolidColorBrush x:Key="ElevatedSurfaceBrush" Color="{StaticResource ElevatedSurfaceColor}" />
    <SolidColorBrush x:Key="MidnightBlueBrush" Color="{StaticResource MidnightBlueColor}" />

    <!-- Organ Accent Brushes -->
    <SolidColorBrush x:Key="HeartAccentBrush" Color="{StaticResource HeartAccentColor}" />
    <SolidColorBrush x:Key="BrainAccentBrush" Color="{StaticResource BrainAccentColor}" />
    <SolidColorBrush x:Key="LungsAccentBrush" Color="{StaticResource LungsAccentColor}" />
    <SolidColorBrush x:Key="LiverAccentBrush" Color="{StaticResource LiverAccentColor}" />
    <SolidColorBrush x:Key="KidneysAccentBrush" Color="{StaticResource KidneysAccentColor}" />
    <SolidColorBrush x:Key="PancreasAccentBrush" Color="{StaticResource PancreasAccentColor}" />

    <!-- Semantic Brushes -->
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <!-- Glass Effect Brushes (semi-transparent) -->
    <SolidColorBrush x:Key="GlassSurfaceBrush" Color="#0DFFFFFF" />
    <SolidColorBrush x:Key="GlassSurfaceHoverBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="#14FFFFFF" />
    <SolidColorBrush x:Key="GlassBorderActiveBrush" Color="#26FFFFFF" />
    <SolidColorBrush x:Key="GlassStrongBrush" Color="#1AFFFFFF" />

    <!-- Text Brushes -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />

    <!-- Override Application Background -->
    <StaticResource x:Key="ApplicationPageBackgroundThemeBrush" ResourceKey="DeepSpaceBrush" />

</ResourceDictionary>

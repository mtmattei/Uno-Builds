<UserControl x:Class="Wellmetrix.Controls.TrendChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <utu:AutoLayout Orientation="Vertical" Spacing="16">

        <!-- Header -->
        <utu:AutoLayout Orientation="Horizontal"
                       Justify="SpaceBetween"
                       PrimaryAxisAlignment="Stretch">
            <TextBlock Text="WEEKLY TREND"
                      Style="{StaticResource OverlineTextStyle}" />
            <TextBlock x:Name="ChangeText"
                      Text="+3.2% vs last week"
                      Style="{StaticResource CaptionTextStyle}"
                      Foreground="{StaticResource KidneysAccentBrush}" />
        </utu:AutoLayout>

        <!-- Chart -->
        <Grid Height="100">
            <ItemsControl x:Name="BarsContainer">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <utu:AutoLayout Orientation="Horizontal"
                                       Spacing="8"
                                       Justify="SpaceBetween"
                                       PrimaryAxisAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <utu:AutoLayout Orientation="Vertical"
                                       Spacing="8"
                                       CounterAxisAlignment="Center"
                                       utu:AutoLayout.PrimaryAlignment="Stretch">
                            <!-- Bar container -->
                            <Grid Height="70"
                                 VerticalAlignment="Bottom"
                                 utu:AutoLayout.PrimaryAlignment="Stretch">
                                <Border x:Name="Bar"
                                       Background="{StaticResource GlassBorderBrush}"
                                       Width="24"
                                       CornerRadius="4"
                                       VerticalAlignment="Bottom"
                                       Height="{Binding NormalizedHeight}" />
                            </Grid>
                            <!-- Day label -->
                            <TextBlock Text="{Binding Day}"
                                      Style="{StaticResource CaptionTextStyle}"
                                      HorizontalAlignment="Center" />
                        </utu:AutoLayout>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

    </utu:AutoLayout>

</UserControl>

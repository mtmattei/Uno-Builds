<UserControl x:Class="Wellmetrix.Controls.CircularProgress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Viewbox>
        <Grid Width="120" Height="120">
            <!-- Background ring -->
            <Ellipse Stroke="{StaticResource GlassBorderBrush}"
                     StrokeThickness="10"
                     Width="100"
                     Height="100" />

            <!-- Progress arc -->
            <Path x:Name="ProgressArc"
                  Stroke="{StaticResource LungsAccentBrush}"
                  StrokeThickness="10">
                <Path.Data>
                    <PathGeometry>
                        <PathGeometry.Figures>
                            <PathFigure StartPoint="60,10">
                                <ArcSegment x:Name="ArcSegment"
                                           Point="59.99,10"
                                           Size="50,50"
                                           SweepDirection="Clockwise"
                                           IsLargeArc="True" />
                            </PathFigure>
                        </PathGeometry.Figures>
                    </PathGeometry>
                </Path.Data>
            </Path>

            <!-- Center content -->
            <StackPanel HorizontalAlignment="Center"
                       VerticalAlignment="Center">
                <TextBlock x:Name="ValueText"
                          Text="94"
                          Style="{StaticResource MetricValueTextStyle}"
                          HorizontalAlignment="Center"
                          FontSize="36" />
                <TextBlock Text="/100"
                          Style="{StaticResource CaptionTextStyle}"
                          HorizontalAlignment="Center"
                          Margin="0,-4,0,0" />
            </StackPanel>
        </Grid>
    </Viewbox>

</UserControl>

<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>

    <!--
      Black Monochromatic Theme
      A pure black-on-black design using only shades of black, charcoal, and gray.
      Inspired by Bloomberg Terminal and high-end financial dashboards.
    -->
    <ResourceDictionary x:Key="Dark">
      <!-- Primary accent: bright white against pure black for maximum contrast -->
      <Color x:Key="PrimaryColor">#FFE0E0E0</Color>
      <Color x:Key="OnPrimaryColor">#FF000000</Color>
      <Color x:Key="PrimaryContainerColor">#FF1A1A1A</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFD0D0D0</Color>

      <!-- Secondary: medium gray tones -->
      <Color x:Key="SecondaryColor">#FFA0A0A0</Color>
      <Color x:Key="OnSecondaryColor">#FF000000</Color>
      <Color x:Key="SecondaryContainerColor">#FF151515</Color>
      <Color x:Key="OnSecondaryContainerColor">#FFB8B8B8</Color>

      <!-- Tertiary: darker gray -->
      <Color x:Key="TertiaryColor">#FF787878</Color>
      <Color x:Key="OnTertiaryColor">#FF000000</Color>
      <Color x:Key="TertiaryContainerColor">#FF111111</Color>
      <Color x:Key="OnTertiaryContainerColor">#FF909090</Color>

      <!-- Error: muted warm gray (subtle red undertone) -->
      <Color x:Key="ErrorColor">#FFB0B0B0</Color>
      <Color x:Key="ErrorContainerColor">#FF1C1C1C</Color>
      <Color x:Key="OnErrorColor">#FF000000</Color>
      <Color x:Key="OnErrorContainerColor">#FFC8C8C8</Color>

      <!-- Surfaces: pure black gradient -->
      <Color x:Key="BackgroundColor">#FF000000</Color>
      <Color x:Key="OnBackgroundColor">#FFE8E8E8</Color>
      <Color x:Key="SurfaceColor">#FF0A0A0A</Color>
      <Color x:Key="OnSurfaceColor">#FFE8E8E8</Color>
      <Color x:Key="SurfaceVariantColor">#FF141414</Color>
      <Color x:Key="OnSurfaceVariantColor">#FF9E9E9E</Color>

      <!-- Borders and dividers: subtle charcoal lines -->
      <Color x:Key="OutlineColor">#FF222222</Color>
      <Color x:Key="OutlineVariantColor">#FF333333</Color>

      <!-- Inverse and tint -->
      <Color x:Key="OnSurfaceInverseColor">#FF000000</Color>
      <Color x:Key="SurfaceInverseColor">#FFE8E8E8</Color>
      <Color x:Key="PrimaryInverseColor">#FF303030</Color>
      <Color x:Key="SurfaceTintColor">#FFE0E0E0</Color>
    </ResourceDictionary>

    <!-- Light theme (kept minimal for completeness) -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#FF303030</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#FFE0E0E0</Color>
      <Color x:Key="OnPrimaryContainerColor">#FF1A1A1A</Color>
      <Color x:Key="SecondaryColor">#FF606060</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#FFEEEEEE</Color>
      <Color x:Key="OnSecondaryContainerColor">#FF333333</Color>
      <Color x:Key="TertiaryColor">#FF808080</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#FFF5F5F5</Color>
      <Color x:Key="OnTertiaryContainerColor">#FF444444</Color>
      <Color x:Key="ErrorColor">#FF505050</Color>
      <Color x:Key="ErrorContainerColor">#FFF0F0F0</Color>
      <Color x:Key="OnErrorColor">#FFFFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#FF333333</Color>
      <Color x:Key="BackgroundColor">#FFFAFAFA</Color>
      <Color x:Key="OnBackgroundColor">#FF1A1A1A</Color>
      <Color x:Key="SurfaceColor">#FFFFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#FF1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#FFF5F5F5</Color>
      <Color x:Key="OnSurfaceVariantColor">#FF757575</Color>
      <Color x:Key="OutlineColor">#FFD0D0D0</Color>
      <Color x:Key="OutlineVariantColor">#FFE0E0E0</Color>
      <Color x:Key="OnSurfaceInverseColor">#FFF5F5F5</Color>
      <Color x:Key="SurfaceInverseColor">#FF303030</Color>
      <Color x:Key="PrimaryInverseColor">#FFE0E0E0</Color>
      <Color x:Key="SurfaceTintColor">#FF303030</Color>
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

<UserControl x:Class="ListHold.Controls.HoldProgressRing"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ListHold.Controls"
             Width="36"
             Height="36">

    <Grid>
        <!-- Background circle -->
        <Ellipse Width="32"
                 Height="32"
                 Stroke="{StaticResource RingBackgroundBrush}"
                 StrokeThickness="2"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <!-- Progress arc using Path -->
        <Path x:Name="ProgressArc"
              Stroke="{StaticResource RingFillBrush}"
              StrokeThickness="2"
              HorizontalAlignment="Center"
              VerticalAlignment="Center" />

        <!-- Center icon -->
        <FontIcon x:Name="CenterIcon"
                  Glyph="&#xE710;"
                  FontSize="14"
                  Foreground="{StaticResource TextTertiaryBrush}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
            <FontIcon.RenderTransform>
                <RotateTransform x:Name="IconRotation" CenterX="7" CenterY="7" Angle="0" />
            </FontIcon.RenderTransform>
        </FontIcon>
    </Grid>
</UserControl>

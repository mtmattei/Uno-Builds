<UserControl x:Class="ListHold.Controls.RevealableListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ListHold.Controls"
             xmlns:utu="using:Uno.Toolkit.UI"
             x:Name="Root">

    <Border x:Name="ContainerBorder"
            Background="{ThemeResource SurfaceBrush}"
            CornerRadius="12"
            Margin="0,0,0,8"
            MinHeight="80"
            PointerPressed="OnPointerPressed"
            PointerReleased="OnPointerReleased"
            PointerExited="OnPointerExited"
            PointerCanceled="OnPointerCanceled"
            PointerEntered="OnPointerEntered">

        <Border.RenderTransform>
            <ScaleTransform x:Name="ContainerScale" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>

        <Grid Padding="20,20,20,20">
            <!-- Progress Ring - absolute positioned, clickable to collapse -->
            <local:HoldProgressRing x:Name="ProgressRing"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    PointerPressed="OnProgressRingPressed" />

            <!-- Content Area with left padding for indicator -->
            <Grid Margin="52,0,0,0">
                <StackPanel>
                    <!-- Stage 0: Always visible - Title and Preview -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="TitleText"
                                   Style="{StaticResource ItemTitleStyle}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />

                        <TextBlock x:Name="PreviewText"
                                   Grid.Column="1"
                                   Style="{StaticResource ItemPreviewStyle}"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>

                    <!-- Stage 1: Details paragraph -->
                    <Border x:Name="Stage1Container"
                            Visibility="Collapsed"
                            Opacity="0"
                            Margin="0,16,0,0"
                            MaxHeight="80">
                        <TextBlock x:Name="DetailsText"
                                   Style="{StaticResource ItemDescriptionStyle}" />
                    </Border>

                    <!-- Stage 2: Meta tags -->
                    <Border x:Name="Stage2Container"
                            Visibility="Collapsed"
                            Opacity="0"
                            Margin="0,12,0,0"
                            MaxHeight="50">
                        <ItemsControl x:Name="MetaItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource MetaBackgroundBrush}"
                                            CornerRadius="6"
                                            Padding="10,4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{Binding Key}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                            <TextBlock Text="{Binding Value}"
                                                       FontSize="11"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource ButtonSecondaryTextBrush}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <!-- Stage 3: Action buttons -->
                    <Border x:Name="Stage3Container"
                            Visibility="Collapsed"
                            Opacity="0"
                            Margin="0,16,0,0"
                            MaxHeight="60">
                        <ItemsControl x:Name="ActionsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="8" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Hold hint - bottom right -->
            <TextBlock x:Name="HoldHintText"
                       Text="Hold to reveal"
                       Style="{StaticResource HoldHintStyle}"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,-12"
                       Opacity="0" />

        </Grid>
    </Border>
</UserControl>

<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <!-- Dark Theme - Primary theme per design brief -->
    <ResourceDictionary x:Key="Dark">
      <!-- Surface/Background Colors from Design Brief -->
      <Color x:Key="PrimaryColor">#6366F1</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#4F46E5</Color>
      <Color x:Key="OnPrimaryContainerColor">#A5B4FC</Color>
      <Color x:Key="SecondaryColor">#A5B4FC</Color>
      <Color x:Key="OnSecondaryColor">#0A0A0F</Color>
      <Color x:Key="SecondaryContainerColor">#1E1E2D</Color>
      <Color x:Key="OnSecondaryContainerColor">#A5B4FC</Color>
      <Color x:Key="TertiaryColor">#FFB693</Color>
      <Color x:Key="OnTertiaryColor">#0A0A0F</Color>
      <Color x:Key="TertiaryContainerColor">#1E1E2D</Color>
      <Color x:Key="OnTertiaryContainerColor">#FFB693</Color>
      <Color x:Key="ErrorColor">#FFB4AB</Color>
      <Color x:Key="ErrorContainerColor">#93000A</Color>
      <Color x:Key="OnErrorColor">#690005</Color>
      <Color x:Key="OnErrorContainerColor">#FFDAD6</Color>
      <Color x:Key="BackgroundColor">#0A0A0F</Color>
      <Color x:Key="OnBackgroundColor">#FFFFFF</Color>
      <Color x:Key="SurfaceColor">#14141F</Color>
      <Color x:Key="OnSurfaceColor">#FFFFFF</Color>
      <Color x:Key="SurfaceVariantColor">#1E1E2D</Color>
      <Color x:Key="OnSurfaceVariantColor">#D9D9D9</Color>
      <Color x:Key="OutlineColor">#0FFFFFFF</Color>
      <Color x:Key="OnSurfaceInverseColor">#0A0A0F</Color>
      <Color x:Key="SurfaceInverseColor">#FFFFFF</Color>
      <Color x:Key="PrimaryInverseColor">#4F46E5</Color>
      <Color x:Key="SurfaceTintColor">#6366F1</Color>
      <Color x:Key="OutlineVariantColor">#14FFFFFF</Color>
    </ResourceDictionary>
    <!-- Light Theme - Fallback -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#6366F1</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#E5DEFF</Color>
      <Color x:Key="OnPrimaryContainerColor">#4F46E5</Color>
      <Color x:Key="SecondaryColor">#6366F1</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#EBDDFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#4F46E5</Color>
      <Color x:Key="TertiaryColor">#FFB693</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#CFE4FF</Color>
      <Color x:Key="OnTertiaryContainerColor">#001D36</Color>
      <Color x:Key="ErrorColor">#B3261E</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#0A0A0F</Color>
      <Color x:Key="OnBackgroundColor">#FFFFFF</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1C1B1F</Color>
      <Color x:Key="SurfaceVariantColor">#F2EFF5</Color>
      <Color x:Key="OnSurfaceVariantColor">#8B8494</Color>
      <Color x:Key="OutlineColor">#79747E</Color>
      <Color x:Key="OnSurfaceInverseColor">#F4EFF4</Color>
      <Color x:Key="SurfaceInverseColor">#313033</Color>
      <Color x:Key="PrimaryInverseColor">#C8BFFF</Color>
      <Color x:Key="SurfaceTintColor">#6366F1</Color>
      <Color x:Key="OutlineVariantColor">#C9C5D0</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

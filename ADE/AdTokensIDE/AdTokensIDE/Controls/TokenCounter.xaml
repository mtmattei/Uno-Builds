<UserControl x:Class="AdTokensIDE.Controls.TokenCounter"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AdTokensIDE.Controls">

    <Border Background="{ThemeResource SurfaceVariantBrush}"
            CornerRadius="6"
            Padding="12,8">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <!-- Odometer display -->
            <Border Background="#0D0D0D"
                    CornerRadius="4"
                    Padding="8,6"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <!-- Digit containers - each digit rolls independently -->
                    <Border x:Name="Digit0" Width="14" Height="20" Background="#1A1A1A" CornerRadius="2">
                        <TextBlock x:Name="DigitText0" Text="0"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="Digit1" Width="14" Height="20" Background="#1A1A1A" CornerRadius="2">
                        <TextBlock x:Name="DigitText1" Text="0"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="Digit2" Width="14" Height="20" Background="#1A1A1A" CornerRadius="2">
                        <TextBlock x:Name="DigitText2" Text="0"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="Digit3" Width="14" Height="20" Background="#1A1A1A" CornerRadius="2">
                        <TextBlock x:Name="DigitText3" Text="0"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="Digit4" Width="14" Height="20" Background="#1A1A1A" CornerRadius="2">
                        <TextBlock x:Name="DigitText4" Text="0"
                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Label stack -->
            <StackPanel VerticalAlignment="Center" Spacing="0">
                <TextBlock x:Name="TokenLabel" Text="tokens"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock x:Name="EarnedLabel" Text=""
                           Style="{StaticResource LabelSmall}"
                           Foreground="{StaticResource SponsorLimeGreenBrush}"
                           Visibility="Collapsed" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

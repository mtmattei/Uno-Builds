<Page x:Class="AdTokensIDE.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AdTokensIDE"
      xmlns:controls="using:AdTokensIDE.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      Background="{ThemeResource BackgroundBrush}">

    <Grid x:Name="RootGrid">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarColumn.Width" Value="220" />
                        <Setter Target="SolutionExplorerPanel.Visibility" Value="Visible" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarColumn.Width" Value="0" />
                        <Setter Target="SolutionExplorerPanel.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <MenuBar Grid.Row="0" Background="{ThemeResource SurfaceBrush}">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="New Project..." />
                <MenuFlyoutItem Text="Open..." />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Exit" />
            </MenuBarItem>
            <MenuBarItem Title="Edit">
                <MenuFlyoutItem Text="Undo" />
                <MenuFlyoutItem Text="Redo" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="Cut" />
                <MenuFlyoutItem Text="Copy" />
                <MenuFlyoutItem Text="Paste" />
            </MenuBarItem>
            <MenuBarItem Title="View">
                <MenuFlyoutItem Text="Solution Explorer" />
                <MenuFlyoutItem Text="Output" />
                <MenuFlyoutItem Text="Error List" />
            </MenuBarItem>
            <MenuBarItem Title="Build">
                <MenuFlyoutItem Text="Build Solution" />
                <MenuFlyoutItem Text="Rebuild Solution" />
                <MenuFlyoutItem Text="Clean Solution" />
            </MenuBarItem>
            <MenuBarItem Title="AI Chat">
                <MenuFlyoutItem Text="New Conversation" />
                <MenuFlyoutItem Text="Clear History" />
                <MenuFlyoutSeparator />
                <MenuFlyoutItem Text="View Sponsors" />
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="Documentation" />
                <MenuFlyoutItem Text="About AdTokens IDE" />
            </MenuBarItem>
        </MenuBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Solution Explorer Sidebar -->
            <Border x:Name="SolutionExplorerPanel"
                    Grid.Column="0"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="SOLUTION EXPLORER"
                               Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               Margin="12,12,12,8" />

                    <TreeView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.SolutionItems}"
                              SelectionMode="Single">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <TreeViewItem ItemsSource="{Binding Children}"
                                              IsExpanded="{Binding IsExpanded}">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="{Binding IconGlyph}"
                                                  FontSize="14"
                                                  Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource BodySmall}"
                                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                                    </StackPanel>
                                </TreeViewItem>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>
            </Border>

            <!-- Chat Panel -->
            <Grid Grid.Column="1" Background="{ThemeResource BackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Chat Header -->
                <Border Grid.Row="0"
                        Background="{ThemeResource SurfaceBrush}"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                            <Border Background="{ThemeResource PrimaryBrush}"
                                    CornerRadius="20"
                                    Width="40" Height="40">
                                <FontIcon Glyph="&#xE77B;"
                                          Foreground="{ThemeResource OnPrimaryBrush}"
                                          FontSize="20"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="AI Assistant"
                                           Style="{StaticResource TitleMedium}" />
                                <TextBlock Text="Powered by ads • Free tier"
                                           Style="{StaticResource LabelSmall}"
                                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Token Counter - Digital Odometer Style -->
                        <controls:TokenCounter Grid.Column="2"
                                               Value="{x:Bind ViewModel.DisplayedTokenCount, Mode=OneWay}"
                                               VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Messages List -->
                <ScrollViewer Grid.Row="1" Padding="16">
                    <StackPanel Spacing="16">
                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Messages}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,8">
                                        <Border HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignmentConverter}}"
                                                MaxWidth="500"
                                                Padding="16,12"
                                                CornerRadius="12"
                                                Background="{Binding IsUser, Converter={StaticResource BoolToMessageBgConverter}}">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding Content}"
                                                           TextWrapping="Wrap"
                                                           Style="{StaticResource BodyMedium}"
                                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            Visibility="{Binding SponsorName, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <FontIcon Glyph="&#xE8EC;"
                                                              FontSize="10"
                                                              Foreground="{StaticResource SponsorLimeGreenBrush}" />
                                                    <TextBlock Style="{StaticResource LabelSmall}"
                                                               Foreground="{StaticResource SponsorLimeGreenBrush}">
                                                        <Run Text="Sponsored by " />
                                                        <Run Text="{Binding SponsorName}" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>

                        <!-- Generating Response Panel -->
                        <Border Visibility="{x:Bind ViewModel.IsGenerating, Mode=OneWay}"
                                Background="{ThemeResource SurfaceVariantBrush}"
                                CornerRadius="12"
                                Padding="16"
                                MaxWidth="500"
                                HorizontalAlignment="Left">
                            <StackPanel Spacing="12">
                                <!-- Typing Indicator -->
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Generating response..."
                                               Style="{StaticResource BodySmall}"
                                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                                </StackPanel>

                                <!-- Current Response Preview -->
                                <TextBlock Text="{x:Bind ViewModel.CurrentResponse, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource BodyMedium}"
                                           Visibility="{x:Bind ViewModel.CurrentResponse, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" />

                                <!-- Ad Card -->
                                <Border Background="{ThemeResource SurfaceBrush}"
                                        CornerRadius="8"
                                        Padding="12"
                                        BorderBrush="{ThemeResource OutlineBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Style="{StaticResource LabelSmall}"
                                                       Foreground="{StaticResource SponsorLimeGreenBrush}">
                                                <Run Text="Your response is " />
                                                <Run Text="sponsored by" FontWeight="SemiBold" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="1"
                                                       Style="{StaticResource LabelSmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                <Run Text="Ad " />
                                                <Run Text="{x:Bind ViewModel.CurrentAdIndex, Mode=OneWay}" />
                                                <Run Text="/5" />
                                            </TextBlock>
                                        </Grid>

                                        <ProgressBar IsIndeterminate="True"
                                                     Height="4" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="48" Height="48"
                                                    CornerRadius="8"
                                                    Margin="0,0,12,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#606060" Offset="0" />
                                                        <GradientStop Color="#303030" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <FontIcon Glyph="{x:Bind ViewModel.CurrentAd.IconGlyph, Mode=OneWay, FallbackValue='&#xE7F4;'}"
                                                          FontSize="24"
                                                          Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Text="{x:Bind ViewModel.CurrentAd.ProductName, Mode=OneWay, FallbackValue='Loading...'}"
                                                           Style="{StaticResource TitleSmall}"
                                                           Foreground="{StaticResource SponsorLimeGreenBrush}" />
                                                <TextBlock Text="{x:Bind ViewModel.CurrentAd.Tagline, Mode=OneWay}"
                                                           Style="{StaticResource BodySmall}"
                                                           TextWrapping="Wrap"
                                                           MaxLines="2"
                                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                                <TextBlock Text="{x:Bind ViewModel.CurrentAd.Disclaimer, Mode=OneWay}"
                                                           Style="{StaticResource LabelSmall}"
                                                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                           Opacity="0.7" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Style="{StaticResource LabelSmall}"
                                                       Foreground="{StaticResource SponsorLimeGreenBrush}">
                                                <Run Text="This ad sponsors ~" />
                                                <Run Text="{x:Bind ViewModel.CurrentAd.SponsoredTokens, Mode=OneWay, FallbackValue='0'}" />
                                                <Run Text=" tokens" />
                                            </TextBlock>
                                            <Button Grid.Column="1"
                                                    Content="Learn More"
                                                    Style="{StaticResource TextButtonStyle}"
                                                    Padding="8,4" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Input Area -->
                <Border Grid.Row="2"
                        Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 PlaceholderText="Ask the AI anything... (sponsored response)"
                                 Text="{x:Bind ViewModel.InputText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{x:Bind ViewModel.IsGenerating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                 VerticalAlignment="Center" />

                        <Button Grid.Column="1"
                                Command="{x:Bind ViewModel.SendMessageCommand}"
                                IsEnabled="{x:Bind ViewModel.IsGenerating, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
                                Margin="8,0,0,0"
                                Style="{StaticResource FilledButtonStyle}">
                            <FontIcon Glyph="&#xE724;" FontSize="16" />
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource TertiaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Ready"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{ThemeResource SecondaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="AI: Connected"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource SponsorLimeGreenBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="Ads: Active"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{StaticResource SponsorLimeGreenBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16">
                    <TextBlock Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}">
                        <Run Text="Free Tier • 5,000 tokens" />
                    </TextBlock>
                    <Button Content="GO PREMIUM"
                            Style="{StaticResource TextButtonStyle}"
                            Foreground="{ThemeResource SecondaryBrush}"
                            FontWeight="Bold"
                            Padding="8,2" />
                    <TextBlock Text="Ln 42"
                               Style="{StaticResource LabelSmall}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>

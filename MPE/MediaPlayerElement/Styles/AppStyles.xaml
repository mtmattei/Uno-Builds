<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:utu="using:Uno.Toolkit.UI">

    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#1C1C1E" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8E8E93" />
    <SolidColorBrush x:Key="AccentBrush" Color="#8B7CF6" />
    <SolidColorBrush x:Key="VideoOverlayBrush" Color="#80000000" />
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F5F7" />

    <utu:ResponsiveLayout x:Key="DefaultResponsiveLayout"
                          Narrow="400"
                          Normal="600" 
                          Wide="800" />

    <x:Double x:Key="NarrowMaxWidth">350</x:Double>
    <x:Double x:Key="NormalMaxWidth">500</x:Double>
    <x:Double x:Key="WideMaxWidth">600</x:Double>

    <Thickness x:Key="NarrowMargin">10</Thickness>
    <Thickness x:Key="NormalMargin">20</Thickness>
    <Thickness x:Key="WideMargin">40</Thickness>

    <x:Double x:Key="NarrowTitleSize">18</x:Double>
    <x:Double x:Key="NormalTitleSize">22</x:Double>
    <x:Double x:Key="WideTitleSize">26</x:Double>

    <Style x:Key="StyledMediaTransportControlsStyle" TargetType="MediaTransportControls">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="#33000000" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0,0,16,16" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Opacity" Value="0.85" />
    </Style>

    <Style x:Key="StyledMediaPlayerElementStyle" TargetType="MediaPlayerElement">
        <Setter Property="Background" Value="#1A1A1A" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="BorderBrush">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6B46C1" Offset="0"/>
                    <GradientStop Color="#9333EA" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="CornerRadius" Value="16,16,0,0" />
    </Style>

    <Style x:Key="BottomTabBarStyle" TargetType="utu:TabBar">
        <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="#E5E5EA" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="0,8" />
        <Setter Property="Height" Value="80" />
    </Style>

</ResourceDictionary>

<UserControl x:Class="MPE.Controls.TechBiteCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <Border Background="{StaticResource CardBackgroundBrush}"
            CornerRadius="16"
            Padding="{utu:Responsive Narrow=12, Normal=16, Wide=20}"
            BorderThickness="0">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="⚡" FontSize="{utu:Responsive Narrow=14, Normal=14, Wide=16}"/>
                    <TextBlock Text="Uno Tech Bites"
                               Foreground="{StaticResource AccentBrush}"
                               FontWeight="Medium"/>
                </StackPanel>
                <TextBlock Text="{x:Bind Title}"
                           FontWeight="Medium"
                           Foreground="{StaticResource PrimaryTextBrush}"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Width="60" 
                    Height="60"
                    CornerRadius="12"
                    Background="{x:Bind BackgroundColor}">
                <TextBlock Text="{x:Bind Emoji}"
                           FontSize="{utu:Responsive Narrow=20, Normal=24, Wide=28}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
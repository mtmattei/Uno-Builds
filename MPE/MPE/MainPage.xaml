<Page x:Class="MPE.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:MPE.Controls"
      Background="{StaticResource PageBackgroundBrush}">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="ms-appx:///Styles/AppStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="{utu:Responsive Layout={StaticResource DefaultResponsiveLayout},
                                          Narrow={StaticResource NarrowMaxWidth},
                                          Normal={StaticResource NormalMaxWidth},
                                          Wide={StaticResource WideMaxWidth}}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Top"
                  Margin="8">
                <StackPanel Spacing="{utu:Responsive Narrow=12, Normal=16, Wide=20}">

                    <Border Background="{StaticResource CardBackgroundBrush}"
                            CornerRadius="16"
                            Padding="0"
                            BorderThickness="0">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" CornerRadius="16,16,0,0" Background="#E0E0E0">
                                <Viewbox Stretch="Uniform">
                                    <Grid Width="400" Height="225">
                                        <MediaPlayerElement x:Name="myMediaPlayer"
                                                            AutoPlay="False"
                                                            AreTransportControlsEnabled="True"
                                                            Stretch="UniformToFill"
                                                            Source="{x:Bind ViewModel.FeaturedCourse.VideoSource}"
                                                            Style="{StaticResource StyledMediaPlayerElementStyle}">
                                            <MediaPlayerElement.TransportControls>
                                                <MediaTransportControls VerticalAlignment="Bottom"
                                                                        Style="{StaticResource StyledMediaTransportControlsStyle}"
                                                                        IsFullWindowButtonVisible="False"
                                                                        IsFullWindowEnabled="False" />
                                            </MediaPlayerElement.TransportControls>
                                        </MediaPlayerElement>

                                        <Border Background="{StaticResource VideoOverlayBrush}"
                                                CornerRadius="12"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Margin="12">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="▶" FontSize="12" Foreground="White" VerticalAlignment="Center"/>
                                                <TextBlock Text="Video" FontSize="12" FontWeight="Medium"
                                                           Foreground="White" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Viewbox>
                            </Border>

                            <StackPanel Grid.Row="1" Margin="16,16,16,8"
                                        Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <Border Background="#F0F0F0" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="📚" FontSize="12"/>
                                </Border>
                                <TextBlock Text="{x:Bind ViewModel.FeaturedCourse.Category}"
                                           FontSize="14"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Grid.Row="2"
                                       Text="{x:Bind ViewModel.FeaturedCourse.Title}"
                                       FontSize="{utu:Responsive Layout={StaticResource DefaultResponsiveLayout},
                                                               Narrow={StaticResource NarrowTitleSize},
                                                               Normal={StaticResource NormalTitleSize},
                                                               Wide={StaticResource WideTitleSize}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryTextBrush}"
                                       Margin="16,0,16,8"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>

                            <StackPanel Grid.Row="3" Margin="16,0,16,16"
                                        Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <Border Width="24" Height="24" CornerRadius="12" Background="#4A90E2">
                                    <TextBlock Text="{x:Bind ViewModel.FeaturedCourse.Emoji}"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{x:Bind ViewModel.FeaturedCourse.Instructor}"
                                           FontSize="14"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button Grid.Row="4"
                                    Background="{StaticResource AccentBrush}"
                                    Foreground="White"
                                    BorderThickness="0"
                                    CornerRadius="12"
                                    Padding="0,12"
                                    Margin="16,0,16,16"
                                    HorizontalAlignment="Stretch"
                                    Click="OnWatchCourseClick">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <TextBlock Text="▶" FontSize="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Watch Course" FontSize="16" FontWeight="Medium" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.TechBites}">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="12" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <controls:TechBiteCard Title="{Binding Title}"
                                                       Emoji="{Binding Emoji}"
                                                       BackgroundColor="{Binding BackgroundColor}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>

                </StackPanel>
            </Grid>
        </ScrollViewer>

        <utu:TabBar Grid.Row="1"
                    SelectedIndex="1"
                    Style="{StaticResource BottomTabBarStyle}">
            <utu:TabBarItem Content="Home">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE80F;" FontFamily="Segoe MDL2 Assets"/>
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>

            <utu:TabBarItem IsSelected="True" Content="Watch">
                <utu:TabBarItem.Icon>
                    <FontIcon Glyph="&#xE714;" FontFamily="Segoe MDL2 Assets"/>
                </utu:TabBarItem.Icon>
            </utu:TabBarItem>

        </utu:TabBar>
    </Grid>
</Page>

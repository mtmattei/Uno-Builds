<Application x:Class="Sanctum.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utum="using:Uno.Toolkit.UI.Material"
       xmlns:converters="using:Sanctum.Converters">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml">
        </utum:MaterialToolkitTheme>
        <!-- Sanctum custom styles -->
        <ResourceDictionary Source="ms-appx:///Styles/SanctumStyles.xaml"/>
      </ResourceDictionary.MergedDictionaries>

      <!-- Converters -->
      <converters:BoolToVisibilityInverseConverter x:Key="BoolToVisibilityInverseConverter"/>
      <converters:ModeToCheckedConverter x:Key="ModeToCheckedConverter"/>
      <converters:StatusToBackgroundConverter x:Key="StatusToBackgroundConverter"/>
      <converters:StatusToForegroundConverter x:Key="StatusToForegroundConverter"/>
      <converters:StatusToTextConverter x:Key="StatusToTextConverter"/>
      <converters:IntToTimeStringConverter x:Key="IntToTimeStringConverter"/>

    </ResourceDictionary>
  </Application.Resources>

</Application>

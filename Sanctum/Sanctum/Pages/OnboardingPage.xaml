<UserControl x:Class="Sanctum.Pages.OnboardingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

  <Grid Background="{ThemeResource BackgroundBrush}">

    <!-- Stepper - Fixed Top Center -->
    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,48,0,0"
                Spacing="8">
      <Border Width="{x:Bind GetStepWidth(1, ViewModel.CurrentStep), Mode=OneWay}"
              Height="3"
              CornerRadius="1.5"
              Background="{x:Bind GetStepColor(1, ViewModel.CurrentStep), Mode=OneWay}"/>
      <Border Width="{x:Bind GetStepWidth(2, ViewModel.CurrentStep), Mode=OneWay}"
              Height="3"
              CornerRadius="1.5"
              Background="{x:Bind GetStepColor(2, ViewModel.CurrentStep), Mode=OneWay}"/>
      <Border Width="{x:Bind GetStepWidth(3, ViewModel.CurrentStep), Mode=OneWay}"
              Height="3"
              CornerRadius="1.5"
              Background="{x:Bind GetStepColor(3, ViewModel.CurrentStep), Mode=OneWay}"/>
    </StackPanel>

    <!-- Main Content Area -->
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Margin="0,100,0,140">
      <Grid HorizontalAlignment="Center">

        <!-- ========== STEP 1: WELCOME ========== -->
        <StackPanel Visibility="{x:Bind IsStep(1, ViewModel.CurrentStep), Mode=OneWay}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="720"
                    Spacing="48"
                    Padding="48">

          <!-- Wind/Air Icon -->
          <Border Width="80" Height="80"
                  CornerRadius="40"
                  Background="{ThemeResource SurfaceVariantBrush}"
                  HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE81E;"
                      FontSize="36"
                      Foreground="{ThemeResource OnSurfaceVariantBrush}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
          </Border>

          <!-- Headline with Italic Emphasis -->
          <StackPanel HorizontalAlignment="Center" Spacing="20">
            <TextBlock HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="56"
                       FontWeight="Bold"
                       Foreground="{ThemeResource OnBackgroundBrush}"
                       LineHeight="64">
              <Run Text="Silence the "/>
              <Run Text="digital noise" FontStyle="Italic"/>
              <Run Text="."/>
            </TextBlock>

            <TextBlock HorizontalAlignment="Center"
                       TextAlignment="Center"
                       FontSize="18"
                       LineHeight="28"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       MaxWidth="480">
              Sanctum curates your digital life by intelligently filtering notifications, batching distractions, and protecting your focus.
            </TextBlock>
          </StackPanel>

          <!-- Feature Grid - 3 Cards -->
          <Grid ColumnSpacing="20" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="200"/>
              <ColumnDefinition Width="200"/>
              <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <!-- Focus First -->
            <Border Grid.Column="0"
                    Background="{ThemeResource SurfaceBrush}"
                    CornerRadius="20"
                    Padding="24"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="1">
              <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{ThemeResource TertiaryContainerBrush}"
                        HorizontalAlignment="Center">
                  <FontIcon Glyph="&#xE8BE;" FontSize="22"
                            Foreground="{ThemeResource TertiaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Focus First"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Protect your deep work sessions"
                           FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Privacy Core -->
            <Border Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    CornerRadius="20"
                    Padding="24"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="1">
              <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{ThemeResource TertiaryContainerBrush}"
                        HorizontalAlignment="Center">
                  <FontIcon Glyph="&#xE72E;" FontSize="22"
                            Foreground="{ThemeResource TertiaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Privacy Core"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Your data stays entirely local"
                           FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <!-- Calm UI -->
            <Border Grid.Column="2"
                    Background="{ThemeResource SurfaceBrush}"
                    CornerRadius="20"
                    Padding="24"
                    BorderBrush="{ThemeResource OutlineBrush}"
                    BorderThickness="1">
              <StackPanel Spacing="16" HorizontalAlignment="Center">
                <Border Width="48" Height="48" CornerRadius="24"
                        Background="{ThemeResource TertiaryContainerBrush}"
                        HorizontalAlignment="Center">
                  <FontIcon Glyph="&#xE9E9;" FontSize="22"
                            Foreground="{ThemeResource TertiaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Calm UI"
                           FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Designed for serenity"
                           FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
              </StackPanel>
            </Border>
          </Grid>
        </StackPanel>

        <!-- ========== STEP 2: PERSONALIZE ========== -->
        <StackPanel Visibility="{x:Bind IsStep(2, ViewModel.CurrentStep), Mode=OneWay}"
                    HorizontalAlignment="Center"
                    MaxWidth="560"
                    Spacing="40"
                    Padding="32">

          <!-- Header -->
          <StackPanel HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="What brings you here?"
                       FontSize="36"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource OnBackgroundBrush}"/>
            <TextBlock Text="Select your goals and sources to personalize your experience"
                       FontSize="15"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                       HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Goals Section -->
          <StackPanel Spacing="16">
            <TextBlock Text="PRIMARY INTENTIONS"
                       FontSize="11"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"/>

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Goals}">
              <ItemsRepeater.Layout>
                <StackLayout Spacing="12"/>
              </ItemsRepeater.Layout>
              <ItemsRepeater.ItemTemplate>
                <DataTemplate>
                  <Border Background="{ThemeResource SurfaceBrush}"
                          CornerRadius="16"
                          Padding="20"
                          BorderBrush="{ThemeResource OutlineBrush}"
                          BorderThickness="1"
                          PointerPressed="GoalCard_PointerPressed"
                          Tag="{Binding}">
                    <Grid ColumnSpacing="16">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="48"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>

                      <Border Grid.Column="0" Width="48" Height="48" CornerRadius="12"
                              Background="{ThemeResource SurfaceVariantBrush}">
                        <FontIcon Glyph="{Binding Icon}" FontSize="22"
                                  Foreground="{ThemeResource TertiaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>

                      <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{ThemeResource OnSurfaceBrush}"/>
                        <TextBlock Text="{Binding Description}"
                                   FontSize="14"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"/>
                      </StackPanel>

                      <Border Grid.Column="2" Width="24" Height="24" CornerRadius="12"
                              Background="{ThemeResource PrimaryBrush}"
                              Visibility="{Binding IsSelected}"
                              VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE73E;" FontSize="14"
                                  Foreground="{ThemeResource OnPrimaryBrush}"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
          </StackPanel>

          <!-- Sources Section -->
          <StackPanel Spacing="16">
            <TextBlock Text="SOURCES TO REGULATE"
                       FontSize="11"
                       FontWeight="SemiBold"
                       CharacterSpacing="100"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}"/>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <ItemsRepeater ItemsSource="{x:Bind ViewModel.Sources}">
                <ItemsRepeater.Layout>
                  <UniformGridLayout MinItemWidth="130" MinItemHeight="100"
                                     ItemsStretch="Fill"
                                     MinRowSpacing="12" MinColumnSpacing="12"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate>
                    <Border Background="{ThemeResource SurfaceBrush}"
                            CornerRadius="16"
                            Padding="16"
                            BorderBrush="{ThemeResource OutlineBrush}"
                            BorderThickness="1"
                            PointerPressed="SourceCard_PointerPressed"
                            Tag="{Binding}">
                      <StackPanel Spacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="{Binding Icon}" FontSize="28"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="{ThemeResource OnSurfaceBrush}"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </Grid>
          </StackPanel>
        </StackPanel>

        <!-- ========== STEP 3: READY ========== -->
        <StackPanel Visibility="{x:Bind IsStep(3, ViewModel.CurrentStep), Mode=OneWay}"
                    HorizontalAlignment="Center"
                    MaxWidth="560"
                    Spacing="36"
                    Padding="32">

          <!-- Status Badge -->
          <Border Background="{ThemeResource AllowedBackgroundBrush}"
                  CornerRadius="20"
                  Padding="16,10"
                  HorizontalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <Ellipse Width="8" Height="8" Fill="{ThemeResource AllowedForegroundBrush}"/>
              <TextBlock Text="Ready to synchronize"
                         FontSize="14" FontWeight="Medium"
                         Foreground="{ThemeResource AllowedForegroundBrush}"/>
            </StackPanel>
          </Border>

          <!-- Manifesto Quote -->
          <TextBlock Text="{x:Bind ViewModel.Manifesto, Mode=OneWay}"
                     FontSize="28"
                     FontWeight="Normal"
                     FontStyle="Italic"
                     LineHeight="40"
                     TextAlignment="Center"
                     TextWrapping="Wrap"
                     Foreground="{ThemeResource OnBackgroundBrush}"
                     HorizontalAlignment="Center"
                     MaxWidth="500"/>

          <!-- Active Protocols Card -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="20"
                  Padding="28"
                  BorderBrush="{ThemeResource OutlineBrush}"
                  BorderThickness="1">
            <StackPanel Spacing="20">
              <TextBlock Text="ACTIVE PROTOCOLS"
                         FontSize="11"
                         FontWeight="SemiBold"
                         CharacterSpacing="100"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"/>

              <ItemsRepeater ItemsSource="{x:Bind ViewModel.Rules}">
                <ItemsRepeater.Layout>
                  <StackLayout Spacing="16"/>
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Grid ColumnSpacing="16">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>

                      <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                              Background="{ThemeResource PrimaryContainerBrush}">
                        <TextBlock Text="1"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{ThemeResource OnPrimaryContainerBrush}"/>
                      </Border>

                      <TextBlock Grid.Column="1" Text="{x:Bind}"
                                 FontSize="15"
                                 LineHeight="22"
                                 TextWrapping="Wrap"
                                 Foreground="{ThemeResource OnSurfaceBrush}"
                                 VerticalAlignment="Center"/>
                    </Grid>
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </StackPanel>
          </Border>

          <!-- Slide to Enable Toggle -->
          <Border Background="{x:Bind GetToggleBackground(ViewModel.IsFocusModeEnabled), Mode=OneWay}"
                  CornerRadius="32"
                  Height="64"
                  HorizontalAlignment="Center"
                  MinWidth="300"
                  PointerPressed="SlideToggle_PointerPressed">
            <Grid Padding="8">
              <TextBlock Text="{x:Bind GetToggleText(ViewModel.IsFocusModeEnabled), Mode=OneWay}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{x:Bind GetToggleForeground(ViewModel.IsFocusModeEnabled), Mode=OneWay}"/>
            </Grid>
          </Border>

          <!-- Enter Sanctum Button -->
          <Button Visibility="{x:Bind ViewModel.IsFocusModeEnabled, Mode=OneWay}"
                  Command="{x:Bind ViewModel.EnterSanctumCommand}"
                  HorizontalAlignment="Center"
                  Background="{ThemeResource PrimaryBrush}"
                  Foreground="{ThemeResource OnPrimaryBrush}"
                  CornerRadius="28"
                  Padding="40,18"
                  FontSize="16"
                  FontWeight="SemiBold">
            <TextBlock Text="Enter Sanctum"/>
          </Button>
        </StackPanel>

      </Grid>
    </ScrollViewer>

    <!-- Bottom Action Bar with Gradient -->
    <Grid VerticalAlignment="Bottom" Height="140">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="Transparent" Offset="0"/>
          <GradientStop Color="{ThemeResource BackgroundColor}" Offset="0.4"/>
          <GradientStop Color="{ThemeResource BackgroundColor}" Offset="1"/>
        </LinearGradientBrush>
      </Grid.Background>

      <!-- Step 1 CTA -->
      <Button Visibility="{x:Bind IsStep(1, ViewModel.CurrentStep), Mode=OneWay}"
              Command="{x:Bind ViewModel.NextStepCommand}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="{ThemeResource PrimaryBrush}"
              Foreground="{ThemeResource OnPrimaryBrush}"
              CornerRadius="28"
              Padding="40,18"
              FontSize="16"
              FontWeight="SemiBold">
        <TextBlock Text="Set Preferences"/>
      </Button>

      <!-- Step 2 CTA -->
      <Button Visibility="{x:Bind IsStep(2, ViewModel.CurrentStep), Mode=OneWay}"
              Command="{x:Bind ViewModel.NextStepCommand}"
              IsEnabled="{x:Bind ViewModel.CanProceed, Mode=OneWay}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Background="{ThemeResource PrimaryBrush}"
              Foreground="{ThemeResource OnPrimaryBrush}"
              CornerRadius="28"
              Padding="40,18"
              FontSize="16"
              FontWeight="SemiBold">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Width="20" Height="20"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                        Foreground="{ThemeResource OnPrimaryBrush}"/>
          <TextBlock Text="{x:Bind GetGenerateButtonText(ViewModel.IsLoading), Mode=OneWay}"/>
        </StackPanel>
      </Button>
    </Grid>

  </Grid>
</UserControl>

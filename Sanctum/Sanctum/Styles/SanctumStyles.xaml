<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:utu="using:Uno.Toolkit.UI">

  <!-- Status Colors -->
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="AllowedBackgroundBrush" Color="#DCFCE7"/>
      <SolidColorBrush x:Key="AllowedForegroundBrush" Color="#15803D"/>
      <SolidColorBrush x:Key="BatchedBackgroundBrush" Color="#FEF3C7"/>
      <SolidColorBrush x:Key="BatchedForegroundBrush" Color="#B45309"/>
      <SolidColorBrush x:Key="MutedBackgroundBrush" Color="#F5F5F4"/>
      <SolidColorBrush x:Key="MutedForegroundBrush" Color="#78716C"/>
      <SolidColorBrush x:Key="UrgentBackgroundBrush" Color="#FEF2F2"/>
      <SolidColorBrush x:Key="UrgentForegroundBrush" Color="#DC2626"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#8B5E3C"/>
      <SolidColorBrush x:Key="SubtleBrush" Color="#A8A29E"/>
      <SolidColorBrush x:Key="HighlightBrush" Color="#E7E5E4"/>
      <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#1C1917"/>
      <SolidColorBrush x:Key="OnDarkSurfaceBrush" Color="#FFFFFF"/>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="AllowedBackgroundBrush" Color="#14532D"/>
      <SolidColorBrush x:Key="AllowedForegroundBrush" Color="#86EFAC"/>
      <SolidColorBrush x:Key="BatchedBackgroundBrush" Color="#78350F"/>
      <SolidColorBrush x:Key="BatchedForegroundBrush" Color="#FCD34D"/>
      <SolidColorBrush x:Key="MutedBackgroundBrush" Color="#44403C"/>
      <SolidColorBrush x:Key="MutedForegroundBrush" Color="#A8A29E"/>
      <SolidColorBrush x:Key="UrgentBackgroundBrush" Color="#7F1D1D"/>
      <SolidColorBrush x:Key="UrgentForegroundBrush" Color="#FCA5A5"/>
      <SolidColorBrush x:Key="AccentBrush" Color="#D4A574"/>
      <SolidColorBrush x:Key="SubtleBrush" Color="#78716C"/>
      <SolidColorBrush x:Key="HighlightBrush" Color="#44403C"/>
      <SolidColorBrush x:Key="DarkSurfaceBrush" Color="#F5F5F4"/>
      <SolidColorBrush x:Key="OnDarkSurfaceBrush" Color="#1C1917"/>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <!-- Typography Styles -->
  <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="48"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="28"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="BodyTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="Normal"/>
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="LineHeight" Value="24"/>
  </Style>

  <Style x:Key="MutedTextStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="Normal"/>
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
  </Style>

  <Style x:Key="MicroLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="11"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="CharacterSpacing" Value="80"/>
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}"/>
  </Style>

  <!-- Primary Button (Pill) -->
  <Style x:Key="PrimaryPillButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="{ThemeResource PrimaryBrush}"/>
    <Setter Property="Foreground" Value="{ThemeResource OnPrimaryBrush}"/>
    <Setter Property="CornerRadius" Value="24"/>
    <Setter Property="Padding" Value="32,16"/>
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
  </Style>

  <!-- Secondary Button -->
  <Style x:Key="SecondaryButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}"/>
    <Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="24"/>
    <Setter Property="Padding" Value="24,12"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="Medium"/>
  </Style>

  <!-- Card Style -->
  <Style x:Key="ElevatedCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="24"/>
    <Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- Dark Card Style -->
  <Style x:Key="DarkCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource DarkSurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="24"/>
  </Style>

  <!-- Selection Card (Unselected) -->
  <Style x:Key="SelectionCardStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="20"/>
    <Setter Property="BorderBrush" Value="{ThemeResource OutlineBrush}"/>
    <Setter Property="BorderThickness" Value="1"/>
  </Style>

  <!-- Selection Card (Selected) -->
  <Style x:Key="SelectionCardSelectedStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceBrush}"/>
    <Setter Property="CornerRadius" Value="16"/>
    <Setter Property="Padding" Value="20"/>
    <Setter Property="BorderBrush" Value="{ThemeResource PrimaryBrush}"/>
    <Setter Property="BorderThickness" Value="2"/>
  </Style>

  <!-- Status Pill Styles -->
  <Style x:Key="StatusPillStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="12"/>
    <Setter Property="Padding" Value="12,6"/>
  </Style>

  <!-- Nav Rail Item -->
  <Style x:Key="NavRailItemStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}"/>
    <Setter Property="Padding" Value="16,12"/>
    <Setter Property="HorizontalAlignment" Value="Stretch"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="CornerRadius" Value="12"/>
  </Style>

  <!-- Mode Switcher Tab -->
  <Style x:Key="ModeSwitcherTabStyle" TargetType="RadioButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}"/>
    <Setter Property="Padding" Value="20,12"/>
    <Setter Property="CornerRadius" Value="24"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="Medium"/>
  </Style>

</ResourceDictionary>

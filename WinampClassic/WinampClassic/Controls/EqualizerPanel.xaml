<UserControl x:Class="WinampClassic.Controls.EqualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:WinampClassic.Controls">

    <UserControl.Resources>
        <!-- EQ Metal brushed gradient background -->
        <LinearGradientBrush x:Key="EqMetalBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#C8CAD0" Offset="0.00" />
            <GradientStop Color="#B0B2B8" Offset="0.15" />
            <GradientStop Color="#A0A2A8" Offset="0.30" />
            <GradientStop Color="#C0C2C8" Offset="0.50" />
            <GradientStop Color="#A8AAB0" Offset="0.70" />
            <GradientStop Color="#909298" Offset="0.85" />
            <GradientStop Color="#B8BAC0" Offset="1.00" />
        </LinearGradientBrush>

        <!-- EQ Slider track gradient (inset) -->
        <LinearGradientBrush x:Key="EqSliderTrackBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#505560" Offset="0.0" />
            <GradientStop Color="#606570" Offset="0.3" />
            <GradientStop Color="#505560" Offset="0.7" />
            <GradientStop Color="#404550" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Inset gradient - dark edges fading to lighter center (horizontal) -->
        <LinearGradientBrush x:Key="EqSlotInsetHorizontalBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#404550" Offset="0.0" />
            <GradientStop Color="#606878" Offset="0.3" />
            <GradientStop Color="#707880" Offset="0.5" />
            <GradientStop Color="#606878" Offset="0.7" />
            <GradientStop Color="#505560" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Dark center line gradient -->
        <LinearGradientBrush x:Key="EqSlotCenterLineBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#181C20" Offset="0.0" />
            <GradientStop Color="#252A30" Offset="0.3" />
            <GradientStop Color="#303540" Offset="0.5" />
            <GradientStop Color="#252A30" Offset="0.7" />
            <GradientStop Color="#181C20" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Symmetric shadow for inset effect - dark at both top and bottom, lighter in middle -->
        <LinearGradientBrush x:Key="EqSlotTopShadowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#80000000" Offset="0.0" />
            <GradientStop Color="#40000000" Offset="0.2" />
            <GradientStop Color="#00000000" Offset="0.5" />
            <GradientStop Color="#40000000" Offset="0.8" />
            <GradientStop Color="#80000000" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Symmetric highlight for inset effect - highlights at both ends, darker in middle -->
        <LinearGradientBrush x:Key="EqSlotBottomHighlightBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#50FFFFFF" Offset="0.0" />
            <GradientStop Color="#20FFFFFF" Offset="0.2" />
            <GradientStop Color="#00FFFFFF" Offset="0.5" />
            <GradientStop Color="#20FFFFFF" Offset="0.8" />
            <GradientStop Color="#50FFFFFF" Offset="1.0" />
        </LinearGradientBrush>

        <!-- EQ Slider thumb gradient (metallic capsule) -->
        <LinearGradientBrush x:Key="EqThumbBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E8E6EE" Offset="0.0" />
            <GradientStop Color="#D0CED6" Offset="0.2" />
            <GradientStop Color="#B8B6BE" Offset="0.5" />
            <GradientStop Color="#A0A0A8" Offset="0.8" />
            <GradientStop Color="#888890" Offset="1.0" />
        </LinearGradientBrush>

        <!-- Active ON button glow -->
        <SolidColorBrush x:Key="EqOnActiveBrush" Color="#44AAFF" />
        <SolidColorBrush x:Key="EqOnInactiveBrush" Color="#606878" />

        <!-- Tab backgrounds -->
        <LinearGradientBrush x:Key="EqTabSelectedBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#D0D2D8" Offset="0.0" />
            <GradientStop Color="#B8BAC0" Offset="1.0" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="EqTabNormalBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#A0A2A8" Offset="0.0" />
            <GradientStop Color="#888A90" Offset="1.0" />
        </LinearGradientBrush>

    </UserControl.Resources>

    <!-- Main EQ Panel Container - seamless with upper section -->
    <Border x:Name="EqContainer"
            Background="{StaticResource EqMetalBrush}"
            BorderBrush="#707580"
            BorderThickness="1,0,1,1"
            CornerRadius="0,0,2,2">
        <!-- Inner shadow on sides and bottom only -->
        <Border BorderBrush="#505560"
                BorderThickness="0,0,1,1"
                CornerRadius="0,0,2,2">
            <Grid RowDefinitions="*,24">

                <!-- Main EQ Content -->
                <Grid Grid.Row="0" Padding="6,6,6,4" ColumnDefinitions="60,Auto,*">

                        <!-- Left Control Panel: Balance, ON+indicator, AUTO+indicator, PRESETS -->
                        <StackPanel Grid.Column="0" Spacing="4" VerticalAlignment="Top">

                            <!-- Balance Slider (horizontal) -->
                            <StackPanel Spacing="2">
                                <Grid Height="12" Width="50" HorizontalAlignment="Center">
                                    <!-- Track background -->
                                    <Border Background="{StaticResource EqSliderTrackBrush}"
                                            BorderBrush="#303540"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            Height="6"
                                            VerticalAlignment="Center" />
                                    <!-- Center marker -->
                                    <Border Width="1" Height="8" Background="#808090" HorizontalAlignment="Center" />
                                    <!-- Balance thumb -->
                                    <Border x:Name="BalanceThumb"
                                            Width="10" Height="12"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570"
                                            BorderThickness="1"
                                            CornerRadius="2"
                                            HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border Width="1" Height="6" Background="#80FFFFFF" />
                                            <Border Width="1" Height="6" Background="#40000000" />
                                            <Border Width="1" Height="6" Background="#80FFFFFF" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <TextBlock Text="BALANCE" FontSize="6" Foreground="#505060" HorizontalAlignment="Center" />
                            </StackPanel>

                            <!-- EQ/PL buttons side by side -->
                            <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center" Margin="0,4,0,4">
                                <!-- EQ Button with indicator -->
                                <StackPanel Orientation="Horizontal" Spacing="2">
                                    <Grid Width="22" Height="16">
                                        <Border Background="#C8CAD0"
                                                BorderBrush="#808590"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Border BorderBrush="#E0E2E8"
                                                    BorderThickness="1,1,0,0"
                                                    CornerRadius="7"
                                                    Margin="1">
                                                <TextBlock Text="EQ"
                                                           FontSize="7"
                                                           FontWeight="Bold"
                                                           Foreground="#202030"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Border>
                                    </Grid>
                                    <!-- EQ Indicator light -->
                                    <Grid Width="6" Height="6" VerticalAlignment="Center">
                                        <Ellipse Fill="#40000000" Margin="0.5,0.5,0,0" />
                                        <Ellipse x:Name="EqIndicator"
                                                 Fill="#44AAFF"
                                                 Stroke="#303540"
                                                 StrokeThickness="0.5" />
                                        <Ellipse Width="3" Height="1.5"
                                                 Fill="#60FFFFFF"
                                                 VerticalAlignment="Top"
                                                 HorizontalAlignment="Center"
                                                 Margin="0,1,0,0" />
                                    </Grid>
                                </StackPanel>
                                <!-- PL Button -->
                                <Grid Width="22" Height="16">
                                    <Border Background="#C8CAD0"
                                            BorderBrush="#808590"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border BorderBrush="#E0E2E8"
                                                BorderThickness="1,1,0,0"
                                                CornerRadius="7"
                                                Margin="1">
                                            <TextBlock Text="PL"
                                                       FontSize="7"
                                                       FontWeight="Bold"
                                                       Foreground="#202030"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <!-- ON/AUTO/PRESETS container with dark background -->
                            <Border Background="#505560"
                                    CornerRadius="4"
                                    Padding="4,2,4,2"
                                    BorderBrush="#404550"
                                    BorderThickness="1"
                                    Margin="0,8,0,0">
                                <StackPanel Spacing="3">
                                    <!-- ON Button with indicator light -->
                                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                        <Grid x:Name="OnButton" Tapped="OnToggleEnabled" Width="36" Height="16">
                                            <Border x:Name="OnButtonBorder"
                                                    Background="#C8CAD0"
                                                    BorderBrush="#808590"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <Border BorderBrush="#E0E2E8"
                                                        BorderThickness="1,1,0,0"
                                                        CornerRadius="5"
                                                        Margin="1">
                                                    <TextBlock x:Name="OnButtonText"
                                                               Text="ON"
                                                               FontSize="8"
                                                               FontWeight="Bold"
                                                               Foreground="#202030"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Border>
                                        </Grid>
                                        <!-- Indicator light -->
                                        <Grid Width="7" Height="7" VerticalAlignment="Center">
                                            <Ellipse Fill="#40000000" Margin="0.5,0.5,0,0" />
                                            <Ellipse x:Name="OnIndicator"
                                                     Fill="#405060"
                                                     Stroke="#303540"
                                                     StrokeThickness="0.5" />
                                            <Ellipse Width="4" Height="2"
                                                     Fill="#40FFFFFF"
                                                     VerticalAlignment="Top"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,1,0,0" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- AUTO Button with indicator light -->
                                    <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                                        <Grid x:Name="AutoButton" Tapped="OnToggleAuto" Width="36" Height="16">
                                            <Border x:Name="AutoButtonBorder"
                                                    Background="#C8CAD0"
                                                    BorderBrush="#808590"
                                                    BorderThickness="1"
                                                    CornerRadius="6">
                                                <Border BorderBrush="#E0E2E8"
                                                        BorderThickness="1,1,0,0"
                                                        CornerRadius="5"
                                                        Margin="1">
                                                    <TextBlock x:Name="AutoButtonText"
                                                               Text="AUTO"
                                                               FontSize="7"
                                                               FontWeight="Bold"
                                                               Foreground="#202030"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </Border>
                                        </Grid>
                                        <!-- Indicator light -->
                                        <Grid Width="7" Height="7" VerticalAlignment="Center">
                                            <Ellipse Fill="#40000000" Margin="0.5,0.5,0,0" />
                                            <Ellipse x:Name="AutoIndicator"
                                                     Fill="#405060"
                                                     Stroke="#303540"
                                                     StrokeThickness="0.5" />
                                            <Ellipse Width="4" Height="2"
                                                     Fill="#40FFFFFF"
                                                     VerticalAlignment="Top"
                                                     HorizontalAlignment="Center"
                                                     Margin="0,1,0,0" />
                                        </Grid>
                                    </StackPanel>

                                    <!-- PRESETS Button -->
                                    <Grid Width="50" Height="18" HorizontalAlignment="Center" Margin="0,2,0,0">
                                        <Border Background="#C8CAD0"
                                                BorderBrush="#808590"
                                                BorderThickness="1"
                                                CornerRadius="6">
                                            <Border BorderBrush="#E0E2E8"
                                                    BorderThickness="1,1,0,0"
                                                    CornerRadius="5"
                                                    Margin="1">
                                                <TextBlock Text="PRESETS"
                                                           FontSize="7"
                                                           FontWeight="Bold"
                                                           Foreground="#202030"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Preamp Slider (separate column) -->
                        <Grid Grid.Column="1" Margin="4,0,8,0" Width="30">
                            <StackPanel Spacing="2" HorizontalAlignment="Center">
                                <TextBlock Text="+12" FontSize="6" Foreground="#505060" HorizontalAlignment="Center" />

                                <!-- Preamp vertical slider track -->
                                <Grid Height="120" Width="16" HorizontalAlignment="Center">
                                    <!-- Rounded inset slot -->
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <!-- Outer inset gradient background -->
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <!-- Top shadow overlay -->
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <!-- Bottom highlight overlay -->
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <!-- Dark center line/slot -->
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>

                                    <!-- Preamp thumb -->
                                    <Border x:Name="PreampThumb"
                                            Width="14" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570"
                                            BorderThickness="1"
                                            CornerRadius="7"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center">
                                        <!-- Grip lines on thumb -->
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="8" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="8" Background="#90FFFFFF" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <TextBlock Text="-12" FontSize="6" Foreground="#505060" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <!-- Main EQ Sliders (10 bands) -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Top dB scale labels -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                                <TextBlock Text="--" FontSize="6" Foreground="#505060" Width="20" />
                                <TextBlock Text="+12db" FontSize="6" Foreground="#505060" />
                            </StackPanel>

                            <!-- 10-band EQ sliders -->
                            <Grid Grid.Row="1" Height="120">
                                <!-- Sliders -->
                                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <!-- Band 1: 70Hz -->
                                <Grid x:Name="Band1Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <!-- Rounded inset slot -->
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <!-- Outer inset gradient background -->
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <!-- Top shadow overlay -->
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <!-- Bottom highlight overlay -->
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <!-- Dark center line/slot -->
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band1Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 2: 180Hz -->
                                <Grid x:Name="Band2Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band2Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 3: 320Hz -->
                                <Grid x:Name="Band3Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band3Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 4: 600Hz -->
                                <Grid x:Name="Band4Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band4Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 5: 1K -->
                                <Grid x:Name="Band5Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band5Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 6: 3K -->
                                <Grid x:Name="Band6Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band6Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 7: 6K -->
                                <Grid x:Name="Band7Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band7Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 8: 12K -->
                                <Grid x:Name="Band8Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band8Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 9: 14K -->
                                <Grid x:Name="Band9Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band9Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                                <!-- Band 10: 16K -->
                                <Grid x:Name="Band10Track" Height="120" Width="20"
                                      PointerPressed="OnBandPointerPressed" PointerMoved="OnBandPointerMoved" PointerReleased="OnBandPointerReleased">
                                    <Grid Width="12" HorizontalAlignment="Center">
                                        <Border Background="{StaticResource EqSlotInsetHorizontalBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotTopShadowBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotBottomHighlightBrush}" CornerRadius="6" />
                                        <Border Background="{StaticResource EqSlotCenterLineBrush}"
                                                CornerRadius="3" Width="4" HorizontalAlignment="Center" Margin="0,3" />
                                    </Grid>
                                    <Border x:Name="Band10Thumb" Width="16" Height="30"
                                            Background="{StaticResource EqThumbBrush}"
                                            BorderBrush="#606570" BorderThickness="1" CornerRadius="8"
                                            VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#90FFFFFF" CornerRadius="0.5" />
                                            <Border Height="1" Width="10" Background="#50000000" CornerRadius="0.5" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                            </Grid>

                            <!-- Frequency labels -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center" Margin="0,2,0,0">
                                <TextBlock Text="70" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="180" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="320" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="600" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="1K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="3K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="6K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="12K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="14K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                                <TextBlock Text="16K" FontSize="6" Foreground="#505060" Width="20" TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <!-- Bottom Tab Bar - Flipped: rounded corners at bottom, flat top touching container -->
                    <Grid Grid.Row="1" Background="#606878" ColumnDefinitions="*,*,*" Padding="4,0,4,0" Height="24">
                        <!-- EQUALIZER Tab (selected) - Raised, full height -->
                        <Grid Grid.Column="0" Height="24" Margin="0,0,1,0" VerticalAlignment="Top">
                            <!-- Tab shadow (behind) -->
                            <Path Fill="#40000000" Margin="2,0,0,2"
                                  Data="M 0,0 L 194,0 L 194,18 Q 194,24 186,24 L 8,24 Q 0,24 0,18 Z"
                                  Stretch="Fill" />
                            <!-- Tab body - raised/selected appearance -->
                            <Path Fill="{StaticResource EqTabSelectedBrush}" Stroke="#505560" StrokeThickness="1"
                                  Data="M 0,0 L 194,0 L 194,18 Q 194,24 186,24 L 8,24 Q 0,24 0,18 Z"
                                  Stretch="Fill" />
                            <!-- Bottom highlight line for raised effect -->
                            <Path Stroke="#60000000" StrokeThickness="1" Margin="4,0,4,2"
                                  Data="M 6,23 L 188,23"
                                  Stretch="None" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" />
                            <!-- Side highlight for 3D -->
                            <Path Stroke="#80FFFFFF" StrokeThickness="1" Margin="1,0,0,4"
                                  Data="M 1,4 L 1,20"
                                  Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top" />
                            <TextBlock Text="EQUALIZER"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="#101020"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                        </Grid>

                        <!-- OPTIONS Tab - Recessed, shorter height to appear behind -->
                        <Grid Grid.Column="1" Height="18" Margin="1,0,1,0" VerticalAlignment="Top">
                            <!-- Inset shadow on bottom for recessed look -->
                            <Path Fill="#30000000" Margin="0,0,0,2"
                                  Data="M 2,0 L 192,0 L 192,12 Q 192,16 186,16 L 8,16 Q 2,16 2,12 Z"
                                  Stretch="Fill" />
                            <!-- Tab body - darker/recessed appearance -->
                            <Path Fill="{StaticResource EqTabNormalBrush}" Stroke="#404550" StrokeThickness="1"
                                  Data="M 0,0 L 194,0 L 194,14 Q 194,18 188,18 L 6,18 Q 0,18 0,14 Z"
                                  Stretch="Fill" />
                            <TextBlock Text="OPTIONS"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="#505060"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                        </Grid>

                        <!-- COLOR THEMES Tab - Recessed, shorter height to appear behind -->
                        <Grid Grid.Column="2" Height="18" Margin="1,0,0,0" VerticalAlignment="Top">
                            <!-- Inset shadow on bottom for recessed look -->
                            <Path Fill="#30000000" Margin="0,0,0,2"
                                  Data="M 2,0 L 192,0 L 192,12 Q 192,16 186,16 L 8,16 Q 2,16 2,12 Z"
                                  Stretch="Fill" />
                            <!-- Tab body - darker/recessed appearance -->
                            <Path Fill="{StaticResource EqTabNormalBrush}" Stroke="#404550" StrokeThickness="1"
                                  Data="M 0,0 L 194,0 L 194,14 Q 194,18 188,18 L 6,18 Q 0,18 0,14 Z"
                                  Stretch="Fill" />
                            <TextBlock Text="COLOR THEMES"
                                       FontSize="8"
                                       FontWeight="Bold"
                                       Foreground="#505060"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,0" />
                        </Grid>
                    </Grid>

                </Grid>
            </Border>
    </Border>

</UserControl>

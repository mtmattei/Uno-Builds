<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Frame/Metal Colors ===== -->
    <SolidColorBrush x:Key="WinampLightBrush" Color="#DDDBE3" />
    <SolidColorBrush x:Key="WinampBaseBrush" Color="#C1C4CF" />
    <SolidColorBrush x:Key="WinampDarkBrush" Color="#A5AAB9" />
    <SolidColorBrush x:Key="WinampShadowBrush" Color="#6A6F7D" />

    <!-- ===== Text on Metal ===== -->
    <SolidColorBrush x:Key="WinampTextBrush" Color="#1A1A1A" />
    <SolidColorBrush x:Key="WinampTextDimBrush" Color="#404050" />

    <!-- ===== LCD Display ===== -->
    <SolidColorBrush x:Key="LcdBgBrush" Color="#1A3060" />
    <SolidColorBrush x:Key="LcdGreenBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LcdGreenDimBrush" Color="#CCCCCC" />
    <SolidColorBrush x:Key="LcdGreenGlowBrush" Color="#1A3A6A" />
    <SolidColorBrush x:Key="LcdScanlineBrush" Color="#20000000" />

    <!-- ===== Hardcoded colors extracted ===== -->
    <SolidColorBrush x:Key="WinampOrangeBrush" Color="#CC6600" />
    <SolidColorBrush x:Key="WinampLogoTextBrush" Color="#303030" />
    <SolidColorBrush x:Key="LcdWhiteBoxBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="LcdGhostSegmentBrush" Color="#15406080" />
    <SolidColorBrush x:Key="LcdBorderAccentBrush" Color="#1A5599" />
    <SolidColorBrush x:Key="TickerTextBrush" Color="#6071A3" />
    <SolidColorBrush x:Key="DropShadowBrush" Color="#60000000" />
    <SolidColorBrush x:Key="DropShadowLightBrush" Color="#50000000" />
    <SolidColorBrush x:Key="ButtonStrokeBrush" Color="#80000000" />
    <SolidColorBrush x:Key="InnerBevelDarkBrush" Color="#40000000" />
    <SolidColorBrush x:Key="InnerBevelLightBrush" Color="#60FFFFFF" />
    <SolidColorBrush x:Key="SpecularHighlightBrush" Color="#40FFFFFF" />
    <SolidColorBrush x:Key="PlayButtonForegroundBrush" Color="#4488FF" />
    <SolidColorBrush x:Key="ShuffleIndicatorBrush" Color="#4488FF" />
    <SolidColorBrush x:Key="ShuffleIndicatorStrokeBrush" Color="#2255AA" />
    <SolidColorBrush x:Key="EqNotchFillBrush" Color="#B0B2B8" />
    <SolidColorBrush x:Key="EqNotchStrokeBrush" Color="#707580" />
    <SolidColorBrush x:Key="TransportStrokeBrush" Color="#70000000" />

    <!-- ===== LCD Texture Gradient ===== -->
    <LinearGradientBrush x:Key="LcdTextureBrush" StartPoint="0,1" EndPoint="0,0">
        <GradientStop Color="#2A4578" Offset="0.0" />
        <GradientStop Color="#304A80" Offset="0.15" />
        <GradientStop Color="#385590" Offset="0.5" />
        <GradientStop Color="#304A80" Offset="0.85" />
        <GradientStop Color="#2D4575" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===== Button Gradients ===== -->
    <LinearGradientBrush x:Key="RoundButtonBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F8F6FC" Offset="0.0" />
        <GradientStop Color="#E8E6EE" Offset="0.15" />
        <GradientStop Color="#D0CED6" Offset="0.5" />
        <GradientStop Color="#B8B6BE" Offset="0.85" />
        <GradientStop Color="#A8A6AE" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SliderThumbBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F0EEF5" Offset="0.0" />
        <GradientStop Color="#C0BEC6" Offset="0.5" />
        <GradientStop Color="#9A989F" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===== Inner Shadow/Highlight ===== -->
    <SolidColorBrush x:Key="InnerShadowBrush" Color="#40000000" />
    <SolidColorBrush x:Key="InnerHighlightBrush" Color="#60FFFFFF" />

    <!-- ===== Slider Track Gradients ===== -->
    <LinearGradientBrush x:Key="SlotInsetVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#404550" Offset="0.0" />
        <GradientStop Color="#606878" Offset="0.3" />
        <GradientStop Color="#707880" Offset="0.5" />
        <GradientStop Color="#606878" Offset="0.7" />
        <GradientStop Color="#505560" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SlotCenterLineVerticalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#181C20" Offset="0.0" />
        <GradientStop Color="#252A30" Offset="0.3" />
        <GradientStop Color="#303540" Offset="0.5" />
        <GradientStop Color="#252A30" Offset="0.7" />
        <GradientStop Color="#181C20" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SlotShadowHorizontalBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#80000000" Offset="0.0" />
        <GradientStop Color="#40000000" Offset="0.2" />
        <GradientStop Color="#00000000" Offset="0.5" />
        <GradientStop Color="#40000000" Offset="0.8" />
        <GradientStop Color="#80000000" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SlotHighlightHorizontalBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#50FFFFFF" Offset="0.0" />
        <GradientStop Color="#20FFFFFF" Offset="0.2" />
        <GradientStop Color="#00FFFFFF" Offset="0.5" />
        <GradientStop Color="#20FFFFFF" Offset="0.8" />
        <GradientStop Color="#50FFFFFF" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===== LCD Screen Inset Gradients ===== -->
    <LinearGradientBrush x:Key="LcdInsetGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1A3055" Offset="0.0" />
        <GradientStop Color="#203A65" Offset="0.3" />
        <GradientStop Color="#284575" Offset="0.5" />
        <GradientStop Color="#203A65" Offset="0.7" />
        <GradientStop Color="#1A3055" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LcdInsetTopShadowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#50000000" Offset="0.0" />
        <GradientStop Color="#20000000" Offset="0.3" />
        <GradientStop Color="#00000000" Offset="0.6" />
        <GradientStop Color="#10FFFFFF" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LcdInsetHorizontalShadowBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#30000000" Offset="0.0" />
        <GradientStop Color="#00000000" Offset="0.15" />
        <GradientStop Color="#00000000" Offset="0.85" />
        <GradientStop Color="#30000000" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="LcdGlareHighlightBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#40FFFFFF" Offset="0.0" />
        <GradientStop Color="#20FFFFFF" Offset="0.3" />
        <GradientStop Color="#00FFFFFF" Offset="0.6" />
    </LinearGradientBrush>

    <!-- ===== Metal Gradients ===== -->
    <LinearGradientBrush x:Key="BrushedMetalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#D0D2D8" Offset="0.0" />
        <GradientStop Color="#A0A2AA" Offset="0.3" />
        <GradientStop Color="#C0C2CA" Offset="0.5" />
        <GradientStop Color="#909298" Offset="0.8" />
        <GradientStop Color="#B8BAC2" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TitleBarBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#DDDBE3" Offset="0.0" />
        <GradientStop Color="#D0CED6" Offset="0.3" />
        <GradientStop Color="#C0BEC6" Offset="0.6" />
        <GradientStop Color="#B0AEB6" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ButtonMetalBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E5E3EB" Offset="0.0" />
        <GradientStop Color="#D5D3DB" Offset="0.2" />
        <GradientStop Color="#C5C3CB" Offset="0.5" />
        <GradientStop Color="#B5B3BB" Offset="0.8" />
        <GradientStop Color="#A5A3AB" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ButtonPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#95939B" Offset="0.0" />
        <GradientStop Color="#A5A3AB" Offset="0.3" />
        <GradientStop Color="#B5B3BB" Offset="0.7" />
        <GradientStop Color="#C5C3CB" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===== LCD Inner Shadow (inline gradient extracted) ===== -->
    <LinearGradientBrush x:Key="LcdInnerShadowBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#40000000" Offset="0.0" />
        <GradientStop Color="#10000000" Offset="0.15" />
        <GradientStop Color="#00000000" Offset="0.4" />
        <GradientStop Color="#00000000" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ===== Miscellaneous ===== -->
    <SolidColorBrush x:Key="InsetBrush" Color="#E6E9EC" />
    <SolidColorBrush x:Key="TickerBgBrush" Color="#10205A" />

    <!-- ===== Custom Fonts ===== -->
    <FontFamily x:Key="LcdPixelFont">ms-appx:///Assets/Fonts/PressStart2P-Regular.ttf#Press Start 2P</FontFamily>
    <FontFamily x:Key="DigitalClockFont">ms-appx:///Assets/Fonts/DS-DIGI.TTF#DS-Digital</FontFamily>
    <FontFamily x:Key="BitcountFont">ms-appx:///Assets/Fonts/BitcountPropSingle-Medium.ttf#Bitcount Prop Single</FontFamily>

    <!-- ===== Skin Bitmap Brushes ===== -->
    <ImageBrush x:Key="SkinMainBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/main.bmp"
                Stretch="Fill" />
    <ImageBrush x:Key="SkinTitlebarBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/titlebar.bmp"
                Stretch="Fill" />
    <ImageBrush x:Key="SkinCButtonsBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/cbuttons.bmp"
                Stretch="None" />
    <ImageBrush x:Key="SkinPosbarBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/posbar.bmp"
                Stretch="None" />
    <ImageBrush x:Key="SkinVolumeBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/volume.bmp"
                Stretch="None" />
    <ImageBrush x:Key="SkinNumbersBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/numbers.bmp"
                Stretch="None" />
    <ImageBrush x:Key="SkinEqMainBrush"
                ImageSource="ms-appx:///Assets/Skins/Winamp5_Classified/eqmain.bmp"
                Stretch="Fill" />

</ResourceDictionary>

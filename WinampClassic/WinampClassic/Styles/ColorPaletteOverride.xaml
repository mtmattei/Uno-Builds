<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Winamp Classic Color Palette - Industrial Metallic Theme -->
    <!-- Note: Only keeping colors needed for Material theme overrides -->

    <!-- Material Theme Overrides -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="PrimaryColor">#808080</Color>
            <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
            <Color x:Key="PrimaryContainerColor">#C0C0C0</Color>
            <Color x:Key="OnPrimaryContainerColor">#000000</Color>
            <Color x:Key="SecondaryColor">#FF8800</Color>
            <Color x:Key="OnSecondaryColor">#000000</Color>
            <Color x:Key="SecondaryContainerColor">#FFD088</Color>
            <Color x:Key="OnSecondaryContainerColor">#402200</Color>
            <Color x:Key="TertiaryColor">#00FF88</Color>
            <Color x:Key="OnTertiaryColor">#000000</Color>
            <Color x:Key="TertiaryContainerColor">#80FFB0</Color>
            <Color x:Key="OnTertiaryContainerColor">#003320</Color>
            <Color x:Key="ErrorColor">#FF0000</Color>
            <Color x:Key="ErrorContainerColor">#FFD0D0</Color>
            <Color x:Key="OnErrorColor">#FFFFFF</Color>
            <Color x:Key="OnErrorContainerColor">#400000</Color>
            <Color x:Key="BackgroundColor">#606060</Color>
            <Color x:Key="OnBackgroundColor">#E0E0E0</Color>
            <Color x:Key="SurfaceColor">#808080</Color>
            <Color x:Key="OnSurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceVariantColor">#707070</Color>
            <Color x:Key="OnSurfaceVariantColor">#D0D0D0</Color>
            <Color x:Key="OutlineColor">#505050</Color>
            <Color x:Key="OnSurfaceInverseColor">#404040</Color>
            <Color x:Key="SurfaceInverseColor">#C0C0C0</Color>
            <Color x:Key="PrimaryInverseColor">#A0A0A0</Color>
            <Color x:Key="SurfaceTintColor">#909090</Color>
            <Color x:Key="OutlineVariantColor">#606060</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="PrimaryColor">#808080</Color>
            <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
            <Color x:Key="PrimaryContainerColor">#505050</Color>
            <Color x:Key="OnPrimaryContainerColor">#E0E0E0</Color>
            <Color x:Key="SecondaryColor">#FF8800</Color>
            <Color x:Key="OnSecondaryColor">#000000</Color>
            <Color x:Key="SecondaryContainerColor">#804400</Color>
            <Color x:Key="OnSecondaryContainerColor">#FFD088</Color>
            <Color x:Key="TertiaryColor">#00FF88</Color>
            <Color x:Key="OnTertiaryColor">#000000</Color>
            <Color x:Key="TertiaryContainerColor">#006638</Color>
            <Color x:Key="OnTertiaryContainerColor">#80FFB0</Color>
            <Color x:Key="ErrorColor">#FF6666</Color>
            <Color x:Key="ErrorContainerColor">#660000</Color>
            <Color x:Key="OnErrorColor">#000000</Color>
            <Color x:Key="OnErrorContainerColor">#FFB0B0</Color>
            <Color x:Key="BackgroundColor">#404040</Color>
            <Color x:Key="OnBackgroundColor">#E0E0E0</Color>
            <Color x:Key="SurfaceColor">#505050</Color>
            <Color x:Key="OnSurfaceColor">#FFFFFF</Color>
            <Color x:Key="SurfaceVariantColor">#606060</Color>
            <Color x:Key="OnSurfaceVariantColor">#C0C0C0</Color>
            <Color x:Key="OutlineColor">#808080</Color>
            <Color x:Key="OnSurfaceInverseColor">#C0C0C0</Color>
            <Color x:Key="SurfaceInverseColor">#303030</Color>
            <Color x:Key="PrimaryInverseColor">#909090</Color>
            <Color x:Key="SurfaceTintColor">#707070</Color>
            <Color x:Key="OutlineVariantColor">#484848</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>

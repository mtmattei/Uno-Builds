<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App Colors -->
    <Color x:Key="PrimaryColor">#283B8A</Color>
    <Color x:Key="PrimaryLightColor">#4158AB</Color>
    <Color x:Key="AccentColor">#4C6EF5</Color>
    <Color x:Key="TextPrimaryColor">#212121</Color>
    <Color x:Key="TextSecondaryColor">#6C757D</Color>
    <Color x:Key="BackgroundColor">#FFFFFF</Color>
    <Color x:Key="BackgroundAltColor">#F8F9FA</Color>

    <!-- Position Colors -->
    <Color x:Key="GoalieBackgroundColor">#FFEFEF</Color>
    <Color x:Key="GoalieTextColor">#E53E3E</Color>
    <Color x:Key="DefenseBackgroundColor">#E8F0FE</Color>
    <Color x:Key="DefenseTextColor">#3670E3</Color>
    <Color x:Key="ForwardBackgroundColor">#E8F5E9</Color>
    <Color x:Key="ForwardTextColor">#2E7D32</Color>

    <!-- Game Status Colors -->
    <Color x:Key="TodayBackgroundColor">#E8F5E9</Color>
    <Color x:Key="TodayTextColor">#2E7D32</Color>
    <Color x:Key="TomorrowBackgroundColor">#E3F2FD</Color>
    <Color x:Key="TomorrowTextColor">#1565C0</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="BackgroundAltBrush" Color="{StaticResource BackgroundAltColor}"/>

    <!-- Position Brushes -->
    <SolidColorBrush x:Key="GoalieBackgroundBrush" Color="{StaticResource GoalieBackgroundColor}"/>
    <SolidColorBrush x:Key="GoalieTextBrush" Color="{StaticResource GoalieTextColor}"/>
    <SolidColorBrush x:Key="DefenseBackgroundBrush" Color="{StaticResource DefenseBackgroundColor}"/>
    <SolidColorBrush x:Key="DefenseTextBrush" Color="{StaticResource DefenseTextColor}"/>
    <SolidColorBrush x:Key="ForwardBackgroundBrush" Color="{StaticResource ForwardBackgroundColor}"/>
    <SolidColorBrush x:Key="ForwardTextBrush" Color="{StaticResource ForwardTextColor}"/>

    <!-- Game Status Brushes -->
    <SolidColorBrush x:Key="TodayBackgroundBrush" Color="{StaticResource TodayBackgroundColor}"/>
    <SolidColorBrush x:Key="TodayTextBrush" Color="{StaticResource TodayTextColor}"/>
    <SolidColorBrush x:Key="TomorrowBackgroundBrush" Color="{StaticResource TomorrowBackgroundColor}"/>
    <SolidColorBrush x:Key="TomorrowTextBrush" Color="{StaticResource TomorrowTextColor}"/>

</ResourceDictionary>

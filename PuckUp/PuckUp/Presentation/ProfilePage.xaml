<Page
    x:Class="PuckUp.Presentation.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PuckUp.Presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.Toolkit.UI"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SurfaceColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto" Grid.Row="0" Background="{ThemeResource PrimaryColor}" Padding="16,12">
            <TextBlock TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1"
                Text="My Profile"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{ThemeResource OnPrimaryColor}"/>

            <Button
                Grid.Column="2"
                Margin="0,0,16,0"
                Background="{ThemeResource PrimaryContainerColor}"
                CornerRadius="20"
                Width="40"
                Height="40"
                Command="{x:Bind ViewModel.EditProfileCommand}">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE70F;" Foreground="{ThemeResource OnPrimaryColor}"/>
            </Button>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Padding="16" Spacing="24">
                <!-- Profile Header -->
                <Grid HorizontalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <PersonPicture
                        Grid.Row="0"
                        Width="100"
                        Height="100"
                        ProfilePicture="{x:Null}"
                        HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1"
                               Text="{x:Bind ViewModel.UserName}"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"/>
                </Grid>

                <!-- Profile Stats -->
                <Grid ColumnDefinitions="*,*,*" Margin="0,8">
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.GamesPlayed}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Games"
                                   FontSize="14"
                                   Opacity="0.8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.FavoritePosition}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Position"
                                   FontSize="14"
                                   Opacity="0.8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <TextBlock Text="{x:Bind ViewModel.AverageRating}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Rating"
                                   FontSize="14"
                                   Opacity="0.8"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <!-- About Me Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="About Me" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="{x:Bind ViewModel.AboutMe}" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Preferences Section -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Preferences" FontSize="18" FontWeight="SemiBold"/>

                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <FontIcon Grid.Row="0" Grid.Column="0" FontFamily="Segoe MDL2 Assets" Glyph="&#xEE40;"
                                  Foreground="{ThemeResource PrimaryColor}" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.PreferredLeagues}" TextWrapping="Wrap"/>

                        <FontIcon Grid.Row="1" Grid.Column="0" FontFamily="Segoe MDL2 Assets" Glyph="&#xEC43;"
                                  Foreground="{ThemeResource PrimaryColor}" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.PreferredArenas}" TextWrapping="Wrap"/>

                        <FontIcon Grid.Row="2" Grid.Column="0" FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;"
                                  Foreground="{ThemeResource PrimaryColor}" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.PreferredPositions}" TextWrapping="Wrap"/>

                        <FontIcon Grid.Row="3" Grid.Column="0" FontFamily="Segoe MDL2 Assets" Glyph="&#xE823;"
                                  Foreground="{ThemeResource PrimaryColor}" Margin="0,0,16,16"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.PreferredSchedule}" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>

                <!-- Settings Button -->
                <Button Content="Settings" HorizontalAlignment="Stretch" Command="{x:Bind ViewModel.GoToSettingsCommand}"/>

                <!-- Logout Button -->
                <Button Content="Log Out"
                        HorizontalAlignment="Stretch"
                        Foreground="{ThemeResource ErrorColor}"
                        Command="{x:Bind ViewModel.LogoutCommand}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Bottom Navigation TabBar -->
        <toolkit:TabBar
            Grid.Row="2"
            SelectedIndex="{x:Bind ViewModel.SelectedBottomTabIndex, Mode=TwoWay}"
            Background="{ThemeResource SurfaceColor}"
            BorderBrush="{ThemeResource OutlineColor}"
            BorderThickness="0,1,0,0">
            <toolkit:TabBar.Items>
                <!-- Find Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE721;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Find"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Upcoming Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE823;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Upcoming"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Teams Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE716;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Teams"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Profile Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;"
                                      Foreground="{ThemeResource PrimaryColor}" FontSize="20"/>
                            <TextBlock Text="Profile"
                                       Foreground="{ThemeResource PrimaryColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>
            </toolkit:TabBar.Items>
        </toolkit:TabBar>
    </Grid>
</Page>

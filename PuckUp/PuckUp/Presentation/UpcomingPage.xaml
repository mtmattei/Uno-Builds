<Page
    x:Class="PuckUp.Presentation.UpcomingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PuckUp.Presentation"
    xmlns:viewmodels="using:PuckUp.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.Toolkit.UI"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SurfaceColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto" Grid.Row="0" Background="{ThemeResource PrimaryColor}" Padding="16,12">
            <TextBlock TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1"
                Text="Upcoming Games"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{ThemeResource OnPrimaryColor}"/>

            <PersonPicture
                Grid.Column="2"
                Width="40"
                Height="40"
                ProfilePicture="{x:Null}"/>
        </Grid>

        <!-- Content -->
        <Grid Grid.Row="1" Padding="16">
            <ListView ItemsSource="{x:Bind ViewModel.UpcomingGames}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:UpcomingGameItem">
                        <Grid Margin="0,8" Padding="16" Background="{ThemeResource SurfaceContainerColor}" CornerRadius="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{x:Bind Date}"
                                       Foreground="{ThemeResource PrimaryColor}"
                                       FontWeight="SemiBold"
                                       FontSize="16"/>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="{x:Bind Time}" FontWeight="Medium"/>
                                <TextBlock Text=" at " Opacity="0.8"/>
                                <TextBlock Text="{x:Bind Arena}" FontWeight="Medium"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="{x:Bind League}" Opacity="0.8"/>
                                <TextBlock Text=" • "/>
                                <TextBlock Text="{x:Bind Position}" Opacity="0.8"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Text="No upcoming games"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Opacity="0.6"
                       FontSize="16"
                       Visibility="{x:Bind ViewModel.NoGamesVisibility}"/>
        </Grid>

        <!-- Bottom Navigation TabBar -->
        <toolkit:TabBar
            Grid.Row="2"
            SelectedIndex="{x:Bind ViewModel.SelectedBottomTabIndex, Mode=TwoWay}"
            Background="{ThemeResource SurfaceColor}"
            BorderBrush="{ThemeResource OutlineColor}"
            BorderThickness="0,1,0,0">
            <toolkit:TabBar.Items>
                <!-- Find Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE721;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Find"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Upcoming Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE823;"
                                      Foreground="{ThemeResource PrimaryColor}" FontSize="20"/>
                            <TextBlock Text="Upcoming"
                                       Foreground="{ThemeResource PrimaryColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Teams Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE716;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Teams"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Profile Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Profile"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>
            </toolkit:TabBar.Items>
        </toolkit:TabBar>
    </Grid>
</Page>

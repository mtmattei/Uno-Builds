<Page
    x:Class="PuckUp.Presentation.HockeyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PuckUp.Presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:Uno.Toolkit.UI"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource SurfaceColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,*,Auto" Grid.Row="0" Background="{ThemeResource PrimaryColor}" Padding="16,12">

            <TextBlock TextAlignment="Center" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="1"
                Text="PuckUp"
                FontSize="24"
                FontWeight="Bold"
                Foreground="{ThemeResource OnPrimaryColor}"/>

            <Button
                Margin="0,0,16,0"
                Background="{ThemeResource PrimaryContainerColor}"
                CornerRadius="20"
                Width="40"
                Height="40">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8FA;" Foreground="{ThemeResource OnPrimaryColor}"/>
            </Button>

            <PersonPicture
                Grid.Column="2"
                Width="40"
                Height="40"
                ProfilePicture="{x:Null}"/>
        </Grid>

        <!-- Search Box -->
        <AutoSuggestBox
            Grid.Row="1"
            PlaceholderText="Find players or games..."
            Margin="16"
            QueryIcon="Find"
            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

        <!-- Filter Buttons with Dropdowns -->
        <ScrollViewer
            Grid.Row="2"
            HorizontalScrollMode="Auto"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollMode="Disabled"
            Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Margin="16,0,16,0" Spacing="8">
                <!-- Arena Button -->
                <Button
                    Style="{StaticResource FilterButtonStyle}"
                    Tag="&#xEC43;"
                    Content="Arena"
                    Command="{x:Bind ViewModel.ShowArenaFilterCommand}">
                    <Button.Flyout>
                        <Flyout FlyoutPresenterStyle="{StaticResource FilterFlyoutStyle}">
                            <ListView
                                Style="{StaticResource FilterListViewStyle}"
                                ItemsSource="{x:Bind ViewModel.Arenas}"
                                SelectedItem="{x:Bind ViewModel.SelectedArena, Mode=TwoWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource FilterListViewItemStyle}"/>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- League Button -->
                <Button
                    Style="{StaticResource FilterButtonStyle}"
                    Tag="&#xEE40;"
                    Content="League"
                    Command="{x:Bind ViewModel.ShowLeagueFilterCommand}">
                    <Button.Flyout>
                        <Flyout FlyoutPresenterStyle="{StaticResource FilterFlyoutStyle}">
                            <ListView
                                Style="{StaticResource FilterListViewStyle}"
                                ItemsSource="{x:Bind ViewModel.Leagues}"
                                SelectedItem="{x:Bind ViewModel.SelectedLeague, Mode=TwoWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource FilterListViewItemStyle}"/>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Position Button -->
                <Button
                    Style="{StaticResource FilterButtonStyle}"
                    Tag="&#xE77B;"
                    Content="Position"
                    Command="{x:Bind ViewModel.ShowPositionFilterCommand}">
                    <Button.Flyout>
                        <Flyout FlyoutPresenterStyle="{StaticResource FilterFlyoutStyle}">
                            <ListView
                                Style="{StaticResource FilterListViewStyle}"
                                ItemsSource="{x:Bind ViewModel.Positions}"
                                SelectedItem="{x:Bind ViewModel.SelectedPosition, Mode=TwoWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource FilterListViewItemStyle}"/>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Time Button -->
                <Button
                    Style="{StaticResource FilterButtonStyle}"
                    Tag="&#xE823;"
                    Content="Time"
                    Command="{x:Bind ViewModel.ShowTimeFilterCommand}">
                    <Button.Flyout>
                        <Flyout FlyoutPresenterStyle="{StaticResource FilterFlyoutStyle}">
                            <ListView
                                Style="{StaticResource FilterListViewStyle}"
                                ItemsSource="{x:Bind ViewModel.TimeFrames}"
                                SelectedItem="{x:Bind ViewModel.SelectedTimeFrame, Mode=TwoWay}">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem" BasedOn="{StaticResource FilterListViewItemStyle}"/>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </ScrollViewer>

        <!-- TabBar for navigation between views -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Bar -->
            <toolkit:TabBar
                Grid.Row="0"
                SelectedIndex="{x:Bind ViewModel.SelectedTabIndex, Mode=TwoWay}"
                Background="{ThemeResource SurfaceColor}"
                HorizontalAlignment="Stretch">
                <toolkit:TabBar.Items>
                    <toolkit:TabBarItem x:Name="FindPlayersTab"
                                      Content="Find Players"
                                      IsSelected="True"
                                      Foreground="{x:Bind ViewModel.FindPlayersTabColor, Mode=OneWay}">
                    </toolkit:TabBarItem>
                    <toolkit:TabBarItem x:Name="OpenGamesTab"
                                      Content="Open Games"
                                      Foreground="{x:Bind ViewModel.OpenGamesTabColor, Mode=OneWay}">
                    </toolkit:TabBarItem>
                </toolkit:TabBar.Items>
            </toolkit:TabBar>

            <!-- Tab content -->
            <ContentControl
                Grid.Row="1"
                Content="{x:Bind ViewModel.CurrentTabView, Mode=OneWay}"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Margin="0"/>
        </Grid>

        <!-- Bottom Navigation TabBar -->
        <toolkit:TabBar
            Grid.Row="4"
            SelectedIndex="{x:Bind ViewModel.SelectedBottomTabIndex, Mode=TwoWay}"
            Background="{ThemeResource SurfaceColor}"
            BorderBrush="{ThemeResource OutlineColor}"
            BorderThickness="0,1,0,0">
            <toolkit:TabBar.Items>
                <!-- Find Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE721;"
                                      Foreground="{ThemeResource PrimaryColor}" FontSize="20"/>
                            <TextBlock Text="Find"
                                       Foreground="{ThemeResource PrimaryColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Upcoming Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE823;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Upcoming"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Teams Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE716;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Teams"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>

                <!-- Profile Tab -->
                <toolkit:TabBarItem>
                    <toolkit:TabBarItem.Content>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;"
                                      Foreground="{ThemeResource OnSurfaceVariantColor}" FontSize="20"/>
                            <TextBlock Text="Profile"
                                       Foreground="{ThemeResource OnSurfaceVariantColor}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </toolkit:TabBarItem.Content>
                </toolkit:TabBarItem>
            </toolkit:TabBar.Items>
        </toolkit:TabBar>
    </Grid>
</Page>
<UserControl x:Class="PuckUp.Presentation.OpenGamesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PuckUp.Presentation"
    xmlns:models="using:PuckUp.Models"
    xmlns:system="using:System.Collections.Generic"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:um="using:Uno.Material"
    x:Name="_root"
    Background="{ThemeResource BackgroundColor}">

    <Grid>
        <ProgressRing
            IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
            Width="50"
            Height="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <ListView
            ItemsSource="{x:Bind ViewModel.Games, Mode=OneWay}"
            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
            SelectionMode="None"
            Padding="0">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem" BasedOn="{StaticResource StandardListViewItemStyle}"/>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Game">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Header with League and Time -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Text="{x:Bind League, Mode=OneWay}"
                                    FontSize="18"
                                    FontWeight="SemiBold"/>

                                <Border
                                    Grid.Column="1"
                                    Style="{StaticResource GameTimeBadgeStyle}">
                                    <TextBlock
                                        Text="{x:Bind GameTime, Mode=OneWay}"
                                        FontSize="14"/>
                                </Border>
                            </Grid>

                            <!-- Location -->
                            <TextBlock
                                Grid.Row="1"
                                Text="{x:Bind Arena, Mode=OneWay}"
                                Margin="0,8,0,0"/>

                            <!-- Needs -->
                            <StackPanel Grid.Row="2" Margin="0,16,0,0">
                                <TextBlock
                                    Text="Needs:"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Margin="0,0,0,8"/>

                                <!-- Use regular binding for the positions needed -->
                                <ItemsControl ItemsSource="{x:Bind PositionsNeeded, Mode=OneWay}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource PositionNeededBadgeStyle}">
                                                <TextBlock>
                                                    <Run Text="{Binding Key}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="(" Foreground="{ThemeResource PrimaryColor}"/>
                                                    <Run Text="{Binding Value}" Foreground="{ThemeResource PrimaryColor}"/>
                                                    <Run Text=")" Foreground="{ThemeResource PrimaryColor}"/>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Button -->
                            <Button
                                Grid.Row="3"
                                Content="Sign Up"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Margin="0,16,0,0"
                                Command="{Binding DataContext.SignUpCommand, ElementName=_root}"
                                CommandParameter="{x:Bind}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>

<UserControl x:Class="AdaptiveInputDemo.Controls.AdaptiveInputControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AdaptiveInputDemo.Controls"
             xmlns:pickers="using:AdaptiveInputDemo.Controls.Pickers"
             xmlns:utu="using:Uno.Toolkit.UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main Input Container -->
        <Border x:Name="InputContainer"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="8"
                Translation="0,0,8">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Type Badge -->
                <Border x:Name="TypeBadge"
                        Grid.Column="0"
                        Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon x:Name="TypeIcon"
                                  Glyph="&#xE734;"
                                  FontSize="14"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  VerticalAlignment="Center" />
                        <TextBlock x:Name="TypeLabel"
                                   Text="Auto"
                                   Style="{StaticResource LabelSmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Text Input -->
                <TextBox x:Name="InputTextBox"
                         Grid.Column="1"
                         PlaceholderText="Type anything..."
                         Style="{StaticResource AdaptiveTextBoxStyle}"
                         PlaceholderForeground="{ThemeResource OnSurfaceVariantBrush}"
                         VerticalAlignment="Center"
                         TextChanged="OnTextChanged"
                         KeyDown="OnInputKeyDown"
                         GotFocus="OnInputGotFocus"
                         LostFocus="OnInputLostFocus"
                         AutomationProperties.Name="Adaptive input field"
                         AutomationProperties.HelpText="Type to detect input type automatically" />

                <!-- Submit Button -->
                <Button x:Name="SubmitButton"
                        Grid.Column="2"
                        Click="OnSubmitClicked"
                        Style="{StaticResource FilledTonalButtonStyle}"
                        Padding="8,6"
                        Margin="0,0,4,0"
                        CornerRadius="8"
                        MinWidth="40"
                        MinHeight="40"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Submit input">
                    <FontIcon Glyph="&#xE72A;" FontSize="14" />
                </Button>
            </Grid>
        </Border>

        <!-- Expanded Panel Container -->
        <Border x:Name="PanelContainer"
                Grid.Row="1"
                Margin="0,8,0,0"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                Visibility="Collapsed"
                Translation="0,0,16"
                RenderTransformOrigin="0.5,0">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Border.RenderTransform>
                <CompositeTransform />
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Panel Header -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon x:Name="PanelIcon"
                                  Glyph="&#xE734;"
                                  FontSize="16"
                                  Foreground="{ThemeResource PrimaryBrush}" />
                        <TextBlock x:Name="PanelTitle"
                                   Text="Select"
                                   Style="{StaticResource TitleSmall}"
                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                    </StackPanel>

                    <Button x:Name="CloseButton"
                            Grid.Column="1"
                            Click="OnClosePanel"
                            Style="{StaticResource IconButtonStyle}"
                            AutomationProperties.Name="Close picker">
                        <FontIcon Glyph="&#xE711;" FontSize="14" />
                    </Button>
                </Grid>

                <!-- Picker Content Area -->
                <ContentPresenter x:Name="PickerContent" Grid.Row="1" />
            </Grid>
        </Border>
    </Grid>
</UserControl>

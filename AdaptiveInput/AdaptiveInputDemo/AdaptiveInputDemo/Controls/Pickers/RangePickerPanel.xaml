<UserControl x:Class="AdaptiveInputDemo.Controls.RangePickerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Min/Max Number Inputs -->
        <Grid ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="Min"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <NumberBox x:Name="MinInput"
                           Value="0"
                           Minimum="0"
                           Maximum="999"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="OnMinValueChanged" />
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="to"
                       Style="{StaticResource BodyMedium}"
                       VerticalAlignment="Bottom"
                       Margin="0,0,0,12"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />

            <StackPanel Grid.Column="2" Spacing="4">
                <TextBlock Text="Max"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <NumberBox x:Name="MaxInput"
                           Value="100"
                           Minimum="0"
                           Maximum="999"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="OnMaxValueChanged" />
            </StackPanel>
        </Grid>

        <!-- Visual Range Bar -->
        <Grid Grid.Row="1" Height="8" CornerRadius="4" Background="{ThemeResource SurfaceVariantBrush}">
            <Border x:Name="RangeFill"
                    Background="{ThemeResource PrimaryBrush}"
                    CornerRadius="4"
                    HorizontalAlignment="Left" />
        </Grid>

        <!-- Sliders -->
        <Grid Grid.Row="2">
            <Slider x:Name="MinSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="0"
                    ValueChanged="OnMinSliderChanged"
                    Opacity="0.5" />
            <Slider x:Name="MaxSlider"
                    Minimum="0"
                    Maximum="100"
                    Value="100"
                    ValueChanged="OnMaxSliderChanged" />
        </Grid>

        <!-- Quick Presets and Apply -->
        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="0-50"
                        Tag="0-50"
                        Click="OnPresetClick"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Padding="12,6" />
                <Button Content="0-100"
                        Tag="0-100"
                        Click="OnPresetClick"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Padding="12,6" />
                <Button Content="50-150"
                        Tag="50-150"
                        Click="OnPresetClick"
                        Style="{StaticResource OutlinedButtonStyle}"
                        Padding="12,6" />
            </StackPanel>

            <Button x:Name="ApplyButton"
                    Grid.Column="1"
                    Content="Apply"
                    Click="OnApplyClick"
                    Style="{StaticResource FilledButtonStyle}" />
        </Grid>
    </Grid>
</UserControl>

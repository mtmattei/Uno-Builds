<Page x:Class="AdaptiveInputDemo.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:AdaptiveInputDemo.Presentation"
      xmlns:controls="using:AdaptiveInputDemo.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <StackPanel Spacing="32"
                    MaxWidth="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="24">

            <!-- Heading and Description -->
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="Type naturally, get the right tool"
                           Style="{StaticResource HeadlineMedium}"
                           Foreground="{ThemeResource OnSurfaceBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center" />
                <TextBlock Text="The input detects what you're typing and transforms to give you the perfect interface - calendar, colors, mentions, and more."
                           Style="{StaticResource BodyMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500" />
            </StackPanel>

            <!-- Adaptive Input -->
            <controls:AdaptiveInputControl x:Name="MainInput"
                                           Placeholder="Try typing: tomorrow, #FF0000, #urgent, @alice, 50-100"
                                           Submitted="OnInputSubmitted" />

            <!-- Example Section -->
            <StackPanel Spacing="16">
                <TextBlock Text="TRY THESE EXAMPLES"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           CharacterSpacing="80" />

                <StackPanel Spacing="12">
                    <!-- Row 1 -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Click="OnExampleClick" Tag="tomorrow" Style="{StaticResource OutlinedButtonStyle}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE787;" FontSize="14" Foreground="#2DD4BF" />
                                <TextBlock Text="tomorrow" />
                                <TextBlock Text="→ date" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Button>
                        <Button Click="OnExampleClick" Tag="#FF5500" Style="{StaticResource OutlinedButtonStyle}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE790;" FontSize="14" Foreground="#F472B6" />
                                <TextBlock Text="#FF5500" />
                                <TextBlock Text="→ color" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Button>
                        <Button Click="OnExampleClick" Tag="#urgent" Style="{StaticResource OutlinedButtonStyle}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8EC;" FontSize="14" Foreground="#4ADE80" />
                                <TextBlock Text="#urgent" />
                                <TextBlock Text="→ tag" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Row 2 -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button Click="OnExampleClick" Tag="@alice" Style="{StaticResource OutlinedButtonStyle}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77B;" FontSize="14" Foreground="#F87171" />
                                <TextBlock Text="@alice" />
                                <TextBlock Text="→ mention" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Button>
                        <Button Click="OnExampleClick" Tag="50-100" Style="{StaticResource OutlinedButtonStyle}" Padding="16,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE9E9;" FontSize="14" Foreground="#60A5FA" />
                                <TextBlock Text="50-100" />
                                <TextBlock Text="→ range" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>

      <Color x:Key="BackgroundColor">#0D0D1A</Color>
      <Color x:Key="OnBackgroundColor">#E8E8E8</Color>
      <Color x:Key="SurfaceColor">#1A1A2E</Color>
      <Color x:Key="OnSurfaceColor">#E8E8E8</Color>
      <Color x:Key="SurfaceVariantColor">#252538</Color>
      <Color x:Key="OnSurfaceVariantColor">#8888A0</Color>
      <Color x:Key="OutlineColor">#4A4A5A</Color>
      <Color x:Key="OnSurfaceInverseColor">#1A1A2E</Color>
      <Color x:Key="SurfaceInverseColor">#E8E8E8</Color>
      <Color x:Key="PrimaryInverseColor">#2D2D44</Color>
      <Color x:Key="SurfaceTintColor">#E0E0E0</Color>
      <Color x:Key="OutlineVariantColor">#3A3A4A</Color>

      <!-- Adaptive Input Badge Colors - Colorful accents -->
      <Color x:Key="AutoBadgeColor">#6B7280</Color>
      <Color x:Key="DateBadgeColor">#2DD4BF</Color>
      <Color x:Key="ColorBadgeColor">#F472B6</Color>

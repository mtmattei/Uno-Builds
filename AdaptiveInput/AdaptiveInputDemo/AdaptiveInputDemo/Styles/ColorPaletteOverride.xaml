<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Dark Theme (inverted - using dark colors for light key) -->
      <Color x:Key="PrimaryColor">#E0E0E0</Color>
      <Color x:Key="OnPrimaryColor">#1A1A2E</Color>
      <Color x:Key="PrimaryContainerColor">#2D2D44</Color>
      <Color x:Key="OnPrimaryContainerColor">#E8E8E8</Color>
      <Color x:Key="SecondaryColor">#B0B0B0</Color>
      <Color x:Key="OnSecondaryColor">#1A1A2E</Color>
      <Color x:Key="SecondaryContainerColor">#252538</Color>
      <Color x:Key="OnSecondaryContainerColor">#D0D0D0</Color>
      <Color x:Key="TertiaryColor">#9090A0</Color>
      <Color x:Key="OnTertiaryColor">#1A1A2E</Color>
      <Color x:Key="TertiaryContainerColor">#2A2A3D</Color>
      <Color x:Key="OnTertiaryContainerColor">#C0C0C0</Color>
      <Color x:Key="ErrorColor">#FF6B6B</Color>
      <Color x:Key="ErrorContainerColor">#3D2A2A</Color>
      <Color x:Key="OnErrorColor">#1A1A2E</Color>
      <Color x:Key="OnErrorContainerColor">#FFB0B0</Color>
      <Color x:Key="BackgroundColor">#0D0D1A</Color>
      <Color x:Key="OnBackgroundColor">#E8E8E8</Color>
      <Color x:Key="SurfaceColor">#1A1A2E</Color>
      <Color x:Key="OnSurfaceColor">#E8E8E8</Color>
      <Color x:Key="SurfaceVariantColor">#252538</Color>
      <Color x:Key="OnSurfaceVariantColor">#8888A0</Color>
      <Color x:Key="OutlineColor">#4A4A5A</Color>
      <Color x:Key="OnSurfaceInverseColor">#1A1A2E</Color>
      <Color x:Key="SurfaceInverseColor">#E8E8E8</Color>
      <Color x:Key="PrimaryInverseColor">#2D2D44</Color>
      <Color x:Key="SurfaceTintColor">#E0E0E0</Color>
      <Color x:Key="OutlineVariantColor">#3A3A4A</Color>

      <!-- Adaptive Input Badge Colors - Colorful accents -->
      <Color x:Key="AutoBadgeColor">#6B7280</Color>
      <Color x:Key="DateBadgeColor">#2DD4BF</Color>
      <Color x:Key="ColorBadgeColor">#F472B6</Color>
      <Color x:Key="MentionBadgeColor">#F87171</Color>
      <Color x:Key="TagBadgeColor">#4ADE80</Color>
      <Color x:Key="RangeBadgeColor">#60A5FA</Color>
      <Color x:Key="UrlBadgeColor">#A78BFA</Color>
      <Color x:Key="EmailBadgeColor">#FBBF24</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <!-- Dark Theme -->
      <Color x:Key="PrimaryColor">#E0E0E0</Color>

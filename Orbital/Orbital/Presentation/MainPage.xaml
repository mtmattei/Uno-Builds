<Page x:Class="Orbital.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:controls="using:Orbital.Controls"
      Background="{ThemeResource OrbitalSurface0Brush}">

  <Grid uen:Region.Attached="True">

    <muxc:NavigationView x:Name="NavView"
                         uen:Region.Attached="True"
                         PaneDisplayMode="Left"
                         IsPaneOpen="True"
                         OpenPaneLength="220"
                         CompactPaneLength="64"
                         IsBackButtonVisible="Collapsed"
                         IsSettingsVisible="False"
                         IsPaneToggleButtonVisible="True"
                         FontFamily="{StaticResource OrbitalDisplayFont}"
                         Background="{ThemeResource OrbitalSurface0Brush}">

      <muxc:NavigationView.Resources>
        <!-- Pane background (matches app background) -->
        <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="#FF0A0A0B" />
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="#FF0A0A0B" />
        <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="#FF0A0A0B" />
        <SolidColorBrush x:Key="SplitViewPaneBackground" Color="#FF0A0A0B" />

        <!-- Content area -->
        <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
        <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
        <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>

        <!-- Selection indicator (emerald left bar) -->
        <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="{ThemeResource OrbitalEmerald400}" />

        <!-- Item foreground: idle → Text-38, hover → Text-65, selected → emerald-400 -->
        <SolidColorBrush x:Key="NavigationViewItemForeground" Color="{ThemeResource OrbitalText38}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="{ThemeResource OrbitalText65}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundPressed" Color="{ThemeResource OrbitalText72}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="{ThemeResource OrbitalEmerald400}" />
        <!-- Material overrides for content presenter text -->
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedNotPrimary" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOverNotPrimary" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressedNotPrimary" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemOnIndicatorForeground" Color="{ThemeResource OrbitalEmerald400}" />

        <!-- Item background: idle → transparent, hover → emerald/5%, selected → emerald/8% -->
        <SolidColorBrush x:Key="NavigationViewItemBackground" Color="Transparent" />
        <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.05" />
        <SolidColorBrush x:Key="NavigationViewItemBackgroundPressed" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.07" />
        <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.08" />
        <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.12" />
        <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.14" />

        <!-- Icon foreground tracks item foreground -->
        <SolidColorBrush x:Key="NavigationViewItemIconForeground" Color="{ThemeResource OrbitalText38}" />
        <SolidColorBrush x:Key="NavigationViewItemIconForegroundPointerOver" Color="{ThemeResource OrbitalText65}" />
        <SolidColorBrush x:Key="NavigationViewItemIconForegroundPressed" Color="{ThemeResource OrbitalText72}" />
        <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelected" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPointerOver" Color="{ThemeResource OrbitalEmerald400}" />
        <SolidColorBrush x:Key="NavigationViewItemIconForegroundSelectedPressed" Color="{ThemeResource OrbitalEmerald400}" />

        <!-- InfoBadge styling (emerald pill) -->
        <!-- InfoBadge styling (emerald pill) -->
        <SolidColorBrush x:Key="InfoBadgeBackground" Color="{ThemeResource OrbitalEmerald500}" Opacity="0.15" />
        <SolidColorBrush x:Key="InfoBadgeForeground" Color="{ThemeResource OrbitalEmerald400}" />

        <!-- Toggle (hamburger) button -->
        <SolidColorBrush x:Key="NavigationViewButtonForegroundPointerOver" Color="{ThemeResource OrbitalText65}" />
        <SolidColorBrush x:Key="NavigationViewButtonForegroundPressed" Color="{ThemeResource OrbitalText72}" />
        <SolidColorBrush x:Key="NavigationViewButtonForegroundDisabled" Color="{ThemeResource OrbitalText25}" />

        <!-- Nav item shape + compact height -->
        <CornerRadius x:Key="NavigationViewItemCornerRadius">8</CornerRadius>
        <x:Double x:Key="NavigationViewItemOnLeftMinHeight">36</x:Double>
        <Thickness x:Key="NavigationViewItemOnLeftIconBoxMargin">0</Thickness>
        <Thickness x:Key="NavigationViewItemContentPresenterMargin">0</Thickness>
      </muxc:NavigationView.Resources>

      <!-- Pane Header: Logo region -->
      <muxc:NavigationView.PaneHeader>
        <utu:AutoLayout Spacing="0"
                        Padding="0,0,0,4">
          <!-- Logo row — left padding 16 aligns 32px icon center with nav item icon center at 32px (CompactPaneLength=64) -->
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="12"
                          Padding="16,16,16,16"
                          PrimaryAxisAlignment="Start"
                          CounterAxisAlignment="Center">
            <!-- Uno Logo with periodic spin -->
            <Image x:Name="LogoImage"
                   Source="ms-appx:///Assets/Icons/Uno-logo.png"
                   Width="32" Height="32"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5">
              <Image.RenderTransform>
                <RotateTransform x:Name="LogoRotate" Angle="0" />
              </Image.RenderTransform>
            </Image>
            <utu:AutoLayout x:Name="LogoTextBlock" Spacing="2"
                            PrimaryAxisAlignment="Center">
              <TextBlock Text="Orbital"
                         Style="{StaticResource OrbitalBody}"
                         Foreground="{ThemeResource OrbitalText88Brush}" />
              <TextBlock Text="v0.1.0-alpha"
                         Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </utu:AutoLayout>
          </utu:AutoLayout>

          <!-- Project selector -->
          <TextBlock x:Name="ProjectSectionLabel" Text="PROJECT"
                     Style="{StaticResource OrbitalSectionSubLabel}"
                     Foreground="{ThemeResource OrbitalText30Brush}"
                     Margin="16,8,16,4" />
          <Button x:Name="ProjectSelectorButton"
                  Margin="8,0,8,0"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  MinHeight="0">
            <Button.Style>
              <Style TargetType="Button">
                <Setter Property="Background" Value="{ThemeResource OrbitalSurface1Brush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource OrbitalSurface3Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="RootBorder"
                              Background="{TemplateBinding Background}"
                              BorderBrush="{TemplateBinding BorderBrush}"
                              BorderThickness="{TemplateBinding BorderThickness}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Padding="{TemplateBinding Padding}">
                        <VisualStateManager.VisualStateGroups>
                          <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal" />
                            <VisualState x:Name="PointerOver">
                              <VisualState.Setters>
                                <Setter Target="RootBorder.Background" Value="{ThemeResource OrbitalSurface15Brush}" />
                                <Setter Target="RootBorder.BorderBrush" Value="{ThemeResource OrbitalEmerald500_20Brush}" />
                              </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                              <VisualState.Setters>
                                <Setter Target="RootBorder.Background" Value="{ThemeResource OrbitalSurface2Brush}" />
                              </VisualState.Setters>
                            </VisualState>
                          </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                      </Border>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </Button.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0" Glyph="&#xE943;" FontSize="14"
                        Foreground="{ThemeResource OrbitalEmerald400Brush}"
                        VerticalAlignment="Center" />
              <TextBlock x:Name="ProjectSelectorName"
                         Grid.Column="2"
                         Text="{Binding ActiveProjectName}"
                         Style="{StaticResource OrbitalMonoSmall}"
                         Foreground="{ThemeResource OrbitalText65Brush}"
                         VerticalAlignment="Center"
                         TextTrimming="CharacterEllipsis" />
              <FontIcon Grid.Column="3" Glyph="&#xE70D;" FontSize="10"
                        Foreground="{ThemeResource OrbitalText30Brush}"
                        VerticalAlignment="Center" />
            </Grid>
            <Button.Flyout>
              <Flyout x:Name="ProjectFlyout" Placement="Bottom">
                <Flyout.FlyoutPresenterStyle>
                  <Style TargetType="FlyoutPresenter">
                    <Setter Property="Background" Value="{ThemeResource OrbitalSurface1Brush}" />
                    <Setter Property="BorderBrush" Value="{ThemeResource OrbitalSurface3Brush}" />
                    <Setter Property="BorderThickness" Value="1" />
                    <Setter Property="CornerRadius" Value="8" />
                    <Setter Property="Padding" Value="4" />
                  </Style>
                </Flyout.FlyoutPresenterStyle>
                <StackPanel x:Name="ProjectFlyoutContent" Spacing="4" MinWidth="200" />
              </Flyout>
            </Button.Flyout>
          </Button>

          <!-- Section label -->
          <TextBlock x:Name="NavigateSectionLabel" Text="NAVIGATE"
                     Style="{StaticResource OrbitalSectionSubLabel}"
                     Foreground="{ThemeResource OrbitalText30Brush}"
                     Margin="16,8,16,4" />
        </utu:AutoLayout>
      </muxc:NavigationView.PaneHeader>

      <!-- Nav Items — outlined icons (20×20 viewbox, 1.5px stroke weight aesthetic) -->
      <muxc:NavigationView.MenuItems>
        <muxc:NavigationViewItem Content="Home"
                                 uen:Region.Name="Home">
          <muxc:NavigationViewItem.Icon>
            <!-- 4-square grid: outlined rounded squares -->
            <PathIcon Data="M1.5,2.5 A1,1,0,0,1,2.5,1.5 H7.5 A1,1,0,0,1,8.5,2.5 V7.5 A1,1,0,0,1,7.5,8.5 H2.5 A1,1,0,0,1,1.5,7.5Z M11.5,2.5 A1,1,0,0,1,12.5,1.5 H17.5 A1,1,0,0,1,18.5,2.5 V7.5 A1,1,0,0,1,17.5,8.5 H12.5 A1,1,0,0,1,11.5,7.5Z M1.5,12.5 A1,1,0,0,1,2.5,11.5 H7.5 A1,1,0,0,1,8.5,12.5 V17.5 A1,1,0,0,1,7.5,18.5 H2.5 A1,1,0,0,1,1.5,17.5Z M11.5,12.5 A1,1,0,0,1,12.5,11.5 H17.5 A1,1,0,0,1,18.5,12.5 V17.5 A1,1,0,0,1,17.5,18.5 H12.5 A1,1,0,0,1,11.5,17.5Z" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Project"
                                 uen:Region.Name="Project">
          <muxc:NavigationViewItem.Icon>
            <!-- Code brackets: < / > -->
            <PathIcon Data="M7,4 L2,10 L7,16 M13,4 L18,10 L13,16 M11,2 L9,18" />
          </muxc:NavigationViewItem.Icon>
          <muxc:NavigationViewItem.InfoBadge>
            <muxc:InfoBadge x:Name="ProjectBadge" Value="1" />
          </muxc:NavigationViewItem.InfoBadge>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Agent Sessions"
                                 uen:Region.Name="Agents">
          <muxc:NavigationViewItem.Icon>
            <!-- Sparkle: 4-point star outline -->
            <PathIcon Data="M10,1 L11.8,7.2 L18,5.5 L12.8,9.5 L18,13.5 L11.8,12 L10,19 L8.2,12 L2,13.5 L7.2,9.5 L2,5.5 L8.2,7.2Z" />
          </muxc:NavigationViewItem.Icon>
          <muxc:NavigationViewItem.InfoBadge>
            <muxc:InfoBadge Value="1" />
          </muxc:NavigationViewItem.InfoBadge>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Studio"
                                 uen:Region.Name="Studio">
          <muxc:NavigationViewItem.Icon>
            <!-- Layers: three stacked planes -->
            <PathIcon Data="M10,1 L19,5.5 L10,10 L1,5.5Z M1,10 L10,14.5 L19,10 M1,14 L10,18.5 L19,14" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Skills"
                                 uen:Region.Name="Skills">
          <muxc:NavigationViewItem.Icon>
            <!-- Bolt / lightning: energy -->
            <PathIcon Data="M11,1 L4,11 H9.5 L8,19 L17,9 H11.5Z" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Diagnostics"
                                 uen:Region.Name="Diagnostics">
          <muxc:NavigationViewItem.Icon>
            <!-- Pulse line: cleaner ECG -->
            <PathIcon Data="M1,10 H5 L7,4 L10,16 L13,4 L15,10 H19" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Settings"
                                 uen:Region.Name="Settings">
          <muxc:NavigationViewItem.Icon>
            <!-- Gear -->
            <FontIcon Glyph="&#xE713;" FontSize="16" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
      </muxc:NavigationView.MenuItems>

      <!-- Pane Footer: Clock + MCP status -->
      <muxc:NavigationView.PaneFooter>
        <utu:AutoLayout Spacing="12"
                        Padding="12,12,12,16">
          <!-- Clock -->
          <utu:AutoLayout x:Name="ClockRow" Orientation="Horizontal"
                          Spacing="8"
                          Padding="8,0,0,0"
                          CounterAxisAlignment="Center">
            <FontIcon Glyph="&#xE823;"
                      FontSize="12"
                      Foreground="{ThemeResource OrbitalText40Brush}" />
            <TextBlock x:Name="SidebarClock"
                       Text="{Binding ClockDisplay}"
                       Style="{StaticResource OrbitalSidebarClock}" />
          </utu:AutoLayout>

          <!-- MCP Status Card -->
          <Border x:Name="McpCard" Background="{ThemeResource OrbitalSurface1Brush}"
                  BorderBrush="{ThemeResource OrbitalSurface3Brush}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12">
            <utu:AutoLayout Spacing="6">
              <utu:AutoLayout Orientation="Horizontal"
                              Spacing="8"
                              CounterAxisAlignment="Center">
                <Ellipse Width="8" Height="8"
                         Fill="{ThemeResource OrbitalEmerald400Brush}" />
                <TextBlock Text="MCP Connected"
                           Style="{StaticResource OrbitalMonoSmall}"
                           Foreground="{ThemeResource OrbitalText50Brush}" />
                <controls:PulsingBars BarCount="3" BarColor="emerald" VerticalAlignment="Center" />
              </utu:AutoLayout>
              <TextBlock x:Name="McpDetail"
                         Text="{Binding McpDetail}"
                         Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText30Brush}" />
            </utu:AutoLayout>
          </Border>
        </utu:AutoLayout>
      </muxc:NavigationView.PaneFooter>

      <!-- Content Region -->
      <Grid uen:Region.Attached="True"
            uen:Region.Navigator="Visibility"
            Background="{ThemeResource OrbitalSurface0Brush}" />

    </muxc:NavigationView>

    <!-- SEARCH OVERLAY (command palette) -->
    <Grid x:Name="SearchOverlay" Visibility="Collapsed">
      <!-- Backdrop -->
      <Border x:Name="SearchBackdrop" Background="#CC000000" />

      <!-- Search Panel -->
      <Border x:Name="SearchPanel"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Margin="0,80,0,0"
              Width="560"
              MaxHeight="480"
              Background="{ThemeResource OrbitalSurface1Brush}"
              BorderBrush="{ThemeResource OrbitalSurface35Brush}"
              BorderThickness="1"
              CornerRadius="12"
              Padding="0"
              Translation="0,0,32">
        <Border.Shadow>
          <ThemeShadow />
        </Border.Shadow>
        <StackPanel>
          <!-- Search input row -->
          <Grid Padding="16,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="16"
                      Foreground="{ThemeResource OrbitalText38Brush}"
                      VerticalAlignment="Center" Margin="0,0,12,0" />
            <TextBox x:Name="SearchInput"
                     Grid.Column="1"
                     PlaceholderText="Search pages, actions, skills, tools..."
                     FontFamily="{StaticResource OrbitalMonoFont}"
                     FontSize="14"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{ThemeResource OrbitalText85Brush}"
                     VerticalAlignment="Center" />
            <Border Grid.Column="2"
                    Background="{ThemeResource OrbitalSurface2Brush}"
                    CornerRadius="4" Padding="6,2"
                    VerticalAlignment="Center" Margin="8,0,0,0">
              <TextBlock Text="Esc"
                         FontFamily="{StaticResource OrbitalMonoFont}"
                         FontSize="10"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </Border>
          </Grid>

          <!-- Divider -->
          <Border Height="1" Background="{ThemeResource OrbitalSurface2Brush}" />

          <!-- Results list -->
          <ScrollViewer x:Name="SearchResultsScroller" MaxHeight="380">
            <StackPanel x:Name="SearchResultsList" Padding="8" Spacing="2" />
          </ScrollViewer>

          <!-- Empty state -->
          <TextBlock x:Name="SearchEmpty"
                     Text="No results found"
                     FontFamily="{StaticResource OrbitalMonoFont}"
                     FontSize="12"
                     Foreground="{ThemeResource OrbitalText30Brush}"
                     HorizontalAlignment="Center"
                     Margin="0,16,0,16"
                     Visibility="Collapsed" />
        </StackPanel>
      </Border>
    </Grid>

  </Grid>
</Page>

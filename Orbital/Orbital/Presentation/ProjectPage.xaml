<Page x:Class="Orbital.Presentation.ProjectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uer="using:Uno.Extensions.Reactive.UI"
      xmlns:controls="using:Orbital.Controls"
      Background="{ThemeResource OrbitalSurface0Brush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <controls:PageHeader x:Name="Header" Grid.Row="0"
                         Title="Project"
                         Subtitle="{Binding HeaderSubtitle}" />

    <ScrollViewer Grid.Row="1">
      <utu:AutoLayout Spacing="24" Padding="{utu:Responsive Narrow='16', Normal='32', Wide='32'}" PrimaryAxisAlignment="Start">

        <!-- META STRIP: 5-column grid -->
        <Grid x:Name="MetaStrip" Opacity="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource OrbitalCardStyle}" Margin="0,0,8,0">
            <utu:AutoLayout Spacing="4">
              <TextBlock Text="SOLUTION" Style="{StaticResource OrbitalSectionSubLabel}" />
              <TextBlock Text="{Binding SolutionName}" Style="{StaticResource OrbitalMetaValue}" />
              <TextBlock Text="{Binding SolutionDetail}" Style="{StaticResource OrbitalMonoSmall}" />
            </utu:AutoLayout>
          </Border>

          <Border Grid.Column="1" Style="{StaticResource OrbitalCardStyle}" Margin="8,0,8,0">
            <utu:AutoLayout Spacing="4">
              <TextBlock Text="TARGETS" Style="{StaticResource OrbitalSectionSubLabel}" />
              <TextBlock Text="{Binding TargetsDisplay}" Style="{StaticResource OrbitalMetaValue}" />
              <TextBlock Text="{Binding TargetsDetail}" Style="{StaticResource OrbitalMonoSmall}" />
            </utu:AutoLayout>
          </Border>

          <Border Grid.Column="2" Style="{StaticResource OrbitalCardStyle}" Margin="8,0,8,0">
            <utu:AutoLayout Spacing="4">
              <TextBlock Text="BUILD" Style="{StaticResource OrbitalSectionSubLabel}" />
              <TextBlock Text="{Binding BuildConfig}" Style="{StaticResource OrbitalMetaValue}" />
              <TextBlock Text="{Binding BuildDetail}" Style="{StaticResource OrbitalMonoSmall}" />
            </utu:AutoLayout>
          </Border>

          <Border Grid.Column="3" Style="{StaticResource OrbitalCardStyle}" Margin="8,0,8,0">
            <utu:AutoLayout Spacing="4">
              <TextBlock Text="BRANCH" Style="{StaticResource OrbitalSectionSubLabel}" />
              <TextBlock Text="{Binding BranchName}" Style="{StaticResource OrbitalMetaValue}" />
              <TextBlock Text="{Binding BranchDetail}" Style="{StaticResource OrbitalMonoSmall}" />
            </utu:AutoLayout>
          </Border>

          <Border Grid.Column="4" Style="{StaticResource OrbitalCardStyle}" Margin="8,0,0,0">
            <utu:AutoLayout Spacing="4">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="HOT RELOAD" Style="{StaticResource OrbitalSectionSubLabel}" />
                <controls:PulsingBars Grid.Column="1" BarCount="3" BarColor="amber" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Text="{Binding HotReloadStatus}" Style="{StaticResource OrbitalMetaValue}" />
              <TextBlock Text="{Binding HotReloadDetail}" Style="{StaticResource OrbitalMonoSmall}" />
            </utu:AutoLayout>
          </Border>
        </Grid>

        <!-- TASK BAR -->
        <Grid x:Name="TaskBar" Opacity="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="BuildButton" Style="{StaticResource OrbitalSecondaryButtonSm}" AutomationProperties.Name="Build Project">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE912;" FontSize="14" />
                <TextBlock Text="Build" />
              </StackPanel>
            </Button>
            <Button x:Name="RunButton" Style="{StaticResource OrbitalPrimaryButtonSm}" AutomationProperties.Name="Run Project">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE768;" FontSize="14" />
                <TextBlock Text="Run" />
              </StackPanel>
            </Button>
            <Button x:Name="PackageButton" Style="{StaticResource OrbitalSecondaryButtonSm}" AutomationProperties.Name="Package Project">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE7B8;" FontSize="14" />
                <TextBlock Text="Package" />
              </StackPanel>
            </Button>
            <Button x:Name="HotReloadButton" Style="{StaticResource OrbitalSecondaryButtonSm}" AutomationProperties.Name="Hot Reload">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
                <TextBlock Text="Hot Reload" />
              </StackPanel>
            </Button>
            <Button x:Name="SmokeTestButton" Style="{StaticResource OrbitalSecondaryButtonSm}" AutomationProperties.Name="UI Smoke Test">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE78B;" FontSize="14" />
                <TextBlock Text="UI Smoke Test" />
              </StackPanel>
            </Button>
          </StackPanel>
          <Button x:Name="BuildRunVerifyButton" Grid.Column="1" Style="{StaticResource OrbitalGhostButtonSm}"
                  HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE945;" FontSize="14"
                        Foreground="{ThemeResource OrbitalText55Brush}" />
              <TextBlock Text="Build &gt; Run &gt; Verify" Style="{StaticResource OrbitalBody}"
                         Foreground="{ThemeResource OrbitalText55Brush}" />
            </StackPanel>
          </Button>
        </Grid>

        <!-- TABBED CONSOLE -->
        <Border x:Name="ConsoleCard" Style="{StaticResource OrbitalCardStyle}" Opacity="0">
          <utu:AutoLayout Spacing="16">
            <!-- Tab row -->
            <StackPanel Orientation="Horizontal" Spacing="4">
              <Border x:Name="TabBuild" Background="{ThemeResource OrbitalSurface3Brush}"
                      CornerRadius="6" Padding="12,6" Tapped="OnBuildTabTapped">
                <TextBlock Text="Build" Style="{StaticResource OrbitalTabLabel}"
                           Foreground="{ThemeResource OrbitalText85Brush}" />
              </Border>
              <Border x:Name="TabRun" Background="Transparent"
                      CornerRadius="6" Padding="12,6" Tapped="OnRunTabTapped">
                <TextBlock Text="Run" Style="{StaticResource OrbitalTabLabel}" />
              </Border>
              <Border x:Name="TabArtifacts" Background="Transparent"
                      CornerRadius="6" Padding="12,6" Tapped="OnArtifactsTabTapped">
                <TextBlock Text="Artifacts" Style="{StaticResource OrbitalTabLabel}" />
              </Border>
            </StackPanel>

            <controls:ConsoleBlock x:Name="BuildConsole" Title="{Binding BuildConsoleTitle}" />
            <controls:ConsoleBlock x:Name="RunConsole" Title="{Binding RunConsoleTitle}" Visibility="Collapsed" />
            <StackPanel x:Name="ArtifactsPanel" Spacing="4" Visibility="Collapsed" />
          </utu:AutoLayout>
        </Border>

      </utu:AutoLayout>
    </ScrollViewer>
  </Grid>
</Page>

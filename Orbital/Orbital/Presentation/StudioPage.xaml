<Page x:Class="Orbital.Presentation.StudioPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:Orbital.Controls"
      Background="{ThemeResource OrbitalSurface0Brush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <controls:PageHeader Grid.Row="0"
                         Title="Studio &amp; Connectors"
                         Subtitle="Uno Platform Studio configuration and integrations" />

    <ScrollViewer Grid.Row="1">
      <utu:AutoLayout Spacing="24" Padding="{utu:Responsive Narrow='16', Normal='32', Wide='32'}" PrimaryAxisAlignment="Start">

        <!-- LICENSE CARD -->
        <Border x:Name="LicenseCard" Style="{StaticResource OrbitalCardStyle}" Opacity="0"
                BorderBrush="{ThemeResource OrbitalEmerald500_20Brush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: icon + info -->
            <StackPanel Orientation="Horizontal" Spacing="16">
              <!-- Shield icon -->
              <Border Width="48" Height="48" CornerRadius="12">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3310B981" Offset="0" />
                    <GradientStop Color="#1A059669" Offset="1" />
                  </LinearGradientBrush>
                </Border.Background>
                <FontIcon Glyph="&#xEA18;" FontSize="22"
                          Foreground="{ThemeResource OrbitalEmerald400Brush}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock Text="{Binding LicenseTitle, FallbackValue='Uno Platform Studio'}" Style="{StaticResource OrbitalMetaValue}" />
                <TextBlock Text="{Binding LicenseDetail, FallbackValue='Detecting...'}" Style="{StaticResource OrbitalMonoConsole}"
                           Foreground="{ThemeResource OrbitalText42Brush}" />
              </StackPanel>
            </StackPanel>

            <!-- Right: badge + bars + button -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                        VerticalAlignment="Center">
              <Border x:Name="LicenseBadge" Style="{StaticResource OrbitalBadgeSuccess}"
                      VerticalAlignment="Center">
                <TextBlock x:Name="LicenseBadgeText" Text="{Binding LicenseBadge, FallbackValue='...'}" Style="{StaticResource OrbitalMonoSmall}"
                           Foreground="{ThemeResource OrbitalEmerald400Brush}"
                           VerticalAlignment="Center" />
              </Border>
              <controls:PulsingBars BarCount="3" BarColor="emerald" VerticalAlignment="Center" />
              <Button x:Name="RefreshButton"
                      Style="{StaticResource OrbitalSecondaryButtonSm}"
                      AutomationProperties.Name="Refresh License"
                      Padding="8"
                      MinWidth="0"
                      VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <!-- FEATURES SECTION -->
        <utu:AutoLayout x:Name="FeaturesSection" Spacing="12" PrimaryAxisAlignment="Start" Opacity="0">
          <TextBlock Text="STUDIO FEATURES" Style="{StaticResource OrbitalSectionHeader}"
                     Foreground="{ThemeResource OrbitalText38Brush}" />
          <Grid x:Name="FeaturesGrid">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- Populated in code-behind -->
          </Grid>
        </utu:AutoLayout>

        <!-- CONNECTORS SECTION -->
        <utu:AutoLayout x:Name="ConnectorsSection" Spacing="12" PrimaryAxisAlignment="Start" Opacity="0">
          <TextBlock Text="CONNECTORS" Style="{StaticResource OrbitalSectionHeader}"
                     Foreground="{ThemeResource OrbitalText38Brush}" />
          <StackPanel x:Name="ConnectorsList" Spacing="8" />
        </utu:AutoLayout>

      </utu:AutoLayout>
    </ScrollViewer>
  </Grid>
</Page>

<Page x:Class="Orbital.Presentation.SkillsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:controls="using:Orbital.Controls"
      Background="{ThemeResource OrbitalSurface0Brush}">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <controls:PageHeader Grid.Row="0"
                         Title="Skills"
                         Subtitle="Claude Code skill extensions and slash commands" />

    <ScrollViewer Grid.Row="1">
      <utu:AutoLayout Spacing="24"
                      Padding="{utu:Responsive Narrow='16', Normal='32', Wide='32'}"
                      MaxWidth="1200">

        <!-- Stat Cards -->
        <Grid x:Name="StatsRow" Opacity="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <!-- Installed -->
          <Border Grid.Column="0" Style="{StaticResource OrbitalCardStyle}">
            <utu:AutoLayout Spacing="4" Padding="4">
              <TextBlock Text="INSTALLED" Style="{StaticResource OrbitalSectionSubLabel}"
                         Foreground="{ThemeResource OrbitalText30Brush}" />
              <TextBlock x:Name="StatInstalled" Text="{Binding InstalledCount, FallbackValue='--'}"
                         Style="{StaticResource OrbitalCardValue}"
                         Foreground="{ThemeResource OrbitalText88Brush}" />
              <TextBlock Text="skill extensions" Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </utu:AutoLayout>
          </Border>

          <!-- Active -->
          <Border Grid.Column="2" Style="{StaticResource OrbitalCardStyle}">
            <utu:AutoLayout Spacing="4" Padding="4">
              <TextBlock Text="ACTIVE" Style="{StaticResource OrbitalSectionSubLabel}"
                         Foreground="{ThemeResource OrbitalText30Brush}" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="StatActive" Text="{Binding ActiveCount, FallbackValue='--'}"
                           Style="{StaticResource OrbitalCardValue}"
                           Foreground="{ThemeResource OrbitalEmerald400Brush}" />
                <controls:PulsingBars BarCount="3" BarColor="emerald" VerticalAlignment="Center" />
              </StackPanel>
              <TextBlock Text="enabled" Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </utu:AutoLayout>
          </Border>

          <!-- Invocations 30D -->
          <Border Grid.Column="4" Style="{StaticResource OrbitalCardStyle}">
            <utu:AutoLayout Spacing="4" Padding="4">
              <TextBlock Text="INVOCATIONS" Style="{StaticResource OrbitalSectionSubLabel}"
                         Foreground="{ThemeResource OrbitalText30Brush}" />
              <TextBlock x:Name="StatInvocations" Text="{Binding InvocationCount, FallbackValue='--'}"
                         Style="{StaticResource OrbitalCardValue}"
                         Foreground="{ThemeResource OrbitalText88Brush}" />
              <TextBlock Text="last 30 days" Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </utu:AutoLayout>
          </Border>

          <!-- Avg Accuracy -->
          <Border Grid.Column="6" Style="{StaticResource OrbitalCardStyle}">
            <utu:AutoLayout Spacing="4" Padding="4">
              <TextBlock Text="AVG ACCURACY" Style="{StaticResource OrbitalSectionSubLabel}"
                         Foreground="{ThemeResource OrbitalText30Brush}" />
              <TextBlock x:Name="StatAccuracy" Text="{Binding AvgAccuracy, FallbackValue='--'}"
                         Style="{StaticResource OrbitalCardValue}"
                         Foreground="{ThemeResource OrbitalText88Brush}" />
              <TextBlock Text="trigger match" Style="{StaticResource OrbitalMonoMeta}"
                         Foreground="{ThemeResource OrbitalText35Brush}" />
            </utu:AutoLayout>
          </Border>
        </Grid>

        <!-- Skill groups are populated in code-behind -->
        <StackPanel x:Name="SkillGroupsPanel" Spacing="24" Opacity="0" />
      </utu:AutoLayout>
    </ScrollViewer>
  </Grid>
</Page>

<UserControl x:Class="Orbital.Controls.ConsoleBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Orbital.Controls">

  <Border Background="{ThemeResource OrbitalSurface15Brush}"
          BorderBrush="{ThemeResource OrbitalSurface2Brush}"
          BorderThickness="1"
          CornerRadius="8">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Title bar -->
      <Border Grid.Row="0"
              BorderBrush="{ThemeResource OrbitalSurface2Brush}"
              BorderThickness="0,0,0,1"
              Padding="16,8">
        <Grid>
          <StackPanel Orientation="Horizontal" Spacing="8"
                      VerticalAlignment="Center">
            <!-- Traffic dots -->
            <Ellipse Width="10" Height="10" Fill="#B3EF4444" />
            <Ellipse Width="10" Height="10" Fill="#B3FBBF24" />
            <Ellipse Width="10" Height="10" Fill="#B310B981" />
            <!-- Title -->
            <TextBlock x:Name="TitleText"
                       Style="{StaticResource OrbitalMonoSmall}"
                       Foreground="{ThemeResource OrbitalText35Brush}"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center" />
          </StackPanel>
          <controls:PulsingBars BarCount="4" BarColor="emerald"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center" />
        </Grid>
      </Border>

      <!-- Console body -->
      <Grid Grid.Row="1">
        <ScrollViewer MaxHeight="280"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16">
          <StackPanel x:Name="LinesPanel" Spacing="0" />
        </ScrollViewer>

        <!-- Scanline overlay -->
        <Rectangle x:Name="Scanline"
                   Height="70"
                   IsHitTestVisible="False"
                   VerticalAlignment="Top">
          <Rectangle.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Color="Transparent" Offset="0" />
              <GradientStop Color="#0834D399" Offset="0.4" />
              <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
          </Rectangle.Fill>
          <Rectangle.RenderTransform>
            <TranslateTransform x:Name="ScanlineTranslate" Y="-70" />
          </Rectangle.RenderTransform>
        </Rectangle>
      </Grid>
    </Grid>
  </Border>

  <UserControl.Resources>
    <Storyboard x:Name="ScanlineAnimation" RepeatBehavior="Forever">
      <DoubleAnimation Storyboard.TargetName="ScanlineTranslate"
                       Storyboard.TargetProperty="Y"
                       From="-70" To="350"
                       Duration="0:0:4" />
    </Storyboard>
  </UserControl.Resources>
</UserControl>

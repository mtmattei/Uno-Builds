<UserControl x:Class="Orbital.Controls.VersionPill"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="{ThemeResource OrbitalSurface1Brush}"
          BorderBrush="{ThemeResource OrbitalSurface3Brush}"
          BorderThickness="1"
          CornerRadius="6"
          Padding="12,5">
    <StackPanel Orientation="Horizontal" Spacing="7">
      <TextBlock x:Name="LabelText"
                 Style="{StaticResource OrbitalMonoPillLabel}"
                 Foreground="{ThemeResource OrbitalText32Brush}"
                 FontSize="11" />
      <TextBlock x:Name="ValueText"
                 Style="{StaticResource OrbitalMonoMeta}"
                 Foreground="{ThemeResource OrbitalText55Brush}"
                 FontSize="11" />
    </StackPanel>
  </Border>
</UserControl>

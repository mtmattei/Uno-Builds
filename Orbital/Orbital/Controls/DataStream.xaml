<UserControl x:Class="Orbital.Controls.DataStream"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <TextBlock x:Name="StreamText"
             FontFamily="{StaticResource OrbitalMonoFont}"
             FontSize="9"
             Foreground="{ThemeResource OrbitalEmerald500Brush}"
             Opacity="0.3"
             MaxWidth="160"
             TextTrimming="CharacterEllipsis"
             TextWrapping="NoWrap"
             IsTextSelectionEnabled="False" />

  <UserControl.Resources>
    <!-- Irregular opacity flicker: 0.15 -> 0.5 -> 0.2 -> 0.45 -> 0.15, 3s loop -->
    <Storyboard x:Name="FlickerAnimation" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="StreamText"
                                      Storyboard.TargetProperty="Opacity">
        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.15" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="0.5" />
        <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="0.2" />
        <LinearDoubleKeyFrame KeyTime="0:0:1.3" Value="0.45" />
        <LinearDoubleKeyFrame KeyTime="0:0:1.8" Value="0.15" />
        <LinearDoubleKeyFrame KeyTime="0:0:2.2" Value="0.4" />
        <LinearDoubleKeyFrame KeyTime="0:0:2.6" Value="0.2" />
        <LinearDoubleKeyFrame KeyTime="0:0:3" Value="0.15" />
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>
  </UserControl.Resources>
</UserControl>

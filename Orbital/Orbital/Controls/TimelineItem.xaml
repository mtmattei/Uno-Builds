<UserControl x:Class="Orbital.Controls.TimelineItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="12" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Dot + connector line -->
    <Grid Grid.Column="0" Width="12">
      <Ellipse x:Name="DotOuter"
               Width="12" Height="12"
               StrokeThickness="2"
               VerticalAlignment="Top"
               Margin="0,2,0,0" />
      <Ellipse x:Name="DotInner"
               Width="8" Height="8"
               VerticalAlignment="Top"
               Margin="2,4,2,0"
               Opacity="0.2" />
      <Border x:Name="ConnectorLine"
              Width="2"
              CornerRadius="1"
              VerticalAlignment="Stretch"
              HorizontalAlignment="Center"
              Margin="0,16,0,0">
        <Border.Background>
          <SolidColorBrush Color="#FF2A2A2E" />
        </Border.Background>
      </Border>
    </Grid>

    <!-- Content -->
    <StackPanel Grid.Column="2" Padding="0,0,0,20">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock x:Name="TitleText"
                   Style="{StaticResource OrbitalBody}"
                   Foreground="{ThemeResource OrbitalText85Brush}" />
        <TextBlock x:Name="TimeText"
                   Style="{StaticResource OrbitalMonoSmall}"
                   Foreground="{ThemeResource OrbitalText35Brush}"
                   VerticalAlignment="Center" />
      </StackPanel>
      <TextBlock x:Name="DetailText"
                 Style="{StaticResource OrbitalCaption}"
                 Foreground="{ThemeResource OrbitalText45Brush}"
                 Margin="0,4,0,0"
                 Visibility="Collapsed" />
    </StackPanel>
  </Grid>
</UserControl>

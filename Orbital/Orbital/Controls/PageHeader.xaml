<UserControl x:Class="Orbital.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

  <Border BorderBrush="{ThemeResource OrbitalSurface2Brush}"
          BorderThickness="0,0,0,1"
          Padding="32,20">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Title + Subtitle -->
      <utu:AutoLayout Grid.Column="0"
                      Spacing="4"
                      PrimaryAxisAlignment="Center">
        <TextBlock x:Name="TitleText"
                   Style="{StaticResource OrbitalPageTitle}" />
        <TextBlock x:Name="SubtitleText"
                   Style="{StaticResource OrbitalBody}"
                   Foreground="{ThemeResource OrbitalText40Brush}"
                   FontWeight="Normal" />
      </utu:AutoLayout>

      <!-- Search Bar (clickable border) -->
      <Border x:Name="SearchBorder"
              Grid.Column="1"
              Background="{ThemeResource OrbitalSurface1Brush}"
              BorderBrush="{ThemeResource OrbitalSurface3Brush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="12,8"
              VerticalAlignment="Center"
              AutomationProperties.Name="Search or run command">
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <FontIcon Glyph="&#xE721;"
                    FontSize="14"
                    Foreground="{ThemeResource OrbitalText35Brush}"
                    VerticalAlignment="Center" />
          <TextBlock Text="Search or run command..."
                     FontFamily="{StaticResource OrbitalMonoFont}"
                     FontSize="12"
                     Foreground="{ThemeResource OrbitalText30Brush}"
                     VerticalAlignment="Center" />
          <Border Background="{ThemeResource OrbitalSurface2Brush}"
                  CornerRadius="4"
                  Padding="6,2"
                  VerticalAlignment="Center">
            <TextBlock Text="Ctrl+K"
                       FontFamily="{StaticResource OrbitalMonoFont}"
                       FontSize="10"
                       Foreground="{ThemeResource OrbitalText35Brush}" />
          </Border>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>

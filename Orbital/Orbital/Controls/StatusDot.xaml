<UserControl x:Class="Orbital.Controls.StatusDot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid x:Name="RootGrid">
    <!-- Pulse ring (expands + fades, ok status only) -->
    <Ellipse x:Name="PulseRing"
             Width="8" Height="8"
             StrokeThickness="1.5"
             Opacity="0"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
      <Ellipse.RenderTransform>
        <ScaleTransform x:Name="RingScale" />
      </Ellipse.RenderTransform>
      <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
    </Ellipse>

    <!-- Main dot -->
    <Ellipse x:Name="Dot"
             Width="8" Height="8"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
      <Ellipse.RenderTransform>
        <ScaleTransform x:Name="DotScale" />
      </Ellipse.RenderTransform>
      <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
    </Ellipse>
  </Grid>

  <UserControl.Resources>
    <!-- Dot breathe: scale 1 -> 0.8 -> 1, 2s cycle -->
    <Storyboard x:Name="PulseAnimation" RepeatBehavior="Forever">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DotScale"
                                      Storyboard.TargetProperty="ScaleX">
        <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
        <SplineDoubleKeyFrame KeyTime="0:0:1" Value="0.8" KeySpline="0.42,0,0.58,1" />
        <SplineDoubleKeyFrame KeyTime="0:0:2" Value="1" KeySpline="0.42,0,0.58,1" />
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="DotScale"
                                      Storyboard.TargetProperty="ScaleY">
        <SplineDoubleKeyFrame KeyTime="0:0:0" Value="1" />
        <SplineDoubleKeyFrame KeyTime="0:0:1" Value="0.8" KeySpline="0.42,0,0.58,1" />
        <SplineDoubleKeyFrame KeyTime="0:0:2" Value="1" KeySpline="0.42,0,0.58,1" />
      </DoubleAnimationUsingKeyFrames>
      <!-- Ring expand + fade over 2.5s -->
      <DoubleAnimation Storyboard.TargetName="RingScale"
                       Storyboard.TargetProperty="ScaleX"
                       From="0.85" To="1.5" Duration="0:0:2.5" />
      <DoubleAnimation Storyboard.TargetName="RingScale"
                       Storyboard.TargetProperty="ScaleY"
                       From="0.85" To="1.5" Duration="0:0:2.5" />
      <DoubleAnimation Storyboard.TargetName="PulseRing"
                       Storyboard.TargetProperty="Opacity"
                       From="0.6" To="0" Duration="0:0:2.5" />
    </Storyboard>
  </UserControl.Resources>
</UserControl>

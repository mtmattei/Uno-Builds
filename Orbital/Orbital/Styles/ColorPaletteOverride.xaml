<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Dark">
      <!-- Surface Palette (monochrome near-black) -->
      <Color x:Key="BackgroundColor">#FF0A0A0B</Color>
      <Color x:Key="SurfaceColor">#FF141416</Color>
      <Color x:Key="SurfaceContainerColor">#FF141416</Color>
      <Color x:Key="SurfaceContainerLowColor">#FF0E0E10</Color>
      <Color x:Key="SurfaceContainerHighColor">#FF1A1A1C</Color>
      <Color x:Key="SurfaceContainerHighestColor">#FF212123</Color>
      <Color x:Key="SurfaceVariantColor">#FF1A1A1C</Color>
      <Color x:Key="SurfaceTintColor">#FF34D399</Color>

      <!-- Primary: Emerald (unchanged) -->
      <Color x:Key="PrimaryColor">#FF34D399</Color>
      <Color x:Key="OnPrimaryColor">#FF0A0A0B</Color>
      <Color x:Key="PrimaryContainerColor">#FF0D3B2A</Color>
      <Color x:Key="OnPrimaryContainerColor">#FF34D399</Color>

      <!-- Secondary: Violet (unchanged) -->
      <Color x:Key="SecondaryColor">#FFA78BFA</Color>
      <Color x:Key="OnSecondaryColor">#FF0A0A0B</Color>
      <Color x:Key="SecondaryContainerColor">#FF2D1F5E</Color>
      <Color x:Key="OnSecondaryContainerColor">#FFA78BFA</Color>

      <!-- Tertiary: Amber (unchanged) -->
      <Color x:Key="TertiaryColor">#FFFBBF24</Color>
      <Color x:Key="OnTertiaryColor">#FF0A0A0B</Color>
      <Color x:Key="TertiaryContainerColor">#FF3D2E00</Color>
      <Color x:Key="OnTertiaryContainerColor">#FFFBBF24</Color>

      <!-- Text (unchanged) -->
      <Color x:Key="OnSurfaceColor">#FFE8EAF0</Color>
      <Color x:Key="OnSurfaceVariantColor">#FF7B8191</Color>
      <Color x:Key="OnBackgroundColor">#FFE8EAF0</Color>

      <!-- Outline (monochrome) -->
      <Color x:Key="OutlineColor">#FF1E1E20</Color>
      <Color x:Key="OutlineVariantColor">#FF1A1A1C</Color>

      <!-- Error (unchanged) -->
      <Color x:Key="ErrorColor">#FFEF4444</Color>
      <Color x:Key="OnErrorColor">#FFFFFFFF</Color>
      <Color x:Key="ErrorContainerColor">#FF3B1111</Color>
      <Color x:Key="OnErrorContainerColor">#FFF87171</Color>

      <!-- Inverse -->
      <Color x:Key="OnSurfaceInverseColor">#FF0A0A0B</Color>
      <Color x:Key="SurfaceInverseColor">#FFE8EAF0</Color>
      <Color x:Key="PrimaryInverseColor">#FF10B981</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

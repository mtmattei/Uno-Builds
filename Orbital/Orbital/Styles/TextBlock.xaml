<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Font families -->
  <FontFamily x:Key="OrbitalSansFont">ms-appx:///Assets/Fonts/DMSans-Variable.ttf#DM Sans</FontFamily>
  <FontFamily x:Key="OrbitalMonoFont">ms-appx:///Assets/Fonts/JetBrainsMono-Variable.ttf#JetBrains Mono</FontFamily>
  <FontFamily x:Key="OrbitalDisplayFont">ms-appx:///Assets/Fonts/SpaceGrotesk-Variable.ttf#Space Grotesk</FontFamily>

  <!-- === DISPLAY / HEADER STYLES (Space Grotesk) === -->

  <!-- 28px Bold - Greeting headline -->
  <Style x:Key="OrbitalHeroTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="CharacterSpacing" Value="-25" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText100Brush}" />
  </Style>

  <!-- 20px SemiBold - Page titles -->
  <Style x:Key="OrbitalPageTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-25" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText90Brush}" />
  </Style>

  <!-- 18px SemiBold - Card primary values -->
  <Style x:Key="OrbitalCardValue" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="-25" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText88Brush}" />
  </Style>

  <!-- 16px SemiBold - Session detail title -->
  <Style x:Key="OrbitalDetailTitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText88Brush}" />
  </Style>

  <!-- 15px SemiBold - Meta values, license title -->
  <Style x:Key="OrbitalMetaValue" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText85Brush}" />
  </Style>

  <!-- 14px Medium - Session name, active title -->
  <Style x:Key="OrbitalSessionName" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText85Brush}" />
  </Style>

  <!-- === BODY STYLES (DM Sans) === -->

  <!-- 14px Regular - Subtitle text -->
  <Style x:Key="OrbitalSubtitle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalSansFont}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText42Brush}" />
  </Style>

  <!-- 13px Medium - Nav labels, button labels (Space Grotesk for sidebar) -->
  <Style x:Key="OrbitalBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText80Brush}" />
  </Style>

  <!-- 12px Regular - Session goal, acceptance check text -->
  <Style x:Key="OrbitalCaption" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalSansFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText65Brush}" />
  </Style>

  <!-- 12px Medium - Tab labels, console title -->
  <Style x:Key="OrbitalTabLabel" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalSansFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText40Brush}" />
  </Style>

  <!-- === MONO STYLES === -->

  <!-- 32px Light - Hero clock display -->
  <Style x:Key="OrbitalClockHero" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="32" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="CharacterSpacing" Value="-25" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText30Brush}" />
  </Style>

  <!-- 13px Medium Mono - Check text, feature names, platform labels -->
  <Style x:Key="OrbitalMonoBody" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText75Brush}" />
  </Style>

  <!-- 12px Regular Mono - Console body, artifact filename, dep name -->
  <Style x:Key="OrbitalMonoConsole" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText65Brush}" />
  </Style>

  <!-- 11px Medium Mono Uppercase - Section headers -->
  <Style x:Key="OrbitalSectionHeader" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText38Brush}" />
  </Style>

  <!-- 11px Regular Mono - Badge text, MCP status, metadata, path -->
  <Style x:Key="OrbitalMonoSmall" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText35Brush}" />
  </Style>

  <!-- 10px Medium Uppercase - Section sub-labels (Space Grotesk for sidebar) -->
  <Style x:Key="OrbitalSectionSubLabel" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalDisplayFont}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="CharacterSpacing" Value="120" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText32Brush}" />
  </Style>

  <!-- 10px Regular Mono - Version pill values, feature desc, timestamps -->
  <Style x:Key="OrbitalMonoMeta" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText55Brush}" />
  </Style>

  <!-- 9px Regular Mono Uppercase - Version pill labels -->
  <Style x:Key="OrbitalMonoPillLabel" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText32Brush}" />
  </Style>

  <!-- Console line numbers -->
  <Style x:Key="OrbitalMonoLineNumber" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText25Brush}" />
    <Setter Property="TextAlignment" Value="Right" />
    <Setter Property="Width" Value="24" />
  </Style>

  <!-- Sidebar clock -->
  <Style x:Key="OrbitalSidebarClock" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource OrbitalMonoFont}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="Foreground" Value="{ThemeResource OrbitalText40Brush}" />
  </Style>

</ResourceDictionary>

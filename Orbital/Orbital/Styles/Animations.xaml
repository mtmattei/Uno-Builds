<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Animations are triggered programmatically from code-behind on Loaded events.
       This file serves as a placeholder for shared animation constants and will be
       populated with reusable Storyboard resources in Phase 4 (Animations). -->

  <!-- Shared timing constants as doubles for code-behind reference -->
  <x:Double x:Key="OrbitalFadeUpDuration">350</x:Double>
  <x:Double x:Key="OrbitalStaggerDelay">70</x:Double>
  <x:Double x:Key="OrbitalPulseDuration">2000</x:Double>
  <x:Double x:Key="OrbitalBreatheDuration">3000</x:Double>
  <x:Double x:Key="OrbitalScanlineDuration">4000</x:Double>

</ResourceDictionary>

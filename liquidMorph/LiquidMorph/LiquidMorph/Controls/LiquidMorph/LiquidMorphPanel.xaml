<UserControl
    x:Class="LiquidMorph.Controls.LiquidMorph.LiquidMorphPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LiquidMorph.Controls.LiquidMorph">

    <Grid x:Name="RootGrid">
        <!-- Kill all implicit entrance/reposition animations -->
        <Grid.ChildrenTransitions>
            <TransitionCollection />
        </Grid.ChildrenTransitions>

        <Border x:Name="ContentHostA"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" />
        <Border x:Name="ContentHostB"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Opacity="0" />
    </Grid>
</UserControl>

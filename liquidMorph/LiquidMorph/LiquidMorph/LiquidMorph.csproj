<Project Sdk="Uno.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net10.0-desktop</TargetFrameworks>

    <OutputType>Exe</OutputType>
    <UnoSingleProject>true</UnoSingleProject>

    <!-- Display name -->
    <ApplicationTitle>LiquidMorph</ApplicationTitle>
    <!-- App Identifier -->
    <ApplicationId>com.companyname.liquidmorph</ApplicationId>
    <!-- Versions -->
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <!-- Package Publisher -->
    <ApplicationPublisher>LiquidMorph</ApplicationPublisher>
    <!-- Package Description -->
    <Description>LiquidMorph powered by Uno Platform.</Description>

    <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <UnoFeatures>
      Material;
      Toolkit;
      SkiaRenderer;
    </UnoFeatures>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\Images\ocean.jpg" />
    <Content Include="Assets\Images\volcano.jpg" />
    <Content Include="Assets\Images\glacier.jpg" />
  </ItemGroup>

</Project>

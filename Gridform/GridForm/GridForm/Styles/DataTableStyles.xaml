<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Table header text -->
  <Style x:Key="TableHeaderTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelSmall}">
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
    <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Table cell text -->
  <Style x:Key="TableCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BodyLarge}">
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <!-- Table cell mono text (amounts, PO numbers) -->
  <Style x:Key="TableCellMonoStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelMedium}">
    <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Table row border (odd) -->
  <Style x:Key="TableRowOddStyle" TargetType="Border">
    <Setter Property="Background" Value="{ThemeResource SurfaceVariantBrush}" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

  <!-- Table row border (even) -->
  <Style x:Key="TableRowEvenStyle" TargetType="Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="12,10" />
  </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Base badge style -->
  <Style x:Key="BadgeBaseStyle" TargetType="Border">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Status badge text -->
  <Style x:Key="BadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelSmall}">
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- Status dot -->
  <Style x:Key="StatusDotStyle" TargetType="Ellipse">
    <Setter Property="Width" Value="5" />
    <Setter Property="Height" Value="5" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- SLA badge text (mono) -->
  <Style x:Key="SlaBadgeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelSmall}">
    <Setter Property="FontFamily" Value="Cascadia Code, Consolas, monospace" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- AI chip pulsing dot -->
  <Style x:Key="AiDotStyle" TargetType="Ellipse">
    <Setter Property="Width" Value="6" />
    <Setter Property="Height" Value="6" />
    <Setter Property="Fill" Value="{ThemeResource PrimaryBrush}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

</ResourceDictionary>

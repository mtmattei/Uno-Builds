<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <FontFamily x:Key="MonoFontFamily">ms-appx:///Assets/Fonts/JetBrains_Mono/JetBrainsMono-VariableFont_wght.ttf#JetBrains Mono</FontFamily>

  <!-- Mono data style: PO numbers, amounts, SKUs -->
  <Style x:Key="MonoDataStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="40" />
  </Style>

  <!-- Mono label style: table headers, timestamps -->
  <Style x:Key="MonoLabelStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource MonoFontFamily}" />
    <Setter Property="FontSize" Value="9" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="CharacterSpacing" Value="80" />
    <Setter Property="Foreground" Value="{ThemeResource SurfaceTintBrush}" />
  </Style>

</ResourceDictionary>

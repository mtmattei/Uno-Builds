<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Toolbar button: ghost style with icon, used in warehouse toolbar -->
  <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <!-- Active toolbar button: accent tint background -->
  <Style x:Key="ToolbarActiveButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledTonalButtonStyle}">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="MinWidth" Value="36" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <!-- Ghost button: text-only, no background -->
  <Style x:Key="GhostButtonStyle" TargetType="Button" BasedOn="{StaticResource TextButtonStyle}">
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <!-- Accent action button: used for Approve, etc. -->
  <Style x:Key="AccentActionButtonStyle" TargetType="Button" BasedOn="{StaticResource FilledButtonStyle}">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="16,6" />
    <Setter Property="CornerRadius" Value="6" />
  </Style>

  <!-- Danger button: red-tinted for Reject actions -->
  <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource OutlinedButtonStyle}">
    <Setter Property="MinHeight" Value="36" />
    <Setter Property="Padding" Value="16,6" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Foreground" Value="{ThemeResource ErrorBrush}" />
    <Setter Property="BorderBrush" Value="{ThemeResource ErrorBrush}" />
  </Style>

</ResourceDictionary>

<UserControl x:Class="GridForm.Controls.NotificationFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI"
             xmlns:models="using:GridForm.Models"
             Width="340">

  <Border Background="{ThemeResource SurfaceVariantBrush}"
          BorderBrush="{ThemeResource OutlineBrush}"
          BorderThickness="1"
          CornerRadius="10"
          Translation="0,0,32">
    <Border.Shadow>
      <ThemeShadow />
    </Border.Shadow>

    <StackPanel>
      <!-- Header -->
      <Grid Padding="14,10"
            BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="0,0,0,1">
        <TextBlock Text="Notifications" FontSize="12" FontWeight="Bold" />
        <Button Content="Mark all read"
                Style="{StaticResource TextButtonStyle}"
                HorizontalAlignment="Right"
                FontSize="10" Padding="4,2"
                Foreground="{ThemeResource OnSurfaceVariantBrush}" />
      </Grid>

      <!-- Notification list -->
      <ScrollViewer MaxHeight="320">
        <ItemsRepeater x:Name="NotifList"
                       ItemsSource="{x:Bind Notifications, Mode=OneWay}">
          <ItemsRepeater.Layout>
            <StackLayout Spacing="0" />
          </ItemsRepeater.Layout>
          <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="models:Notification">
              <Border Padding="14,10"
                      BorderBrush="{ThemeResource OutlineBrush}"
                      BorderThickness="0,0,0,1">
                <StackPanel Spacing="3">
                  <Grid ColumnDefinitions="Auto,*,Auto">
                    <Ellipse Grid.Column="0" Width="6" Height="6"
                             VerticalAlignment="Center" Margin="0,0,6,0"
                             Fill="{ThemeResource SecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                               FontSize="11" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Grid.Column="2" Text="{Binding Timestamp}"
                               FontSize="9"
                               Foreground="{ThemeResource SurfaceTintBrush}"
                               FontFamily="{StaticResource MonoFontFamily}" />
                  </Grid>
                  <TextBlock Text="{Binding Body}"
                             FontSize="11"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}"
                             TextTrimming="CharacterEllipsis"
                             Padding="12,0,0,0" />
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsRepeater.ItemTemplate>
        </ItemsRepeater>
      </ScrollViewer>
    </StackPanel>
  </Border>
</UserControl>

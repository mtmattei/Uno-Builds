<UserControl x:Class="GridForm.Controls.AiChip"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="{ThemeResource PrimaryContainerBrush}"
          BorderBrush="{ThemeResource PrimaryBrush}"
          BorderThickness="1"
          CornerRadius="4"
          Padding="10,8"
          Visibility="{x:Bind HasNote, Mode=OneWay}">
    <StackPanel Spacing="6">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <Ellipse Width="6" Height="6"
                 Fill="{ThemeResource PrimaryBrush}"
                 VerticalAlignment="Center">
          </Ellipse>
        <TextBlock Text="AI ANALYSIS"
                   Style="{StaticResource LabelSmall}"
                   Foreground="{ThemeResource PrimaryBrush}"
                   FontFamily="{StaticResource MonoFontFamily}"
                   CharacterSpacing="80" />
      </StackPanel>
      <TextBlock Text="{x:Bind Note, Mode=OneWay}"
                 Style="{StaticResource BodyMedium}"
                 Foreground="{ThemeResource OnSurfaceVariantBrush}"
                 TextWrapping="Wrap"
                 MaxWidth="600" />
    </StackPanel>
  </Border>
</UserControl>

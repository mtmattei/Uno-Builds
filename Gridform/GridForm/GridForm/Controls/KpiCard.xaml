<UserControl x:Class="GridForm.Controls.KpiCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border Background="{ThemeResource SurfaceVariantBrush}"
          BorderBrush="{ThemeResource OutlineBrush}"
          BorderThickness="1"
          CornerRadius="10"
          Padding="16,18"
          MinWidth="160">
    <Grid RowDefinitions="Auto,Auto,Auto,4">
      <!-- Label -->
      <TextBlock Grid.Row="0"
                 Text="{x:Bind Label, Mode=OneWay}"
                 Style="{StaticResource BodySmall}"
                 Foreground="{ThemeResource SurfaceTintBrush}" />

      <!-- Value + Delta -->
      <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
        <TextBlock Text="{x:Bind Value, Mode=OneWay}"
                   Style="{StaticResource DisplaySmall}" />
        <Border CornerRadius="4" Padding="6,2"
                Background="{ThemeResource PrimaryContainerBrush}"
                Visibility="{x:Bind HasDelta, Mode=OneWay}"
                VerticalAlignment="Center">
          <TextBlock Text="{x:Bind Delta, Mode=OneWay}"
                     Style="{StaticResource LabelSmall}"
                     Foreground="{ThemeResource PrimaryBrush}" />
        </Border>
      </StackPanel>

      <!-- Subtitle -->
      <TextBlock Grid.Row="2"
                 Text="{x:Bind Subtitle, Mode=OneWay}"
                 Style="{StaticResource LabelSmall}"
                 Foreground="{ThemeResource SurfaceTintBrush}"
                 FontFamily="{StaticResource MonoFontFamily}"
                 Margin="0,4,0,0" />

      <!-- Accent strip -->
      <Border Grid.Row="3"
              Background="{x:Bind AccentBrush, Mode=OneWay}"
              CornerRadius="1"
              Margin="0,8,0,0" />
    </Grid>
  </Border>
</UserControl>

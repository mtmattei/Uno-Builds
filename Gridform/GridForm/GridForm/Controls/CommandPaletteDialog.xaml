<UserControl x:Class="GridForm.Controls.CommandPaletteDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

  <!-- Full-screen overlay with backdrop -->
  <Grid x:Name="Overlay" Visibility="Collapsed"
        Background="#80080A0E">
    <Grid.RowDefinitions>
      <RowDefinition Height="16*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="84*" />
    </Grid.RowDefinitions>

    <!-- Dialog card -->
    <Border Grid.Row="1"
            Width="520"
            HorizontalAlignment="Center"
            Background="{ThemeResource SurfaceVariantBrush}"
            BorderBrush="{ThemeResource OutlineBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Translation="0,0,48">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <StackPanel>
        <!-- Search input -->
        <Grid Padding="12,12,12,10"
              BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="0,0,0,1"
              ColumnDefinitions="Auto,*">
          <TextBlock Grid.Column="0" Text="⌘" FontSize="14"
                     Foreground="{ThemeResource SurfaceTintBrush}"
                     VerticalAlignment="Center" Margin="0,0,10,0" />
          <TextBox x:Name="SearchInput" Grid.Column="1"
                   PlaceholderText="Search POs, vendors, actions..."
                   Background="Transparent"
                   BorderThickness="0"
                   FontSize="14" />
        </Grid>

        <!-- Results -->
        <ScrollViewer MaxHeight="300" Padding="4">
          <StackPanel Spacing="0">
            <!-- Search results -->
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*,Auto">
                <TextBlock Grid.Column="0" Text="◇" FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="PO-7420 — Sandvik Coromant" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Search" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*">
                <TextBlock Grid.Column="0" Text="◇" FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="Kennametal — Carbide Inserts" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Search" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*">
                <TextBlock Grid.Column="0" Text="✦" FontSize="13"
                           Foreground="{ThemeResource PrimaryBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="AI: Summarize pending approvals" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Action" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*">
                <TextBlock Grid.Column="0" Text="✦" FontSize="13"
                           Foreground="{ThemeResource PrimaryBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="AI: Flag budget overruns" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Action" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*">
                <TextBlock Grid.Column="0" Text="↓" FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="Export pending POs as CSV" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Action" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                    Padding="12,8" CornerRadius="6" Click="OnResultClick">
              <Grid ColumnDefinitions="20,*">
                <TextBlock Grid.Column="0" Text="◆" FontSize="13"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                  <TextBlock Text="Warehouse Planner" FontSize="12" FontWeight="Medium" />
                  <TextBlock Text="Navigate" FontSize="9" Foreground="{ThemeResource SurfaceTintBrush}" />
                </StackPanel>
              </Grid>
            </Button>
          </StackPanel>
        </ScrollViewer>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>

<UserControl x:Class="GridForm.Controls.RiskBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:GridForm.Converters">

  <UserControl.Resources>
    <converters:RiskToColorConverter x:Key="RiskToColor" />
  </UserControl.Resources>

  <Border CornerRadius="4" Padding="8,2">
    <TextBlock Text="{x:Bind RiskText, Mode=OneWay}"
               Style="{StaticResource LabelSmall}"
               Foreground="{x:Bind Risk, Mode=OneWay, Converter={StaticResource RiskToColor}}"
               VerticalAlignment="Center" />
  </Border>
</UserControl>

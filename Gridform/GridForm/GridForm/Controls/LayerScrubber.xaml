<UserControl x:Class="GridForm.Controls.LayerScrubber"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32">

  <StackPanel Spacing="4" VerticalAlignment="Center" HorizontalAlignment="Center">
    <Button Content="&#xE70E;"
            FontFamily="{ThemeResource SymbolThemeFontFamily}"
            Style="{StaticResource TextButtonStyle}"
            MinWidth="28" MinHeight="28" Padding="0"
            HorizontalAlignment="Center"
            Click="OnLayerUp" />

    <ItemsRepeater x:Name="LayerBars" ItemsSource="{x:Bind LayerIndicators, Mode=OneWay}">
      <ItemsRepeater.Layout>
        <StackLayout Spacing="2" />
      </ItemsRepeater.Layout>
      <ItemsRepeater.ItemTemplate>
        <DataTemplate x:DataType="x:Boolean">
          <Border Width="20" Height="8" CornerRadius="2"
                  HorizontalAlignment="Center" />
        </DataTemplate>
      </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>

    <TextBlock Text="{x:Bind LayerLabel, Mode=OneWay}"
               Style="{StaticResource LabelSmall}"
               HorizontalAlignment="Center"
               Foreground="{ThemeResource OnSurfaceVariantBrush}" />

    <Button Content="&#xE70D;"
            FontFamily="{ThemeResource SymbolThemeFontFamily}"
            Style="{StaticResource TextButtonStyle}"
            MinWidth="28" MinHeight="28" Padding="0"
            HorizontalAlignment="Center"
            Click="OnLayerDown" />
  </StackPanel>
</UserControl>

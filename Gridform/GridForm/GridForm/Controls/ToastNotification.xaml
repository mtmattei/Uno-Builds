<UserControl x:Class="GridForm.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border x:Name="ToastBorder"
          Visibility="Collapsed"
          HorizontalAlignment="Center"
          VerticalAlignment="Bottom"
          Margin="0,0,0,40"
          Background="{ThemeResource OnSurfaceBrush}"
          CornerRadius="10"
          Padding="22,10"
          Translation="0,0,24">
    <Border.Shadow>
      <ThemeShadow />
    </Border.Shadow>

    <TextBlock x:Name="ToastText"
               FontSize="12"
               FontWeight="SemiBold"
               Foreground="{ThemeResource BackgroundBrush}" />
  </Border>
</UserControl>

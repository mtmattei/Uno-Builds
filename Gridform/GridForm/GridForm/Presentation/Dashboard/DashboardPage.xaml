<Page x:Class="GridForm.Presentation.Dashboard.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:GridForm.Controls"
      xmlns:models="using:GridForm.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:converters="using:GridForm.Converters"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <converters:StatusToColorConverter x:Key="StatusToColor" />
  </Page.Resources>

  <ScrollViewer>
    <StackPanel Spacing="20" Padding="24,20">

      <!-- ═══ KPI ROW ═══ -->
      <utu:AutoLayout Orientation="Horizontal" Spacing="10">

        <!-- Open POs -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,18" MinWidth="160" HorizontalAlignment="Stretch">
          <Grid RowDefinitions="Auto,Auto,Auto,4">
            <TextBlock Grid.Row="0" Text="Open POs" FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
              <TextBlock Text="8" FontSize="26" FontWeight="Bold" />
              <Border CornerRadius="4" Padding="6,2"
                      Background="{ThemeResource PrimaryContainerBrush}"
                      VerticalAlignment="Center">
                <TextBlock Text="↑ 12%" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource PrimaryBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Border>
            </StackPanel>
            <TextBlock Grid.Row="2" Text="vs last quarter" FontSize="10"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,4,0,0" />
            <Border Grid.Row="3" Background="{ThemeResource PrimaryBrush}"
                    CornerRadius="1" Margin="0,8,0,0" Opacity="0.4" />
          </Grid>
        </Border>

        <!-- Pending Approval -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,18" MinWidth="160">
          <Grid RowDefinitions="Auto,Auto,Auto,4">
            <TextBlock Grid.Row="0" Text="Pending Approval" FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
              <TextBlock Text="3" FontSize="26" FontWeight="Bold" />
              <Border CornerRadius="4" Padding="6,2"
                      Background="{ThemeResource SecondaryContainerBrush}"
                      VerticalAlignment="Center">
                <TextBlock Text="2 overdue" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource SecondaryBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Border>
            </StackPanel>
            <TextBlock Grid.Row="2" Text="avg wait: 2.4d" FontSize="10"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,4,0,0" />
            <Border Grid.Row="3" Background="{ThemeResource SecondaryBrush}"
                    CornerRadius="1" Margin="0,8,0,0" Opacity="0.4" />
          </Grid>
        </Border>

        <!-- Q2 Committed -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,18" MinWidth="160">
          <Grid RowDefinitions="Auto,Auto,Auto,4">
            <TextBlock Grid.Row="0" Text="Q2 Committed" FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
              <TextBlock Text="$2.4M" FontSize="26" FontWeight="Bold" />
              <Border CornerRadius="4" Padding="6,2"
                      Background="{ThemeResource PrimaryContainerBrush}"
                      VerticalAlignment="Center">
                <TextBlock Text="87%" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource PrimaryBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Border>
            </StackPanel>
            <TextBlock Grid.Row="2" Text="of quarterly budget" FontSize="10"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,4,0,0" />
            <Border Grid.Row="3" Background="{ThemeResource PrimaryBrush}"
                    CornerRadius="1" Margin="0,8,0,0" Opacity="0.4" />
          </Grid>
        </Border>

        <!-- Warehouse -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,18" MinWidth="160">
          <Grid RowDefinitions="Auto,Auto,Auto,4">
            <TextBlock Grid.Row="0" Text="Warehouse" FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <TextBlock Grid.Row="1" Text="42.3%" FontSize="26" FontWeight="Bold"
                       Margin="0,8,0,0" />
            <TextBlock Grid.Row="2" Text="96 units · 28.4t" FontSize="10"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,4,0,0" />
            <Border Grid.Row="3" Background="{ThemeResource TertiaryBrush}"
                    CornerRadius="1" Margin="0,8,0,0" Opacity="0.4" />
          </Grid>
        </Border>

        <!-- Savings YTD -->
        <Border Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                CornerRadius="10" Padding="16,18" MinWidth="160">
          <Grid RowDefinitions="Auto,Auto,Auto,4">
            <TextBlock Grid.Row="0" Text="Savings YTD" FontSize="11" FontWeight="Medium"
                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
              <TextBlock Text="$184K" FontSize="26" FontWeight="Bold" />
              <Border CornerRadius="4" Padding="6,2"
                      Background="{ThemeResource PrimaryContainerBrush}"
                      VerticalAlignment="Center">
                <TextBlock Text="↑ 23%" FontSize="10" FontWeight="SemiBold"
                           Foreground="{ThemeResource PrimaryBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Border>
            </StackPanel>
            <TextBlock Grid.Row="2" Text="negotiation + consolidation" FontSize="10"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,4,0,0" />
            <Border Grid.Row="3" Background="{ThemeResource PrimaryBrush}"
                    CornerRadius="1" Margin="0,8,0,0" Opacity="0.4" />
          </Grid>
        </Border>
      </utu:AutoLayout>

      <!-- ═══ PIPELINE + ACTIVITY ═══ -->
      <Grid ColumnDefinitions="*,*" ColumnSpacing="14">

        <!-- Order Pipeline -->
        <Border Grid.Column="0"
                Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}"
                BorderThickness="1" CornerRadius="10" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="Order Pipeline" FontSize="13" FontWeight="Bold" />

            <!-- Pipeline status bar -->
            <controls:PipelineBar PendingCount="3" ReviewCount="2"
                                  ApprovedCount="2" FlaggedCount="1" />

            <!-- Pipeline order cards -->
            <mvux:FeedView Source="{Binding PipelineOrders}">
              <mvux:FeedView.ValueTemplate>
                <DataTemplate>
                  <ItemsRepeater ItemsSource="{Binding Data}">
                    <ItemsRepeater.Layout>
                      <StackLayout Spacing="6" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                      <DataTemplate x:DataType="models:PurchaseOrder">
                        <Border Padding="10,12"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource OutlineBrush}"
                                BorderThickness="1">
                          <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Id}"
                                       FontSize="10" FontWeight="SemiBold"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       MinWidth="56" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding VendorName}"
                                       FontSize="12" FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       Margin="10,0" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Amount}"
                                       FontSize="10"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       FontFamily="{StaticResource MonoFontFamily}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <controls:SlaBadge Grid.Column="3"
                                               Deadline="{Binding SlaDeadline}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                            <controls:StatusBadge Grid.Column="4"
                                                  Status="{Binding Status}"
                                                  VerticalAlignment="Center" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                  </ItemsRepeater>
                </DataTemplate>
              </mvux:FeedView.ValueTemplate>
              <mvux:FeedView.ProgressTemplate>
                <DataTemplate>
                  <ProgressRing IsActive="True" Width="32" Height="32"
                                HorizontalAlignment="Center" Margin="0,24" />
                </DataTemplate>
              </mvux:FeedView.ProgressTemplate>
            </mvux:FeedView>

            <Button Content="View all →"
                    Style="{StaticResource TextButtonStyle}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="8" CornerRadius="6"
                    BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                    uen:Navigation.Request="Orders" />
          </StackPanel>
        </Border>

        <!-- Activity Feed -->
        <Border Grid.Column="1"
                Background="{ThemeResource SurfaceVariantBrush}"
                BorderBrush="{ThemeResource OutlineBrush}"
                BorderThickness="1" CornerRadius="10" Padding="20">
          <StackPanel Spacing="14">
            <TextBlock Text="Activity" FontSize="13" FontWeight="Bold" />

            <mvux:FeedView Source="{Binding ActivityEvents}">
              <mvux:FeedView.ValueTemplate>
                <DataTemplate>
                  <controls:ActivityFeed Events="{Binding Data}" />
                </DataTemplate>
              </mvux:FeedView.ValueTemplate>
              <mvux:FeedView.ProgressTemplate>
                <DataTemplate>
                  <ProgressRing IsActive="True" Width="32" Height="32"
                                HorizontalAlignment="Center" Margin="0,24" />
                </DataTemplate>
              </mvux:FeedView.ProgressTemplate>
            </mvux:FeedView>
          </StackPanel>
        </Border>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</Page>

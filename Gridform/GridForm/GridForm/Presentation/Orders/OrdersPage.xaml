<Page x:Class="GridForm.Presentation.Orders.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:GridForm.Controls"
      xmlns:models="using:GridForm.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:converters="using:GridForm.Converters"
      Background="{ThemeResource BackgroundBrush}">

  <Page.Resources>
    <converters:StatusToColorConverter x:Key="StatusToColor" />
  </Page.Resources>

  <ScrollViewer Padding="24,20">
    <StackPanel Spacing="14">

      <TextBlock Text="Purchase Orders" Style="{StaticResource HeadlineSmall}" />

      <!-- Pipeline summary cards -->
      <utu:AutoLayout Orientation="Horizontal" Spacing="10">
        <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="14,10"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" MinWidth="140">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="5" Height="5" Fill="{StaticResource StatusPendingBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Pending" Style="{StaticResource LabelSmall}" Foreground="{StaticResource StatusPendingBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding PendingCount}" Style="{StaticResource TitleMedium}" />
          </StackPanel>
        </Border>
        <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="14,10"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" MinWidth="140">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="5" Height="5" Fill="{StaticResource StatusReviewBrush}" VerticalAlignment="Center" />
              <TextBlock Text="In Review" Style="{StaticResource LabelSmall}" Foreground="{StaticResource StatusReviewBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding ReviewCount}" Style="{StaticResource TitleMedium}" />
          </StackPanel>
        </Border>
        <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="14,10"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" MinWidth="140">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="5" Height="5" Fill="{StaticResource StatusApprovedBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Approved" Style="{StaticResource LabelSmall}" Foreground="{StaticResource StatusApprovedBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding ApprovedCount}" Style="{StaticResource TitleMedium}" />
          </StackPanel>
        </Border>
        <Border Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="8" Padding="14,10"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" MinWidth="140">
          <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="5" Height="5" Fill="{StaticResource StatusFlaggedBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Flagged" Style="{StaticResource LabelSmall}" Foreground="{StaticResource StatusFlaggedBrush}" />
            </StackPanel>
            <TextBlock Text="{Binding FlaggedCount}" Style="{StaticResource TitleMedium}" />
          </StackPanel>
        </Border>
      </utu:AutoLayout>

      <!-- Bulk action bar -->
      <controls:BulkActionBar SelectedCount="{Binding SelectedCount}"
                              ApproveCommand="{Binding BulkApprove}"
                              ClearCommand="{Binding ClearSelection}" />

      <!-- Table Header -->
      <Grid Padding="12,8" ColumnDefinitions="40,100,*,120,100,100,120">
        <TextBlock Grid.Column="0" Text="" />
        <TextBlock Grid.Column="1" Text="PO #" Style="{StaticResource TableHeaderTextStyle}" />
        <TextBlock Grid.Column="2" Text="VENDOR" Style="{StaticResource TableHeaderTextStyle}" />
        <TextBlock Grid.Column="3" Text="AMOUNT" Style="{StaticResource TableHeaderTextStyle}" HorizontalAlignment="Right" />
        <TextBlock Grid.Column="4" Text="STATUS" Style="{StaticResource TableHeaderTextStyle}" />
        <TextBlock Grid.Column="5" Text="RISK" Style="{StaticResource TableHeaderTextStyle}" />
        <TextBlock Grid.Column="6" Text="SLA" Style="{StaticResource TableHeaderTextStyle}" />
      </Grid>

      <!-- Order Rows -->
      <mvux:FeedView Source="{Binding Orders}">
        <mvux:FeedView.ValueTemplate>
          <DataTemplate>
            <ItemsRepeater ItemsSource="{Binding Data}">
              <ItemsRepeater.Layout>
                <StackLayout Spacing="0" />
              </ItemsRepeater.Layout>
              <ItemsRepeater.ItemTemplate>
                <DataTemplate x:DataType="models:PurchaseOrder">
                  <Border Padding="12,10"
                          Background="{ThemeResource SurfaceVariantBrush}"
                          BorderBrush="{ThemeResource OutlineBrush}"
                          BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="40,100,*,120,100,100,120">
                      <CheckBox Grid.Column="0" MinWidth="32" Padding="0"
                                VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding Id}"
                                 Style="{StaticResource TableCellMonoStyle}"
                                 Foreground="{ThemeResource PrimaryBrush}" />
                      <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding VendorName}" Style="{StaticResource TableCellTextStyle}" />
                        <TextBlock Style="{StaticResource BodySmall}" Foreground="{ThemeResource SurfaceTintBrush}">
                          <Run Text="{Binding VendorLocation}" />
                          <Run Text=" · " />
                          <Run Text="{Binding Category}" />
                        </TextBlock>
                      </StackPanel>
                      <TextBlock Grid.Column="3"
                                 Text="{Binding Amount}"
                                 Style="{StaticResource TableCellMonoStyle}"
                                 HorizontalAlignment="Right" />
                      <controls:StatusBadge Grid.Column="4" Status="{Binding Status}" />
                      <controls:RiskBadge Grid.Column="5" Risk="{Binding Risk}" />
                      <controls:SlaBadge Grid.Column="6" Deadline="{Binding SlaDeadline}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
          </DataTemplate>
        </mvux:FeedView.ValueTemplate>
        <mvux:FeedView.ProgressTemplate>
          <DataTemplate>
            <ProgressRing IsActive="True" Width="40" Height="40"
                          HorizontalAlignment="Center" Margin="0,48" />
          </DataTemplate>
        </mvux:FeedView.ProgressTemplate>
        <mvux:FeedView.NoneTemplate>
          <DataTemplate>
            <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,48">
              <FontIcon Glyph="&#xE8A5;" FontSize="32" Foreground="{ThemeResource SurfaceTintBrush}" />
              <TextBlock Text="No purchase orders" Style="{StaticResource BodyLarge}"
                         Foreground="{ThemeResource SurfaceTintBrush}" />
            </StackPanel>
          </DataTemplate>
        </mvux:FeedView.NoneTemplate>
      </mvux:FeedView>

    </StackPanel>
  </ScrollViewer>
</Page>

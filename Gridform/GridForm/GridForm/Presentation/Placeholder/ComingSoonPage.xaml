<Page x:Class="GridForm.Presentation.Placeholder.ComingSoonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource BackgroundBrush}">

  <StackPanel HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="12">
    <FontIcon Glyph="&#xE946;" FontSize="48"
              Foreground="{ThemeResource SurfaceTintBrush}" />
    <TextBlock Text="Coming Soon"
               Style="{StaticResource HeadlineSmall}"
               HorizontalAlignment="Center" />
    <TextBlock Text="This feature is under development."
               Style="{StaticResource BodyLarge}"
               Foreground="{ThemeResource OnSurfaceVariantBrush}"
               HorizontalAlignment="Center" />
  </StackPanel>
</Page>

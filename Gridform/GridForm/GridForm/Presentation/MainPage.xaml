<Page x:Class="GridForm.Presentation.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:uen="using:Uno.Extensions.Navigation.UI"
      xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
      xmlns:controls="using:GridForm.Controls"
      Background="{ThemeResource BackgroundBrush}">

  <Grid uen:Region.Attached="True"
        RowDefinitions="48,*,28">

    <!-- ═══ TOPBAR ═══ -->
    <Border Grid.Row="0"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- Logo + Brand -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" Margin="0,0,14,0">
          <Border Width="24" Height="24" CornerRadius="6">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#D4A959" Offset="0" />
                <GradientStop Color="#D4927A" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="G" FontSize="11" FontWeight="ExtraBold"
                       Foreground="{ThemeResource BackgroundBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Text="GRIDFORM" FontSize="13" FontWeight="Bold"
                     CharacterSpacing="80" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Separator -->
        <Border Grid.Column="1" Width="1" Height="24"
                Background="{ThemeResource OutlineBrush}" Margin="0,0,10,0" />

        <!-- Spacer -->
        <Border Grid.Column="2" />

        <!-- Search trigger -->
        <Button x:Name="SearchTrigger" Grid.Column="3" Style="{StaticResource TextButtonStyle}"
                VerticalAlignment="Center" Padding="12,5" MinWidth="200" Margin="0,0,8,0"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" CornerRadius="6"
                Click="OnSearchTriggerClick">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Search..." Style="{StaticResource BodySmall}"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       VerticalAlignment="Center" />
            <Border Background="{ThemeResource SurfaceVariantBrush}"
                    CornerRadius="3" Padding="5,1"
                    BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1"
                    VerticalAlignment="Center">
              <TextBlock Text="⌘K" FontSize="9"
                         Foreground="{ThemeResource SurfaceTintBrush}"
                         FontFamily="{StaticResource MonoFontFamily}" />
            </Border>
          </StackPanel>
        </Button>

        <!-- Notification bell -->
        <Button x:Name="NotifBell" Grid.Column="4" Style="{StaticResource TextButtonStyle}"
                VerticalAlignment="Center" MinWidth="32" MinHeight="32"
                Padding="0" Margin="0,0,8,0"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="1" CornerRadius="6">
          <Button.Flyout>
            <Flyout Placement="Bottom">
              <controls:NotificationFlyout x:Name="NotifFlyoutContent" />
            </Flyout>
          </Button.Flyout>
          <Grid>
            <FontIcon Glyph="&#xEA8F;" FontSize="14"
                      Foreground="{ThemeResource OnSurfaceVariantBrush}" />
            <Ellipse Width="7" Height="7" Fill="{ThemeResource SecondaryBrush}"
                     HorizontalAlignment="Right" VerticalAlignment="Top"
                     Margin="0,-2,-2,0"
                     Stroke="{ThemeResource SurfaceBrush}" StrokeThickness="2" />
          </Grid>
        </Button>

        <!-- User avatar -->
        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center" Padding="8,0,0,0">
          <Border Width="28" Height="28" CornerRadius="14">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#D4A959" Offset="0" />
                <GradientStop Color="#D4927A" Offset="1" />
              </LinearGradientBrush>
            </Border.Background>
            <TextBlock Text="MP" FontSize="10" FontWeight="Bold"
                       Foreground="{ThemeResource BackgroundBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Matt P." FontSize="11" FontWeight="SemiBold" />
            <TextBlock Text="Ops Manager" FontSize="9"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}" />
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══ NAV + CONTENT ═══ -->
    <muxc:NavigationView Grid.Row="1"
                         uen:Region.Attached="True"
                         PaneDisplayMode="Left"
                         IsPaneToggleButtonVisible="False"
                         IsBackButtonVisible="Collapsed"
                         IsSettingsVisible="False"
                         OpenPaneLength="200"
                         Background="{ThemeResource BackgroundBrush}">

      <muxc:NavigationView.Resources>
        <!-- Override NavigationView pane background -->
        <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{ThemeResource SurfaceColor}" />
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{ThemeResource SurfaceColor}" />
      </muxc:NavigationView.Resources>

      <muxc:NavigationView.MenuItems>
        <muxc:NavigationViewItemHeader Content="OPERATIONS" />
        <muxc:NavigationViewItem Content="Dashboard" uen:Region.Name="Dashboard">
          <muxc:NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE80F;" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Warehouse" uen:Region.Name="Warehouse">
          <muxc:NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE913;" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Orders" uen:Region.Name="Orders">
          <muxc:NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8A5;" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItemSeparator />
        <muxc:NavigationViewItemHeader Content="REFERENCE" />
        <muxc:NavigationViewItem Content="Inventory" uen:Region.Name="Inventory">
          <muxc:NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8F1;" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
        <muxc:NavigationViewItem Content="Vendors" uen:Region.Name="Vendors">
          <muxc:NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE779;" />
          </muxc:NavigationViewItem.Icon>
        </muxc:NavigationViewItem>
      </muxc:NavigationView.MenuItems>

      <muxc:NavigationView.PaneFooter>
        <Border Padding="12,10"
                BorderBrush="{ThemeResource OutlineBrush}" BorderThickness="0,1,0,0">
          <StackPanel Spacing="5">
            <TextBlock Text="WAREHOUSE" FontSize="9" FontWeight="SemiBold"
                       CharacterSpacing="120"
                       Foreground="{ThemeResource SurfaceTintBrush}"
                       FontFamily="{StaticResource MonoFontFamily}"
                       Margin="0,0,0,6" />
            <!-- Floor -->
            <StackPanel Spacing="2">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Floor" FontSize="9" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Grid.Column="1" Text="42.3%" FontSize="9" FontWeight="SemiBold"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Grid>
              <Border Height="2" CornerRadius="1" Background="{ThemeResource SurfaceVariantBrush}">
                <Border Width="72" Height="2" CornerRadius="1"
                        Background="{ThemeResource PrimaryBrush}"
                        HorizontalAlignment="Left" />
              </Border>
            </StackPanel>
            <!-- Volume -->
            <StackPanel Spacing="2">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Volume" FontSize="9" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Grid.Column="1" Text="8.2%" FontSize="9" FontWeight="SemiBold"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Grid>
              <Border Height="2" CornerRadius="1" Background="{ThemeResource SurfaceVariantBrush}">
                <Border Width="14" Height="2" CornerRadius="1"
                        Background="{ThemeResource TertiaryBrush}"
                        HorizontalAlignment="Left" />
              </Border>
            </StackPanel>
            <!-- Load -->
            <StackPanel Spacing="2">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Load" FontSize="9" Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBlock Grid.Column="1" Text="28.4t" FontSize="9" FontWeight="SemiBold"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           FontFamily="{StaticResource MonoFontFamily}" />
              </Grid>
              <Border Height="2" CornerRadius="1" Background="{ThemeResource SurfaceVariantBrush}">
                <Border Width="80" Height="2" CornerRadius="1"
                        Background="{ThemeResource SecondaryBrush}"
                        HorizontalAlignment="Left" />
              </Border>
            </StackPanel>
          </StackPanel>
        </Border>
      </muxc:NavigationView.PaneFooter>

      <!-- Content Frame -->
      <Frame uen:Region.Attached="True" />
    </muxc:NavigationView>

    <!-- ═══ STATUS BAR ═══ -->
    <Border Grid.Row="2"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource OutlineBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <Ellipse Width="5" Height="5" Fill="{ThemeResource PrimaryBrush}" />
          <TextBlock Text="Connected" FontSize="9"
                     Foreground="{ThemeResource SurfaceTintBrush}"
                     FontFamily="{StaticResource MonoFontFamily}" />
        </StackPanel>
        <TextBlock Grid.Column="1" Text="Last sync: 2m ago" FontSize="9"
                   Foreground="{ThemeResource SurfaceTintBrush}"
                   FontFamily="{StaticResource MonoFontFamily}"
                   VerticalAlignment="Center" Margin="16,0" />
        <TextBlock Grid.Column="2" Text="Org: Precision Tools Midwest" FontSize="9"
                   Foreground="{ThemeResource SurfaceTintBrush}"
                   FontFamily="{StaticResource MonoFontFamily}"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="7 orders · 96 warehouse units · 28.4t" FontSize="9"
                   Foreground="{ThemeResource SurfaceTintBrush}"
                   FontFamily="{StaticResource MonoFontFamily}"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- ═══ OVERLAYS ═══ -->
    <controls:CommandPaletteDialog x:Name="CmdPalette"
                                   Grid.RowSpan="3" />
    <controls:ToastNotification x:Name="Toast"
                                Grid.RowSpan="3" />
  </Grid>
</Page>

<Application x:Class="GridForm.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utum="using:Uno.Toolkit.UI.Material"
       xmlns:converters="using:GridForm.Converters">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml" />

        <!-- Custom styles -->
        <ResourceDictionary Source="ms-appx:///Styles/TextBlockStyles.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/ButtonStyles.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/BadgeStyles.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/DataTableStyles.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- ═══ Semantic Status Brushes ═══ -->
      <!-- Foreground -->
      <SolidColorBrush x:Key="StatusPendingBrush" Color="{ThemeResource PrimaryColor}" />
      <SolidColorBrush x:Key="StatusApprovedBrush" Color="#A0B87A" />
      <SolidColorBrush x:Key="StatusReviewBrush" Color="{ThemeResource TertiaryColor}" />
      <SolidColorBrush x:Key="StatusFlaggedBrush" Color="{ThemeResource SecondaryColor}" />
      <!-- Background (dim) -->
      <SolidColorBrush x:Key="StatusPendingDimBrush" Color="{ThemeResource PrimaryContainerColor}" />
      <SolidColorBrush x:Key="StatusApprovedDimBrush" Color="#1A231A" />
      <SolidColorBrush x:Key="StatusReviewDimBrush" Color="{ThemeResource TertiaryContainerColor}" />
      <SolidColorBrush x:Key="StatusFlaggedDimBrush" Color="{ThemeResource SecondaryContainerColor}" />

      <!-- ═══ Semantic Role Brushes (syntax-named) ═══ -->
      <Color x:Key="StringColor">#A0B87A</Color>
      <Color x:Key="FunctionColor">#C2B57A</Color>
      <Color x:Key="CommentColor">#4A4E59</Color>
      <SolidColorBrush x:Key="StringBrush" Color="{StaticResource StringColor}" />
      <SolidColorBrush x:Key="FunctionBrush" Color="{StaticResource FunctionColor}" />
      <SolidColorBrush x:Key="CommentBrush" Color="{StaticResource CommentColor}" />

      <!-- ═══ Risk Brushes ═══ -->
      <SolidColorBrush x:Key="RiskLowBrush" Color="#A0B87A" />
      <SolidColorBrush x:Key="RiskMediumBrush" Color="{ThemeResource PrimaryColor}" />
      <SolidColorBrush x:Key="RiskHighBrush" Color="{ThemeResource SecondaryColor}" />

      <!-- ═══ Converters (registered globally) ═══ -->
      <converters:StatusToColorConverter x:Key="StatusToColor" />
      <converters:RiskToColorConverter x:Key="RiskToColor" />
      <converters:SlaToColorConverter x:Key="SlaToColor" />
      <converters:EventTypeToColorConverter x:Key="EventTypeToColor" />

    </ResourceDictionary>
  </Application.Resources>

</Application>

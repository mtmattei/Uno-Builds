{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DOTNET_ENVIRONMENT": "Development"
  },
  "permissions": {
    "allow": [
      "mcp__uno__uno_platform_agent_rules_init",
      "mcp__uno__uno_platform_usage_rules_init",
      "mcp__uno__uno_platform_docs_search",
      "Bash(tasklist)",
      "WebFetch(domain:claude.ai)",
      "Bash(taskkill /PID 31028 /F)",
      "Bash(taskkill:*)",
      "Bash(taskkill.exe:*)",
      "Bash(powershell:*)",
      "Bash(DOTNET_MODIFIABLE_ASSEMBLIES=Debug dotnet run -f net10.0-desktop)",
      "mcp__uno__uno_platform_docs_fetch"
    ]
  }
}

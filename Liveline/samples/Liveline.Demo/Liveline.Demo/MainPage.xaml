<Page x:Class="Liveline.Demo.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:liveline="using:Liveline"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <StackPanel utu:SafeArea.Insets="VisibleBounds"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="16">

    <!-- Chart (hero) -->
    <Border CornerRadius="16"
            Width="520"
            Height="300"
            Translation="0,0,24">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <liveline:LivelineChart x:Name="Chart"
                               ShowGrid="True"
                               ShowBadge="True"
                               ShowFill="True"
                               LerpSpeed="0.04" />
    </Border>

    <!-- Control strip -->
    <Border Padding="16,10"
            CornerRadius="12"
            HorizontalAlignment="Center"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Translation="0,0,8">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <StackPanel Orientation="Horizontal" Spacing="0">

        <!-- Layer toggles -->
        <StackPanel Orientation="Horizontal" Spacing="12">
          <ToggleSwitch x:Name="GridSwitch" IsOn="True" Toggled="OnToggle"
                        OnContent="Grid" OffContent="Grid"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch x:Name="FillSwitch" IsOn="True" Toggled="OnToggle"
                        OnContent="Fill" OffContent="Fill"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch x:Name="BadgeSwitch" IsOn="True" Toggled="OnToggle"
                        OnContent="Badge" OffContent="Badge"
                        MinWidth="0" MinHeight="0" />
          <ToggleSwitch x:Name="DotSwitch" IsOn="True" Toggled="OnToggle"
                        OnContent="Dot" OffContent="Dot"
                        MinWidth="0" MinHeight="0" />
        </StackPanel>

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Playback -->
        <ToggleSwitch x:Name="PauseSwitch" IsOn="False" Toggled="OnToggle"
                      OnContent="Pause" OffContent="Pause"
                      MinWidth="0" MinHeight="0" />

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Accent colors -->
        <StackPanel Orientation="Horizontal" Spacing="8"
                    VerticalAlignment="Center">
          <Button Tag="#4CAF50" Click="OnColorPreset"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Green">
            <Border Width="24" Height="24" CornerRadius="12" Background="#4CAF50" />
          </Button>
          <Button Tag="#2196F3" Click="OnColorPreset"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Blue">
            <Border Width="24" Height="24" CornerRadius="12" Background="#2196F3" />
          </Button>
          <Button Tag="#FF9800" Click="OnColorPreset"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Amber">
            <Border Width="24" Height="24" CornerRadius="12" Background="#FF9800" />
          </Button>
          <Button Tag="#9C27B0" Click="OnColorPreset"
                  Width="24" Height="24" MinWidth="0" MinHeight="0"
                  Padding="0" CornerRadius="12"
                  ToolTipService.ToolTip="Purple">
            <Border Width="24" Height="24" CornerRadius="12" Background="#9C27B0" />
          </Button>
        </StackPanel>

        <!-- Divider -->
        <Border Width="1" Height="24" Margin="16,0"
                VerticalAlignment="Center"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Theme -->
        <ToggleSwitch x:Name="DarkSwitch" IsOn="True" Toggled="OnToggle"
                      OnContent="Dark" OffContent="Light"
                      MinWidth="0" MinHeight="0" />

      </StackPanel>
    </Border>

  </StackPanel>
</Page>

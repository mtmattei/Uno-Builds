<Page x:Class="HockeyBarn.Presentation.GameDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:models="using:HockeyBarn.Models"
      Background="{ThemeResource BackgroundBrush}">

  <Grid>
    <!-- Background gradient -->
    <Grid.Background>
      <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#0C1118" Offset="0" />
        <GradientStop Color="#1E293B" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header with Back Button -->
    <Border Grid.Row="0"
            Background="{ThemeResource SurfaceColor}"
            Padding="8,8,16,8">
      <Grid>
        <Button Background="Transparent"
                Click="Back_Click"
                HorizontalAlignment="Left"
                Width="48"
                Height="48">
          <FontIcon Glyph="&#xE72B;"
                    FontSize="20"
                    Foreground="{ThemeResource OnSurfaceColor}" />
        </Button>

        <TextBlock x:Name="GameTitle"
                   Style="{StaticResource MaterialSubtitle1}"
                   Foreground="{ThemeResource OnSurfaceColor}"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

        <Button Background="Transparent"
                HorizontalAlignment="Right"
                Width="48"
                Height="48">
          <FontIcon Glyph="&#xE712;"
                    FontSize="20"
                    Foreground="{ThemeResource OnSurfaceColor}" />
        </Button>
      </Grid>
    </Border>

    <!-- Main Content -->
    <ScrollViewer Grid.Row="1">
      <utu:AutoLayout Orientation="Vertical"
                      Spacing="24"
                      Padding="16,16,16,16">

        <!-- Game Info Card -->
        <Border Style="{StaticResource GlassCardStyle}">
          <utu:AutoLayout Orientation="Vertical"
                          Spacing="16">

            <!-- Location -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="12">
              <TextBlock Text="Location"
                         Style="{StaticResource MaterialBody1}"
                         Foreground="{ThemeResource OnSurfaceVariantColor}"
                         Width="120" />
              <TextBlock x:Name="LocationText"
                         Style="{StaticResource MaterialSubtitle2}"
                         Foreground="{ThemeResource OnSurfaceColor}"
                         FontWeight="SemiBold" />
            </utu:AutoLayout>

            <Border Height="1"
                    Background="{ThemeResource OutlineVariantColor}" />

            <!-- Game Type -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="12">
              <TextBlock Text="Game Type"
                         Style="{StaticResource MaterialBody1}"
                         Foreground="{ThemeResource OnSurfaceVariantColor}"
                         Width="120" />
              <TextBlock x:Name="GameTypeText"
                         Style="{StaticResource MaterialSubtitle2}"
                         Foreground="{ThemeResource OnSurfaceColor}"
                         FontWeight="SemiBold" />
            </utu:AutoLayout>

            <Border Height="1"
                    Background="{ThemeResource OutlineVariantColor}" />

            <!-- Skill Level -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="12"
                            CounterAlignment="Center">
              <TextBlock Text="Skill Level"
                         Style="{StaticResource MaterialBody1}"
                         Foreground="{ThemeResource OnSurfaceVariantColor}"
                         Width="120" />
              <utu:AutoLayout Orientation="Horizontal"
                              Spacing="8">
                <TextBlock x:Name="SkillLevelText"
                           Style="{StaticResource MaterialSubtitle2}"
                           Foreground="{ThemeResource IceBlueBrush}"
                           FontWeight="SemiBold" />
                <!-- Star Rating -->
                <utu:AutoLayout Orientation="Horizontal"
                                Spacing="2">
                  <FontIcon Glyph="&#xE735;"
                            FontSize="16"
                            Foreground="{ThemeResource SecondaryColor}" />
                  <FontIcon Glyph="&#xE735;"
                            FontSize="16"
                            Foreground="{ThemeResource SecondaryColor}" />
                  <FontIcon Glyph="&#xE735;"
                            FontSize="16"
                            Foreground="{ThemeResource SecondaryColor}" />
                  <FontIcon Glyph="&#xE734;"
                            FontSize="16"
                            Foreground="{ThemeResource OnSurfaceVariantColor}" />
                  <FontIcon Glyph="&#xE734;"
                            FontSize="16"
                            Foreground="{ThemeResource OnSurfaceVariantColor}" />
                </utu:AutoLayout>
              </utu:AutoLayout>
            </utu:AutoLayout>

          </utu:AutoLayout>
        </Border>

        <!-- Rink Diagram -->
        <Border Style="{StaticResource GlassCardStyle}">
          <utu:AutoLayout Orientation="Vertical"
                          Spacing="12">
            <TextBlock Text="Rink Layout"
                       Style="{StaticResource SectionTitleStyle}"
                       Margin="0" />
            
            <Border Height="200"
                    CornerRadius="12"
                    BorderBrush="{ThemeResource OutlineVariantColor}"
                    BorderThickness="2">
              <Border.Background>
                <ImageBrush ImageSource="https://picsum.photos/600/300"
                            Stretch="UniformToFill" />
              </Border.Background>
            </Border>
          </utu:AutoLayout>
        </Border>

        <!-- Jersey Colors & Dressing Room -->
        <Border Style="{StaticResource GlassCardStyle}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Jersey Colors -->
            <utu:AutoLayout Grid.Column="0"
                            Orientation="Vertical"
                            Spacing="12">
              <TextBlock Text="Jersey Colors"
                         Style="{StaticResource MaterialSubtitle2}"
                         Foreground="{ThemeResource OnSurfaceColor}"
                         FontWeight="SemiBold" />
              
              <utu:AutoLayout Orientation="Horizontal"
                              Spacing="12"
                              HorizontalAlignment="Left">
                <utu:AutoLayout Orientation="Vertical"
                                Spacing="4"
                                HorizontalAlignment="Center">
                  <Ellipse Width="48"
                           Height="48"
                           Fill="#2A2E33" />
                  <TextBlock Text="Dark"
                             Style="{StaticResource MaterialCaption}"
                             Foreground="{ThemeResource OnSurfaceVariantColor}"
                             HorizontalAlignment="Center" />
                </utu:AutoLayout>

                <utu:AutoLayout Orientation="Vertical"
                                Spacing="4"
                                HorizontalAlignment="Center">
                  <Ellipse Width="48"
                           Height="48"
                           Fill="#E8EAED" />
                  <TextBlock Text="Light"
                             Style="{StaticResource MaterialCaption}"
                             Foreground="{ThemeResource OnSurfaceVariantColor}"
                             HorizontalAlignment="Center" />
                </utu:AutoLayout>
              </utu:AutoLayout>
            </utu:AutoLayout>

            <!-- Dressing Room -->
            <utu:AutoLayout Grid.Column="1"
                            Orientation="Vertical"
                            Spacing="8">
              <TextBlock Text="Dressing Room"
                         Style="{StaticResource MaterialSubtitle2}"
                         Foreground="{ThemeResource OnSurfaceColor}"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="DressingRoomText"
                         Style="{StaticResource MaterialHeadline6}"
                         Foreground="{ThemeResource IceBlueBrush}"
                         FontWeight="Bold" />
              <TextBlock Text="Be ready 30 mins prior."
                         Style="{StaticResource MaterialCaption}"
                         Foreground="{ThemeResource OnSurfaceVariantColor}" />
            </utu:AutoLayout>

          </Grid>
        </Border>

        <!-- Cost -->
        <Border Style="{StaticResource GlassCardStyle}">
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="0"
                          Justify="SpaceBetween">
            <TextBlock Text="Cost Per Player"
                       Style="{StaticResource MaterialSubtitle1}"
                       Foreground="{ThemeResource OnSurfaceColor}"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="12"
                            CounterAlignment="Center">
              <TextBlock x:Name="CostText"
                         Style="{StaticResource MaterialHeadline5}"
                         Foreground="{ThemeResource OnSurfaceColor}"
                         FontWeight="Bold" />
              <Border Background="{ThemeResource TertiaryContainerColor}"
                      CornerRadius="8"
                      Padding="12,6">
                <TextBlock Text="Pay at Rink"
                           Style="{StaticResource MaterialCaption}"
                           Foreground="{ThemeResource OnTertiaryContainerColor}"
                           FontWeight="SemiBold" />
              </Border>
            </utu:AutoLayout>
          </utu:AutoLayout>
        </Border>

        <!-- Roster Section -->
        <utu:AutoLayout Orientation="Vertical"
                        Spacing="12">
          <TextBlock Text="Roster"
                     Style="{StaticResource SectionTitleStyle}" />

          <!-- Alert Banner -->
          <Border Background="#5AFF8C52"
                  CornerRadius="12"
                  Padding="16,12"
                  BorderBrush="{ThemeResource SecondaryColor}"
                  BorderThickness="1">
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="12">
              <FontIcon Glyph="&#xE7BA;"
                        FontSize="24"
                        Foreground="{ThemeResource SecondaryColor}" />
              <TextBlock Text="1 Goalie Spot Left!"
                         Style="{StaticResource MaterialSubtitle2}"
                         Foreground="{ThemeResource OnSecondaryContainerColor}"
                         FontWeight="Bold"
                         VerticalAlignment="Center" />
            </utu:AutoLayout>
          </Border>

          <!-- Roster List -->
          <ItemsRepeater x:Name="RosterList">
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="models:RosterPlayer">
                <Border Background="{ThemeResource SurfaceColor}"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,4"
                        BorderBrush="{ThemeResource OutlineVariantColor}"
                        BorderThickness="1">
                  <utu:AutoLayout Orientation="Horizontal"
                                  Spacing="12"
                                  Justify="SpaceBetween">
                    
                    <utu:AutoLayout Orientation="Horizontal"
                                    Spacing="12">
                      <!-- Avatar -->
                      <Ellipse Width="44"
                               Height="44">
                        <Ellipse.Fill>
                          <ImageBrush ImageSource="{Binding AvatarUrl}"
                                      Stretch="UniformToFill" />
                        </Ellipse.Fill>
                      </Ellipse>

                      <!-- Player Info -->
                      <utu:AutoLayout Orientation="Vertical"
                                      Spacing="2"
                                      PrimaryAxisAlignment="Center">
                        <TextBlock Text="{Binding Name}"
                                   Style="{StaticResource MaterialBody1}"
                                   Foreground="{ThemeResource OnSurfaceColor}"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Position}"
                                   Style="{StaticResource MaterialCaption}"
                                   Foreground="{ThemeResource OnSurfaceVariantColor}" />
                      </utu:AutoLayout>
                    </utu:AutoLayout>

                    <!-- Payment Status -->
                    <Border CornerRadius="8"
                            Padding="8,4"
                            Background="{Binding PaymentStatus, Converter={StaticResource PaymentStatusColorConverter}}"
                            VerticalAlignment="Center">
                      <TextBlock Text="{Binding PaymentStatus}"
                                 Style="{StaticResource MaterialCaption}"
                                 FontWeight="SemiBold" />
                    </Border>

                  </utu:AutoLayout>
                </Border>
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>

        </utu:AutoLayout>

      </utu:AutoLayout>
    </ScrollViewer>

    <!-- Sticky Join Button -->
    <Border Grid.Row="2"
            Background="{ThemeResource SurfaceColor}"
            Padding="16,12"
            Translation="0,0,16">
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>
      
      <Button Content="Request to Join"
              Style="{StaticResource PrimaryButtonStyle}"
              HorizontalAlignment="Stretch"
              Click="RequestToJoin_Click" />
    </Border>

  </Grid>
</Page>

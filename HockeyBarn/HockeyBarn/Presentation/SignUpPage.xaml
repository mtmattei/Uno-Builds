<Page x:Class="HockeyBarn.Presentation.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid>
    <!-- Background gradient -->
    <Grid.Background>
      <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#0C1118" Offset="0" />
        <GradientStop Color="#1E293B" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <ScrollViewer>
      <utu:AutoLayout Orientation="Vertical"
                      Spacing="24"
                      Padding="24"
                      MaxWidth="500"
                      HorizontalAlignment="Center">

        <!-- Header -->
        <utu:AutoLayout Orientation="Vertical"
                        Spacing="8"
                        Margin="0,32,0,16">
          <utu:AutoLayout Orientation="Horizontal"
                          Spacing="12"
                          HorizontalAlignment="Center">
            <FontIcon Glyph="&#xE8FE;"
                      Foreground="{ThemeResource IceBlueBrush}"
                      FontSize="32" />
            <TextBlock Text="The Hockey Barn"
                       Style="{StaticResource MaterialHeadline5}"
                       Foreground="{ThemeResource OnBackgroundColor}"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
          </utu:AutoLayout>
        </utu:AutoLayout>

        <!-- Card Container -->
        <Border Style="{StaticResource GlassCardStyle}"
                Padding="24"
                Background="{ThemeResource SurfaceColor}">

          <utu:AutoLayout Orientation="Vertical"
                          Spacing="24">

            <!-- Title -->
            <TextBlock Text="Join the Roster"
                       Style="{StaticResource MaterialHeadline5}"
                       Foreground="{ThemeResource OnSurfaceColor}"
                       FontWeight="Bold"
                       HorizontalAlignment="Center" />

            <!-- Tab Switcher -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="0"
                            HorizontalAlignment="Center">
              <Button x:Name="SignUpTabButton"
                      Content="Sign Up"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Background="{ThemeResource PrimaryContainerColor}"
                      Foreground="{ThemeResource PrimaryColor}"
                      Height="44"
                      Padding="32,0"
                      CornerRadius="22,0,0,22"
                      BorderThickness="0"
                      Click="SignUpTab_Click" />
              <Button x:Name="LoginTabButton"
                      Content="Login"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Background="Transparent"
                      Height="44"
                      Padding="32,0"
                      CornerRadius="0,22,22,0"
                      BorderThickness="0"
                      Click="LoginTab_Click" />
            </utu:AutoLayout>

            <!-- Sign Up Form -->
            <utu:AutoLayout x:Name="SignUpForm"
                            Orientation="Vertical"
                            Spacing="16"
                            Visibility="Visible">

              <utu:AutoLayout Orientation="Vertical"
                              Spacing="8">
                <TextBlock Text="Full Name"
                           Style="{StaticResource MaterialBody1}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
                <TextBox x:Name="FullNameInput"
                         PlaceholderText="Enter your full name"
                         Style="{StaticResource InputFieldStyle}" />
              </utu:AutoLayout>

              <utu:AutoLayout Orientation="Vertical"
                              Spacing="8">
                <TextBlock Text="Email"
                           Style="{StaticResource MaterialBody1}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
                <TextBox x:Name="EmailInput"
                         PlaceholderText="Enter your email address"
                         Style="{StaticResource InputFieldStyle}"
                         InputScope="EmailSmtpAddress" />
              </utu:AutoLayout>

              <utu:AutoLayout Orientation="Vertical"
                              Spacing="8">
                <TextBlock Text="Password"
                           Style="{StaticResource MaterialBody1}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
                <PasswordBox x:Name="PasswordInput"
                             PlaceholderText="Enter your password"
                             Style="{StaticResource InputFieldStyle}" />
              </utu:AutoLayout>

              <Button FontSize="24" HorizontalAlignment="Center" Content="Create Account"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Margin="0,8,0,0"
                      Click="CreateAccount_Click" />

            </utu:AutoLayout>

            <!-- Login Form -->
            <utu:AutoLayout x:Name="LoginForm"
                            Orientation="Vertical"
                            Spacing="16"
                            Visibility="Collapsed">

              <utu:AutoLayout Orientation="Vertical"
                              Spacing="8">
                <TextBlock Text="Email"
                           Style="{StaticResource MaterialBody1}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
                <TextBox x:Name="LoginEmailInput"
                         PlaceholderText="Enter your email address"
                         Style="{StaticResource InputFieldStyle}"
                         InputScope="EmailSmtpAddress" />
              </utu:AutoLayout>

              <utu:AutoLayout Orientation="Vertical"
                              Spacing="8">
                <TextBlock Text="Password"
                           Style="{StaticResource MaterialBody1}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
                <PasswordBox x:Name="LoginPasswordInput"
                             PlaceholderText="Enter your password"
                             Style="{StaticResource InputFieldStyle}" />
              </utu:AutoLayout>

              <Button Content="Log In"
                      Style="{StaticResource PrimaryButtonStyle}"
                      HorizontalAlignment="Stretch"
                      Margin="0,8,0,0"
                      Click="Login_Click" />

            </utu:AutoLayout>

            <!-- Divider -->
            <Grid>
              <Border Height="1"
                      Background="{ThemeResource OutlineVariantColor}"
                      VerticalAlignment="Center" />
              <Border Background="{ThemeResource SurfaceColor}"
                      Padding="12,0"
                      HorizontalAlignment="Center">
                <TextBlock Text="Or continue with"
                           Style="{StaticResource MaterialCaption}"
                           Foreground="{ThemeResource OnSurfaceVariantColor}" />
              </Border>
            </Grid>

            <!-- Social Login Options -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="16"
                            HorizontalAlignment="Center">
              
              <Border Width="64"
                      Height="64"
                      CornerRadius="32"
                      Background="{ThemeResource SurfaceVariantColor}"
                      BorderBrush="{ThemeResource OutlineVariantColor}"
                      BorderThickness="1">
                <FontIcon Glyph="&#xE909;"
                          FontSize="28"
                          Foreground="{ThemeResource OnSurfaceColor}" />
              </Border>

              <Border Width="64"
                      Height="64"
                      CornerRadius="32"
                      Background="{ThemeResource SurfaceVariantColor}"
                      BorderBrush="{ThemeResource OutlineVariantColor}"
                      BorderThickness="1">
                <FontIcon Glyph="&#xF22B;"
                          FontSize="28"
                          Foreground="{ThemeResource OnSurfaceColor}" />
              </Border>

            </utu:AutoLayout>

            <!-- Footer Link -->
            <utu:AutoLayout Orientation="Horizontal"
                            Spacing="4"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
              <TextBlock x:Name="FooterText"
                         Text="Already have an account?"
                         Style="{StaticResource MaterialBody2}"
                         Foreground="{ThemeResource OnSurfaceVariantColor}" />
              <HyperlinkButton x:Name="FooterLink"
                               Content="Log In"
                               Foreground="{ThemeResource IceBlueBrush}"
                               Padding="4,0"
                               FontSize="14"
                               Click="FooterLink_Click" />
            </utu:AutoLayout>

          </utu:AutoLayout>

        </Border>

      </utu:AutoLayout>
    </ScrollViewer>

  </Grid>
</Page>

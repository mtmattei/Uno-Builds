<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <!-- GRIDFORM Monochromatic Dark Palette — dark-only, no light theme -->
    <ResourceDictionary x:Key="Light">
      <!-- Force dark palette even in "light" to maintain monochrome instrument aesthetic -->
      <Color x:Key="PrimaryColor">#D9FFFFFF</Color>
      <Color x:Key="OnPrimaryColor">#FF050507</Color>
      <Color x:Key="PrimaryContainerColor">#1AFFFFFF</Color>
      <Color x:Key="OnPrimaryContainerColor">#D9FFFFFF</Color>
      <Color x:Key="SecondaryColor">#B3FFFFFF</Color>
      <Color x:Key="OnSecondaryColor">#FF050507</Color>
      <Color x:Key="SecondaryContainerColor">#14FFFFFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#B3FFFFFF</Color>
      <Color x:Key="TertiaryColor">#80FFFFFF</Color>
      <Color x:Key="OnTertiaryColor">#FF050507</Color>
      <Color x:Key="TertiaryContainerColor">#0DFFFFFF</Color>
      <Color x:Key="OnTertiaryContainerColor">#80FFFFFF</Color>
      <Color x:Key="ErrorColor">#D9FFFFFF</Color>
      <Color x:Key="ErrorContainerColor">#33FFFFFF</Color>
      <Color x:Key="OnErrorColor">#FF050507</Color>
      <Color x:Key="OnErrorContainerColor">#D9FFFFFF</Color>
      <Color x:Key="BackgroundColor">#FF0D0E12</Color>
      <Color x:Key="OnBackgroundColor">#FFDEDBD4</Color>
      <Color x:Key="SurfaceColor">#FF1A1C22</Color>
      <Color x:Key="OnSurfaceColor">#FFDEDBD4</Color>
      <Color x:Key="SurfaceVariantColor">#FF1E2028</Color>
      <Color x:Key="OnSurfaceVariantColor">#59FFFFFF</Color>
      <Color x:Key="OutlineColor">#0AFFFFFF</Color>
      <Color x:Key="OnSurfaceInverseColor">#FF050507</Color>
      <Color x:Key="SurfaceInverseColor">#D9FFFFFF</Color>
      <Color x:Key="PrimaryInverseColor">#FF050507</Color>
      <Color x:Key="SurfaceTintColor">#1AFFFFFF</Color>
      <Color x:Key="OutlineVariantColor">#0FFFFFFF</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#D9FFFFFF</Color>
      <Color x:Key="OnPrimaryColor">#FF050507</Color>
      <Color x:Key="PrimaryContainerColor">#1AFFFFFF</Color>
      <Color x:Key="OnPrimaryContainerColor">#D9FFFFFF</Color>
      <Color x:Key="SecondaryColor">#B3FFFFFF</Color>
      <Color x:Key="OnSecondaryColor">#FF050507</Color>
      <Color x:Key="SecondaryContainerColor">#14FFFFFF</Color>
      <Color x:Key="OnSecondaryContainerColor">#B3FFFFFF</Color>
      <Color x:Key="TertiaryColor">#80FFFFFF</Color>
      <Color x:Key="OnTertiaryColor">#FF050507</Color>
      <Color x:Key="TertiaryContainerColor">#0DFFFFFF</Color>
      <Color x:Key="OnTertiaryContainerColor">#80FFFFFF</Color>
      <Color x:Key="ErrorColor">#D9FFFFFF</Color>
      <Color x:Key="ErrorContainerColor">#33FFFFFF</Color>
      <Color x:Key="OnErrorColor">#FF050507</Color>
      <Color x:Key="OnErrorContainerColor">#D9FFFFFF</Color>
      <Color x:Key="BackgroundColor">#FF0D0E12</Color>
      <Color x:Key="OnBackgroundColor">#FFDEDBD4</Color>
      <Color x:Key="SurfaceColor">#FF1A1C22</Color>
      <Color x:Key="OnSurfaceColor">#FFDEDBD4</Color>
      <Color x:Key="SurfaceVariantColor">#FF1E2028</Color>
      <Color x:Key="OnSurfaceVariantColor">#59FFFFFF</Color>
      <Color x:Key="OutlineColor">#0AFFFFFF</Color>
      <Color x:Key="OnSurfaceInverseColor">#FF050507</Color>
      <Color x:Key="SurfaceInverseColor">#D9FFFFFF</Color>
      <Color x:Key="PrimaryInverseColor">#FF050507</Color>
      <Color x:Key="SurfaceTintColor">#1AFFFFFF</Color>
      <Color x:Key="OutlineVariantColor">#0FFFFFFF</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

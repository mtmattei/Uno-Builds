<Page x:Class="VoxelWarehouse.Presentation.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource GfBgBrush}"
      NavigationCacheMode="Required">

  <ScrollViewer Padding="24,20">
    <StackPanel Spacing="24">

      <!-- ═══ KPI CARDS ═══ -->
      <StackPanel x:Name="KpiPanel" Orientation="Horizontal" Spacing="12" />

      <!-- ═══ ACTIVITY TIMELINE ═══ -->
      <StackPanel Spacing="10">
        <TextBlock Text="ACTIVITY FEED" Style="{StaticResource GfSectionHeaderStyle}" />
        <Border Height="1" Background="{StaticResource GfBorderBrush}" />
        <StackPanel x:Name="ActivityPanel" Spacing="6" />
      </StackPanel>

      <!-- ═���═ NEEDS ATTENTION ═══ -->
      <StackPanel Spacing="10">
        <TextBlock Text="NEEDS ATTENTION" Style="{StaticResource GfSectionHeaderStyle}" />
        <Border Height="1" Background="{StaticResource GfBorderBrush}" />
        <StackPanel x:Name="AttentionPanel" Spacing="8" />
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>

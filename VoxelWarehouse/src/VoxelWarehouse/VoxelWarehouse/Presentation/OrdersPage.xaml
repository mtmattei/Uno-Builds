<Page x:Class="VoxelWarehouse.Presentation.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource GfBgBrush}"
      NavigationCacheMode="Required">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Table header -->
    <Border Grid.Row="0" Background="{StaticResource GfPanelBrush}"
            BorderBrush="{StaticResource GfBorderBrush}" BorderThickness="0,0,0,1"
            Padding="16,10">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="100" />
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="60" />
          <ColumnDefinition Width="80" />
          <ColumnDefinition Width="70" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="PO#" Style="{StaticResource GfSectionHeaderStyle}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="1" Text="VENDOR" Style="{StaticResource GfSectionHeaderStyle}" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="AMOUNT" Style="{StaticResource GfSectionHeaderStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="STATUS" Style="{StaticResource GfSectionHeaderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="RISK" Style="{StaticResource GfSectionHeaderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Grid.Column="5" Text="AI" Style="{StaticResource GfSectionHeaderStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBlock Grid.Column="6" Text="SUBMITTED" Style="{StaticResource GfSectionHeaderStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <!-- Table rows -->
    <ScrollViewer Grid.Row="1">
      <StackPanel x:Name="OrderRows" Spacing="0" />
    </ScrollViewer>
  </Grid>
</Page>

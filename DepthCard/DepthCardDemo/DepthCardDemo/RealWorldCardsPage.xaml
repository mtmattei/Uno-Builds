<Page x:Class="DepthCardDemo.RealWorldCardsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:DepthCardDemo"
      xmlns:controls="using:DepthCardDemo.Controls"
      xmlns:utu="using:Uno.Toolkit.UI">
    <Page.Background>
        <SolidColorBrush Color="#1a1d25"/>
    </Page.Background>

    <Grid>
        <!-- Back button in top-left -->
        <Button x:Name="BackButton"
                Click="BackButton_Click"
                Style="{StaticResource TextBlockButtonStyle}"
                Padding="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="56,48,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="#64748b"/>
                <TextBlock Text="Back to Demo"
                           FontSize="13"
                           Foreground="#64748b"
                           FontWeight="Medium"/>
            </StackPanel>
        </Button>

        <!-- Centered invitation card with depth effect and shadow -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Padding="60">
            <utu:ShadowContainer CornerRadius="4">
                <utu:ShadowContainer.Shadows>
                    <utu:ShadowCollection>
                        <utu:Shadow OffsetY="20"
                                   BlurRadius="40"
                                   Opacity="0.6"
                                   Color="Black"/>
                    </utu:ShadowCollection>
                </utu:ShadowContainer.Shadows>

                <controls:DepthCard Width="420"
                                    Height="600"
                                    Intensity="6"
                                    DepthScale="15"
                                    GlareOpacity="0"
                                    EnableEdgeLighting="False"
                                    EnableBreathingEffect="True"
                                    BreathingCycle="4000"
                                    BreathingIntensity="0.006"
                                    FloatingRange="6"
                                    FloatingCycle="7000"
                                    Background="Transparent"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">

                <!-- Gala Invitation Card -->
                <Border Width="420"
                        Height="600"
                        CornerRadius="4"
                        BorderThickness="1">

                    <!-- Gradient border (fades in middle) -->
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#D4AF37" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="0.3"/>
                            <GradientStop Color="#00000000" Offset="0.7"/>
                            <GradientStop Color="#8B7A3B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>

                    <!-- Dark gradient background -->
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.2,0" EndPoint="0.8,1">
                            <GradientStop Color="#14141E" Offset="0"/>
                            <GradientStop Color="#0A0A0F" Offset="0.5"/>
                            <GradientStop Color="#0F0F16" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Grid>
                        <!-- Corner accent brackets with dynamic highlights -->
                        <!-- Top-left corner -->
                        <Canvas Width="20" Height="20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="15,15,0,0">
                            <Path x:Name="TopLeftCorner"
                                  Stroke="#D4AF37" StrokeThickness="1" Opacity="0.6"
                                  Data="M 20,0 L 0,0 L 0,20"/>
                        </Canvas>

                        <!-- Top-right corner -->
                        <Canvas Width="20" Height="20"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,15,15,0">
                            <Path x:Name="TopRightCorner"
                                  Stroke="#D4AF37" StrokeThickness="1" Opacity="0.6"
                                  Data="M 0,0 L 20,0 L 20,20"/>
                        </Canvas>

                        <!-- Bottom-left corner -->
                        <Canvas Width="20" Height="20"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Bottom"
                                Margin="15,0,0,15">
                            <Path x:Name="BottomLeftCorner"
                                  Stroke="#D4AF37" StrokeThickness="1" Opacity="0.6"
                                  Data="M 0,0 L 0,20 L 20,20"/>
                        </Canvas>

                        <!-- Bottom-right corner -->
                        <Canvas Width="20" Height="20"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,15,15">
                            <Path x:Name="BottomRightCorner"
                                  Stroke="#D4AF37" StrokeThickness="1" Opacity="0.6"
                                  Data="M 0,20 L 20,20 L 20,0"/>
                        </Canvas>

                        <!-- Content grid -->
                        <Grid Padding="48,56">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Preheader -->
                                <TextBlock Grid.Row="0"
                                           Text="YOU ARE CORDIALLY INVITED"
                                           FontSize="13"
                                           FontWeight="Normal"
                                           CharacterSpacing="280"
                                           Foreground="#D4AF37"
                                           Opacity="0.9"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,16"
                                           FontFamily="Bebas Neue"
                                           IsHitTestVisible="False"/>

                                <!-- Main title -->
                                <StackPanel Grid.Row="1"
                                            HorizontalAlignment="Center"
                                            Margin="0,0,0,16"
                                            IsHitTestVisible="False">
                                    <TextBlock Text="THE GALA"
                                               FontSize="48"
                                               FontWeight="Light"
                                               Foreground="#F4E4BC"
                                               HorizontalAlignment="Center"
                                               FontFamily="Cormorant Garamond"/>
                                    <TextBlock Text="OF WONDERS"
                                               FontSize="28"
                                               FontWeight="Light"
                                               FontStyle="Italic"
                                               CharacterSpacing="150"
                                               Foreground="#F4E4BC"
                                               HorizontalAlignment="Center"
                                               Opacity="0.85"
                                               Margin="0,4,0,0"
                                               FontFamily="Cormorant Garamond"/>
                                </StackPanel>

                                <!-- 3D Icosahedron with PBR Material -->
                                <controls:Simple3DObject Grid.Row="2"
                                                         GeometryType="Icosahedron"
                                                         Size="90"
                                                         Width="340"
                                                         Height="340"
                                                         FaceColor="#90D4AF37"
                                                         TextureType="PBR"
                                                         Metallic="0.9"
                                                         Roughness="0.3"
                                                         TiltRotationMultiplier="0"
                                                         EnableAutoRotate="True"
                                                         AutoRotateSpeed="0.3"
                                                         Margin="0,8,0,8"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>

                                <!-- Event details -->
                                <StackPanel Grid.Row="3"
                                            HorizontalAlignment="Center"
                                            Spacing="12"
                                            Margin="0,0,0,24"
                                            IsHitTestVisible="False">
                                    <TextBlock Text="DECEMBER 31ST, 2025 • 8:00 PM"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               CharacterSpacing="280"
                                               Foreground="#D4AF37"
                                               HorizontalAlignment="Center"
                                               FontFamily="Bebas Neue"/>
                                    <TextBlock Text="The Crystal Pavilion"
                                               FontSize="18"
                                               FontWeight="Normal"
                                               Foreground="#F4E4BC"
                                               HorizontalAlignment="Center"
                                               FontFamily="Cormorant Garamond"/>
                                    <TextBlock Text="1234 Starlight Avenue, New York"
                                               FontSize="12"
                                               FontWeight="Normal"
                                               Foreground="#F4E4BC"
                                               Opacity="0.6"
                                               HorizontalAlignment="Center"
                                               FontFamily="Cormorant Garamond"/>

                                    <!-- Divider -->
                                    <Border Height="1"
                                            Width="60"
                                            Background="#D4AF37"
                                            Opacity="0.3"
                                            Margin="0,8"/>
                                </StackPanel>

                                <!-- RSVP -->
                                <TextBlock Grid.Row="4"
                                           Text="Kindly respond by December 15th"
                                           FontSize="11"
                                           FontWeight="Light"
                                           FontStyle="Italic"
                                           Foreground="#D4AF37"
                                           Opacity="0.6"
                                           HorizontalAlignment="Center"
                                           FontFamily="Cormorant Garamond"
                                           IsHitTestVisible="False"/>
                        </Grid>
                    </Grid>
                </Border>

                </controls:DepthCard>
            </utu:ShadowContainer>
        </Grid>
    </Grid>
</Page>

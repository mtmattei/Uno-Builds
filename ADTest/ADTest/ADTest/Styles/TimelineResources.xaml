<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Timeline-specific colors -->
  <Color x:Key="TimelineAccentColor">#FF1493</Color>
  <Color x:Key="TimelineConnectorColor">#C4BEB6</Color>
  <Color x:Key="TimelineDotColor">#C4BEB6</Color>
  <Color x:Key="TimelineHoverColor">#E8E4DE</Color>
  <Color x:Key="TimelineTextSecondaryColor">#706B63</Color>
  <Color x:Key="TimelineTextPrimaryColor">#2C2A26</Color>
  <Color x:Key="TimelineIconDefaultColor">#9B958D</Color>
  <Color x:Key="TimelineIconActiveColor">#6B6560</Color>
  <Color x:Key="TimelineSidebarActiveBgColor">#FFFFFF</Color>
  <Color x:Key="TimelinePageBgColor">#F0EDE8</Color>
  <Color x:Key="TimelineSegmentInactiveColor">#A8A29E</Color>

  <SolidColorBrush x:Key="TimelineAccentBrush" Color="{StaticResource TimelineAccentColor}" />
  <SolidColorBrush x:Key="TimelineConnectorBrush" Color="{StaticResource TimelineConnectorColor}" />
  <SolidColorBrush x:Key="TimelineDotBrush" Color="{StaticResource TimelineDotColor}" />
  <SolidColorBrush x:Key="TimelineHoverBrush" Color="{StaticResource TimelineHoverColor}" />
  <SolidColorBrush x:Key="TimelineTextSecondaryBrush" Color="{StaticResource TimelineTextSecondaryColor}" />
  <SolidColorBrush x:Key="TimelineTextPrimaryBrush" Color="{StaticResource TimelineTextPrimaryColor}" />
  <SolidColorBrush x:Key="TimelineIconDefaultBrush" Color="{StaticResource TimelineIconDefaultColor}" />
  <SolidColorBrush x:Key="TimelineIconActiveBrush" Color="{StaticResource TimelineIconActiveColor}" />
  <SolidColorBrush x:Key="TimelineSidebarActiveBgBrush" Color="{StaticResource TimelineSidebarActiveBgColor}" />
  <SolidColorBrush x:Key="TimelinePageBgBrush" Color="{StaticResource TimelinePageBgColor}" />
  <SolidColorBrush x:Key="TimelineSegmentInactiveBrush" Color="{StaticResource TimelineSegmentInactiveColor}" />

  <!-- Sidebar icon button style -->
  <Style x:Key="SidebarIconStyle" TargetType="Button">
    <Setter Property="Width" Value="40" />
    <Setter Property="Height" Value="40" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SidebarIconActiveStyle" TargetType="Button" BasedOn="{StaticResource SidebarIconStyle}">
    <Setter Property="Background" Value="{StaticResource TimelineSidebarActiveBgBrush}" />
  </Style>

  <!-- Segmented control pill style -->
  <Style x:Key="SegmentButtonStyle" TargetType="RadioButton">
    <Setter Property="MinWidth" Value="48" />
    <Setter Property="MinHeight" Value="32" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource TimelineSegmentInactiveBrush}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RadioButton">
          <Grid x:Name="RootGrid"
                Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}"
                Padding="{TemplateBinding Padding}">
            <VisualStateManager.VisualStateGroups>
              <VisualStateGroup x:Name="CheckStates">
                <VisualState x:Name="Checked">
                  <VisualState.Setters>
                    <Setter Target="RootGrid.Background" Value="{StaticResource TimelineSidebarActiveBgBrush}" />
                    <Setter Target="ContentText.Foreground" Value="{StaticResource TimelineTextPrimaryBrush}" />
                  </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Unchecked" />
                <VisualState x:Name="Indeterminate" />
              </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <TextBlock x:Name="ContentText"
                       Text="{TemplateBinding Content}"
                       Foreground="{TemplateBinding Foreground}"
                       FontSize="{TemplateBinding FontSize}"
                       FontWeight="{TemplateBinding FontWeight}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

</ResourceDictionary>

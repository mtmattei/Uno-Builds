<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Warm monochromatic palette with magenta accent -->
      <Color x:Key="PrimaryColor">#FF1493</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#FFD6EC</Color>
      <Color x:Key="OnPrimaryContainerColor">#3B0020</Color>
      <Color x:Key="SecondaryColor">#6B6560</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E8E4DE</Color>
      <Color x:Key="OnSecondaryContainerColor">#2C2A26</Color>
      <Color x:Key="TertiaryColor">#9B958D</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#F0EDE8</Color>
      <Color x:Key="OnTertiaryContainerColor">#2C2A26</Color>
      <Color x:Key="ErrorColor">#B3261E</Color>
      <Color x:Key="ErrorContainerColor">#F9DEDC</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#410E0B</Color>
      <Color x:Key="BackgroundColor">#F0EDE8</Color>
      <Color x:Key="OnBackgroundColor">#2C2A26</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#2C2A26</Color>
      <Color x:Key="SurfaceVariantColor">#E8E4DE</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B6560</Color>
      <Color x:Key="OutlineColor">#9B958D</Color>
      <Color x:Key="OnSurfaceInverseColor">#F0EDE8</Color>
      <Color x:Key="SurfaceInverseColor">#2C2A26</Color>
      <Color x:Key="PrimaryInverseColor">#FF6DB8</Color>
      <Color x:Key="SurfaceTintColor">#FF1493</Color>
      <Color x:Key="OutlineVariantColor">#C4BEB6</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <Color x:Key="PrimaryColor">#FF6DB8</Color>
      <Color x:Key="OnPrimaryColor">#5C0036</Color>
      <Color x:Key="PrimaryContainerColor">#84004F</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFD6EC</Color>
      <Color x:Key="SecondaryColor">#D4CCC4</Color>
      <Color x:Key="OnSecondaryColor">#3A3632</Color>
      <Color x:Key="SecondaryContainerColor">#524D48</Color>
      <Color x:Key="OnSecondaryContainerColor">#F0EDE8</Color>
      <Color x:Key="TertiaryColor">#C4BEB6</Color>
      <Color x:Key="OnTertiaryColor">#2C2A26</Color>
      <Color x:Key="TertiaryContainerColor">#524D48</Color>
      <Color x:Key="OnTertiaryContainerColor">#E8E4DE</Color>
      <Color x:Key="ErrorColor">#FFB4AB</Color>
      <Color x:Key="ErrorContainerColor">#93000A</Color>
      <Color x:Key="OnErrorColor">#690005</Color>
      <Color x:Key="OnErrorContainerColor">#FFDAD6</Color>
      <Color x:Key="BackgroundColor">#1C1A18</Color>
      <Color x:Key="OnBackgroundColor">#E8E4DE</Color>
      <Color x:Key="SurfaceColor">#2C2A26</Color>
      <Color x:Key="OnSurfaceColor">#E8E4DE</Color>
      <Color x:Key="SurfaceVariantColor">#3A3632</Color>
      <Color x:Key="OnSurfaceVariantColor">#C4BEB6</Color>
      <Color x:Key="OutlineColor">#9B958D</Color>
      <Color x:Key="OnSurfaceInverseColor">#2C2A26</Color>
      <Color x:Key="SurfaceInverseColor">#E8E4DE</Color>
      <Color x:Key="PrimaryInverseColor">#FF1493</Color>
      <Color x:Key="SurfaceTintColor">#FF6DB8</Color>
      <Color x:Key="OutlineVariantColor">#524D48</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Light">
      <!-- Caffè Brand Colors -->
      <Color x:Key="PrimaryColor">#1B4332</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#2D6A4F</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFFFFF</Color>
      <Color x:Key="SecondaryColor">#2D6A4F</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#E8F5E9</Color>
      <Color x:Key="OnSecondaryContainerColor">#1B4332</Color>
      <Color x:Key="TertiaryColor">#C1121F</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#FFCDD2</Color>
      <Color x:Key="OnTertiaryContainerColor">#7F0000</Color>
      <Color x:Key="ErrorColor">#C1121F</Color>
      <Color x:Key="ErrorContainerColor">#FFCDD2</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#7F0000</Color>
      <Color x:Key="BackgroundColor">#FAFAFA</Color>
      <Color x:Key="OnBackgroundColor">#1A1A1A</Color>
      <Color x:Key="SurfaceColor">#FFFFFF</Color>
      <Color x:Key="OnSurfaceColor">#1A1A1A</Color>
      <Color x:Key="SurfaceVariantColor">#F5F5F5</Color>
      <Color x:Key="OnSurfaceVariantColor">#888888</Color>
      <Color x:Key="OutlineColor">#E0E0E0</Color>
      <Color x:Key="OnSurfaceInverseColor">#FAFAFA</Color>
      <Color x:Key="SurfaceInverseColor">#1A1A1A</Color>
      <Color x:Key="PrimaryInverseColor">#2D6A4F</Color>
      <Color x:Key="SurfaceTintColor">#1B4332</Color>
      <Color x:Key="OutlineVariantColor">#E0E0E0</Color>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Dark">
      <!-- Dark theme - keep same brand feel -->
      <Color x:Key="PrimaryColor">#2D6A4F</Color>
      <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
      <Color x:Key="PrimaryContainerColor">#1B4332</Color>
      <Color x:Key="OnPrimaryContainerColor">#FFFFFF</Color>
      <Color x:Key="SecondaryColor">#40916C</Color>
      <Color x:Key="OnSecondaryColor">#FFFFFF</Color>
      <Color x:Key="SecondaryContainerColor">#1B4332</Color>
      <Color x:Key="OnSecondaryContainerColor">#A8DADC</Color>
      <Color x:Key="TertiaryColor">#E07070</Color>
      <Color x:Key="OnTertiaryColor">#FFFFFF</Color>
      <Color x:Key="TertiaryContainerColor">#7F0000</Color>
      <Color x:Key="OnTertiaryContainerColor">#FFCDD2</Color>
      <Color x:Key="ErrorColor">#E07070</Color>
      <Color x:Key="ErrorContainerColor">#7F0000</Color>
      <Color x:Key="OnErrorColor">#FFFFFF</Color>
      <Color x:Key="OnErrorContainerColor">#FFCDD2</Color>
      <Color x:Key="BackgroundColor">#121212</Color>
      <Color x:Key="OnBackgroundColor">#FAFAFA</Color>
      <Color x:Key="SurfaceColor">#1E1E1E</Color>
      <Color x:Key="OnSurfaceColor">#FAFAFA</Color>
      <Color x:Key="SurfaceVariantColor">#2A2A2A</Color>
      <Color x:Key="OnSurfaceVariantColor">#999999</Color>
      <Color x:Key="OutlineColor">#3A3A3A</Color>
      <Color x:Key="OnSurfaceInverseColor">#121212</Color>
      <Color x:Key="SurfaceInverseColor">#FAFAFA</Color>
      <Color x:Key="PrimaryInverseColor">#1B4332</Color>
      <Color x:Key="SurfaceTintColor">#2D6A4F</Color>
      <Color x:Key="OutlineVariantColor">#3A3A3A</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

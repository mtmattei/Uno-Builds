<Page x:Class="Caffe.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:Caffe"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:models="using:Caffe.Models"
      xmlns:converters="using:Caffe.Converters"
      Background="{StaticResource CaffeBackgroundBrush}">

  <Page.Resources>
    <converters:TemperatureToFillHeightConverter x:Key="TempToHeight" />
    <converters:BoolToOpacityConverter x:Key="BoolToOpacity" />
    <converters:BrewProgressToHeightConverter x:Key="BrewToHeight" />
    <converters:InverseBoolConverter x:Key="InverseBool" />
  </Page.Resources>

  <Grid>
    <!-- Main Content (hidden when brewing) -->
    <ScrollViewer Visibility="{x:Bind ViewModel.IsBrewing, Mode=OneWay, Converter={StaticResource InverseBool}}">
      <Grid utu:SafeArea.Insets="All"
            MaxWidth="520" Padding="16,0"
            HorizontalAlignment="Center">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Spacing="8" Padding="0,40,0,28" HorizontalAlignment="Center">
          <!-- Accent Bar -->
          <Grid Width="56" Height="4" CornerRadius="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource CaffePrimaryBrush}" CornerRadius="2,0,0,2" />
            <Border Grid.Column="1" Background="{StaticResource CaffeAccentRedBrush}" CornerRadius="0,2,2,0" />
          </Grid>

          <!-- Logo -->
          <TextBlock Text="Caffè"
                     FontFamily="{StaticResource CormorantGaramond}"
                     FontSize="48"
                     FontWeight="Light"
                     Foreground="{StaticResource CaffeTextPrimaryBrush}"
                     HorizontalAlignment="Center" />

          <!-- Tagline -->
          <TextBlock Text="NOTHING MORE. NOTHING LESS."
                     FontFamily="{StaticResource DMSans}"
                     FontSize="11"
                     CharacterSpacing="150"
                     Foreground="{StaticResource CaffeTextSecondaryBrush}"
                     HorizontalAlignment="Center" />
        </StackPanel>

        <!-- MAIN CONTENT -->
        <StackPanel Grid.Row="1" Spacing="20">

          <!-- Espresso Selection Grid -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="12" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Espresso Card -->
            <Button Grid.Column="0" Grid.Row="0"
                    Command="{x:Bind ViewModel.SelectEspressoCommand}"
                    CommandParameter="{x:Bind ViewModel.EspressoOptions[0]}"
                    Style="{StaticResource EspressoCardStyle}"
                    BorderBrush="{x:Bind local:MainPage.GetCardBorderBrush(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[0]), Mode=OneWay}">
              <Grid Padding="16,20">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!-- Volume text -->
                <TextBlock Grid.Row="0" Text="30ml" FontFamily="{StaticResource DMSans}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource CaffeAccentRedBrush}"
                           HorizontalAlignment="Left" />
                <!-- Checkmark -->
                <FontIcon Grid.Row="0" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{StaticResource CaffePrimaryBrush}"
                          HorizontalAlignment="Right"
                          Visibility="{x:Bind local:MainPage.IsSelected(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[0]), Mode=OneWay}" />
                <TextBlock Grid.Row="2" Text="Espresso"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}" />
                <TextBlock Grid.Row="4" Text="Pure, concentrated, bold"
                           FontFamily="{StaticResource DMSans}" FontSize="12"
                           Foreground="{StaticResource CaffeTextMutedBrush}" TextWrapping="Wrap" />
              </Grid>
            </Button>

            <!-- Doppio Card -->
            <Button Grid.Column="2" Grid.Row="0"
                    Command="{x:Bind ViewModel.SelectEspressoCommand}"
                    CommandParameter="{x:Bind ViewModel.EspressoOptions[1]}"
                    Style="{StaticResource EspressoCardStyle}"
                    BorderBrush="{x:Bind local:MainPage.GetCardBorderBrush(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[1]), Mode=OneWay}">
              <Grid Padding="16,20">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="60ml" FontFamily="{StaticResource DMSans}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource CaffeAccentRedBrush}"
                           HorizontalAlignment="Left" />
                <FontIcon Grid.Row="0" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{StaticResource CaffePrimaryBrush}"
                          HorizontalAlignment="Right"
                          Visibility="{x:Bind local:MainPage.IsSelected(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[1]), Mode=OneWay}" />
                <TextBlock Grid.Row="2" Text="Doppio"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}" />
                <TextBlock Grid.Row="4" Text="Double the intensity"
                           FontFamily="{StaticResource DMSans}" FontSize="12"
                           Foreground="{StaticResource CaffeTextMutedBrush}" TextWrapping="Wrap" />
              </Grid>
            </Button>

            <!-- Ristretto Card -->
            <Button Grid.Column="0" Grid.Row="2"
                    Command="{x:Bind ViewModel.SelectEspressoCommand}"
                    CommandParameter="{x:Bind ViewModel.EspressoOptions[2]}"
                    Style="{StaticResource EspressoCardStyle}"
                    BorderBrush="{x:Bind local:MainPage.GetCardBorderBrush(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[2]), Mode=OneWay}">
              <Grid Padding="16,20">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="20ml" FontFamily="{StaticResource DMSans}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource CaffeAccentRedBrush}"
                           HorizontalAlignment="Left" />
                <FontIcon Grid.Row="0" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{StaticResource CaffePrimaryBrush}"
                          HorizontalAlignment="Right"
                          Visibility="{x:Bind local:MainPage.IsSelected(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[2]), Mode=OneWay}" />
                <TextBlock Grid.Row="2" Text="Ristretto"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}" />
                <TextBlock Grid.Row="4" Text="Short, sweet, powerful"
                           FontFamily="{StaticResource DMSans}" FontSize="12"
                           Foreground="{StaticResource CaffeTextMutedBrush}" TextWrapping="Wrap" />
              </Grid>
            </Button>

            <!-- Lungo Card -->
            <Button Grid.Column="2" Grid.Row="2"
                    Command="{x:Bind ViewModel.SelectEspressoCommand}"
                    CommandParameter="{x:Bind ViewModel.EspressoOptions[3]}"
                    Style="{StaticResource EspressoCardStyle}"
                    BorderBrush="{x:Bind local:MainPage.GetCardBorderBrush(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[3]), Mode=OneWay}">
              <Grid Padding="16,20">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="4" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="50ml" FontFamily="{StaticResource DMSans}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource CaffeAccentRedBrush}"
                           HorizontalAlignment="Left" />
                <FontIcon Grid.Row="0" Glyph="&#xE73E;" FontSize="14"
                          Foreground="{StaticResource CaffePrimaryBrush}"
                          HorizontalAlignment="Right"
                          Visibility="{x:Bind local:MainPage.IsSelected(ViewModel.SelectedEspresso, ViewModel.EspressoOptions[3]), Mode=OneWay}" />
                <TextBlock Grid.Row="2" Text="Lungo"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}" />
                <TextBlock Grid.Row="4" Text="Long pull, smooth finish"
                           FontFamily="{StaticResource DMSans}" FontSize="12"
                           Foreground="{StaticResource CaffeTextMutedBrush}" TextWrapping="Wrap" />
              </Grid>
            </Button>
          </Grid>

          <!-- Parameters Panel - Aligned Grid Layout -->
          <Border Background="{StaticResource CaffeSurfaceBrush}"
                  CornerRadius="16" Padding="16"
                  BorderBrush="{StaticResource CaffeBorderBrush}" BorderThickness="1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="70" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="40" />
              </Grid.RowDefinitions>

              <!-- ==================== TEMPERATURE ==================== -->
              <!-- Visual -->
              <Grid Grid.Column="0" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Height="60" Width="24">
                  <!-- Track -->
                  <Border Width="8" Height="40" VerticalAlignment="Top"
                          Background="{StaticResource CaffeBorderBrush}" CornerRadius="4" />
                  <!-- Fill -->
                  <Border Width="8" VerticalAlignment="Bottom" Margin="0,0,0,18"
                          Background="{StaticResource CaffeAccentRedBrush}" CornerRadius="4"
                          Height="{x:Bind ViewModel.Temperature, Mode=OneWay, Converter={StaticResource TempToHeight}}" />
                  <!-- Bulb -->
                  <Ellipse Width="16" Height="16" VerticalAlignment="Bottom"
                           Fill="{StaticResource CaffeAccentRedBrush}" />
                </Grid>
              </Grid>
              <!-- Value + Label -->
              <StackPanel Grid.Column="0" Grid.Row="1" HorizontalAlignment="Center" Spacing="2" Margin="0,8,0,8">
                <TextBlock FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}"
                           HorizontalAlignment="Center">
                  <Run Text="{x:Bind ViewModel.Temperature, Mode=OneWay}" /><Run Text="°" />
                </TextBlock>
                <TextBlock Text="TEMP" FontFamily="{StaticResource DMSans}"
                           FontSize="9" CharacterSpacing="80"
                           Foreground="{StaticResource CaffeTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
              </StackPanel>
              <!-- Slider -->
              <Slider Grid.Column="0" Grid.Row="2"
                      Minimum="88" Maximum="96"
                      Value="{x:Bind ViewModel.Temperature, Mode=TwoWay}"
                      Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" />

              <!-- ==================== TIME ==================== -->
              <!-- Visual -->
              <Grid Grid.Column="1" Grid.Row="0" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Background track -->
                <Ellipse Width="60" Height="60" StrokeThickness="5"
                         Stroke="{StaticResource CaffeBorderBrush}" />
                <!-- Foreground fill circle -->
                <Ellipse Width="{x:Bind GetTimeGaugeSize(ViewModel.ExtractionTime), Mode=OneWay}"
                         Height="{x:Bind GetTimeGaugeSize(ViewModel.ExtractionTime), Mode=OneWay}"
                         Fill="{StaticResource CaffePrimaryBrush}"
                         Opacity="0.2"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>
              <!-- Value + Label -->
              <StackPanel Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" Spacing="2" Margin="0,8,0,8">
                <TextBlock FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="22" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}"
                           HorizontalAlignment="Center">
                  <Run Text="{x:Bind ViewModel.ExtractionTime, Mode=OneWay}" /><Run Text="s" />
                </TextBlock>
                <TextBlock Text="TIME" FontFamily="{StaticResource DMSans}"
                           FontSize="9" CharacterSpacing="80"
                           Foreground="{StaticResource CaffeTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
              </StackPanel>
              <!-- Slider -->
              <Slider Grid.Column="1" Grid.Row="2"
                      Minimum="20" Maximum="35"
                      Value="{x:Bind ViewModel.ExtractionTime, Mode=TwoWay}"
                      Width="90" HorizontalAlignment="Center" VerticalAlignment="Center" />

              <!-- ==================== GRIND ==================== -->
              <!-- Visual -->
              <Grid Grid.Column="2" Grid.Row="0" Width="60" Height="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Outer ring -->
                <Ellipse Width="60" Height="60" StrokeThickness="2"
                         Stroke="{StaticResource CaffeBorderBrush}" />
                <!-- Middle ring -->
                <Ellipse Width="42" Height="42" StrokeThickness="1.5"
                         Stroke="{StaticResource CaffeBorderBrush}" Opacity="0.5" />
                <!-- Inner ring -->
                <Ellipse Width="26" Height="26" StrokeThickness="1"
                         Stroke="{StaticResource CaffeBorderBrush}" Opacity="0.25" />
                <!-- Center dot -->
                <Ellipse Width="{x:Bind GetGrindVisualSize(ViewModel.GrindLevel), Mode=OneWay}"
                         Height="{x:Bind GetGrindVisualSize(ViewModel.GrindLevel), Mode=OneWay}"
                         Fill="{StaticResource CaffePrimaryBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>
              <!-- Value + Label -->
              <StackPanel Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" Spacing="2" Margin="0,8,0,8">
                <TextBlock Text="{x:Bind ViewModel.GrindLabel, Mode=OneWay}"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="18" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="GRIND" FontFamily="{StaticResource DMSans}"
                           FontSize="9" CharacterSpacing="80"
                           Foreground="{StaticResource CaffeTextSecondaryBrush}"
                           HorizontalAlignment="Center" />
              </StackPanel>
              <!-- Grind Selector -->
              <StackPanel Grid.Column="2" Grid.Row="2" Orientation="Horizontal" Spacing="12"
                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Fine -->
                <Grid Width="28" Height="28" Tapped="OnGrindFineTapped">
                  <Ellipse Width="28" Height="28"
                           Fill="{x:Bind GetGrindButtonFill(ViewModel.GrindLevel, 0), Mode=OneWay}"
                           Opacity="0.15" />
                  <Ellipse Width="6" Height="6"
                           Fill="{x:Bind GetGrindDotColor(ViewModel.GrindLevel, 0), Mode=OneWay}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <!-- Medium -->
                <Grid Width="28" Height="28" Tapped="OnGrindMediumTapped">
                  <Ellipse Width="28" Height="28"
                           Fill="{x:Bind GetGrindButtonFill(ViewModel.GrindLevel, 1), Mode=OneWay}"
                           Opacity="0.15" />
                  <Ellipse Width="10" Height="10"
                           Fill="{x:Bind GetGrindDotColor(ViewModel.GrindLevel, 1), Mode=OneWay}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <!-- Coarse -->
                <Grid Width="28" Height="28" Tapped="OnGrindCoarseTapped">
                  <Ellipse Width="28" Height="28"
                           Fill="{x:Bind GetGrindButtonFill(ViewModel.GrindLevel, 2), Mode=OneWay}"
                           Opacity="0.15" />
                  <Ellipse Width="14" Height="14"
                           Fill="{x:Bind GetGrindDotColor(ViewModel.GrindLevel, 2), Mode=OneWay}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Selection Overview (only visible when selected) -->
          <Border Background="{StaticResource CaffePrimaryBrush}"
                  CornerRadius="14" Padding="20,16"
                  Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <!-- Left: Selection info -->
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="YOUR SELECTION" FontFamily="{StaticResource DMSans}"
                           FontSize="10" CharacterSpacing="100" Foreground="#99FFFFFF" />
                <TextBlock Text="{x:Bind ViewModel.SelectedEspresso.Name, Mode=OneWay, FallbackValue=''}"
                           FontFamily="{StaticResource CormorantGaramond}"
                           FontSize="20" FontWeight="Medium" Foreground="White" />
              </StackPanel>

              <!-- Right: Stats -->
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <StackPanel>
                  <TextBlock FontFamily="{StaticResource CormorantGaramond}"
                             FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center">
                    <Run Text="{x:Bind ViewModel.Temperature, Mode=OneWay}" />
                    <Run Text="°" />
                  </TextBlock>
                  <TextBlock Text="Temp" FontFamily="{StaticResource DMSans}" FontSize="9"
                             Foreground="#99FFFFFF" HorizontalAlignment="Center" />
                </StackPanel>
                <Border Width="1" Height="30" Background="#33FFFFFF" />
                <StackPanel>
                  <TextBlock Text="{x:Bind ViewModel.GrindFirstLetter, Mode=OneWay}"
                             FontFamily="{StaticResource CormorantGaramond}"
                             FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center" />
                  <TextBlock Text="Grind" FontFamily="{StaticResource DMSans}" FontSize="9"
                             Foreground="#99FFFFFF" HorizontalAlignment="Center" />
                </StackPanel>
                <Border Width="1" Height="30" Background="#33FFFFFF" />
                <StackPanel>
                  <TextBlock FontFamily="{StaticResource CormorantGaramond}"
                             FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center">
                    <Run Text="{x:Bind ViewModel.ExtractionTime, Mode=OneWay}" />
                    <Run Text="s" />
                  </TextBlock>
                  <TextBlock Text="Time" FontFamily="{StaticResource DMSans}" FontSize="9"
                             Foreground="#99FFFFFF" HorizontalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>

          <!-- Brew Button -->
          <Button Command="{x:Bind ViewModel.BrewCommand}"
                  HorizontalAlignment="Stretch" CornerRadius="14" Padding="0,18"
                  Background="{StaticResource CaffePrimaryBrush}"
                  Opacity="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToOpacity}}">
            <TextBlock Text="{x:Bind ViewModel.BrewButtonText, Mode=OneWay}"
                       FontFamily="{StaticResource DMSans}" FontSize="15" FontWeight="Medium"
                       Foreground="White" />
          </Button>
        </StackPanel>

        <!-- FOOTER -->
        <StackPanel Grid.Row="2" Padding="0,20" HorizontalAlignment="Center">
          <Grid Width="36" Height="3" CornerRadius="1.5">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{StaticResource CaffeAccentRedBrush}" CornerRadius="1.5,0,0,1.5" />
            <Border Grid.Column="1" Background="{StaticResource CaffePrimaryBrush}" CornerRadius="0,1.5,1.5,0" />
          </Grid>
        </StackPanel>
      </Grid>
    </ScrollViewer>

    <!-- Brewing Screen Overlay -->
    <Grid Visibility="{x:Bind ViewModel.IsBrewing, Mode=OneWay}"
          Background="{StaticResource CaffeBackgroundBrush}">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
        <!-- Coffee Cup -->
        <Grid Width="100" Height="100" HorizontalAlignment="Center">
          <!-- Cup body -->
          <Border Width="60" Height="80" VerticalAlignment="Bottom"
                  Background="{StaticResource CaffeSurfaceBrush}"
                  BorderBrush="{StaticResource CaffeBorderBrush}" BorderThickness="2"
                  CornerRadius="4,4,12,12" HorizontalAlignment="Center">
            <!-- Coffee fill -->
            <Border VerticalAlignment="Bottom" Margin="4"
                    Background="#3E2723" CornerRadius="0,0,8,8"
                    Height="{x:Bind ViewModel.BrewProgress, Mode=OneWay, Converter={StaticResource BrewToHeight}}" />
          </Border>
          <!-- Cup handle -->
          <Border Width="16" Height="30" HorizontalAlignment="Right" Margin="0,0,-4,25"
                  VerticalAlignment="Bottom"
                  BorderBrush="{StaticResource CaffeBorderBrush}" BorderThickness="2"
                  CornerRadius="0,8,8,0" Background="Transparent" />
        </Grid>

        <!-- Brewing Text -->
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <TextBlock FontFamily="{StaticResource CormorantGaramond}"
                     FontSize="24" FontWeight="Medium" Foreground="{StaticResource CaffeTextPrimaryBrush}"
                     HorizontalAlignment="Center">
            <Run Text="Brewing " />
            <Run Text="{x:Bind ViewModel.SelectedEspresso.Name, Mode=OneWay, FallbackValue=''}" />
          </TextBlock>
          <TextBlock FontFamily="{StaticResource DMSans}" FontSize="13"
                     Foreground="{StaticResource CaffeTextSecondaryBrush}"
                     HorizontalAlignment="Center">
            <Run Text="{x:Bind ViewModel.Temperature, Mode=OneWay}" />
            <Run Text="°C · " />
            <Run Text="{x:Bind ViewModel.GrindLabel, Mode=OneWay}" />
            <Run Text=" · " />
            <Run Text="{x:Bind ViewModel.ExtractionTime, Mode=OneWay}" />
            <Run Text="s" />
          </TextBlock>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Page>

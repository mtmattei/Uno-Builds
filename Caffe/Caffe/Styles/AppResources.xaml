<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Caffe.Converters">

  <!-- Converters -->
  <converters:ReverseBoolToVisibilityConverter x:Key="ReverseBoolToVisibilityConverter" />

  <!-- Custom Fonts -->
  <FontFamily x:Key="CormorantLight">ms-appx:///Assets/Fonts/CormorantGaramond-Light.ttf#Cormorant Garamond</FontFamily>
  <FontFamily x:Key="CormorantRegular">ms-appx:///Assets/Fonts/CormorantGaramond-Regular.ttf#Cormorant Garamond</FontFamily>
  <FontFamily x:Key="DMSansRegular">ms-appx:///Assets/Fonts/DMSans-Regular.ttf#DM Sans</FontFamily>
  <FontFamily x:Key="DMSansMedium">ms-appx:///Assets/Fonts/DMSans-Medium.ttf#DM Sans</FontFamily>

  <!-- Caffè Color Brushes -->
  <SolidColorBrush x:Key="CaffeBackgroundBrush" Color="#FAFAFA" />
  <SolidColorBrush x:Key="CaffeSurfaceBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="CaffePrimaryBrush" Color="#1B4332" />
  <SolidColorBrush x:Key="CaffePrimaryHoverBrush" Color="#14352A" />
  <SolidColorBrush x:Key="CaffeAccentRedBrush" Color="#C1121F" />
  <SolidColorBrush x:Key="CaffeAccentGreenBrush" Color="#2D6A4F" />
  <SolidColorBrush x:Key="CaffeTextPrimaryBrush" Color="#1A1A1A" />
  <SolidColorBrush x:Key="CaffeTextSecondaryBrush" Color="#888888" />
  <SolidColorBrush x:Key="CaffeTextMutedBrush" Color="#999999" />
  <SolidColorBrush x:Key="CaffeBorderBrush" Color="#E0E0E0" />
  <SolidColorBrush x:Key="CaffePrimaryDisabledBrush" Color="#591B4332" />
  <SolidColorBrush x:Key="CaffeOnPrimaryBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="CaffeParticleBrush" Color="#1A1A1A" />

  <!-- Gradient Colors -->
  <Color x:Key="CoffeeDarkColor">#3D2314</Color>
  <Color x:Key="CoffeeLightColor">#5D3A1A</Color>
  <Color x:Key="CaffeTemperatureHighColor">#C1121F</Color>
  <Color x:Key="CaffeTemperatureLowColor">#E07070</Color>

  <!-- Typography Styles -->
  <!-- Logo: 3rem = 48px, Light -->
  <Style x:Key="LogoTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CormorantLight}" />
    <Setter Property="FontSize" Value="48" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextPrimaryBrush}" />
  </Style>

  <!-- Tagline: uppercase, letter-spaced -->
  <Style x:Key="TaglineTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansMedium}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="150" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextSecondaryBrush}" />
  </Style>

  <!-- Card Title: 1.4rem = 22px -->
  <Style x:Key="CardTitleTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CormorantRegular}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextPrimaryBrush}" />
  </Style>

  <!-- Card Description -->
  <Style x:Key="CardDescriptionTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansRegular}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextMutedBrush}" />
  </Style>

  <!-- Parameter Value: 1.6rem = 26px -->
  <Style x:Key="ParameterValueTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CormorantRegular}" />
    <Setter Property="FontSize" Value="26" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextPrimaryBrush}" />
  </Style>

  <!-- Parameter Label -->
  <Style x:Key="ParameterLabelTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansMedium}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="CharacterSpacing" Value="100" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextSecondaryBrush}" />
  </Style>

  <!-- Volume Badge -->
  <Style x:Key="VolumeBadgeTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansMedium}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{StaticResource CaffeOnPrimaryBrush}" />
  </Style>

  <!-- Body Text -->
  <Style x:Key="BodyTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansRegular}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextPrimaryBrush}" />
  </Style>

  <!-- Button Text -->
  <Style x:Key="ButtonTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansMedium}" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="Foreground" Value="{StaticResource CaffeOnPrimaryBrush}" />
  </Style>

  <!-- Grind Hint (italic) -->
  <Style x:Key="GrindHintTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansRegular}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="Foreground" Value="{StaticResource CaffeTextMutedBrush}" />
  </Style>

  <!-- Overview Label -->
  <Style x:Key="OverviewLabelTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource DMSansMedium}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="CharacterSpacing" Value="100" />
    <Setter Property="Foreground" Value="{StaticResource CaffeOnPrimaryBrush}" />
    <Setter Property="Opacity" Value="0.7" />
  </Style>

  <!-- Overview Value -->
  <Style x:Key="OverviewValueTextStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CormorantRegular}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="Foreground" Value="{StaticResource CaffeOnPrimaryBrush}" />
  </Style>

  <!-- Brewing Title (based on CardTitleTextStyle, larger) -->
  <Style x:Key="BrewingTitleTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CardTitleTextStyle}">
    <Setter Property="FontSize" Value="28" />
  </Style>

  <!-- Arc Label (based on ParameterLabelTextStyle, smaller) -->
  <Style x:Key="ArcLabelTextStyle" TargetType="TextBlock" BasedOn="{StaticResource ParameterLabelTextStyle}">
    <Setter Property="FontSize" Value="8" />
  </Style>

</ResourceDictionary>

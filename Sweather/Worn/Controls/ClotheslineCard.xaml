<UserControl
    x:Class="Worn.Controls.ClotheslineCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI">

    <Grid x:Name="CardRoot"
          Width="72"
          RenderTransformOrigin="0.5,0"
          PointerEntered="OnCardPointerEntered"
          PointerExited="OnCardPointerExited">
        <Grid.RenderTransform>
            <TransformGroup>
                <RotateTransform x:Name="SwayRotation" Angle="0" />
                <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1" />
                <TranslateTransform x:Name="HoverLift" />
            </TransformGroup>
        </Grid.RenderTransform>

        <Grid.RowDefinitions>
            <RowDefinition Height="28" />   <!-- Annotation zone -->
            <RowDefinition Height="Auto" /> <!-- Clothespin -->
            <RowDefinition Height="20" />   <!-- String -->
            <RowDefinition Height="Auto" /> <!-- Tier bubble -->
            <RowDefinition Height="Auto" /> <!-- Time label -->
            <RowDefinition Height="Auto" /> <!-- Tier label (current only) -->
        </Grid.RowDefinitions>

        <!-- Row 0: Transition annotation -->
        <TextBlock x:Name="TransitionText"
                   Grid.Row="0"
                   Style="{StaticResource WornTaglineStyle}"
                   Foreground="{ThemeResource WornTerracottaBrush}"
                   FontSize="12"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed" />

        <!-- Row 1: Clothespin (small filled circle) -->
        <Ellipse x:Name="Clothespin"
                 Grid.Row="1"
                 Width="8" Height="8"
                 Fill="{ThemeResource WornSlateBrush}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center" />

        <!-- Row 2: Vertical string -->
        <Border Grid.Row="2"
                Width="1.5"
                Background="{ThemeResource WornSlateBrush}"
                Opacity="0.4"
                HorizontalAlignment="Center"
                VerticalAlignment="Stretch" />

        <!-- Row 3: Tier bubble (emoji inside tinted circle) -->
        <Grid Grid.Row="3"
              Width="44" Height="44"
              HorizontalAlignment="Center">
            <!-- Swatch-colored background circle -->
            <Ellipse x:Name="BubbleBackground"
                     Width="44" Height="44"
                     Opacity="0.2" />
            <!-- Accent ring (current hour only) -->
            <Ellipse x:Name="AccentRing"
                     Width="44" Height="44"
                     StrokeThickness="2"
                     Stroke="{ThemeResource WornTerracottaBrush}"
                     Visibility="Collapsed" />
            <!-- Emoji -->
            <TextBlock x:Name="EmojiText"
                       FontSize="22"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center" />
            <!-- Pulsing dot (current hour only) -->
            <Ellipse x:Name="PulsingDot"
                     Width="8" Height="8"
                     Fill="{ThemeResource WornTerracottaBrush}"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top"
                     Margin="0,-2,-2,0"
                     Visibility="Collapsed"
                     Opacity="1" />
        </Grid>

        <!-- Row 4: Time label -->
        <TextBlock x:Name="TimeText"
                   Grid.Row="4"
                   Style="{StaticResource WornLabelStyle}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Margin="0,6,0,0" />

        <!-- Row 5: Tier label (current hour only) -->
        <TextBlock x:Name="TierLabel"
                   Grid.Row="5"
                   Style="{StaticResource WornTaglineStyle}"
                   Foreground="{ThemeResource WornTerracottaBrush}"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Visibility="Collapsed"
                   Margin="0,2,0,0" />
    </Grid>
</UserControl>

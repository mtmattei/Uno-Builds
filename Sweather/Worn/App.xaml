<Application x:Class="Worn.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utum="using:Uno.Toolkit.UI.Material">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml" />
        <ResourceDictionary Source="ms-appx:///Styles/Themes/TextBlock.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Theme-aware custom Worn brushes -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="WornCreamBrush" Color="#F5F0E8" />
          <SolidColorBrush x:Key="WornWarmBlackBrush" Color="#1A1714" />
          <SolidColorBrush x:Key="WornTerracottaBrush" Color="#C4654A" />
          <SolidColorBrush x:Key="WornSageBrush" Color="#8B9E7E" />
          <SolidColorBrush x:Key="WornSlateBrush" Color="#6B7B8D" />
          <SolidColorBrush x:Key="WornBlushBrush" Color="#E8CFC0" />
          <SolidColorBrush x:Key="WornDenimBrush" Color="#4A5E78" />
          <SolidColorBrush x:Key="WornGoldBrush" Color="#C9A96E" />
          <SolidColorBrush x:Key="WornLinenBrush" Color="#EDE6D6" />
          <SolidColorBrush x:Key="WornCharcoalBrush" Color="#3A3632" />
          <LinearGradientBrush x:Key="WornAlertGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#C4654A" Offset="0.0" />
            <GradientStop Color="#D4886E" Offset="0.5" />
            <GradientStop Color="#E8CFC0" Offset="1.0" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="WornFadeLeftBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#F5F0E8" Offset="0.0" />
            <GradientStop Color="#00F5F0E8" Offset="1.0" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="WornFadeRightBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#00F5F0E8" Offset="0.0" />
            <GradientStop Color="#F5F0E8" Offset="1.0" />
          </LinearGradientBrush>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="WornCreamBrush" Color="#141210" />
          <SolidColorBrush x:Key="WornWarmBlackBrush" Color="#EDE6D6" />
          <SolidColorBrush x:Key="WornTerracottaBrush" Color="#E8A08E" />
          <SolidColorBrush x:Key="WornSageBrush" Color="#B0C9A2" />
          <SolidColorBrush x:Key="WornSlateBrush" Color="#9BA5AF" />
          <SolidColorBrush x:Key="WornBlushBrush" Color="#3D2E28" />
          <SolidColorBrush x:Key="WornDenimBrush" Color="#7A96B8" />
          <SolidColorBrush x:Key="WornGoldBrush" Color="#DCC48E" />
          <SolidColorBrush x:Key="WornLinenBrush" Color="#2A2622" />
          <SolidColorBrush x:Key="WornCharcoalBrush" Color="#EDE6D6" />
          <LinearGradientBrush x:Key="WornAlertGradientBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#6B3425" Offset="0.0" />
            <GradientStop Color="#8B5040" Offset="0.5" />
            <GradientStop Color="#3D2E28" Offset="1.0" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="WornFadeLeftBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#141210" Offset="0.0" />
            <GradientStop Color="#00141210" Offset="1.0" />
          </LinearGradientBrush>
          <LinearGradientBrush x:Key="WornFadeRightBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#00141210" Offset="0.0" />
            <GradientStop Color="#141210" Offset="1.0" />
          </LinearGradientBrush>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>

    </ResourceDictionary>
  </Application.Resources>

</Application>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- Font Families -->
  <FontFamily x:Key="PlayfairDisplayFont">ms-appx:///Assets/Fonts/PlayfairDisplay.ttf#Playfair Display</FontFamily>
  <FontFamily x:Key="PlayfairDisplayItalicFont">ms-appx:///Assets/Fonts/PlayfairDisplay-Italic.ttf#Playfair Display</FontFamily>
  <FontFamily x:Key="InstrumentSerifFont">ms-appx:///Assets/Fonts/InstrumentSerif.ttf#Instrument Serif</FontFamily>
  <FontFamily x:Key="LiterataFont">ms-appx:///Assets/Fonts/Literata.ttf#Literata</FontFamily>
  <FontFamily x:Key="InterFont">ms-appx:///Assets/Fonts/Inter.ttf#Inter</FontFamily>
  <FontFamily x:Key="CaveatFont">ms-appx:///Assets/Fonts/Caveat.ttf#Caveat</FontFamily>
  <FontFamily x:Key="DMSansFont">ms-appx:///Assets/Fonts/DMSans.ttf#DM Sans</FontFamily>

  <!-- Display / Headlines: Literata 400 -->
  <Style x:Key="WornDisplayStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource LiterataFont}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="64" />
    <Setter Property="CharacterSpacing" Value="-15" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
  </Style>

  <!-- Section Titles: Literata 400, 28px -->
  <Style x:Key="WornSectionTitleStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource LiterataFont}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
  </Style>

  <!-- Card Titles: Literata 400, 16px -->
  <Style x:Key="WornCardTitleStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource LiterataFont}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
  </Style>

  <!-- Tagline / Handwritten: Caveat 400-600, 16px -->
  <Style x:Key="WornTaglineStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CaveatFont}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="CharacterSpacing" Value="15" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
  </Style>

  <!-- Body / UI: Inter 400, 15px -->
  <Style x:Key="WornBodyStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
    <Setter Property="FontWeight" Value="Normal" />
    <Setter Property="FontSize" Value="15" />
    <Setter Property="TextWrapping" Value="WrapWholeWords" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
  </Style>

  <!-- Labels / Metadata: Inter 500, 11px -->
  <Style x:Key="WornLabelStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource InterFont}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="CharacterSpacing" Value="75" />
    <Setter Property="Foreground" Value="{ThemeResource OnSurfaceVariantBrush}" />
  </Style>

  <!-- Logo wordmark: Playfair Display Italic 28px -->
  <Style x:Key="WornLogoStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PlayfairDisplayItalicFont}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="CharacterSpacing" Value="-40" />
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
  </Style>

  <!-- Small Logo: Playfair Display Italic 18px -->
  <Style x:Key="WornLogoSmallStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource PlayfairDisplayItalicFont}" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontStyle" Value="Italic" />
    <Setter Property="CharacterSpacing" Value="-40" />
    <Setter Property="Foreground" Value="{ThemeResource OnBackgroundBrush}" />
  </Style>

  <!-- Necessity label: Caveat, terracotta -->
  <Style x:Key="WornNecessityStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource CaveatFont}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{ThemeResource PrimaryBrush}" />
  </Style>

  <!-- Emoji display -->
  <Style x:Key="WornEmojiStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="28" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <!-- Large Emoji (hourly/daily) -->
  <Style x:Key="WornEmojiLargeStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="36" />
    <Setter Property="TextAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

</ResourceDictionary>

<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Font Family (fallback to system sans-serif) -->
    <FontFamily x:Key="ZaraFontFamily">Segoe UI, Helvetica Neue, Arial</FontFamily>

    <!-- Text Styles -->
    <Style x:Key="ZaraHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ZaraFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource ZaraTextPrimaryBrush}" />
        <Setter Property="CharacterSpacing" Value="50" />
    </Style>

    <Style x:Key="ZaraProductNameStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ZaraFontFamily}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ZaraTextSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="ZaraPriceStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ZaraFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ZaraTextPrimaryBrush}" />
    </Style>

    <Style x:Key="ZaraTabStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ZaraFontFamily}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Foreground" Value="{StaticResource ZaraTextPrimaryBrush}" />
    </Style>

    <Style x:Key="ZaraFitOverlayStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource ZaraFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

</ResourceDictionary>

<UserControl x:Class="Zara.Views.Controls.FitsGridSection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="using:Zara.Models"
             xmlns:controls="using:Zara.Views.Controls">

    <StackPanel Spacing="16">
        <!-- Section Header -->
        <TextBlock Text="THE FITS - ZARA MAN JEANS"
                   Style="{StaticResource ZaraHeaderStyle}" />

        <!-- 2x2 Grid -->
        <Grid RowSpacing="8"
              ColumnSpacing="8"
              Height="480">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Fit Tiles - will be populated from code-behind or binding -->
            <controls:FitTileControl x:Name="FitTile1"
                                     Grid.Row="0"
                                     Grid.Column="0" />
            <controls:FitTileControl x:Name="FitTile2"
                                     Grid.Row="0"
                                     Grid.Column="1" />
            <controls:FitTileControl x:Name="FitTile3"
                                     Grid.Row="1"
                                     Grid.Column="0" />
            <controls:FitTileControl x:Name="FitTile4"
                                     Grid.Row="1"
                                     Grid.Column="1" />
        </Grid>
    </StackPanel>

</UserControl>

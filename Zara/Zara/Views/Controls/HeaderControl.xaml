<UserControl x:Class="Zara.Views.Controls.HeaderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="60">

    <Grid Background="{StaticResource ZaraPrimaryBackgroundBrush}"
          Padding="16,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Hamburger Menu -->
        <Button Grid.Column="0"
                Style="{StaticResource IconButtonStyle}"
                Click="OnMenuClick">
            <FontIcon Glyph="&#xE700;"
                      FontSize="24"
                      Foreground="{StaticResource ZaraIconBrush}" />
        </Button>

        <!-- Right Icons -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="16">
            <Button Style="{StaticResource IconButtonStyle}"
                    Click="OnFiltersClick"
                    ToolTipService.ToolTip="FILTERS">
                <FontIcon Glyph="&#xE71C;"
                          FontSize="20"
                          Foreground="{StaticResource ZaraIconBrush}" />
            </Button>
            <Button Style="{StaticResource IconButtonStyle}"
                    Click="OnSearchClick"
                    ToolTipService.ToolTip="Search">
                <FontIcon Glyph="&#xE721;"
                          FontSize="20"
                          Foreground="{StaticResource ZaraIconBrush}" />
            </Button>
            <Button Style="{StaticResource IconButtonStyle}"
                    Click="OnCartClick"
                    ToolTipService.ToolTip="Shopping Cart">
                <FontIcon Glyph="&#xE7BF;"
                          FontSize="20"
                          Foreground="{StaticResource ZaraIconBrush}" />
            </Button>
        </StackPanel>
    </Grid>

</UserControl>

<Page x:Class="FriendSonar.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:controls="using:FriendSonar.Controls"
      xmlns:utu="using:Uno.Toolkit.UI"
      mc:Ignorable="d"
      Background="{ThemeResource TerminalBlackBrush}">

  <Grid utu:SafeArea.Insets="Top,Bottom">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header Row (spans full width) -->
    <Grid Grid.Row="0"
          Padding="16,10"
          BorderThickness="0,0,0,1"
          BorderBrush="{ThemeResource PhosphorGreen20Brush}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- Left: Title -->
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
        <Ellipse Width="6" Height="6"
                 Fill="{ThemeResource PhosphorGreen100Brush}"
                 VerticalAlignment="Center" />
        <TextBlock Text="SONAR"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{ThemeResource PhosphorGreen100Brush}"
                   VerticalAlignment="Center" />
      </StackPanel>

      <!-- Center: Share Code -->
      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Margin="8,0">
        <TextBlock Text="YOUR CODE"
                   FontSize="8"
                   Foreground="{ThemeResource PhosphorGreen60Brush}"
                   CharacterSpacing="60"
                   HorizontalAlignment="Center" />
        <TextBlock x:Name="ShareCodeText"
                   Text="------"
                   FontSize="14"
                   FontWeight="Bold"
                   FontFamily="Consolas"
                   Foreground="{ThemeResource PhosphorGreen100Brush}"
                   CharacterSpacing="80"
                   HorizontalAlignment="Center" />
      </StackPanel>

      <!-- Right: Online count -->
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
        <TextBlock x:Name="ContactCount"
                   Text="0"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{ThemeResource PhosphorGreen100Brush}" />
        <TextBlock Text="online"
                   FontSize="10"
                   Opacity="0.5"
                   Foreground="{ThemeResource PhosphorGreen100Brush}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Grid>

    <!-- Responsive Two-Pane Layout: vertical on mobile, horizontal on desktop -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- RADAR PANE: Col 0 always, spans full width on narrow -->
      <Grid Grid.Column="0" Grid.Row="0"
            Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
            Grid.RowSpan="{utu:Responsive Narrow=1, Wide=2}"
            Width="{utu:Responsive Narrow=NaN, Wide=420}"
            BorderThickness="{utu:Responsive Narrow='0,0,0,1', Wide='0,0,1,0'}"
            BorderBrush="{ThemeResource PhosphorGreen12Brush}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Range Toggle Buttons -->
        <Border Grid.Row="0"
                Padding="20,12">
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="8">
            <ToggleButton x:Name="Range1Button"
                          Content="1 MI"
                          Click="RangeButton_Click"
                          Tag="1"
                          Style="{StaticResource SonarRangeToggleButtonStyle}" />
            <ToggleButton x:Name="Range3Button"
                          Content="3 MI"
                          Click="RangeButton_Click"
                          Tag="3"
                          IsChecked="True"
                          Style="{StaticResource SonarRangeToggleButtonStyle}" />
            <ToggleButton x:Name="Range5Button"
                          Content="5 MI"
                          Click="RangeButton_Click"
                          Tag="5"
                          Style="{StaticResource SonarRangeToggleButtonStyle}" />
            <ToggleButton x:Name="Range10Button"
                          Content="10 MI"
                          Click="RangeButton_Click"
                          Tag="10"
                          Style="{StaticResource SonarRangeToggleButtonStyle}" />
          </StackPanel>
        </Border>

        <!-- Radar Display -->
        <controls:RadarDisplay x:Name="RadarDisplay"
                               Grid.Row="1"
                               Margin="0,12,0,0" />

        <!-- Status Bar -->
        <Grid Grid.Row="2"
              Padding="20,12"
              BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource PhosphorGreen12Brush}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="FREQ: 38.2 kHz"
                     Style="{StaticResource SonarStatusBarTextBlockStyle}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Left" />

          <TextBlock x:Name="RangeText"
                     Grid.Column="1"
                     Text="RANGE: 3 MI"
                     Style="{StaticResource SonarStatusBarTextBlockStyle}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center" />

          <TextBlock x:Name="PingAngle"
                     Grid.Column="2"
                     Text="PING: 206°"
                     Style="{StaticResource SonarStatusBarTextBlockStyle}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Right" />
        </Grid>

        <!-- Spacer to push controls to bottom -->
        <Border Grid.Row="3" />

        <!-- Bottom Controls -->
        <Grid Grid.Row="4"
              Padding="16,16"
              BorderThickness="0,1,0,0"
              BorderBrush="{ThemeResource PhosphorGreen12Brush}"
              Background="{ThemeResource TerminalBlackBrush}">
          <Grid HorizontalAlignment="Center" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="PingAllButton"
                    Grid.Column="0"
                    Click="PingAllButton_Click"
                    Style="{StaticResource SonarIconButtonStyle}"
                    MinWidth="100"
                    Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" Fill="{ThemeResource PhosphorGreen100Brush}" VerticalAlignment="Center" />
                <TextBlock Text="PING" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Grid.Column="1"
                    Style="{StaticResource SonarIconButtonStyle}"
                    MinWidth="100"
                    Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE707;" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="NAVIGATE" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button x:Name="AddFriendButton"
                    Grid.Column="2"
                    Click="AddFriendButton_Click"
                    Style="{StaticResource SonarIconButtonStyle}"
                    MinWidth="100"
                    Padding="12,8">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <FontIcon Glyph="&#xE8FA;" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="ADD" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </Grid>
        </Grid>
      </Grid>

      <!-- CONTACTS PANE: repositioned based on breakpoint -->
      <RefreshContainer x:Name="RefreshContainer"
                        Grid.Column="{utu:Responsive Narrow=0, Wide=1}"
                        Grid.Row="{utu:Responsive Narrow=1, Wide=0}"
                        Grid.ColumnSpan="{utu:Responsive Narrow=2, Wide=1}"
                        Grid.RowSpan="{utu:Responsive Narrow=1, Wide=2}"
                        RefreshRequested="RefreshContainer_RefreshRequested">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <controls:ContactList x:Name="ContactListControl" />
        </ScrollViewer>
      </RefreshContainer>
    </Grid>

    <!-- CRT Overlay (Full Screen) -->
    <controls:CRTOverlay Grid.RowSpan="2" />

    <!-- Friend Detail Panel (slide-up overlay) -->
    <controls:FriendDetailPanel x:Name="FriendDetailPanel"
                                 Grid.RowSpan="2" />
  </Grid>
</Page>

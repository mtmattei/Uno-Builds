<UserControl x:Class="FriendSonar.Controls.FriendDetailPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:utu="using:Uno.Toolkit.UI"
             mc:Ignorable="d"
             d:DesignHeight="280" d:DesignWidth="400">

  <Grid x:Name="RootGrid">
    <!-- Dimmed background overlay -->
    <Border x:Name="DimOverlay"
            Background="#80000000"
            Opacity="0"
            Tapped="DimOverlay_Tapped" />

    <!-- Slide-up panel -->
    <Border x:Name="PanelContainer"
            VerticalAlignment="Bottom"
            Background="{ThemeResource DeepGreenBlackBrush}"
            BorderBrush="{ThemeResource PhosphorGreen27Brush}"
            BorderThickness="0,2,0,0"
            CornerRadius="16,16,0,0"
            ManipulationMode="TranslateY"
            ManipulationDelta="Panel_ManipulationDelta"
            ManipulationCompleted="Panel_ManipulationCompleted"
            RenderTransformOrigin="0.5,1">
      <Border.RenderTransform>
        <TranslateTransform x:Name="PanelTranslate" Y="300" />
      </Border.RenderTransform>
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <Grid Padding="24,16,24,32" MinHeight="280">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Handle bar for dragging -->
        <Border Grid.Row="0"
                Width="40" Height="4"
                Background="{ThemeResource PhosphorGreen33Brush}"
                CornerRadius="2"
                HorizontalAlignment="Center"
                Margin="0,0,0,16" />

        <!-- Avatar and Name -->
        <utu:AutoLayout Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,20">
          <!-- Large Avatar Circle -->
          <Border Width="64" Height="64"
                  CornerRadius="32"
                  Background="{ThemeResource PhosphorGreen12Brush}"
                  BorderBrush="{ThemeResource PhosphorGreen27Brush}"
                  BorderThickness="2">
            <TextBlock x:Name="AvatarInitials"
                       Text="AM"
                       FontFamily="Courier New, Consolas, monospace"
                       FontSize="24"
                       Foreground="{ThemeResource PhosphorGreen100Brush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>

          <!-- Name and Status -->
          <StackPanel VerticalAlignment="Center" Spacing="4">
            <TextBlock x:Name="FriendName"
                       Text="Alice Morgan"
                       Style="{StaticResource SonarTitleTextBlockStyle}"
                       FontSize="20" />
            <utu:AutoLayout Orientation="Horizontal" Spacing="8">
              <Ellipse x:Name="StatusDot"
                       Width="8" Height="8"
                       Fill="{ThemeResource StatusActiveBrush}" />
              <TextBlock x:Name="StatusText"
                         Text="ACTIVE"
                         Style="{StaticResource SonarSubtitleTextBlockStyle}" />
            </utu:AutoLayout>
          </StackPanel>
        </utu:AutoLayout>

        <!-- Distance and Bearing Info -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" HorizontalAlignment="Center">
            <TextBlock Text="DISTANCE"
                       Style="{StaticResource SonarSubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Opacity="0.5" />
            <TextBlock x:Name="DistanceText"
                       Text="1.2 MI"
                       Style="{StaticResource SonarContactNameTextBlockStyle}"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <StackPanel Grid.Column="1" HorizontalAlignment="Center">
            <TextBlock Text="BEARING"
                       Style="{StaticResource SonarSubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Opacity="0.5" />
            <TextBlock x:Name="BearingText"
                       Text="045°"
                       Style="{StaticResource SonarContactNameTextBlockStyle}"
                       HorizontalAlignment="Center" />
          </StackPanel>

          <StackPanel Grid.Column="2" HorizontalAlignment="Center">
            <TextBlock Text="LAST SEEN"
                       Style="{StaticResource SonarSubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Opacity="0.5" />
            <TextBlock x:Name="LastSeenText"
                       Text="2s ago"
                       Style="{StaticResource SonarContactNameTextBlockStyle}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border Grid.Row="3"
                Height="1"
                Background="{ThemeResource PhosphorGreen12Brush}"
                Margin="0,0,0,20" />

        <!-- Action Buttons -->
        <utu:AutoLayout Grid.Row="4"
                        Orientation="Horizontal"
                        Spacing="12"
                        HorizontalAlignment="Center">
          <Button x:Name="NavigateButton"
                  Style="{StaticResource SonarButtonStyle}"
                  MinWidth="100"
                  Click="NavigateButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE707;" FontSize="14" />
              <TextBlock Text="NAVIGATE" />
            </StackPanel>
          </Button>

          <Button x:Name="MessageButton"
                  Style="{StaticResource SonarButtonStyle}"
                  MinWidth="100"
                  Click="MessageButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE715;" FontSize="14" />
              <TextBlock Text="MESSAGE" />
            </StackPanel>
          </Button>

          <Button x:Name="CallButton"
                  Style="{StaticResource SonarButtonStyle}"
                  MinWidth="90"
                  Click="CallButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <FontIcon Glyph="&#xE717;" FontSize="14" />
              <TextBlock Text="CALL" />
            </StackPanel>
          </Button>
        </utu:AutoLayout>
      </Grid>
    </Border>
  </Grid>
</UserControl>

<UserControl x:Class="FriendSonar.Controls.RadarDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="360" d:DesignWidth="340">

  <Grid Width="340" Height="360" HorizontalAlignment="Center" VerticalAlignment="Top">

    <!-- Bearing Labels (outside radar circle) - N/S/E/W -->
    <TextBlock Text="N"
               Style="{StaticResource SonarBearingLabelTextBlockStyle}"
               HorizontalAlignment="Center" VerticalAlignment="Top"
               Margin="0,12,0,0" />
    <TextBlock Text="E"
               Style="{StaticResource SonarBearingLabelTextBlockStyle}"
               HorizontalAlignment="Right" VerticalAlignment="Center"
               Margin="0,0,10,0" />
    <TextBlock Text="S"
               Style="{StaticResource SonarBearingLabelTextBlockStyle}"
               HorizontalAlignment="Center" VerticalAlignment="Bottom"
               Margin="0,0,0,12" />
    <TextBlock Text="W"
               Style="{StaticResource SonarBearingLabelTextBlockStyle}"
               HorizontalAlignment="Left" VerticalAlignment="Center"
               Margin="10,0,0,0" />

    <Border Width="300" Height="300" 
            CornerRadius="150"
            BorderThickness="3"
            BorderBrush="{ThemeResource PhosphorGreen27Brush}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Translation="0,0,8">
      <Border.Background>
        <RadialGradientBrush>
          <GradientStop Color="{ThemeResource DeepGreenBlack}" Offset="0" />
          <GradientStop Color="{ThemeResource VoidBlack}" Offset="1" />
        </RadialGradientBrush>
      </Border.Background>
      <Border.Shadow>
        <ThemeShadow />
      </Border.Shadow>

      <Canvas x:Name="RadarCanvas" Width="300" Height="300">
        
        <!-- Concentric Rings -->
        <Ellipse x:Name="Ring1" Width="75" Height="75"
                 Canvas.Left="112.5" Canvas.Top="112.5"
                 Stroke="{ThemeResource PhosphorGreen12Brush}"
                 StrokeThickness="1"
                 RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Ring1Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse x:Name="Ring2" Width="150" Height="150"
                 Canvas.Left="75" Canvas.Top="75"
                 Stroke="{ThemeResource PhosphorGreen12Brush}"
                 StrokeThickness="1"
                 Opacity="0.8"
                 RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Ring2Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse x:Name="Ring3" Width="225" Height="225"
                 Canvas.Left="37.5" Canvas.Top="37.5"
                 Stroke="{ThemeResource PhosphorGreen12Brush}"
                 StrokeThickness="1"
                 Opacity="0.6"
                 RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Ring3Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>

        <Ellipse x:Name="Ring4" Width="300" Height="300"
                 Canvas.Left="0" Canvas.Top="0"
                 Stroke="{ThemeResource PhosphorGreen12Brush}"
                 StrokeThickness="1"
                 Opacity="0.4"
                 RenderTransformOrigin="0.5,0.5">
          <Ellipse.RenderTransform>
            <ScaleTransform x:Name="Ring4Scale" ScaleX="1" ScaleY="1" />
          </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Crosshairs -->
        <Line x:Name="CrosshairH" X1="15" Y1="150" X2="285" Y2="150"
              StrokeThickness="1">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
              <GradientStop Color="Transparent" Offset="0" />
              <GradientStop Color="{ThemeResource PhosphorGreen20}" Offset="0.3" />
              <GradientStop Color="{ThemeResource PhosphorGreen20}" Offset="0.7" />
              <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
          </Line.Stroke>
        </Line>

        <Line x:Name="CrosshairV" X1="150" Y1="15" X2="150" Y2="285"
              StrokeThickness="1">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
              <GradientStop Color="Transparent" Offset="0" />
              <GradientStop Color="{ThemeResource PhosphorGreen20}" Offset="0.3" />
              <GradientStop Color="{ThemeResource PhosphorGreen20}" Offset="0.7" />
              <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
          </Line.Stroke>
        </Line>

        <!-- Distance Labels (positioned along vertical crosshair) -->
        <TextBlock x:Name="DistanceLabel1"
                   Text="1mi"
                   Style="{StaticResource SonarDistanceLabelTextBlockStyle}"
                   Canvas.Left="156" Canvas.Top="108"
                   Opacity="0.33" />

        <TextBlock x:Name="DistanceLabel2"
                   Text="2mi"
                   Style="{StaticResource SonarDistanceLabelTextBlockStyle}"
                   Canvas.Left="156" Canvas.Top="70"
                   Opacity="0.33" />

        <TextBlock x:Name="DistanceLabel3"
                   Text="3mi"
                   Style="{StaticResource SonarDistanceLabelTextBlockStyle}"
                   Canvas.Left="156" Canvas.Top="32"
                   Opacity="0.33" />

        <!-- Sweep Trail (phosphor persistence effect) -->
        <Canvas x:Name="SweepTrailCanvas" Width="300" Height="300"
                RenderTransformOrigin="0.5,0.5">
          <Canvas.RenderTransform>
            <RotateTransform x:Name="SweepTrailRotation" Angle="0" />
          </Canvas.RenderTransform>

          <!-- Wider phosphor glow wedge -->
          <Path Stroke="Transparent" Opacity="0.12">
            <Path.Fill>
              <LinearGradientBrush StartPoint="0.5,0" EndPoint="1,0.5">
                <GradientStop Color="{ThemeResource PhosphorGreen}" Offset="0" />
                <GradientStop Color="Transparent" Offset="0.7" />
              </LinearGradientBrush>
            </Path.Fill>
            <Path.Data>
              <PathGeometry>
                <PathFigure StartPoint="150,150">
                  <ArcSegment Point="150,0" Size="150,150" SweepDirection="Clockwise" IsLargeArc="False" />
                </PathFigure>
              </PathGeometry>
            </Path.Data>
          </Path>
        </Canvas>

        <!-- Echo Line 3 (faintest, furthest behind) -->
        <Line x:Name="EchoLine3"
              X1="150" Y1="150" X2="150" Y2="10"
              StrokeThickness="1"
              Opacity="0.08">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
              <GradientStop Color="{ThemeResource PhosphorGreen}" Offset="0" />
              <GradientStop Color="Transparent" Offset="0.8" />
            </LinearGradientBrush>
          </Line.Stroke>
          <Line.RenderTransform>
            <RotateTransform x:Name="EchoRotation3" Angle="-30" CenterX="150" CenterY="150" />
          </Line.RenderTransform>
        </Line>

        <!-- Echo Line 2 (medium) -->
        <Line x:Name="EchoLine2"
              X1="150" Y1="150" X2="150" Y2="5"
              StrokeThickness="1"
              Opacity="0.15">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
              <GradientStop Color="{ThemeResource PhosphorGreen}" Offset="0" />
              <GradientStop Color="Transparent" Offset="0.85" />
            </LinearGradientBrush>
          </Line.Stroke>
          <Line.RenderTransform>
            <RotateTransform x:Name="EchoRotation2" Angle="-20" CenterX="150" CenterY="150" />
          </Line.RenderTransform>
        </Line>

        <!-- Echo Line 1 (brighter, closer to main sweep) -->
        <Line x:Name="EchoLine1"
              X1="150" Y1="150" X2="150" Y2="2"
              StrokeThickness="1"
              Opacity="0.25">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
              <GradientStop Color="{ThemeResource PhosphorGreen}" Offset="0" />
              <GradientStop Color="Transparent" Offset="0.9" />
            </LinearGradientBrush>
          </Line.Stroke>
          <Line.RenderTransform>
            <RotateTransform x:Name="EchoRotation1" Angle="-10" CenterX="150" CenterY="150" />
          </Line.RenderTransform>
        </Line>

        <!-- Main Sweep Line -->
        <Line x:Name="SweepLine"
              X1="150" Y1="150" X2="150" Y2="0"
              StrokeThickness="2">
          <Line.Stroke>
            <LinearGradientBrush StartPoint="0.5,1" EndPoint="0.5,0">
              <GradientStop Color="{ThemeResource PhosphorGreen}" Offset="0" />
              <GradientStop Color="{ThemeResource PhosphorGreen53}" Offset="0.5" />
              <GradientStop Color="Transparent" Offset="1" />
            </LinearGradientBrush>
          </Line.Stroke>
          <Line.RenderTransform>
            <RotateTransform x:Name="SweepRotation" Angle="0" CenterX="150" CenterY="150" />
          </Line.RenderTransform>
        </Line>

        <!-- Friend Blips Container -->
        <Canvas x:Name="BlipsCanvas" Width="300" Height="300" />

        <!-- Center Point -->
        <Ellipse Width="12" Height="12"
                 Canvas.Left="144" Canvas.Top="144"
                 Fill="{ThemeResource PhosphorGreen100Brush}"
                 Translation="0,0,16">
          <Ellipse.Shadow>
            <ThemeShadow />
          </Ellipse.Shadow>
        </Ellipse>

        <TextBlock Text="YOU"
                   Style="{StaticResource SonarCenterLabelTextBlockStyle}"
                   Canvas.Left="138" Canvas.Top="160"
                   Opacity="0.7" />

      </Canvas>
    </Border>
  </Grid>
</UserControl>

<UserControl x:Class="Vitalis.Controls.BloodPressureGauge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Gauge Arc Background -->
        <Canvas Width="200" Height="120">
            <!-- Gradient Arc (simulated with segments) -->
            <Path x:Name="GaugeArc" StrokeThickness="12">
                <Path.Stroke>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#22c55e" Offset="0" />
                        <GradientStop Color="#a3e635" Offset="0.25" />
                        <GradientStop Color="#eab308" Offset="0.5" />
                        <GradientStop Color="#f97316" Offset="0.75" />
                        <GradientStop Color="#ef4444" Offset="1" />
                    </LinearGradientBrush>
                </Path.Stroke>
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="20,100">
                            <ArcSegment Point="180,100" Size="80,80" SweepDirection="Clockwise" />
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Canvas>

        <!-- Value Display -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="140" FontSize="48" FontWeight="Bold" Foreground="#ffffff" />
                <TextBlock Text="/80" FontSize="28" Foreground="#808080" VerticalAlignment="Bottom" Margin="0,0,0,8" />
            </StackPanel>
            <Border Background="#4a1c1c" CornerRadius="8" Padding="12,4" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="Hypertensive crisis" FontSize="11" Foreground="#f87171" />
            </Border>
        </StackPanel>
    </Grid>
</UserControl>

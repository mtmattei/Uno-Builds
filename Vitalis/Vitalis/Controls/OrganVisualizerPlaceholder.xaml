<UserControl x:Class="Vitalis.Controls.OrganVisualizerPlaceholder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <UserControl.Resources>
        <!-- Glow effect styles -->
        <Style x:Key="OrganButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.15" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.15" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetName="GlowRing"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.8" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                           Storyboard.TargetProperty="ScaleX"
                                                           To="1.25" Duration="0:0:0.1" />
                                            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                                                           Storyboard.TargetProperty="ScaleY"
                                                           To="1.25" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="ContentPresenter"
                                            RenderTransformOrigin="0.5,0.5">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="ScaleTransform" ScaleX="1" ScaleY="1" />
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                            <Ellipse x:Name="GlowRing" Opacity="0" IsHitTestVisible="False"
                                   Stroke="{TemplateBinding Tag}" StrokeThickness="3"
                                   Margin="-20" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Dark space background with subtle glow -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#080c14" Offset="0" />
                <GradientStop Color="#0f172a" Offset="0.5" />
                <GradientStop Color="#0a1020" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Animated background particles/grid -->
        <Grid Opacity="0.15">
            <Ellipse Width="600" Height="600"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="-100,-200,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#2022d3ee" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="400" Height="400"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="200,150,0,0">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#20a855f7" Offset="0" />
                        <GradientStop Color="#00000000" Offset="1" />
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Grid>

        <!-- Decorative HUD frame -->
        <Grid Margin="16">
            <!-- Top left corner -->
            <Path Data="M0,40 L0,0 L40,0" Stroke="#3022d3ee" StrokeThickness="2"
                  HorizontalAlignment="Left" VerticalAlignment="Top" />
            <Path Data="M0,60 L0,0 L60,0" Stroke="#2022d3ee" StrokeThickness="1"
                  HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,8,0,0" />
            <!-- Top right corner -->
            <Path Data="M0,0 L40,0 L40,40" Stroke="#3022d3ee" StrokeThickness="2"
                  HorizontalAlignment="Right" VerticalAlignment="Top" />
            <!-- Bottom left corner -->
            <Path Data="M0,0 L0,40 L40,40" Stroke="#3022d3ee" StrokeThickness="2"
                  HorizontalAlignment="Left" VerticalAlignment="Bottom" />
            <!-- Bottom right corner -->
            <Path Data="M40,0 L40,40 L0,40" Stroke="#3022d3ee" StrokeThickness="2"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom" />
        </Grid>

        <!-- Title -->
        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,24,0,0">
            <TextBlock Text="BIOMETRIC SCANNER"
                     FontSize="11" FontWeight="SemiBold"
                     Foreground="#6022d3ee"
                     CharacterSpacing="200"
                     HorizontalAlignment="Center" />
            <Rectangle Width="120" Height="1" Fill="#3022d3ee" Margin="0,8,0,0" />
        </StackPanel>

        <!-- Organ grid -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- HEART - Dodecahedron style -->
            <Button x:Name="HeartButton" Grid.Row="0" Grid.Column="0"
                  Style="{StaticResource OrganButtonStyle}"
                  Width="180" Height="180" Margin="24"
                  Click="OnOrganClick" Tag="#ef4444">
                <Grid>
                    <!-- Outer glow rings -->
                    <Ellipse Width="160" Height="160" Stroke="#30ef4444" StrokeThickness="1" />
                    <Ellipse Width="140" Height="140" Stroke="#20ef4444" StrokeThickness="1" />

                    <!-- Main shape - Diamond/Dodecahedron approximation -->
                    <Polygon Points="70,10 130,50 130,110 70,150 10,110 10,50"
                           Fill="#25ef4444" Stroke="#ef4444" StrokeThickness="2"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Polygon Points="70,30 110,55 110,105 70,130 30,105 30,55"
                           Fill="#35ef4444" Stroke="#90ef4444" StrokeThickness="1"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Inner highlight -->
                    <Ellipse Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#60ef4444" Offset="0" />
                                <GradientStop Color="#00ef4444" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Label -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-30">
                        <TextBlock Text="HEART" FontSize="12" FontWeight="Bold"
                                 Foreground="#ef4444" HorizontalAlignment="Center"
                                 CharacterSpacing="150" />
                        <TextBlock Text="72 BPM" FontSize="10" Foreground="#80ef4444"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Button>

            <!-- BRAIN - Icosahedron style -->
            <Button x:Name="BrainButton" Grid.Row="0" Grid.Column="1"
                  Style="{StaticResource OrganButtonStyle}"
                  Width="180" Height="180" Margin="24"
                  Click="OnOrganClick" Tag="#a855f7">
                <Grid>
                    <!-- Outer glow rings -->
                    <Ellipse Width="160" Height="160" Stroke="#30a855f7" StrokeThickness="1" />
                    <Ellipse Width="140" Height="140" Stroke="#20a855f7" StrokeThickness="1" />

                    <!-- Main shape - Icosahedron approximation with triangular facets -->
                    <Polygon Points="70,5 130,40 120,100 70,130 20,100 10,40"
                           Fill="#25a855f7" Stroke="#a855f7" StrokeThickness="2"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <!-- Inner facets -->
                    <Polygon Points="70,25 100,50 90,90 70,105 50,90 40,50"
                           Fill="#35a855f7" Stroke="#90a855f7" StrokeThickness="1"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Line X1="70" Y1="25" X2="70" Y2="105" Stroke="#50a855f7" StrokeThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Line X1="40" Y1="50" X2="100" Y2="50" Stroke="#50a855f7" StrokeThickness="1"
                        HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Inner highlight -->
                    <Ellipse Width="35" Height="35" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#60a855f7" Offset="0" />
                                <GradientStop Color="#00a855f7" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Label -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-30">
                        <TextBlock Text="BRAIN" FontSize="12" FontWeight="Bold"
                                 Foreground="#a855f7" HorizontalAlignment="Center"
                                 CharacterSpacing="150" />
                        <TextBlock Text="32% STRESS" FontSize="10" Foreground="#80a855f7"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Button>

            <!-- LUNGS - Capsule style -->
            <Button x:Name="LungsButton" Grid.Row="1" Grid.Column="0"
                  Style="{StaticResource OrganButtonStyle}"
                  Width="180" Height="180" Margin="24"
                  Click="OnOrganClick" Tag="#3b82f6">
                <Grid>
                    <!-- Outer glow rings -->
                    <Ellipse Width="160" Height="160" Stroke="#303b82f6" StrokeThickness="1" />
                    <Ellipse Width="140" Height="140" Stroke="#203b82f6" StrokeThickness="1" />

                    <!-- Main shape - Capsule/Pill shape -->
                    <Rectangle Width="50" Height="100" RadiusX="25" RadiusY="25"
                             Fill="#253b82f6" Stroke="#3b82f6" StrokeThickness="2"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Rectangle Width="35" Height="80" RadiusX="17" RadiusY="17"
                             Fill="#353b82f6" Stroke="#903b82f6" StrokeThickness="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- Side capsules for lung effect -->
                    <Rectangle Width="30" Height="70" RadiusX="15" RadiusY="15"
                             Fill="#203b82f6" Stroke="#603b82f6" StrokeThickness="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="-60,10,0,0" />
                    <Rectangle Width="30" Height="70" RadiusX="15" RadiusY="15"
                             Fill="#203b82f6" Stroke="#603b82f6" StrokeThickness="1"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Margin="60,10,0,0" />

                    <!-- Inner highlight -->
                    <Ellipse Width="30" Height="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#603b82f6" Offset="0" />
                                <GradientStop Color="#003b82f6" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Label -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-30">
                        <TextBlock Text="LUNGS" FontSize="12" FontWeight="Bold"
                                 Foreground="#3b82f6" HorizontalAlignment="Center"
                                 CharacterSpacing="150" />
                        <TextBlock Text="16 /MIN" FontSize="10" Foreground="#803b82f6"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Button>

            <!-- LIVER - Sphere style -->
            <Button x:Name="LiverButton" Grid.Row="1" Grid.Column="1"
                  Style="{StaticResource OrganButtonStyle}"
                  Width="180" Height="180" Margin="24"
                  Click="OnOrganClick" Tag="#eab308">
                <Grid>
                    <!-- Outer glow rings -->
                    <Ellipse Width="160" Height="160" Stroke="#30eab308" StrokeThickness="1" />
                    <Ellipse Width="140" Height="140" Stroke="#20eab308" StrokeThickness="1" />

                    <!-- Main shape - Sphere with shading -->
                    <Ellipse Width="100" Height="100" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#50eab308" Offset="0" />
                                <GradientStop Color="#30eab308" Offset="0.7" />
                                <GradientStop Color="#15eab308" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                        <Ellipse.Stroke>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#eab308" Offset="0" />
                                <GradientStop Color="#a07706" Offset="1" />
                            </LinearGradientBrush>
                        </Ellipse.Stroke>
                        <Ellipse.StrokeThickness>2</Ellipse.StrokeThickness>
                    </Ellipse>

                    <!-- Sphere highlight -->
                    <Ellipse Width="40" Height="25" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="-20,-30,0,0" Opacity="0.4">
                        <Ellipse.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#80eab308" Offset="0" />
                                <GradientStop Color="#00eab308" Offset="1" />
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Inner glow -->
                    <Ellipse Width="50" Height="50" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#40eab308" Offset="0" />
                                <GradientStop Color="#00eab308" Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Label -->
                    <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,-30">
                        <TextBlock Text="LIVER" FontSize="12" FontWeight="Bold"
                                 Foreground="#eab308" HorizontalAlignment="Center"
                                 CharacterSpacing="150" />
                        <TextBlock Text="95 MG/DL" FontSize="10" Foreground="#80eab308"
                                 HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>

        <!-- Selection indicator ring (animated) -->
        <Ellipse x:Name="SelectionRing" Width="200" Height="200"
               Stroke="#ef4444" StrokeThickness="3" StrokeDashArray="4,2"
               HorizontalAlignment="Center" VerticalAlignment="Center"
               Margin="-145,-75,0,0" Opacity="0.7"
               RenderTransformOrigin="0.5,0.5">
            <Ellipse.RenderTransform>
                <RotateTransform x:Name="RingRotation" />
            </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Bottom instruction -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
              Background="#20000000" CornerRadius="4" Padding="16,8" Margin="0,0,0,20">
            <TextBlock Text="SELECT ORGAN FOR DETAILED ANALYSIS"
                     FontSize="11" Foreground="#60ffffff"
                     CharacterSpacing="100" />
        </Border>
    </Grid>
</UserControl>

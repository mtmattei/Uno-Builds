<UserControl x:Class="Vitalis.Controls.MetricCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utu="using:Uno.Toolkit.UI">

    <Grid>
        <!-- Glassmorphism background with gradient border -->
        <Border CornerRadius="12">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#15ffffff" Offset="0" />
                    <GradientStop Color="#08ffffff" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Subtle glow border -->
        <Border CornerRadius="12"
                BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#30ffffff" Offset="0" />
                    <GradientStop Color="#10ffffff" Offset="0.5" />
                    <GradientStop Color="#20ffffff" Offset="1" />
                </LinearGradientBrush>
            </Border.BorderBrush>
        </Border>

        <!-- Content -->
        <utu:AutoLayout Orientation="Vertical" Spacing="8" Padding="14">
            <!-- Label with subtle glow -->
            <TextBlock Text="{Binding Label}"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#70ffffff"
                       CharacterSpacing="100" />

            <!-- Value Row with emphasis -->
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="{Binding Value}"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#f1f5f9" />
                <TextBlock Text="{Binding Unit}"
                           FontSize="11"
                           Foreground="#80ffffff"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,5" />
            </StackPanel>

            <!-- Trend Indicator with colored badge -->
            <Border Background="#1522d3ee" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon x:Name="TrendIcon"
                              Glyph="&#xE74A;"
                              FontSize="10"
                              Foreground="#22d3ee" />
                    <TextBlock x:Name="TrendText"
                               Text="Stable"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#22d3ee" />
                </StackPanel>
            </Border>

            <!-- Animated progress indicator -->
            <Grid Height="3" Margin="0,4,0,0">
                <Border Background="#20ffffff" CornerRadius="2" />
                <Border x:Name="ProgressFill"
                        Background="#22d3ee"
                        CornerRadius="2"
                        HorizontalAlignment="Left"
                        Width="60" />
            </Grid>
        </utu:AutoLayout>
    </Grid>
</UserControl>

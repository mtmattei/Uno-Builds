<Application x:Class="AgentNotifier.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:AgentNotifier.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ToolkitResources xmlns="using:Uno.Toolkit.UI" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:StatusToGlowColorConverter x:Key="StatusToGlowColorConverter" />
            <converters:StatusToDarkColorConverter x:Key="StatusToDarkColorConverter" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <converters:AudioStateConverter x:Key="AudioStateConverter" />
            <converters:AudioColorConverter x:Key="AudioColorConverter" />
            <converters:WaitingIndicatorConverter x:Key="WaitingIndicatorConverter" />
            <converters:AgentCountConverter x:Key="AgentCountConverter" />
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
            <converters:StatusToLabelConverter x:Key="StatusToLabelConverter" />
            <converters:StatusToBgColorConverter x:Key="StatusToBgColorConverter" />
            <converters:StatusToBorderColorConverter x:Key="StatusToBorderColorConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
            <converters:BoolToCardBorderConverter x:Key="BoolToCardBorderConverter" />

            <!-- Base Palette (Monochromatic Grays) -->
            <Color x:Key="BgVoidColor">#0A0A0B</Color>
            <Color x:Key="BgBaseColor">#0D0D0F</Color>
            <Color x:Key="BgCardColor">#131316</Color>
            <Color x:Key="BgElevatedColor">#1A1A1F</Color>
            <Color x:Key="BorderSubtleColor">#1F1F24</Color>
            <Color x:Key="BorderDefaultColor">#252529</Color>
            <Color x:Key="BorderStrongColor">#333338</Color>
            <Color x:Key="TextMutedColor">#444449</Color>
            <Color x:Key="TextSubtleColor">#555560</Color>
            <Color x:Key="TextSecondaryColor">#666670</Color>
            <Color x:Key="TextTertiaryColor">#888890</Color>
            <Color x:Key="TextSecondaryBrightColor">#9999A3</Color>
            <Color x:Key="TextPrimaryColor">#E8E8ED</Color>

            <!-- Accent Color (Orange) -->
            <Color x:Key="AccentColor">#FF8C42</Color>
            <Color x:Key="AccentMutedColor">#CC7035</Color>
            <Color x:Key="AccentGlowColor">#4DFF8C42</Color>
            <Color x:Key="AccentBgColor">#14FF8C42</Color>
            <Color x:Key="AccentBorderColor">#40FF8C42</Color>

            <!-- Attention/Waiting Color (Bright Orange) -->
            <Color x:Key="AttentionColor">#FF9500</Color>
            <Color x:Key="AttentionGlowColor">#80FF9500</Color>
            <Color x:Key="AttentionBorderColor">#FFFF9500</Color>

            <!-- Status Colors -->
            <Color x:Key="StatusProcessingColor">#FF8C42</Color>
            <Color x:Key="StatusCompletedColor">#4ADE80</Color>
            <Color x:Key="StatusQueuedColor">#666670</Color>
            <Color x:Key="StatusErrorColor">#EF4444</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="BgVoidBrush" Color="{StaticResource BgVoidColor}" />
            <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBaseColor}" />
            <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCardColor}" />
            <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevatedColor}" />
            <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}" />
            <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefaultColor}" />
            <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
            <SolidColorBrush x:Key="TextSubtleBrush" Color="{StaticResource TextSubtleColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
            <SolidColorBrush x:Key="TextTertiaryBrush" Color="{StaticResource TextTertiaryColor}" />
            <SolidColorBrush x:Key="TextSecondaryBrightBrush" Color="{StaticResource TextSecondaryBrightColor}" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMutedColor}" />
            <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlowColor}" />
            <SolidColorBrush x:Key="AccentBgBrush" Color="{StaticResource AccentBgColor}" />
            <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentBorderColor}" />
            <SolidColorBrush x:Key="StatusProcessingBrush" Color="{StaticResource StatusProcessingColor}" />
            <SolidColorBrush x:Key="StatusCompletedBrush" Color="{StaticResource StatusCompletedColor}" />
            <SolidColorBrush x:Key="StatusQueuedBrush" Color="{StaticResource StatusQueuedColor}" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusErrorColor}" />
            <SolidColorBrush x:Key="AttentionBrush" Color="{StaticResource AttentionColor}" />
            <SolidColorBrush x:Key="AttentionGlowBrush" Color="{StaticResource AttentionGlowColor}" />
            <SolidColorBrush x:Key="AttentionBorderBrush" Color="{StaticResource AttentionBorderColor}" />

            <!-- Typography Styles -->
            <!-- Page Title: Press Start 2P style (using Consolas as fallback) -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="100" />
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </Style>

            <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            </Style>

            <!-- Section Label -->
            <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="8" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <!-- Micro Label -->
            <Style x:Key="MicroLabelStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="7" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="50" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <!-- Stat Value Large -->
            <Style x:Key="StatValueLargeStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>

            <!-- Stat Value Medium -->
            <Style x:Key="StatValueMediumStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>

            <!-- Body Text -->
            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
            </Style>

            <!-- Micro Text -->
            <Style x:Key="MicroTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <!-- Agent Name Style -->
            <Style x:Key="AgentNameStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            </Style>

            <!-- Agent ID Style -->
            <Style x:Key="AgentIdStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono" />
                <Setter Property="FontSize" Value="9" />
                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            </Style>

            <!-- Status Badge Style -->
            <Style x:Key="StatusBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="6,3" />
                <Setter Property="CornerRadius" Value="2" />
            </Style>

            <!-- Global Corner Radius -->
            <CornerRadius x:Key="SmallCornerRadius">2</CornerRadius>

        </ResourceDictionary>
    </Application.Resources>

</Application>

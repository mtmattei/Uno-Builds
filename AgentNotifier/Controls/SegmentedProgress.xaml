<UserControl x:Class="AgentNotifier.Controls.SegmentedProgress"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <TextBlock x:Name="ProgressTextBlock"
               FontFamily="ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono"
               FontSize="9"
               VerticalAlignment="Center"
               IsTextSelectionEnabled="False">
        <Run x:Name="BracketOpenRun" Text="[" Foreground="{StaticResource TextMutedBrush}" />
        <Run x:Name="PreRun" Text="" Foreground="{StaticResource BorderDefaultBrush}" />
        <Run x:Name="FilledRun" Text="" Foreground="{StaticResource AccentBrush}" />
        <Run x:Name="PostRun" Text="" Foreground="{StaticResource BorderDefaultBrush}" />
        <Run x:Name="BracketCloseRun" Text="]" Foreground="{StaticResource TextMutedBrush}" />
        <Run x:Name="PercentRun" Text="" Foreground="{StaticResource TextSecondaryBrush}" />
    </TextBlock>

</UserControl>

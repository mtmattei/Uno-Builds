<Page x:Class="Pens.Presentation.BeersPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:Pens.Presentation"
      Background="{StaticResource ArenaDarkBrush}">

  <ScrollViewer Padding="20,10,20,20" VerticalScrollBarVisibility="Auto">
    <utu:AutoLayout Spacing="20">

      <!-- Beer Header -->
      <StackPanel HorizontalAlignment="Center" Margin="0,0,0,4"
                  AutomationProperties.Name="Season beer consumption statistics">
        <!-- Total Row -->
        <utu:AutoLayout Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <TextBlock Text="{Binding ConsumedCases}"
                     Foreground="{StaticResource NeonAmberBrush}"
                     FontFamily="{StaticResource BebasNeueFont}"
                     FontSize="80" />
          <TextBlock x:Uid="BeersPage_Cases"
                     Text="cases"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontFamily="{StaticResource BarlowMedium}"
                     FontSize="24"
                     CharacterSpacing="40"
                     VerticalAlignment="Bottom"
                     Margin="0,0,0,16" />
        </utu:AutoLayout>

        <!-- Subtitle -->
        <TextBlock x:Uid="BeersPage_ConsumedThisSeason"
                   Text="CONSUMED THIS SEASON"
                   Foreground="{StaticResource TextMutedBrush}"
                   FontSize="12"
                   CharacterSpacing="80"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" />

        <!-- Beer Count -->
        <TextBlock HorizontalAlignment="Center" Margin="0,4,0,0" FontSize="14">
          <Run Text="{Binding TotalBeers}" Foreground="{StaticResource NeonAmberBrush}" />
          <Run Text=" beers " Foreground="{StaticResource NeonAmberBrush}" />
          <Run Text="(30 per case)" Foreground="{StaticResource TextMutedBrush}" />
        </TextBlock>
      </StackPanel>

      <!-- Cases Section -->
      <Border Background="{StaticResource BoardsDarkBrush}"
              CornerRadius="{StaticResource LargeCornerRadius}"
              Padding="20"
              BorderBrush="{StaticResource SubtleBorderBrush}"
              BorderThickness="1">
        <utu:AutoLayout Spacing="16">
          <!-- Section Header -->
          <Grid>
            <TextBlock x:Uid="BeersPage_SeasonTracker"
                       Text="SEASON TRACKER"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="14"
                       CharacterSpacing="80"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Left" />
            <TextBlock HorizontalAlignment="Right" FontSize="13">
              <Run Text="{Binding ConsumedCases}" Foreground="{StaticResource PowderBlueBrush}" />
              <Run Text=" / 52 cases" Foreground="{StaticResource PowderBlueBrush}" />
            </TextBlock>
          </Grid>

          <!-- Cases Grid -->
          <ItemsRepeater ItemsSource="{Binding CaseBlocks}"
                         utu:CommandExtensions.Command="{Binding ToggleCaseCommand}">
            <ItemsRepeater.Layout>
              <UniformGridLayout MinItemWidth="28"
                                 MinItemHeight="28"
                                 MinColumnSpacing="8"
                                 MinRowSpacing="8"
                                 ItemsStretch="Fill" />
            </ItemsRepeater.Layout>
            <ItemsRepeater.ItemTemplate>
              <DataTemplate x:DataType="local:CaseBlock">
                <Border CornerRadius="{StaticResource SmallCornerRadius}"
                        Background="{Binding IsConsumed, Converter={StaticResource BoolToConsumedBackgroundConverter}}"
                        BorderBrush="{Binding IsConsumed, Converter={StaticResource BoolToConsumedBorderConverter}}"
                        BorderThickness="1" />
              </DataTemplate>
            </ItemsRepeater.ItemTemplate>
          </ItemsRepeater>
        </utu:AutoLayout>
      </Border>

      <!-- Legend -->
      <utu:AutoLayout Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center"
                      AutomationProperties.Name="Legend for beer tracker">
        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
          <Border Width="18" Height="18"
                  CornerRadius="{StaticResource SmallCornerRadius}"
                  Background="{StaticResource BoardsMidBrush}"
                  BorderBrush="{StaticResource SubtleBorderBrush}"
                  BorderThickness="1" />
          <TextBlock x:Uid="BeersPage_Remaining"
                     Text="Remaining"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="12"
                     VerticalAlignment="Center" />
        </utu:AutoLayout>
        <utu:AutoLayout Orientation="Horizontal" Spacing="8">
          <Border Width="18" Height="18"
                  CornerRadius="{StaticResource SmallCornerRadius}"
                  Background="{StaticResource NeonAmberGradientBrush}" />
          <TextBlock x:Uid="BeersPage_Consumed"
                     Text="Consumed"
                     Foreground="{StaticResource TextMutedBrush}"
                     FontSize="12"
                     VerticalAlignment="Center" />
        </utu:AutoLayout>
      </utu:AutoLayout>

      <!-- Stats Grid -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="12" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Stat Box 1 -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{StaticResource BoardsDarkBrush}"
                CornerRadius="{StaticResource CardCornerRadius}"
                Padding="16"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                AutomationProperties.Name="Average beers per game: 10">
          <StackPanel>
            <TextBlock Text="10"
                       Foreground="{StaticResource NeonAmberBrush}"
                       FontFamily="{StaticResource BebasNeueFont}"
                       FontSize="32" />
            <TextBlock x:Uid="BeersPage_AvgPerGame"
                       Text="AVG / GAME"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       CharacterSpacing="40" />
          </StackPanel>
        </Border>

        <!-- Stat Box 2 -->
        <Border Grid.Column="2" Grid.Row="0"
                Background="{StaticResource BoardsDarkBrush}"
                CornerRadius="{StaticResource CardCornerRadius}"
                Padding="16"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                AutomationProperties.Name="Games played: 12">
          <StackPanel>
            <TextBlock Text="12"
                       Foreground="{StaticResource NeonAmberBrush}"
                       FontFamily="{StaticResource BebasNeueFont}"
                       FontSize="32" />
            <TextBlock x:Uid="BeersPage_GamesPlayed"
                       Text="GAMES PLAYED"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       CharacterSpacing="40" />
          </StackPanel>
        </Border>

        <!-- Stat Box 3 -->
        <Border Grid.Column="0" Grid.Row="2"
                Background="{StaticResource BoardsDarkBrush}"
                CornerRadius="{StaticResource CardCornerRadius}"
                Padding="16"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                AutomationProperties.Name="Top beer consumer: B-Rob">
          <StackPanel>
            <TextBlock Text="B-Rob"
                       Foreground="{StaticResource NeonAmberBrush}"
                       FontFamily="{StaticResource BebasNeueFont}"
                       FontSize="32" />
            <TextBlock x:Uid="BeersPage_TopConsumer"
                       Text="TOP CONSUMER"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       CharacterSpacing="40" />
          </StackPanel>
        </Border>

        <!-- Stat Box 4 -->
        <Border Grid.Column="2" Grid.Row="2"
                Background="{StaticResource BoardsDarkBrush}"
                CornerRadius="{StaticResource CardCornerRadius}"
                Padding="16"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                AutomationProperties.Name="Most beers in a game: 18">
          <StackPanel>
            <TextBlock Text="18"
                       Foreground="{StaticResource NeonAmberBrush}"
                       FontFamily="{StaticResource BebasNeueFont}"
                       FontSize="32" />
            <TextBlock x:Uid="BeersPage_MostInGame"
                       Text="MOST IN A GAME"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontSize="11"
                       CharacterSpacing="40" />
          </StackPanel>
        </Border>
      </Grid>

      <!-- Bottom padding for nav -->
      <Border Height="24" />
    </utu:AutoLayout>
  </ScrollViewer>
</Page>

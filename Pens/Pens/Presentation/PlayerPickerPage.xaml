<Page x:Class="Pens.Presentation.PlayerPickerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:local="using:Pens.Presentation"
      Background="{StaticResource ArenaDarkBrush}">

  <Grid Padding="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Spacing="8" Margin="0,40,0,0">
      <FontIcon Glyph="&#xF78A;"
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="64"
                Foreground="{StaticResource PowderBlueBrush}"
                HorizontalAlignment="Center" />
      <TextBlock Text="PENGUINS"
                 FontFamily="{StaticResource BebasNeueFont}"
                 FontSize="42"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 HorizontalAlignment="Center"
                 CharacterSpacing="80" />
    </StackPanel>

    <!-- Instruction -->
    <TextBlock Grid.Row="1"
               Text="WHO ARE YOU?"
               FontSize="14"
               CharacterSpacing="120"
               FontWeight="SemiBold"
               Foreground="{StaticResource TextMutedBrush}"
               HorizontalAlignment="Center"
               Margin="0,32,0,16" />

    <!-- Player List -->
    <ScrollViewer Grid.Row="2">
      <ItemsRepeater ItemsSource="{x:Bind ViewModel.Players, Mode=OneWay}">
        <ItemsRepeater.Layout>
          <StackLayout Spacing="8" />
        </ItemsRepeater.Layout>
        <ItemsRepeater.ItemTemplate>
          <DataTemplate x:DataType="local:PlayerPickerItem">
            <Button Command="{x:Bind SelectCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    AutomationProperties.Name="{x:Bind Name}">
              <Border Background="{StaticResource BoardsDarkBrush}"
                      CornerRadius="{StaticResource CardCornerRadius}"
                      Padding="12,12,16,12"
                      BorderBrush="{StaticResource CardBorderBrush}"
                      BorderThickness="1">
                <utu:AutoLayout Orientation="Horizontal" Spacing="14">
                  <!-- Jersey Number Badge -->
                  <Border Width="44" Height="44"
                          CornerRadius="10"
                          Background="{StaticResource PowderBlueGradientBrush}">
                    <TextBlock Text="{x:Bind Number}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource ArenaDarkBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                  </Border>

                  <!-- Player Info -->
                  <StackPanel VerticalAlignment="Center" utu:AutoLayout.PrimaryAlignment="Stretch">
                    <TextBlock Text="{x:Bind Name}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind Position}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11"
                               CharacterSpacing="40"
                               Margin="0,2,0,0" />
                  </StackPanel>
                </utu:AutoLayout>
              </Border>
            </Button>
          </DataTemplate>
        </ItemsRepeater.ItemTemplate>
      </ItemsRepeater>
    </ScrollViewer>
  </Grid>
</Page>

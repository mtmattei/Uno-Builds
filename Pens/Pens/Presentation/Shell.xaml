<Page x:Class="Pens.Presentation.Shell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{StaticResource ArenaDarkBrush}">

  <Grid Background="{StaticResource ArenaDarkBrush}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0"
          utu:SafeArea.Insets="Top">
      <Border Padding="20,20,20,16"
              BorderBrush="{StaticResource SubtleBorderBrush}"
              BorderThickness="0,0,0,1"
              Background="{StaticResource ArenaDarkBrush}"
              AutomationProperties.Name="Team header">
        <StackPanel Orientation="Horizontal" Spacing="16">
          <!-- Team Logo -->
          <Border Width="56" Height="56"
                  CornerRadius="12"
                  BorderBrush="{StaticResource PowderBlueBorderBrush}"
                  BorderThickness="2"
                  AutomationProperties.Name="Penguins team logo">
            <Image Source="ms-appx:///Assets/images/pens-logo.png"
                   Stretch="UniformToFill" />
          </Border>

          <!-- Team Info -->
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Uid="Shell_TeamName"
                       Text="PENGUINS"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource BebasNeueFont}"
                       FontSize="32"
                       CharacterSpacing="80" />
            <TextBlock x:Uid="Shell_LeagueName"
                       Text="DORVAL YOUNGTIMERS"
                       Foreground="{StaticResource TextMutedBrush}"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="11"
                       CharacterSpacing="60" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Content Area -->
    <ContentControl x:Name="NavigationContent"
                    Grid.Row="1"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch" />

    <!-- Bottom Navigation -->
    <Grid Grid.Row="2"
          utu:SafeArea.Insets="Bottom">
      <Border Padding="8,8,8,20"
              Background="{StaticResource ArenaDarkBrush}"
              BorderBrush="{StaticResource SubtleBorderBrush}"
              BorderThickness="0,1,0,0">
        <utu:TabBar x:Name="TabBar"
                    SelectedIndex="0">
          <utu:TabBar.ItemsPanel>
            <ItemsPanelTemplate>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
              </Grid>
            </ItemsPanelTemplate>
          </utu:TabBar.ItemsPanel>

        <utu:TabBarItem Grid.Column="0" Tag="Schedule"
                        AutomationProperties.Name="Schedule tab">
          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <SymbolIcon Symbol="Calendar"
                        Foreground="{StaticResource TextMutedBrush}"
                        HorizontalAlignment="Center" />
            <TextBlock x:Uid="Shell_Tab_Schedule"
                       Text="Schedule"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </utu:TabBarItem>

        <utu:TabBarItem Grid.Column="1" Tag="Chat"
                        AutomationProperties.Name="Chat tab">
          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <SymbolIcon Symbol="Message"
                        Foreground="{StaticResource TextMutedBrush}"
                        HorizontalAlignment="Center" />
            <TextBlock x:Uid="Shell_Tab_Chat"
                       Text="Chat"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </utu:TabBarItem>

        <utu:TabBarItem Grid.Column="2" Tag="Beers"
                        AutomationProperties.Name="Beers tab">
          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <FontIcon Glyph="&#xE799;"
                      FontSize="20"
                      Foreground="{StaticResource TextMutedBrush}"
                      HorizontalAlignment="Center" />
            <TextBlock x:Uid="Shell_Tab_Beers"
                       Text="Beers"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </utu:TabBarItem>

        <utu:TabBarItem Grid.Column="3" Tag="Duties"
                        AutomationProperties.Name="Duties tab">
          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <SymbolIcon Symbol="Bullets"
                        Foreground="{StaticResource TextMutedBrush}"
                        HorizontalAlignment="Center" />
            <TextBlock x:Uid="Shell_Tab_Duties"
                       Text="Duties"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </utu:TabBarItem>

        <utu:TabBarItem Grid.Column="4" Tag="Roster"
                        AutomationProperties.Name="Roster tab">
          <StackPanel HorizontalAlignment="Center" Spacing="4">
            <SymbolIcon Symbol="People"
                        Foreground="{StaticResource TextMutedBrush}"
                        HorizontalAlignment="Center" />
            <TextBlock x:Uid="Shell_Tab_Roster"
                       Text="Roster"
                       FontFamily="{StaticResource BarlowMedium}"
                       FontSize="10"
                       Foreground="{StaticResource TextMutedBrush}"
                       HorizontalAlignment="Center" />
          </StackPanel>
        </utu:TabBarItem>
      </utu:TabBar>
    </Border>
  </Grid>
  </Grid>
</Page>

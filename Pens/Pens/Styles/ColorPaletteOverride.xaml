<ResourceDictionary xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <ResourceDictionary.ThemeDictionaries>
    <!-- Dark theme only - Hockey Arena theme -->
    <ResourceDictionary x:Key="Dark">
      <!-- Primary: Powder Blue (team accent) -->
      <Color x:Key="PrimaryColor">#B4D7E8</Color>
      <Color x:Key="OnPrimaryColor">#0A0C10</Color>
      <Color x:Key="PrimaryContainerColor">#1A1F2A</Color>
      <Color x:Key="OnPrimaryContainerColor">#B4D7E8</Color>

      <!-- Secondary: Neon Amber (beer/warning elements) -->
      <Color x:Key="SecondaryColor">#FFAA00</Color>
      <Color x:Key="OnSecondaryColor">#0A0C10</Color>
      <Color x:Key="SecondaryContainerColor">#33280A</Color>
      <Color x:Key="OnSecondaryContainerColor">#FFAA00</Color>

      <!-- Tertiary: Success Green (food duty, "in" status) -->
      <Color x:Key="TertiaryColor">#10B981</Color>
      <Color x:Key="OnTertiaryColor">#0A0C10</Color>
      <Color x:Key="TertiaryContainerColor">#0A2E20</Color>
      <Color x:Key="OnTertiaryContainerColor">#10B981</Color>

      <!-- Error: Hot Red ("out" status, destructive) -->
      <Color x:Key="ErrorColor">#FF3B3B</Color>
      <Color x:Key="ErrorContainerColor">#330F0F</Color>
      <Color x:Key="OnErrorColor">#0A0C10</Color>
      <Color x:Key="OnErrorContainerColor">#FF3B3B</Color>

      <!-- Background: Arena Dark -->
      <Color x:Key="BackgroundColor">#0A0C10</Color>
      <Color x:Key="OnBackgroundColor">#F0F4F8</Color>

      <!-- Surface: Boards Dark/Mid -->
      <Color x:Key="SurfaceColor">#12161D</Color>
      <Color x:Key="OnSurfaceColor">#F0F4F8</Color>
      <Color x:Key="SurfaceVariantColor">#1A1F2A</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B7A8F</Color>

      <!-- Outline -->
      <Color x:Key="OutlineColor">#6B7A8F</Color>
      <Color x:Key="OutlineVariantColor">#2A3140</Color>

      <!-- Inverse -->
      <Color x:Key="OnSurfaceInverseColor">#0A0C10</Color>
      <Color x:Key="SurfaceInverseColor">#F0F4F8</Color>
      <Color x:Key="PrimaryInverseColor">#7EB8D4</Color>

      <!-- Surface Tint -->
      <Color x:Key="SurfaceTintColor">#B4D7E8</Color>
    </ResourceDictionary>

    <!-- Light theme maps to same dark arena theme -->
    <ResourceDictionary x:Key="Light">
      <Color x:Key="PrimaryColor">#B4D7E8</Color>
      <Color x:Key="OnPrimaryColor">#0A0C10</Color>
      <Color x:Key="PrimaryContainerColor">#1A1F2A</Color>
      <Color x:Key="OnPrimaryContainerColor">#B4D7E8</Color>
      <Color x:Key="SecondaryColor">#FFAA00</Color>
      <Color x:Key="OnSecondaryColor">#0A0C10</Color>
      <Color x:Key="SecondaryContainerColor">#33280A</Color>
      <Color x:Key="OnSecondaryContainerColor">#FFAA00</Color>
      <Color x:Key="TertiaryColor">#10B981</Color>
      <Color x:Key="OnTertiaryColor">#0A0C10</Color>
      <Color x:Key="TertiaryContainerColor">#0A2E20</Color>
      <Color x:Key="OnTertiaryContainerColor">#10B981</Color>
      <Color x:Key="ErrorColor">#FF3B3B</Color>
      <Color x:Key="ErrorContainerColor">#330F0F</Color>
      <Color x:Key="OnErrorColor">#0A0C10</Color>
      <Color x:Key="OnErrorContainerColor">#FF3B3B</Color>
      <Color x:Key="BackgroundColor">#0A0C10</Color>
      <Color x:Key="OnBackgroundColor">#F0F4F8</Color>
      <Color x:Key="SurfaceColor">#12161D</Color>
      <Color x:Key="OnSurfaceColor">#F0F4F8</Color>
      <Color x:Key="SurfaceVariantColor">#1A1F2A</Color>
      <Color x:Key="OnSurfaceVariantColor">#6B7A8F</Color>
      <Color x:Key="OutlineColor">#6B7A8F</Color>
      <Color x:Key="OutlineVariantColor">#2A3140</Color>
      <Color x:Key="OnSurfaceInverseColor">#0A0C10</Color>
      <Color x:Key="SurfaceInverseColor">#F0F4F8</Color>
      <Color x:Key="PrimaryInverseColor">#7EB8D4</Color>
      <Color x:Key="SurfaceTintColor">#B4D7E8</Color>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

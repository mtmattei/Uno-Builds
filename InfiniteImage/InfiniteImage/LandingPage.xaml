<Page x:Class="InfiniteImage.LandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InfiniteImage">

    <Page.Background>
        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#F5F4F7" Offset="0" />
            <GradientStop Color="#E8E6ED" Offset="1" />
        </LinearGradientBrush>
    </Page.Background>

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="720"
                  HorizontalAlignment="Center"
                  Margin="40,80,40,80">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="120" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="48" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Top brand -->
                <TextBlock Grid.Row="0"
                           HorizontalAlignment="Center">
                    <Run Text="MEMORY"
                         FontSize="14"
                         Foreground="#8B8895"
                         FontFamily="Segoe UI" />
                    <Run Text=" "
                         FontSize="14" />
                    <Run Text="Drift"
                         FontSize="14"
                         Foreground="#8B8895"
                         FontStyle="Italic"
                         FontFamily="Georgia" />
                </TextBlock>

                <!-- Tagline -->
                <TextBlock Grid.Row="2"
                           Text="// YOUR MEMORIES, REIMAGINED"
                           FontSize="11"
                           Foreground="#9B99A6"
                           FontFamily="Consolas"
                           CharacterSpacing="120"
                           HorizontalAlignment="Center" />

                <!-- Main title -->
                <StackPanel Grid.Row="4"
                            HorizontalAlignment="Center"
                            Spacing="0">
                    <TextBlock Text="Memory"
                               FontSize="96"
                               FontFamily="Georgia"
                               Foreground="#3D3846"
                               HorizontalAlignment="Center"
                               LineHeight="96" />
                    <TextBlock Text="Drift"
                               FontSize="96"
                               FontFamily="Georgia"
                               FontStyle="Italic"
                               Foreground="#3D3846"
                               HorizontalAlignment="Center"
                               LineHeight="96"
                               Margin="0,-16,0,0" />
                </StackPanel>

                <!-- Subtitle -->
                <TextBlock Grid.Row="6"
                           Text="Dive beneath the surface of your past"
                           FontSize="20"
                           FontFamily="Georgia"
                           FontStyle="Italic"
                           Foreground="#6B6875"
                           HorizontalAlignment="Center" />

                <!-- Body text -->
                <TextBlock Grid.Row="8"
                           TextAlignment="Center"
                           MaxWidth="540"
                           HorizontalAlignment="Center"
                           LineHeight="28"
                           Foreground="#5D5A66"
                           FontSize="13"
                           FontFamily="Consolas"
                           TextWrapping="Wrap">
                    <Run Text="Your memories aren't just moments frozen in time—they're" />
                    <LineBreak />
                    <Run Text="living, breathing experiences waiting to be rediscovered." />
                    <LineBreak />
                    <Run Text="Explore, connect, and drift through the stories that made you" />
                    <LineBreak />
                    <Run Text="who you are." />
                </TextBlock>

                <!-- Platform checkboxes -->
                <StackPanel Grid.Row="10"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="16">
                    <CheckBox Content="Windows"
                              Foreground="#8B8895"
                              FontSize="12"
                              FontFamily="Consolas" />
                    <CheckBox Content="macOS"
                              Foreground="#8B8895"
                              FontSize="12"
                              FontFamily="Consolas" />
                    <CheckBox Content="iOS"
                              Foreground="#8B8895"
                              FontSize="12"
                              FontFamily="Consolas" />
                    <CheckBox Content="Android"
                              Foreground="#8B8895"
                              FontSize="12"
                              FontFamily="Consolas" />
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="11"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="24"
                            Margin="0,48,0,0">
                    <!-- Begin button (filled) -->
                    <Button x:Name="BeginButton"
                            Click="OnBeginClick"
                            Padding="56,20"
                            Background="#3D3846"
                            BorderThickness="0">
                        <TextBlock Text="BEGIN YOUR DRIFT"
                                   FontSize="12"
                                   Foreground="White"
                                   FontFamily="Consolas"
                                   CharacterSpacing="40" />
                    </Button>

                    <!-- Upload button (outline) -->
                    <Button x:Name="UploadButton"
                            Click="OnUploadClick"
                            Padding="56,20"
                            Background="Transparent"
                            BorderBrush="#B8B6BE"
                            BorderThickness="1">
                        <TextBlock Text="UPLOAD YOUR MEMORY"
                                   FontSize="12"
                                   Foreground="#5D5A66"
                                   FontFamily="Consolas"
                                   CharacterSpacing="40" />
                    </Button>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>

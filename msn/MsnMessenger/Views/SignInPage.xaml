<Page x:Class="MsnMessenger.Views.SignInPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:models="using:MsnMessenger.Models">

    <!-- Neo-Y2K Deep Navy Background -->
    <Grid Background="{StaticResource BackgroundGradientBrush}">

        <!-- Animated Background Orbs -->
        <Canvas IsHitTestVisible="False">
            <!-- Teal Orb - Top Left -->
            <Ellipse x:Name="Circle1" Width="280" Height="280"
                     Canvas.Left="-80" Canvas.Top="-60"
                     Fill="{StaticResource TealOrbBrush}"
                     Opacity="0.3">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Circle1Transform" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- Pink Orb - Top Right -->
            <Ellipse x:Name="Circle2" Width="180" Height="180"
                     Canvas.Left="260" Canvas.Top="60"
                     Fill="{StaticResource PinkOrbBrush}"
                     Opacity="0.25">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Circle2Transform" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- Purple Orb - Bottom Left -->
            <Ellipse x:Name="Circle3" Width="200" Height="200"
                     Canvas.Left="30" Canvas.Top="500"
                     Fill="{StaticResource PurpleOrbBrush}"
                     Opacity="0.25">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Circle3Transform" />
                </Ellipse.RenderTransform>
            </Ellipse>
            <!-- Teal Orb - Bottom Right -->
            <Ellipse x:Name="Circle4" Width="220" Height="220"
                     Canvas.Left="220" Canvas.Top="550"
                     Fill="{StaticResource TealOrbBrush}"
                     Opacity="0.2">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Circle4Transform" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <ScrollViewer>
            <Grid RowDefinitions="Auto,Auto,Auto" Padding="2"
                  utu:SafeArea.Insets="Top,Bottom"
                  MaxWidth="400"
                  HorizontalAlignment="Center">

                <!-- Header with Logo -->
                <StackPanel Grid.Row="0"
                            Spacing="16"
                            Margin="0,32,0,32">
                    <!-- MSN Butterfly Logo with Glow -->
                    <Grid Width="100" Height="100"
                          HorizontalAlignment="Center">
                        <Ellipse Width="80" Height="80"
                                 Fill="{StaticResource TealOrbBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" />
                        <Image Source="ms-appx:///Assets/logos/msn-butterfly-logo.png"
                               Width="64" Height="64"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Stretch="Uniform" />
                    </Grid>

                    <TextBlock Text="Sign In"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" />

                    <TextBlock Text="Welcome back to MSN Messenger"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Sign In Form - Glass Card -->
                <Border Grid.Row="1"
                        Background="{StaticResource GlassBackgroundBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="24"
                        VerticalAlignment="Center"
                        MaxHeight="500">
                    <StackPanel Spacing="12">

                        <!-- Email Field -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Email or Phone"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBox MinHeight="48" x:Name="EmailInput"
                                     PlaceholderText="name@example.com"
                                     Padding="16,14"
                                     CornerRadius="12"
                                     Background="{StaticResource GlassBackgroundBrush}"
                                     BorderBrush="{StaticResource GlassBorderBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <!-- Password Field -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Password"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <PasswordBox x:Name="PasswordInput"
                                         PlaceholderText="Enter your password"
                                         Padding="16,14"
                                         CornerRadius="12"
                                         Background="{StaticResource GlassBackgroundBrush}"
                                         BorderBrush="{StaticResource GlassBorderBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}" />
                        </StackPanel>

                        <!-- Status Selector -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Sign in as"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                            <ComboBox x:Name="StatusComboBox"
                                      HorizontalAlignment="Stretch"
                                      Padding="16,14"
                                      CornerRadius="12"
                                      Background="{StaticResource GlassBackgroundBrush}"
                                      BorderBrush="{StaticResource GlassBorderBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      SelectedIndex="0">
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Ellipse Width="12" Height="12" Fill="#00c896" />
                                        <TextBlock Text="Online" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Ellipse Width="12" Height="12" Fill="#f7b731" />
                                        <TextBlock Text="Away" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Ellipse Width="12" Height="12" Fill="#eb3b5a" />
                                        <TextBlock Text="Busy" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </ComboBoxItem>
                                <ComboBoxItem>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <Ellipse Width="12" Height="12" Fill="#4a4a4a" />
                                        <TextBlock Text="Appear Offline" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <!-- Remember Me -->
                        <CheckBox x:Name="RememberMeCheckBox"
                                  Content="Remember me"
                                  IsChecked="True"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  Margin="0,8,0,0" />

                        <!-- Sign In Button - Teal Gradient -->
                        <Button x:Name="SignInButton"
                                Content="Sign In"
                                Click="OnSignInClick"
                                HorizontalAlignment="Stretch"
                                Padding="16,16"
                                Margin="0,8,0,0"
                                Background="{StaticResource CtaGradientBrush}"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="SemiBold"
                                CornerRadius="25"
                                BorderThickness="0" />

                        <!-- Forgot Password Link -->
                        <HyperlinkButton Content="Forgot your password?"
                                         HorizontalAlignment="Center"
                                         Foreground="{StaticResource TealPrimaryBrush}" />
                    </StackPanel>
                </Border>

                <!-- Footer -->
                <StackPanel Grid.Row="2"
                            Spacing="16"
                            Margin="0,24,0,16">
                    <!-- Divider -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="1" Background="{StaticResource GlassBorderBrush}" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="or" Margin="16,0" Foreground="{StaticResource TextMutedBrush}" />
                        <Border Grid.Column="2" Height="1" Background="{StaticResource GlassBorderBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <!-- Create Account Button - Glass Style -->
                    <Button Content="Create new account"
                            HorizontalAlignment="Stretch"
                            Padding="16,14"
                            Background="{StaticResource GlassBackgroundBrush}"
                            BorderBrush="{StaticResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="25"
                            Foreground="{StaticResource TextPrimaryBrush}" />

                    <!-- Terms Text -->
                    <TextBlock Text="By signing in, you agree to our Terms of Service and Privacy Policy"
                               FontSize="12"
                               Foreground="{StaticResource TextMutedBrush}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
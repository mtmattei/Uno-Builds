<UserControl
    x:Class="MsnMessenger.Views.RecentChatsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MsnMessenger.Controls"
    xmlns:models="using:MsnMessenger.Models"
    xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Background="{ThemeResource BackgroundBrush}">
        <ScrollViewer>
            <StackPanel>
                <!-- Gradient Header -->
                <Border Background="{StaticResource HeaderGradientBrush}"
                        Padding="16,14,16,24">
                    <Grid>
                        <Ellipse Width="80" Height="80"
                                 Fill="#14FFFFFF"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-20,-20,0" />

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🦋" FontSize="28" />
                            <TextBlock Text="Recent Chats"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Chats List -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="16,-12,16,16">
                    <ItemsControl x:Name="ChatsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Chat">
                                <Button HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        Padding="12,14"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource OutlineVariantBrush}"
                                        Click="OnChatClick"
                                        Tag="{x:Bind}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <controls:AvatarControl Size="46"
                                                                 Initials="{x:Bind Contact.Initials}"
                                                                 Status="{x:Bind Contact.Status}"
                                                                 FrameColor="{x:Bind Contact.FrameColor}" />

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Contact.DisplayName}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="6">
                                            <TextBlock Text="{x:Bind TimeDisplay}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                                       HorizontalAlignment="Right" />

                                            <Border Background="{StaticResource NudgeGradientBrush}"
                                                    CornerRadius="10"
                                                    MinWidth="20"
                                                    Height="20"
                                                    Padding="6,0"
                                                    HorizontalAlignment="Right"
                                                    Visibility="{x:Bind UnreadCount, Converter={StaticResource IntToVisibilityConverter}}">
                                                <TextBlock Text="{x:Bind UnreadCount}"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState"
                            Visibility="Collapsed"
                            HorizontalAlignment="Center"
                            Margin="0,60,0,0"
                            Spacing="12">
                    <TextBlock Text="💬"
                               FontSize="48"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="No recent conversations"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OnSurfaceBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Select a buddy to start chatting!"
                               FontSize="14"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

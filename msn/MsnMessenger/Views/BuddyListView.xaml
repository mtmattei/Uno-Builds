<UserControl
    x:Class="MsnMessenger.Views.BuddyListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MsnMessenger.Controls"
    xmlns:models="using:MsnMessenger.Models"
    xmlns:utu="using:Uno.Toolkit.UI">

    <!-- Sidebar with Glass Effect -->
    <Border Background="{StaticResource GlassBackgroundBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="0,0,1,0"
            CornerRadius="0,0,0,24">
        <Grid>
            <ScrollViewer>
                <StackPanel>
                    <!-- ═══════════════════════════════════════════════════════════════════ -->
                    <!-- MY PROFILE SECTION -->
                    <!-- ═══════════════════════════════════════════════════════════════════ -->
                    <Border Background="{StaticResource HeaderGradientBrush}"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <!-- Avatar + Status Row -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Large Avatar (56px) with Status Dot -->
                                <Grid Width="56" Height="56">
                                    <Border CornerRadius="16" Background="{StaticResource GlassHighlightBrush}">
                                        <controls:AvatarControl x:Name="UserAvatar"
                                                                 Size="52"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center" />
                                    </Border>
                                    <!-- Status Indicator Dot -->
                                    <Ellipse x:Name="ProfileStatusDot"
                                             Width="14" Height="14"
                                             Fill="{StaticResource OnlineBrush}"
                                             Stroke="{StaticResource DeepNavyBrush}"
                                             StrokeThickness="2"
                                             HorizontalAlignment="Right"
                                             VerticalAlignment="Bottom" />
                                </Grid>

                                <!-- Name + Status -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="4">
                                    <!-- Display Name - Clickable to Edit -->
                                    <Button x:Name="DisplayNameButton"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalAlignment="Left"
                                            Click="OnDisplayNameClick">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock x:Name="DisplayNameText"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="&#xE70F;"
                                                       FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>

                                    <!-- Display Name Edit TextBox -->
                                    <TextBox x:Name="DisplayNameEditBox"
                                             FontSize="16"
                                             FontWeight="SemiBold"
                                             Background="{StaticResource GlassBackgroundBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderThickness="1"
                                             BorderBrush="{StaticResource TealPrimaryBrush}"
                                             CornerRadius="8"
                                             Padding="8,4"
                                             MaxWidth="180"
                                             Visibility="Collapsed"
                                             KeyDown="OnDisplayNameKeyDown"
                                             LostFocus="OnDisplayNameLostFocus" />

                                    <!-- Status Text -->
                                    <TextBlock x:Name="StatusText"
                                               FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <!-- Personal Message - Editable -->
                            <Button x:Name="PersonalMessageButton"
                                    Background="{StaticResource GlassBackgroundBrush}"
                                    BorderBrush="{StaticResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12,8"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Click="OnPersonalMessageClick">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PersonalMessageText"
                                               FontSize="13"
                                               FontStyle="Italic"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Text="What's on your mind?" />
                                    <TextBlock Grid.Column="1"
                                               Text="&#xE70F;"
                                               FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                               FontSize="12"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center"
                                               Margin="8,0,0,0" />
                                </Grid>
                            </Button>

                            <!-- Personal Message Edit TextBox -->
                            <TextBox x:Name="PersonalMessageEditBox"
                                     FontSize="13"
                                     FontStyle="Italic"
                                     Background="{StaticResource GlassBackgroundBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     BorderThickness="1"
                                     BorderBrush="{StaticResource TealPrimaryBrush}"
                                     CornerRadius="8"
                                     Padding="12,8"
                                     PlaceholderText="What's on your mind?"
                                     HorizontalAlignment="Stretch"
                                     Visibility="Collapsed"
                                     KeyDown="OnPersonalMessageKeyDown"
                                     LostFocus="OnPersonalMessageLostFocus" />

                            <!-- Status Selector (4 buttons) -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                        Background="{StaticResource GlassBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="0,0,4,0"
                                        BorderThickness="0"
                                        Click="OnStatusSelected"
                                        Tag="Online"
                                        ToolTipService.ToolTip="Online">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource OnlineBrush}" />
                                </Button>
                                <Button Grid.Column="1"
                                        Background="{StaticResource GlassBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="2,0"
                                        BorderThickness="0"
                                        Click="OnStatusSelected"
                                        Tag="Away"
                                        ToolTipService.ToolTip="Away">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource AwayBrush}" />
                                </Button>
                                <Button Grid.Column="2"
                                        Background="{StaticResource GlassBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="2,0"
                                        BorderThickness="0"
                                        Click="OnStatusSelected"
                                        Tag="Busy"
                                        ToolTipService.ToolTip="Busy">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource BusyBrush}" />
                                </Button>
                                <Button Grid.Column="3"
                                        Background="{StaticResource GlassBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="4,0,0,0"
                                        BorderThickness="0"
                                        Click="OnStatusSelected"
                                        Tag="Offline"
                                        ToolTipService.ToolTip="Appear Offline">
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource OfflineBrush}" />
                                </Button>
                            </Grid>

                            <!-- ═══════════════════════════════════════════════════════════════════ -->
                            <!-- NOW PLAYING - Spotify Integration -->
                            <!-- ═══════════════════════════════════════════════════════════════════ -->
                            <Border x:Name="NowPlayingCard"
                                    Background="{StaticResource GlassBackgroundBrush}"
                                    BorderBrush="{StaticResource GlassBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Album Art -->
                                    <Border Width="44" Height="44"
                                            CornerRadius="8"
                                            Background="{StaticResource PurpleOrbBrush}">
                                        <Grid>
                                            <!-- Spotify Icon Fallback -->
                                            <TextBlock Text="&#x1F3B5;"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <!-- Album Art Image -->
                                            <Image x:Name="AlbumArtImage"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <!-- Track Info -->
                                    <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Spacing="2">
                                        <!-- Spotify Badge -->
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <TextBlock Text="&#x1F3A7;" FontSize="10" />
                                            <TextBlock Text="LISTENING TO"
                                                       FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SpotifyGreenBrush}"
                                                       CharacterSpacing="80" />
                                        </StackPanel>

                                        <!-- Track Name -->
                                        <TextBlock x:Name="TrackNameText"
                                                   Text="Around the World"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />

                                        <!-- Artist Name -->
                                        <TextBlock x:Name="ArtistNameText"
                                                   Text="Daft Punk"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />

                                        <!-- Progress Bar -->
                                        <Grid Margin="0,4,0,0">
                                            <Border Height="3"
                                                    Background="{StaticResource GlassBorderBrush}"
                                                    CornerRadius="1.5" />
                                            <Border x:Name="ProgressBar"
                                                    Height="3"
                                                    Background="{StaticResource SpotifyGreenBrush}"
                                                    CornerRadius="1.5"
                                                    HorizontalAlignment="Left"
                                                    Width="60" />
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════════════════════════════════════════════════════════════ -->
                    <!-- CONTACTS SECTION -->
                    <!-- ═══════════════════════════════════════════════════════════════════ -->
                    <Border Padding="16,12">
                        <!-- Section Header -->
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="contacts"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       CharacterSpacing="100" />
                            <TextBlock x:Name="OnlineCountText"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{StaticResource TealPrimaryBrush}" />
                        </Grid>
                    </Border>

                    <!-- Contact Groups -->
                    <ItemsControl x:Name="GroupsList" Margin="8,0,8,16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ContactGroup">
                                <StackPanel Margin="0,0,0,8">
                                    <!-- Group Header -->
                                    <Button HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Background="{StaticResource GlassBackgroundBrush}"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            BorderThickness="0"
                                            Click="OnGroupHeaderClick"
                                            Tag="{x:Bind}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{x:Bind ArrowText, Mode=OneWay}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0" />

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Emoji}" FontSize="14" />
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind CountDisplay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextMutedBrush}" />
                                        </Grid>
                                    </Button>

                                    <!-- Contacts List -->
                                    <ItemsControl ItemsSource="{x:Bind Contacts}"
                                                  Visibility="{x:Bind ContactsVisibility, Mode=OneWay}"
                                                  Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Contact">
                                                <Button HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        Padding="12,8"
                                                        BorderThickness="0"
                                                        CornerRadius="8"
                                                        Click="OnContactClick"
                                                        Tag="{x:Bind}"
                                                        Opacity="{x:Bind Status, Converter={StaticResource StatusToOpacityConverter}}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Avatar with Status -->
                                                        <Grid Width="44" Height="44">
                                                            <controls:AvatarControl Size="44"
                                                                                     Initials="{x:Bind Initials}"
                                                                                     Status="{x:Bind Status}"
                                                                                     FrameColor="{x:Bind FrameColor}" />
                                                            <!-- Status Dot -->
                                                            <Ellipse Width="12" Height="12"
                                                                     Fill="{x:Bind Status, Converter={StaticResource StatusToColorConverter}}"
                                                                     Stroke="{StaticResource DeepNavyBrush}"
                                                                     StrokeThickness="2"
                                                                     HorizontalAlignment="Right"
                                                                     VerticalAlignment="Bottom" />
                                                        </Grid>

                                                        <!-- Name + Status Message -->
                                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="{x:Bind DisplayName}"
                                                                           FontSize="14"
                                                                           FontWeight="Medium"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <!-- Music indicator when listening to Spotify -->
                                                                <TextBlock Text="&#x1F3B5;"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="{x:Bind NowPlaying, Converter={StaticResource NullToVisibilityConverter}}" />
                                                            </StackPanel>
                                                            <TextBlock Text="{x:Bind PersonalMessage}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Visibility="{x:Bind PersonalMessage, Converter={StaticResource StringNotEmptyConverter}}" />
                                                        </StackPanel>

                                                        <!-- Unread Badge -->
                                                        <Border Grid.Column="2"
                                                                Style="{StaticResource UnreadBadgeStyle}"
                                                                Visibility="{x:Bind UnreadCount, Converter={StaticResource IntToVisibilityConverter}}"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind UnreadCount}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="White"
                                                                       HorizontalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>

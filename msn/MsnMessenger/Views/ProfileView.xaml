<UserControl
    x:Class="MsnMessenger.Views.ProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MsnMessenger.Controls"
    xmlns:utu="using:Uno.Toolkit.UI">

    <Grid Background="{ThemeResource BackgroundBrush}">
        <ScrollViewer>
            <StackPanel>
                <!-- Gradient Header with Avatar -->
                <Border Background="{StaticResource HeaderGradientBrush}"
                        Padding="16,14,16,50">
                    <Grid>
                        <Ellipse Width="120" Height="120"
                                 Fill="#10FFFFFF"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Top"
                                 Margin="0,-40,-40,0" />
                        <Ellipse Width="70" Height="70"
                                 Fill="#0DFFFFFF"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Bottom"
                                 Margin="-20,0,0,-30" />

                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <!-- Settings button -->
                            <Button HorizontalAlignment="Right"
                                    Margin="0,0,0,8"
                                    Background="#26FFFFFF"
                                    CornerRadius="20"
                                    Width="40" Height="40"
                                    Padding="0">
                                <TextBlock Text="⚙️" FontSize="18" />
                            </Button>

                            <!-- Large Avatar -->
                            <controls:AvatarControl x:Name="ProfileAvatar"
                                                     Size="80"
                                                     ShowStatus="Visible"
                                                     HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Display Name Section -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="16,-24,16,12"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="✏️" FontSize="14" />
                            <TextBlock Text="Display Name"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>

                        <!-- Display Mode -->
                        <Button x:Name="DisplayNameButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="{ThemeResource OutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Click="OnEditNameClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="DisplayNameText"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource OnSurfaceBrush}" />
                                <TextBlock Grid.Column="1" Text="✏️" FontSize="14" />
                            </Grid>
                        </Button>

                        <!-- Edit Mode -->
                        <StackPanel x:Name="EditNamePanel" Visibility="Collapsed" Spacing="8">
                            <TextBox x:Name="NameInput"
                                     PlaceholderText="Enter your display name"
                                     BorderBrush="{ThemeResource PrimaryBrush}"
                                     BorderThickness="2" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Click="OnCancelNameClick" />
                                <Button Content="Save"
                                        Background="{StaticResource CtaGradientBrush}"
                                        Foreground="White"
                                        Click="OnSaveNameClick" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="Add emojis, ~*symbols*~, or whatever makes you YOU!"
                                   FontSize="11"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   FontStyle="Italic" />
                    </StackPanel>
                </Border>

                <!-- Status Section -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="16,0,16,12"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="🎭" FontSize="14" />
                            <TextBlock Text="Status"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>

                        <!-- Status Options -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Click="OnStatusClick" Tag="Online"
                                    Background="Transparent" CornerRadius="8" Padding="8,10" Margin="0,0,4,0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#00CC66" HorizontalAlignment="Center" />
                                    <TextBlock Text="Online" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" Click="OnStatusClick" Tag="Away"
                                    Background="Transparent" CornerRadius="8" Padding="8,10" Margin="2,0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#FFB800" HorizontalAlignment="Center" />
                                    <TextBlock Text="Away" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" Click="OnStatusClick" Tag="Busy"
                                    Background="Transparent" CornerRadius="8" Padding="8,10" Margin="2,0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#FF3B30" HorizontalAlignment="Center" />
                                    <TextBlock Text="Busy" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" Click="OnStatusClick" Tag="Offline"
                                    Background="Transparent" CornerRadius="8" Padding="8,10" Margin="4,0,0,0">
                                <StackPanel Spacing="4" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="#8E8E93" HorizontalAlignment="Center" />
                                    <TextBlock Text="Offline" FontSize="11" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Personal Message Section -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="16,0,16,12"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="💬" FontSize="14" />
                            <TextBlock Text="Personal Message"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                        </StackPanel>

                        <Button x:Name="MessageButton"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderBrush="{ThemeResource OutlineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10"
                                Click="OnEditMessageClick">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PersonalMessageText"
                                           FontSize="14"
                                           FontStyle="Italic"
                                           Foreground="{ThemeResource OnSurfaceBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="✏️" FontSize="14" />
                            </Grid>
                        </Button>

                        <!-- Edit Message Mode -->
                        <StackPanel x:Name="EditMessagePanel" Visibility="Collapsed" Spacing="8">
                            <TextBox x:Name="MessageInput"
                                     PlaceholderText="What's on your mind?"
                                     BorderBrush="{ThemeResource PrimaryBrush}"
                                     BorderThickness="2" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Click="OnCancelMessageClick" />
                                <Button Content="Save"
                                        Background="{StaticResource CtaGradientBrush}"
                                        Foreground="White"
                                        Click="OnSaveMessageClick" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Quick presets -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="🎵 Music" Click="OnQuickMessageClick" Tag="🎵 Listening to music..."
                                    Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12" Padding="10,6" FontSize="11" />
                            <Button Content="🎮 Gaming" Click="OnQuickMessageClick" Tag="🎮 Gaming..."
                                    Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12" Padding="10,6" FontSize="11" />
                            <Button Content="💤 brb" Click="OnQuickMessageClick" Tag="💤 brb"
                                    Background="{ThemeResource SurfaceVariantBrush}" CornerRadius="12" Padding="10,6" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Stats Section -->
                <Grid Margin="16,0,16,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,6,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="👥" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="BuddyCountText"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Buddies"
                                       FontSize="10"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="3,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="💬" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="MessageCountText"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Messages"
                                       FontSize="10"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Background="{ThemeResource SurfaceBrush}"
                            BorderBrush="{ThemeResource OutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="12"
                            Margin="6,0,0,0">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="👊" FontSize="20" HorizontalAlignment="Center" />
                            <TextBlock x:Name="NudgeCountText"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource PrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Nudges"
                                       FontSize="10"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Footer -->
                <StackPanel HorizontalAlignment="Center" Spacing="4" Margin="0,0,0,24">
                    <TextBlock Text="🦋" FontSize="24" HorizontalAlignment="Center" />
                    <TextBlock Text="MSN Messenger"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Version 2026.1.0"
                               FontSize="11"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl
    x:Class="MsnMessenger.Views.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:MsnMessenger.Controls"
    xmlns:models="using:MsnMessenger.Models"
    xmlns:utu="using:Uno.Toolkit.UI">

    <!-- Neo-Y2K Chat Window - Dark Glassmorphism -->
    <Grid x:Name="ChatContainer">
        <Grid.RowDefinitions>
            <!-- Chat Header -->
            <RowDefinition Height="Auto" />
            <!-- Live Activity Card -->
            <RowDefinition Height="Auto" />
            <!-- Messages Area -->
            <RowDefinition Height="*" />
            <!-- Emoji/Wink Panel -->
            <RowDefinition Height="Auto" />
            <!-- Input Area -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- CHAT HEADER -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderGradientBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource GlassBorderBrush}"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Back Button (mobile) + Contact Avatar -->
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Button Background="{StaticResource GlassBackgroundBrush}"
                            CornerRadius="18"
                            Width="36" Height="36"
                            Padding="0"
                            BorderThickness="0"
                            Click="OnBackClick">
                        <FontIcon Glyph="&#xE72B;" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" />
                    </Button>

                    <!-- Contact Avatar with Status -->
                    <Grid Width="44" Height="44">
                        <controls:AvatarControl x:Name="ContactAvatar"
                                                 Size="44"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                        <Ellipse Width="12" Height="12"
                                 Fill="{StaticResource OnlineBrush}"
                                 Stroke="{StaticResource DeepNavyBrush}"
                                 StrokeThickness="2"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Bottom" />
                    </Grid>
                </StackPanel>

                <!-- Contact Info -->
                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ContactNameText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="ContactStatusText"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Video Call">
                        <FontIcon Glyph="&#xE714;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Voice Call">
                        <FontIcon Glyph="&#xE717;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Screen Share">
                        <FontIcon Glyph="&#xE7F4;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- LIVE ACTIVITY CARD -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <controls:LiveActivityCard x:Name="ActivityCard"
                                    Grid.Row="1"
                                    Margin="16,0"
                                    Visibility="Collapsed" />

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- MESSAGES AREA -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" x:Name="MessagesScroller">
            <Grid Padding="16,12">
                <ItemsControl x:Name="MessagesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Message">
                            <Grid Margin="0,6"
                                  HorizontalAlignment="{x:Bind IsSentByMe, Converter={StaticResource MessageAlignmentConverter}}">
                                <StackPanel MaxWidth="320">
                                    <!-- Message Bubble -->
                                    <Border Padding="14,10"
                                            CornerRadius="18">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="BubbleBg" Color="{StaticResource GlassBackground}" />
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind Text}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </Border>

                                    <!-- Timestamp -->
                                    <TextBlock Text="{x:Bind TimeDisplay}"
                                               FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               Margin="4,4,4,0"
                                               HorizontalAlignment="{x:Bind IsSentByMe, Converter={StaticResource MessageAlignmentConverter}}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- EMOJI/WINK PANEL -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                x:Name="WinkPanel"
                Background="{StaticResource GlassBackgroundBrush}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Margin="16,0,16,8"
                Padding="12"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="0,0,0,8">
                    <TextBlock Text="Send an Effect"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <Button HorizontalAlignment="Right"
                            Background="Transparent"
                            Padding="4"
                            BorderThickness="0"
                            Click="OnCloseWinkPanel">
                        <FontIcon Glyph="&#xE711;" FontSize="14" Foreground="{StaticResource TextMutedBrush}" />
                    </Button>
                </Grid>

                <!-- Standard Emojis -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                    <Button Click="OnEmojiClick" Tag="&#x1F602;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F602;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x2764;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x2764;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F525;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F525;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x2728;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x2728;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F480;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F480;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F62D;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F62D;" FontSize="20" />
                    </Button>
                </StackPanel>

                <!-- Winks (Special) -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="4">
                    <Button Click="OnEmojiClick" Tag="&#x1F98B;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F98B;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x2B50;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x2B50;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F308;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F308;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F3B5;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F3B5;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F4AB;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F4AB;" FontSize="20" />
                    </Button>
                    <Button Click="OnEmojiClick" Tag="&#x1F380;" Style="{StaticResource WinkButtonStyle}">
                        <TextBlock Text="&#x1F380;" FontSize="20" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <!-- INPUT AREA -->
        <!-- ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource GlassBackgroundBrush}"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource GlassBorderBrush}"
                Padding="16"
                CornerRadius="0,0,24,0">
            <StackPanel Spacing="12">
                <!-- Action Buttons Row -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Click="OnToggleWinkPanel"
                            ToolTipService.ToolTip="Emoji">
                        <TextBlock Text="&#x1F60A;" FontSize="18" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Attach File">
                        <FontIcon Glyph="&#xE723;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Voice Message">
                        <FontIcon Glyph="&#xE720;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                    <Button Style="{StaticResource IconButtonStyle}"
                            Click="OnNudgeClick"
                            ToolTipService.ToolTip="Send Nudge">
                        <TextBlock Text="&#x1F44A;" FontSize="18" />
                    </Button>
                </StackPanel>

                <!-- Input Row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Text Input -->
                    <Border Background="{StaticResource GlassBackgroundBrush}"
                            BorderBrush="{StaticResource GlassBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="25"
                            Padding="4,0">
                        <TextBox x:Name="MessageInput"
                                 PlaceholderText="Type a message..."
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="14,12"
                                 FontSize="14"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 TextChanged="OnMessageTextChanged"
                                 KeyDown="OnMessageKeyDown" />
                    </Border>

                    <!-- Send Button (50px square, teal gradient) -->
                    <Button x:Name="SendButton"
                            Grid.Column="1"
                            Style="{StaticResource SendButtonStyle}"
                            Margin="12,0,0,0"
                            Click="OnSendOrNudgeClick">
                        <FontIcon x:Name="SendButtonIcon"
                                  Glyph="&#xE724;"
                                  FontSize="20"
                                  Foreground="White" />
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MsnMessenger.Converters">

    <!-- Neo-Y2K Glassmorphism Button Hover States -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="FilledButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="FilledButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="TextButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="TextButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="OutlinedButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="OutlinedButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#14FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="FilledButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="FilledButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="TextButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="TextButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="OutlinedButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="OutlinedButtonBackgroundPressed" Color="#14FFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#0DFFFFFF" />
            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#14FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Converters -->
    <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
    <converters:StatusToTextConverter x:Key="StatusToTextConverter" />
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
    <converters:MessageAlignmentConverter x:Key="MessageAlignmentConverter" />
    <converters:StatusToOpacityConverter x:Key="StatusToOpacityConverter" />
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BACKGROUND COLORS - Deep Navy Palette -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Color x:Key="DeepNavy">#0d0d1a</Color>
    <Color x:Key="DarkBlue">#1a1a2e</Color>
    <Color x:Key="OceanBlue">#0f2027</Color>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ACCENT COLORS -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Color x:Key="TealPrimary">#00c896</Color>
    <Color x:Key="TealLight">#00e6ac</Color>
    <Color x:Key="CyanSecondary">#00a8cc</Color>
    <Color x:Key="PinkAccent">#ff6b9d</Color>
    <Color x:Key="PinkDark">#c44569</Color>
    <Color x:Key="PurpleAccent">#6366f1</Color>
    <Color x:Key="PurpleDark">#4f46e5</Color>
    <Color x:Key="AmberAccent">#fbbf24</Color>
    <Color x:Key="SpotifyGreen">#1DB954</Color>
    <Color x:Key="SpotifyGreenLight">#1ed760</Color>
    <Color x:Key="GamingRed">#ff4655</Color>
    <Color x:Key="GamingCoral">#ff6b7a</Color>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STATUS COLORS -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Color x:Key="PresenceOnline">#00c896</Color>
    <Color x:Key="PresenceOnlineLight">#00e6ac</Color>
    <Color x:Key="PresenceAway">#f7b731</Color>
    <Color x:Key="PresenceAwayLight">#f5cd79</Color>
    <Color x:Key="PresenceBusy">#eb3b5a</Color>
    <Color x:Key="PresenceBusyLight">#fc5c65</Color>
    <Color x:Key="PresenceOffline">#4a4a4a</Color>
    <Color x:Key="PresenceOfflineLight">#6a6a6a</Color>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- UI/GLASS COLORS -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Color x:Key="GlassBackground">#08FFFFFF</Color>
    <Color x:Key="GlassBackgroundHover">#0DFFFFFF</Color>
    <Color x:Key="GlassBackgroundActive">#14FFFFFF</Color>
    <Color x:Key="GlassBorder">#14FFFFFF</Color>
    <Color x:Key="GlassBorderHover">#1AFFFFFF</Color>
    <Color x:Key="GlassHighlight">#10FFFFFF</Color>
    <Color x:Key="GlassInnerShadow">#26000000</Color>
    <Color x:Key="SidebarBackground">#26000000</Color>
    <Color x:Key="SurfaceOverlay">#66000000</Color>
    <Color x:Key="SurfaceInput">#0FFFFFFF</Color>
    <Color x:Key="BorderFocus">#4D00c896</Color>
    <Color x:Key="TextPrimary">#FFFFFF</Color>
    <Color x:Key="TextSecondary">#99FFFFFF</Color>
    <Color x:Key="TextMuted">#80FFFFFF</Color>
    <Color x:Key="TextHint">#66FFFFFF</Color>
    <Color x:Key="TextDisabled">#40FFFFFF</Color>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SPACING SCALE (4px base) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="SpacingXs">4</x:Double>
    <x:Double x:Key="SpacingSm">8</x:Double>
    <x:Double x:Key="SpacingMd">12</x:Double>
    <x:Double x:Key="SpacingLg">16</x:Double>
    <x:Double x:Key="SpacingXl">24</x:Double>
    <x:Double x:Key="SpacingXxl">32</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- RADIUS SCALE -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="RadiusSm">6</CornerRadius>
    <CornerRadius x:Key="RadiusMd">10</CornerRadius>
    <CornerRadius x:Key="RadiusLg">14</CornerRadius>
    <CornerRadius x:Key="RadiusXl">20</CornerRadius>
    <CornerRadius x:Key="RadiusXxl">28</CornerRadius>
    <CornerRadius x:Key="RadiusFull">100</CornerRadius>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY SCALE -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <x:Double x:Key="FontSizeXs">10</x:Double>
    <x:Double x:Key="FontSizeSm">12</x:Double>
    <x:Double x:Key="FontSizeMd">14</x:Double>
    <x:Double x:Key="FontSizeLg">16</x:Double>
    <x:Double x:Key="FontSizeXl">20</x:Double>
    <x:Double x:Key="FontSizeXxl">28</x:Double>
    <x:Double x:Key="FontSizeDisplay">36</x:Double>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- SOLID BRUSHES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <SolidColorBrush x:Key="DeepNavyBrush" Color="{StaticResource DeepNavy}" />
    <SolidColorBrush x:Key="DarkBlueBrush" Color="{StaticResource DarkBlue}" />
    <SolidColorBrush x:Key="OceanBlueBrush" Color="{StaticResource OceanBlue}" />
    <SolidColorBrush x:Key="TealPrimaryBrush" Color="{StaticResource TealPrimary}" />
    <SolidColorBrush x:Key="TealLightBrush" Color="{StaticResource TealLight}" />
    <SolidColorBrush x:Key="CyanSecondaryBrush" Color="{StaticResource CyanSecondary}" />
    <SolidColorBrush x:Key="PinkAccentBrush" Color="{StaticResource PinkAccent}" />
    <SolidColorBrush x:Key="PinkDarkBrush" Color="{StaticResource PinkDark}" />
    <SolidColorBrush x:Key="PurpleAccentBrush" Color="{StaticResource PurpleAccent}" />
    <SolidColorBrush x:Key="PurpleDarkBrush" Color="{StaticResource PurpleDark}" />
    <SolidColorBrush x:Key="SpotifyGreenBrush" Color="{StaticResource SpotifyGreen}" />
    <SolidColorBrush x:Key="GlassBackgroundBrush" Color="{StaticResource GlassBackground}" />
    <SolidColorBrush x:Key="GlassBackgroundHoverBrush" Color="{StaticResource GlassBackgroundHover}" />
    <SolidColorBrush x:Key="GlassBackgroundActiveBrush" Color="{StaticResource GlassBackgroundActive}" />
    <SolidColorBrush x:Key="GlassBorderBrush" Color="{StaticResource GlassBorder}" />
    <SolidColorBrush x:Key="GlassBorderHoverBrush" Color="{StaticResource GlassBorderHover}" />
    <SolidColorBrush x:Key="GlassHighlightBrush" Color="{StaticResource GlassHighlight}" />
    <SolidColorBrush x:Key="GlassInnerShadowBrush" Color="{StaticResource GlassInnerShadow}" />
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabled}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="TextHintBrush" Color="{StaticResource TextHint}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
    <SolidColorBrush x:Key="SurfaceOverlayBrush" Color="{StaticResource SurfaceOverlay}" />
    <SolidColorBrush x:Key="SurfaceInputBrush" Color="{StaticResource SurfaceInput}" />
    <SolidColorBrush x:Key="BorderFocusBrush" Color="{StaticResource BorderFocus}" />
    <SolidColorBrush x:Key="AmberAccentBrush" Color="{StaticResource AmberAccent}" />
    <SolidColorBrush x:Key="GamingRedBrush" Color="{StaticResource GamingRed}" />
    <SolidColorBrush x:Key="GamingCoralBrush" Color="{StaticResource GamingCoral}" />

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="OnlineBrush" Color="{StaticResource PresenceOnline}" />
    <SolidColorBrush x:Key="AwayBrush" Color="{StaticResource PresenceAway}" />
    <SolidColorBrush x:Key="BusyBrush" Color="{StaticResource PresenceBusy}" />
    <SolidColorBrush x:Key="OfflineBrush" Color="{StaticResource PresenceOffline}" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- GRADIENT BRUSHES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Main Background Gradient - Deep Navy -->
    <LinearGradientBrush x:Key="BackgroundGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource DeepNavy}" Offset="0" />
        <GradientStop Color="{StaticResource DarkBlue}" Offset="0.5" />
        <GradientStop Color="{StaticResource OceanBlue}" Offset="1" />
    </LinearGradientBrush>

    <!-- Header Gradient - Teal overlay on glass -->
    <LinearGradientBrush x:Key="HeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A00c896" Offset="0" />
        <GradientStop Color="#0D00a8cc" Offset="1" />
    </LinearGradientBrush>

    <!-- CTA/Primary Button Gradient - Teal to Cyan -->
    <LinearGradientBrush x:Key="CtaGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource TealPrimary}" Offset="0" />
        <GradientStop Color="{StaticResource CyanSecondary}" Offset="1" />
    </LinearGradientBrush>

    <!-- Notification/Badge Gradient - Pink -->
    <LinearGradientBrush x:Key="NotificationGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PinkAccent}" Offset="0" />
        <GradientStop Color="{StaticResource PinkDark}" Offset="1" />
    </LinearGradientBrush>

    <!-- Nudge Gradient - Pink accent -->
    <LinearGradientBrush x:Key="NudgeGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PinkAccent}" Offset="0" />
        <GradientStop Color="{StaticResource PinkDark}" Offset="1" />
    </LinearGradientBrush>

    <!-- Sent Message Bubble Gradient - Teal -->
    <LinearGradientBrush x:Key="SentBubbleGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource TealPrimary}" Offset="0" />
        <GradientStop Color="{StaticResource CyanSecondary}" Offset="1" />
    </LinearGradientBrush>

    <!-- Status Gradients -->
    <LinearGradientBrush x:Key="OnlineGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PresenceOnline}" Offset="0" />
        <GradientStop Color="{StaticResource PresenceOnlineLight}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AwayGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PresenceAway}" Offset="0" />
        <GradientStop Color="{StaticResource PresenceAwayLight}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BusyGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PresenceBusy}" Offset="0" />
        <GradientStop Color="{StaticResource PresenceBusyLight}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OfflineGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource PresenceOffline}" Offset="0" />
        <GradientStop Color="{StaticResource PresenceOfflineLight}" Offset="1" />
    </LinearGradientBrush>

    <!-- Orb Gradients for Background Animation -->
    <RadialGradientBrush x:Key="TealOrbBrush">
        <GradientStop Color="#6600c896" Offset="0" />
        <GradientStop Color="#0000c896" Offset="0.7" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="PinkOrbBrush">
        <GradientStop Color="#59ff6b9d" Offset="0" />
        <GradientStop Color="#00ff6b9d" Offset="0.7" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="PurpleOrbBrush">
        <GradientStop Color="#4D6366f1" Offset="0" />
        <GradientStop Color="#006366f1" Offset="0.7" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="AmberOrbBrush">
        <GradientStop Color="#40fbbf24" Offset="0" />
        <GradientStop Color="#00fbbf24" Offset="0.7" />
    </RadialGradientBrush>

    <!-- Activity Gradients -->
    <LinearGradientBrush x:Key="SpotifyGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource SpotifyGreen}" Offset="0" />
        <GradientStop Color="{StaticResource SpotifyGreenLight}" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="GamingGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource GamingRed}" Offset="0" />
        <GradientStop Color="{StaticResource GamingCoral}" Offset="1" />
    </LinearGradientBrush>

    <!-- Chat-specific gradients (legacy support) -->
    <Color x:Key="ChatPrimaryPurple">#667eea</Color>
    <Color x:Key="ChatPrimaryViolet">#764ba2</Color>
    <Color x:Key="ChatPrimaryPink">#f093fb</Color>
    <Color x:Key="MsnBlue">#4FC3F7</Color>
    <Color x:Key="MsnOrange">#FF8A65</Color>
    <Color x:Key="MsnGreen">#81C784</Color>
    <Color x:Key="MsnYellow">#FFD54F</Color>
    <Color x:Key="ChatTextPrimary">#FFFFFF</Color>
    <Color x:Key="ChatTextSecondary">#99FFFFFF</Color>
    <Color x:Key="ChatTextMuted">#66FFFFFF</Color>

    <SolidColorBrush x:Key="MsnBlueBrush" Color="{StaticResource MsnBlue}" />
    <SolidColorBrush x:Key="MsnOrangeBrush" Color="{StaticResource MsnOrange}" />
    <SolidColorBrush x:Key="MsnGreenBrush" Color="{StaticResource MsnGreen}" />
    <SolidColorBrush x:Key="MsnYellowBrush" Color="{StaticResource MsnYellow}" />
    <SolidColorBrush x:Key="ChatTextPrimaryBrush" Color="{StaticResource ChatTextPrimary}" />
    <SolidColorBrush x:Key="ChatTextSecondaryBrush" Color="{StaticResource ChatTextSecondary}" />
    <SolidColorBrush x:Key="ChatTextMutedBrush" Color="{StaticResource ChatTextMuted}" />

    <LinearGradientBrush x:Key="ChatTitleBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A00c896" Offset="0" />
        <GradientStop Color="#0D00a8cc" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ChatToolbarBrush" Color="#0DFFFFFF" />

    <LinearGradientBrush x:Key="ChatContactHeaderGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A00c896" Offset="0" />
        <GradientStop Color="#0D00a8cc" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ChatInputAreaBrush" Color="#0DFFFFFF" />

    <LinearGradientBrush x:Key="ChatSendButtonGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource TealPrimary}" Offset="0" />
        <GradientStop Color="{StaticResource CyanSecondary}" Offset="1" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="ChatToolButtonBrush" Color="#1AFFFFFF" />

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Glass Card Style -->
    <Style x:Key="GlassCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
    </Style>

    <!-- Glass Panel Style (larger radius for main panels) -->
    <Style x:Key="GlassPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="24" />
    </Style>

    <!-- Contact Row Style -->
    <Style x:Key="ContactRowStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Icon Button Style -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Gradient CTA Button Style -->
    <Style x:Key="GradientButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CtaGradientBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Transparent Button Style -->
    <Style x:Key="TransparentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- Tab Bar Item Style -->
    <Style x:Key="MsnTabBarItemStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Wink/Emoji Button Style -->
    <Style x:Key="WinkButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="Width" Value="48" />
        <Setter Property="Height" Value="48" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Send Button Style (50px square, teal gradient) -->
    <Style x:Key="SendButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CtaGradientBrush}" />
        <Setter Property="Width" Value="50" />
        <Setter Property="Height" Value="50" />
        <Setter Property="CornerRadius" Value="25" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Unread Badge Style -->
    <Style x:Key="UnreadBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource NotificationGradientBrush}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="MinWidth" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

    <!-- Status Dot Style -->
    <Style x:Key="StatusDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Stroke" Value="{StaticResource DeepNavyBrush}" />
        <Setter Property="StrokeThickness" Value="2" />
    </Style>

    <!-- Legacy MsnCardStyle support -->
    <Style x:Key="MsnCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- REFINED INPUT STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Glass TextBox Style -->
    <Style x:Key="GlassTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <!-- Glass PasswordBox Style -->
    <Style x:Key="GlassPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="14,12" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="MinHeight" Value="44" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- REFINED BUTTON STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Primary CTA Button (Teal Gradient) -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource CtaGradientBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="24,14" />
        <Setter Property="MinHeight" Value="48" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <!-- Secondary Glass Button -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="20,12" />
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Ghost Button (Text only) -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TealPrimaryBrush}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Circular Icon Button (refined) -->
    <Style x:Key="CircularIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Small Circular Icon Button -->
    <Style x:Key="SmallIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- REFINED CARD STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Elevated Glass Card -->
    <Style x:Key="ElevatedCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusLg}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Translation" Value="0,0,16" />
    </Style>

    <!-- Interactive Card (for list items) -->
    <Style x:Key="InteractiveCardStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusMd}" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Display Title -->
    <Style x:Key="DisplayTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CharacterSpacing" Value="-20" />
    </Style>

    <!-- Heading -->
    <Style x:Key="HeadingTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXxl}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Subheading -->
    <Style x:Key="SubheadingTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXl}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- Body Text -->
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeMd}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="LineHeight" Value="22" />
    </Style>

    <!-- Caption -->
    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSm}" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
    </Style>

    <!-- Label (All Caps) -->
    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeXs}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
        <Setter Property="CharacterSpacing" Value="80" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- DIVIDER STYLE -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <Style x:Key="DividerStyle" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="Opacity" Value="0.5" />
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- BADGE STYLES -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- Accent Badge (Teal) -->
    <Style x:Key="AccentBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource TealPrimaryBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- Subtle Badge (Glass) -->
    <Style x:Key="SubtleBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource GlassBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource GlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource RadiusFull}" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

</ResourceDictionary>

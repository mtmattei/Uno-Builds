<UserControl x:Class="MsnMessenger.Controls.LiveActivityCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MsnMessenger.Controls">

    <Border x:Name="CardContainer"
            Background="{StaticResource SurfaceOverlayBrush}"
            BorderBrush="{StaticResource GlassBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Margin="0,12,0,0"
            Padding="0">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Collapsed Header (Always Visible) -->
            <Border x:Name="HeaderArea"
                    Grid.Row="0"
                    Padding="14,10"
                    PointerPressed="OnCardTapped"
                    Background="Transparent">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Activity Icon Badge -->
                    <Border x:Name="IconBadge"
                            Grid.Column="0"
                            Width="32" Height="32"
                            CornerRadius="8"
                            Margin="0,0,12,0"
                            Translation="0,0,8">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <TextBlock x:Name="ActivityIcon"
                                   Text="🎵"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>

                    <!-- Activity Info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock x:Name="ServiceLabel"
                                   Text="Listening on Spotify"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}" />
                        <TextBlock x:Name="TitleText"
                                   Text="Blinding Lights"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1" />
                    </StackPanel>

                    <!-- Chevron -->
                    <FontIcon x:Name="ChevronIcon"
                              Grid.Column="2"
                              Glyph="&#xE70D;"
                              FontSize="12"
                              Foreground="{StaticResource TextMutedBrush}"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                        <FontIcon.RenderTransform>
                            <RotateTransform x:Name="ChevronRotation" Angle="0" />
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </Grid>
            </Border>

            <!-- Expanded Content -->
            <Border x:Name="ExpandedContent"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    Padding="14,0,14,14"
                    Opacity="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Album Art / Thumbnail + Details -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Album Art -->
                        <Border x:Name="AlbumArtContainer"
                                Grid.Column="0"
                                Width="64" Height="64"
                                CornerRadius="8"
                                Margin="0,0,12,0"
                                Translation="0,0,8">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                            <Grid>
                                <!-- Placeholder -->
                                <Border x:Name="ArtPlaceholder"
                                        Background="{StaticResource CtaGradientBrush}"
                                        CornerRadius="8">
                                    <TextBlock Text="🎵"
                                               FontSize="24"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <!-- Actual Image -->
                                <Image x:Name="AlbumArtImage"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!-- Track Details -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock x:Name="ExpandedTitle"
                                       Text="Blinding Lights"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock x:Name="ArtistText"
                                       Text="The Weeknd"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                            <TextBlock x:Name="AlbumText"
                                       Text="After Hours"
                                       FontSize="12"
                                       Foreground="{StaticResource TextHintBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                    </Grid>

                    <!-- Progress Bar (Music only) -->
                    <Grid x:Name="ProgressContainer"
                          Grid.Row="1"
                          Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Progress Track -->
                        <Grid Grid.Row="0" Height="4">
                            <!-- Background Track -->
                            <Border Background="{StaticResource GlassHighlightBrush}"
                                    CornerRadius="2" />
                            <!-- Fill -->
                            <Border x:Name="ProgressFill"
                                    Background="{StaticResource SpotifyGradientBrush}"
                                    CornerRadius="2"
                                    HorizontalAlignment="Left"
                                    Width="0" />
                        </Grid>

                        <!-- Time Labels -->
                        <Grid Grid.Row="1" Margin="0,6,0,0">
                            <TextBlock x:Name="CurrentTime"
                                       Text="2:10"
                                       FontSize="10"
                                       Foreground="{StaticResource TextHintBrush}"
                                       HorizontalAlignment="Left" />
                            <TextBlock x:Name="TotalTime"
                                       Text="3:20"
                                       FontSize="10"
                                       Foreground="{StaticResource TextHintBrush}"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>

                    <!-- Gaming Status (Gaming only) -->
                    <StackPanel x:Name="GamingStatusPanel"
                                Grid.Row="1"
                                Orientation="Horizontal"
                                Spacing="16"
                                Margin="0,0,0,12"
                                Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE916;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="GameStatusText"
                                       Text="In Match"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE77B;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="PartySizeText"
                                       Text="3/5"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon Glyph="&#xE823;" FontSize="12" Foreground="{StaticResource TextMutedBrush}" />
                            <TextBlock x:Name="PlayTimeText"
                                       Text="24 min"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Action Button -->
                    <Button x:Name="ActionButton"
                            Grid.Row="2"
                            Content="Listen Along"
                            HorizontalAlignment="Stretch"
                            Padding="10"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            CornerRadius="8"
                            BorderThickness="0"
                            Click="OnActionClick"
                            Translation="0,0,4">
                        <Button.Shadow>
                            <ThemeShadow />
                        </Button.Shadow>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>

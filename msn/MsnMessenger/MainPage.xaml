<Page x:Class="MsnMessenger.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:MsnMessenger"
      xmlns:views="using:MsnMessenger.Views"
      xmlns:utu="using:Uno.Toolkit.UI">

    <!-- Deep Navy Background with Gradient -->
    <Grid Background="{StaticResource BackgroundGradientBrush}">

        <!-- Animated Background Orbs -->
        <Canvas x:Name="OrbCanvas" IsHitTestVisible="False">
            <!-- Orb 1: Teal/Cyan - Top Left - 400px -->
            <Ellipse x:Name="TealOrb"
                     Width="400" Height="400"
                     Canvas.Left="-100" Canvas.Top="-50"
                     Fill="{StaticResource TealOrbBrush}"
                     Opacity="0.25">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="TealOrbTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Orb 2: Pink - Bottom Right - 300px -->
            <Ellipse x:Name="PinkOrb"
                     Width="300" Height="300"
                     Canvas.Left="700" Canvas.Top="400"
                     Fill="{StaticResource PinkOrbBrush}"
                     Opacity="0.2">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="PinkOrbTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>

            <!-- Orb 3: Purple - Center Right - 200px -->
            <Ellipse x:Name="PurpleOrb"
                     Width="200" Height="200"
                     Canvas.Left="300" Canvas.Top="200"
                     Fill="{StaticResource PurpleOrbBrush}"
                     Opacity="0.2">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="PurpleOrbTransform" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- Main Application Window - Centered with Padding -->
        <Border VerticalAlignment="Center" Style="{StaticResource GlassPanelStyle}"
                MaxWidth="1420"
                Margin="24"
                CornerRadius="24">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid Translation="0,0,32">
                <Grid.RowDefinitions>
                    <!-- Header Bar -->
                    <RowDefinition Height="64" />
                    <!-- Main Content -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <!-- HEADER BAR -->
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <Border MinHeight="92" Grid.Row="0"
                        Background="{StaticResource HeaderGradientBrush}"
                        CornerRadius="24,24,0,0"
                        BorderThickness="0,0,0,1"
                        BorderBrush="{StaticResource GlassBorderBrush}">
                    <Grid Padding="16,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left: Logo + Wordmark + Tagline -->
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <!-- Butterfly Logo with Glow -->
                            <Grid x:Name="ButterflyContainer">
                                <Image x:Name="ButterflyLogo"
                                       Source="ms-appx:///Assets/logos/msn-butterfly-logo.png"
                                       Width="32" Height="32"
                                       Stretch="Uniform">
                                    <Image.RenderTransform>
                                        <CompositeTransform x:Name="ButterflyTransform" />
                                    </Image.RenderTransform>
                                </Image>
                            </Grid>

                            <!-- Wordmark -->
                            <TextBlock Text="MSN Messenger"
                                       FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" />

                            <!-- Tagline -->
                        </StackPanel>

                        <!-- Right: Settings + Notifications -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Settings">
                                <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                            <Button Style="{StaticResource IconButtonStyle}" ToolTipService.ToolTip="Notifications">
                                <FontIcon Glyph="&#xE7E7;" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <!-- MAIN CONTENT: Sidebar + Chat Area -->
                <!-- ═══════════════════════════════════════════════════════════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Sidebar: Resizable 250-450px, default 300px -->
                        <ColumnDefinition x:Name="SidebarColumn" Width="300" MinWidth="250" MaxWidth="450" />
                        <!-- Splitter -->
                        <ColumnDefinition Width="Auto" />
                        <!-- Chat Area: Remaining -->
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Sidebar: Buddy List -->
                    <views:BuddyListView x:Name="BuddiesView"
                                          Grid.Column="0"
                                          Visibility="{x:Bind IsBuddyListVisible, Mode=OneWay}" />

                    <!-- Resizable Splitter -->
                    <Border Grid.Column="1"
                            Width="6"
                            Background="Transparent"
                            PointerPressed="OnSplitterPointerPressed"
                            PointerMoved="OnSplitterPointerMoved"
                            PointerReleased="OnSplitterPointerReleased"
                            PointerEntered="OnSplitterPointerEntered"
                            PointerExited="OnSplitterPointerExited">
                        <!-- Visual indicator line -->
                        <Border x:Name="SplitterLine"
                                Width="2"
                                Background="{StaticResource GlassBorderBrush}"
                                HorizontalAlignment="Center"
                                CornerRadius="1" />
                    </Border>

                    <!-- Chat Area -->
                    <Grid Grid.Column="2">
                        <!-- Empty State (when no chat selected) -->
                        <Grid x:Name="EmptyStatePanel"
                              Visibility="{x:Bind IsEmptyStateVisible, Mode=OneWay}">
                            <StackPanel VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Spacing="16">
                                <!-- Floating Butterfly -->
                                <TextBlock x:Name="FloatingButterfly"
                                           Text="&#x1F98B;"
                                           FontSize="80"
                                           HorizontalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="FloatingButterflyTransform" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>

                                <TextBlock Text="Welcome back!"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />

                                <TextBlock Text="Select a chat to start messaging"
                                           FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />

                                <!-- Pro Tip Box -->
                                <Border Background="{StaticResource GlassBackgroundBrush}"
                                        BorderBrush="{StaticResource GlassBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,16,0,0"
                                        MaxWidth="280">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Pro Tip"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TealPrimaryBrush}" />
                                        <TextBlock Text="Send a nudge to get your friend's attention! It'll shake their whole screen."
                                                   FontSize="13"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Chat View (when chat selected) -->
                        <views:ChatView x:Name="ChatOverlay"
                                        Visibility="{x:Bind IsChatVisible, Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
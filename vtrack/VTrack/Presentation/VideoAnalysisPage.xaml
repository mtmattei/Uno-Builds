<Page x:Class="VTrack.Presentation.VideoAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      xmlns:skia="using:SkiaSharp.Views.Windows"
      xmlns:local="using:VTrack.Presentation"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <utu:NavigationBar>
            <utu:NavigationBar.MainCommand>
                <AppBarButton Label="Back"
                              Command="{Binding GoBack}">
                    <AppBarButton.Icon>
                        <FontIcon Glyph="&#xE72B;" />
                    </AppBarButton.Icon>
                </AppBarButton>
            </utu:NavigationBar.MainCommand>
            <utu:NavigationBar.Content>
                <TextBlock Text="{Binding VideoName}"
                           Style="{StaticResource TitleMedium}" />
            </utu:NavigationBar.Content>
        </utu:NavigationBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Video Player Area -->
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Video with Overlay -->
                <Border Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="8">
                    <Grid x:Name="VideoContainer">
                        <MediaPlayerElement x:Name="MediaPlayer"
                                            AreTransportControlsEnabled="True"
                                            Stretch="Uniform" />

                        <!-- Media Error Display -->
                        <Border Background="{ThemeResource ErrorBrush}"
                                Visibility="{Binding MediaError, Converter={StaticResource NullToCollapsedConverter}}"
                                CornerRadius="4"
                                Padding="16"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <utu:AutoLayout Spacing="8"
                                            Orientation="Horizontal"
                                            CounterAxisAlignment="Center">
                                <FontIcon Glyph="&#xE783;"
                                          Foreground="{ThemeResource OnErrorBrush}" />
                                <TextBlock Text="{Binding MediaError}"
                                           Style="{StaticResource BodyMedium}"
                                           Foreground="{ThemeResource OnErrorBrush}"
                                           TextWrapping="Wrap"
                                           MaxWidth="300" />
                            </utu:AutoLayout>
                        </Border>

                        <!-- SkiaSharp Overlay for Bounding Boxes -->
                        <skia:SKXamlCanvas x:Name="BoundingBoxCanvas"
                                           PaintSurface="OnPaintSurface"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                    </Grid>
                </Border>

                <!-- Custom Transport Controls -->
                <Border Grid.Row="1"
                        Background="{ThemeResource SurfaceBrush}"
                        CornerRadius="8"
                        Margin="0,8,0,0"
                        Padding="16">
                    <utu:AutoLayout Spacing="16"
                                    Orientation="Horizontal"
                                    CounterAxisAlignment="Center">
                        <Button Command="{Binding PlayPause}"
                                Style="{StaticResource IconButtonStyle}">
                            <FontIcon Glyph="{Binding PlayPauseIcon}" />
                        </Button>

                        <TextBlock Text="{Binding CurrentTimeText}"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"
                                   MinWidth="60" />

                        <Slider x:Name="TimelineSlider"
                                Minimum="0"
                                Maximum="{Binding VideoDuration}"
                                Value="{Binding CurrentPosition, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Center" />

                        <TextBlock Text="{Binding DurationText}"
                                   Style="{StaticResource BodyMedium}"
                                   VerticalAlignment="Center"
                                   MinWidth="60" />

                        <Button Command="{Binding ToggleMute}"
                                Style="{StaticResource IconButtonStyle}">
                            <FontIcon Glyph="{Binding MuteIcon}" />
                        </Button>
                    </utu:AutoLayout>
                </Border>
            </Grid>

            <!-- Right Sidebar -->
            <Border Grid.Column="1"
                    Background="{ThemeResource SurfaceBrush}"
                    Padding="16">
                <utu:AutoLayout Spacing="24">
                    <!-- Query Input Section -->
                    <utu:AutoLayout Spacing="12">
                        <TextBlock Text="Track Subjects"
                                   Style="{StaticResource TitleMedium}"
                                   x:Uid="VideoAnalysis.QueryTitle" />
                        <TextBlock Text="Describe what you want to track"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   x:Uid="VideoAnalysis.QueryHint" />
                        <TextBox Text="{Binding QueryText, Mode=TwoWay}"
                                 PlaceholderText="e.g., everyone wearing yellow jersey"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="80"
                                 x:Uid="VideoAnalysis.QueryInput" />
                        <Button Content="Start Tracking"
                                Style="{StaticResource FilledButtonStyle}"
                                Command="{Binding StartTracking}"
                                IsEnabled="{Binding CanStartTracking}"
                                HorizontalAlignment="Stretch"
                                x:Uid="VideoAnalysis.StartButton" />
                    </utu:AutoLayout>

                    <!-- Processing Status -->
                    <utu:AutoLayout Spacing="8"
                                    Visibility="{Binding IsProcessing}">
                        <utu:AutoLayout Orientation="Horizontal"
                                        Spacing="8"
                                        CounterAxisAlignment="Center">
                            <ProgressRing IsActive="True"
                                          Width="20"
                                          Height="20" />
                            <TextBlock Text="Processing..."
                                       Style="{StaticResource BodyMedium}" />
                        </utu:AutoLayout>
                        <ProgressBar Value="{Binding ProcessingProgress}"
                                     Maximum="100" />
                    </utu:AutoLayout>

                    <!-- Tracked Subjects List -->
                    <utu:AutoLayout Spacing="12"
                                    Visibility="{Binding HasSubjects}">
                        <TextBlock Text="Tracked Subjects"
                                   Style="{StaticResource TitleMedium}"
                                   x:Uid="VideoAnalysis.SubjectsTitle" />
                        <ListView ItemsSource="{Binding TrackedSubjects}"
                                  SelectionMode="Multiple"
                                  SelectionChanged="OnSubjectSelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="8"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Color indicator -->
                                        <Ellipse Width="12"
                                                 Height="12"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Color}" />
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Label and ID -->
                                        <utu:AutoLayout Grid.Column="1"
                                                        Spacing="2">
                                            <TextBlock Text="{Binding Label}"
                                                       Style="{StaticResource BodyMedium}" />
                                            <TextBlock Style="{StaticResource BodySmall}"
                                                       Foreground="{ThemeResource OnSurfaceVariantBrush}">
                                                <Run Text="ID: " />
                                                <Run Text="{Binding Id}" />
                                            </TextBlock>
                                        </utu:AutoLayout>

                                        <!-- Confidence -->
                                        <TextBlock Grid.Column="2"
                                                   Style="{StaticResource LabelMedium}"
                                                   Foreground="{ThemeResource PrimaryBrush}"
                                                   VerticalAlignment="Center">
                                            <Run Text="{Binding Confidence, Converter={StaticResource PercentageConverter}}" />
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </utu:AutoLayout>

                    <!-- Empty State -->
                    <utu:AutoLayout Spacing="8"
                                    Visibility="{Binding ShowEmptyState}"
                                    HorizontalAlignment="Center"
                                    Padding="16">
                        <FontIcon Glyph="&#xE773;"
                                  FontSize="48"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No subjects tracked yet"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center"
                                   x:Uid="VideoAnalysis.EmptyState" />
                    </utu:AutoLayout>
                </utu:AutoLayout>
            </Border>
        </Grid>

        <!-- Bottom Timeline -->
        <Border Grid.Row="2"
                Background="{ThemeResource SurfaceBrush}"
                Padding="16,8"
                BorderBrush="{ThemeResource OutlineBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Timeline Track Visualization -->
                <Border Background="{ThemeResource SurfaceVariantBrush}"
                        CornerRadius="4"
                        Height="40">
                    <Canvas x:Name="TimelineCanvas" />
                </Border>

                <!-- Frame Counter -->
                <TextBlock Grid.Column="1"
                           Margin="16,0,0,0"
                           VerticalAlignment="Center"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}">
                    <Run Text="Frame: " />
                    <Run Text="{Binding CurrentFrame}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalFrames}" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Page>

<Page x:Class="VTrack.Presentation.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:utu="using:Uno.Toolkit.UI"
      xmlns:um="using:Uno.Material"
      x:Name="PageRoot"
      NavigationCacheMode="Required"
      Background="{ThemeResource BackgroundBrush}">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <utu:NavigationBar Content="VTRACK"
                           x:Uid="HomePage.NavigationBar" />

        <ScrollViewer Grid.Row="1">
            <utu:AutoLayout Padding="24"
                            Spacing="32"
                            PrimaryAxisAlignment="Center"
                            MaxWidth="800"
                            HorizontalAlignment="Center">

                <!-- Hero Section -->
                <utu:AutoLayout Spacing="16"
                                HorizontalAlignment="Center">
                    <TextBlock Text="Video Subject Tracking"
                               Style="{StaticResource DisplaySmall}"
                               HorizontalAlignment="Center"
                               x:Uid="HomePage.Title" />
                    <TextBlock Text="Upload a video and describe what you want to track"
                               Style="{StaticResource BodyLarge}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center"
                               x:Uid="HomePage.Subtitle" />
                </utu:AutoLayout>

                <!-- Upload Drop Zone -->
                <Border Background="{ThemeResource SurfaceVariantBrush}"
                        BorderBrush="{ThemeResource OutlineBrush}"
                        BorderThickness="2"
                        CornerRadius="16"
                        Padding="48"
                        MinHeight="280"
                        AllowDrop="True"
                        Drop="OnFileDrop"
                        DragOver="OnDragOver">
                    <utu:AutoLayout Spacing="24"
                                    HorizontalAlignment="Center"
                                    CounterAxisAlignment="Center">
                        <FontIcon Glyph="&#xE8B7;"
                                  FontSize="64"
                                  Foreground="{ThemeResource PrimaryBrush}" />
                        <TextBlock Text="Drag and drop your video here"
                                   Style="{StaticResource TitleMedium}"
                                   HorizontalAlignment="Center"
                                   x:Uid="HomePage.DropZone.Title" />
                        <TextBlock Text="or"
                                   Style="{StaticResource BodyMedium}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center" />
                        <Button Content="Browse Files"
                                Style="{StaticResource FilledButtonStyle}"
                                Command="{Binding BrowseFiles}"
                                HorizontalAlignment="Center"
                                x:Uid="HomePage.BrowseButton" />
                        <TextBlock Text="Supports MP4 files up to 500MB"
                                   Style="{StaticResource BodySmall}"
                                   Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                   HorizontalAlignment="Center"
                                   x:Uid="HomePage.FileTypes" />
                    </utu:AutoLayout>
                </Border>

                <!-- Upload Progress (shown when uploading) -->
                <utu:AutoLayout Spacing="8"
                                Visibility="{Binding IsUploading}">
                    <TextBlock Style="{StaticResource BodyMedium}">
                        <Run Text="Uploading: " />
                        <Run Text="{Binding UploadFileName}" />
                    </TextBlock>
                    <ProgressBar Value="{Binding UploadProgress}"
                                 Maximum="100"
                                 IsIndeterminate="False" />
                </utu:AutoLayout>

                <!-- Recent Videos Section -->
                <utu:AutoLayout Spacing="16"
                                Visibility="{Binding HasRecentVideos}">
                    <TextBlock Text="Recent Videos"
                               Style="{StaticResource TitleLarge}"
                               x:Uid="HomePage.RecentVideos" />
                    <ItemsRepeater ItemsSource="{Binding RecentVideos}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="200"
                                               MinItemHeight="150"
                                               MinColumnSpacing="16"
                                               MinRowSpacing="16" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <utu:Card Style="{StaticResource FilledCardStyle}"
                                          utu:CommandExtensions.Command="{Binding DataContext.OpenVideo, ElementName=PageRoot}"
                                          utu:CommandExtensions.CommandParameter="{Binding}">
                                    <utu:AutoLayout Spacing="8"
                                                    Padding="12">
                                        <Border Background="{ThemeResource SurfaceVariantBrush}"
                                                CornerRadius="8"
                                                Height="100">
                                            <Image Source="{Binding ThumbnailUrl}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource BodyMedium}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1" />
                                    </utu:AutoLayout>
                                </utu:Card>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </utu:AutoLayout>

            </utu:AutoLayout>
        </ScrollViewer>
    </Grid>
</Page>

<Application x:Class="SalesHeatmap.App"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:utum="using:Uno.Toolkit.UI.Material">

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <!-- Load WinUI resources -->
        <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
        <utum:MaterialToolkitTheme
          ColorOverrideSource="ms-appx:///Styles/ColorPaletteOverride.xaml">
        </utum:MaterialToolkitTheme>

        <!-- Heatmap card theme-aware brushes -->
        <ResourceDictionary Source="ms-appx:///Styles/HeatmapTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>

      <!-- Card Styles -->
      <Style x:Key="DashboardGlassCardStyle" TargetType="Border">
          <Setter Property="Background" Value="{ThemeResource HeatmapCardBackgroundBrush}"/>
          <Setter Property="BorderBrush" Value="{ThemeResource HeatmapCardBorderBrush}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="20"/>
          <Setter Property="Padding" Value="24"/>
          <Setter Property="Translation" Value="0,0,16"/>
      </Style>

      <Style x:Key="DashboardSmallCardStyle" TargetType="Border">
          <Setter Property="Background" Value="{ThemeResource HeatmapCardBackgroundBrush}"/>
          <Setter Property="BorderBrush" Value="{ThemeResource HeatmapCardBorderBrush}"/>
          <Setter Property="BorderThickness" Value="1"/>
          <Setter Property="CornerRadius" Value="16"/>
          <Setter Property="Padding" Value="20"/>
          <Setter Property="Translation" Value="0,0,8"/>
      </Style>

    </ResourceDictionary>
  </Application.Resources>

</Application>

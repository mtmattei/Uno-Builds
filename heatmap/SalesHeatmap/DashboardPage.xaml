<Page x:Class="SalesHeatmap.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:SalesHeatmap.Converters"
      xmlns:models="using:SalesHeatmap.Models"
      xmlns:utu="using:Uno.Toolkit.UI">

    <Page.Resources>
        <converters:IntensityToBrushConverter x:Key="IntensityToBrush"/>
        <converters:IntensityToOpacityConverter x:Key="IntensityToOpacity"/>
        <converters:CurrencyConverter x:Key="Currency"/>
        <converters:PercentageConverter x:Key="Percentage"/>
        <converters:PercentageToBrushConverter x:Key="PercentageToBrush"/>
        <converters:NumberConverter x:Key="Number"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>

        <FontFamily x:Key="MonoFont">Consolas, Courier New, monospace</FontFamily>
    </Page.Resources>

    <Grid Background="{ThemeResource HeatmapPageBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <utu:AutoLayout Orientation="Vertical"
                            Spacing="24"
                            Padding="32"
                            MaxWidth="1200"
                            HorizontalAlignment="Center">

                <!-- ══════════════════════════════════════ -->
                <!-- HEADER                                 -->
                <!-- ══════════════════════════════════════ -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <utu:AutoLayout Grid.Column="0"
                                    Orientation="Vertical"
                                    Spacing="4">
                        <TextBlock Text="Sales Dashboard"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                   CharacterSpacing="-25"/>
                        <TextBlock Text="Real-time performance overview"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="13"
                                   Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                    </utu:AutoLayout>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="6">
                        <Ellipse Width="6" Height="6"
                                 Fill="{ThemeResource HeatmapLiveIndicatorBrush}"
                                 Opacity="{x:Bind ViewModel.LiveIndicatorOpacity, Mode=OneWay}"/>
                        <TextBlock Text="LIVE"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="10"
                                   Foreground="{ThemeResource HeatmapLiveIndicatorBrush}"
                                   FontWeight="SemiBold"
                                   CharacterSpacing="50"
                                   Opacity="{x:Bind ViewModel.LiveIndicatorOpacity, Mode=OneWay}"/>
                    </StackPanel>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!-- KPI STAT CARDS ROW                     -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Monthly Sales KPI -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapMonthlyDotBrush}"/>
                                <TextBlock Text="MONTHLY"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                           CharacterSpacing="50"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.DisplayMonthly, Mode=OneWay, Converter={StaticResource Currency}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{x:Bind ViewModel.MonthlyChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                <Run Text="{x:Bind ViewModel.MonthlyChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                <Run Text=" MoM" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                            </TextBlock>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Yearly Sales KPI -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapYearlyDotBrush}"/>
                                <TextBlock Text="YEARLY"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                           CharacterSpacing="50"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.DisplayYearly, Mode=OneWay, Converter={StaticResource Currency}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{x:Bind ViewModel.YearlyChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                <Run Text="{x:Bind ViewModel.YearlyChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                <Run Text=" YoY" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                            </TextBlock>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Active Cities KPI -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapPrimaryAccentBrush}"/>
                                <TextBlock Text="CITIES"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                           CharacterSpacing="50"/>
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.ActiveCities, Mode=OneWay, Converter={StaticResource Number}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>
                            <TextBlock Text="active regions"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Conversion Rate KPI -->
                    <Border Grid.Column="3" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapSecondaryAccentBrush}"/>
                                <TextBlock Text="CONVERSION"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                           CharacterSpacing="50"/>
                            </StackPanel>
                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50">
                                <Run Text="{x:Bind ViewModel.ConversionRate, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                            </TextBlock>
                            <TextBlock Text="lead to sale"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                        </utu:AutoLayout>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!-- FULL HEATMAP CARD (main feature)       -->
                <!-- ══════════════════════════════════════ -->
                <Border Style="{StaticResource DashboardGlassCardStyle}">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Card Header -->
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Sales Report"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapPrimaryAccentBrush}"
                                       VerticalAlignment="Center"
                                       CharacterSpacing="-25"/>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="6">
                                <Ellipse Width="6" Height="6"
                                         Fill="{ThemeResource HeatmapLiveIndicatorBrush}"
                                         Opacity="{x:Bind ViewModel.LiveIndicatorOpacity, Mode=OneWay}"/>
                                <TextBlock Text="LIVE"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="10"
                                           Foreground="{ThemeResource HeatmapLiveIndicatorBrush}"
                                           FontWeight="SemiBold"
                                           CharacterSpacing="50"
                                           Opacity="{x:Bind ViewModel.LiveIndicatorOpacity, Mode=OneWay}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Primary Heatmap Grid -->
                        <Border Grid.Row="1"
                                Background="{ThemeResource HeatmapContainerBgBrush}"
                                CornerRadius="12"
                                Padding="8"
                                Margin="0,0,0,28"
                                HorizontalAlignment="Center">
                            <Grid>
                                <ItemsRepeater ItemsSource="{x:Bind ViewModel.PrimaryHeatmapCells}">
                                    <ItemsRepeater.Layout>
                                        <UniformGridLayout Orientation="Horizontal"
                                                           ItemsStretch="None"
                                                           MinItemWidth="24"
                                                           MinItemHeight="24"
                                                           MinRowSpacing="3"
                                                           MinColumnSpacing="3"
                                                           MaximumRowsOrColumns="12"/>
                                    </ItemsRepeater.Layout>
                                    <ItemsRepeater.ItemTemplate>
                                        <DataTemplate x:DataType="models:HeatmapCell">
                                            <Border Width="24" Height="24"
                                                    CornerRadius="3"
                                                    Background="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToBrush}}"
                                                    Opacity="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToOpacity}}"
                                                    ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"/>
                                        </DataTemplate>
                                    </ItemsRepeater.ItemTemplate>
                                </ItemsRepeater>

                                <!-- Gradient Overlay -->
                                <Border CornerRadius="6"
                                        IsHitTestVisible="False"
                                        Background="{ThemeResource HeatmapOverlayBrush}"/>
                            </Grid>
                        </Border>

                        <!-- Totals Section -->
                        <Grid Grid.Row="2" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Monthly -->
                            <StackPanel Grid.Column="0" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{ThemeResource HeatmapMonthlyDotBrush}"/>
                                    <TextBlock Text="MONTHLY"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                               CharacterSpacing="50"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.DisplayMonthly, Mode=OneWay, Converter={StaticResource Currency}}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                           CharacterSpacing="-50"/>
                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="13"
                                           Foreground="{x:Bind ViewModel.MonthlyChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                    <Run Text="{x:Bind ViewModel.MonthlyChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                    <Run Text=" MoM" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Yearly -->
                            <StackPanel Grid.Column="2" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Width="8" Height="8"
                                             Fill="{ThemeResource HeatmapYearlyDotBrush}"/>
                                    <TextBlock Text="YEARLY"
                                               FontFamily="{StaticResource MonoFont}"
                                               FontSize="13"
                                               FontWeight="Medium"
                                               Foreground="{ThemeResource HeatmapTextMutedBrush}"
                                               CharacterSpacing="50"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.DisplayYearly, Mode=OneWay, Converter={StaticResource Currency}}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                           CharacterSpacing="-50"/>
                                <TextBlock FontFamily="{StaticResource MonoFont}"
                                           FontSize="13"
                                           Foreground="{x:Bind ViewModel.YearlyChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                    <Run Text="{x:Bind ViewModel.YearlyChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                    <Run Text=" YoY" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>

                        <!-- Divider -->
                        <Border Grid.Row="3"
                                Height="1"
                                Margin="0,8,0,20"
                                Background="{ThemeResource HeatmapDividerGradientBrush}"/>

                        <!-- Cities Section -->
                        <ItemsRepeater Grid.Row="4"
                                       ItemsSource="{x:Bind ViewModel.Cities}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="0"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:CityData">
                                    <Border Padding="0,12"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{ThemeResource HeatmapCityBorderBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Ellipse Grid.Column="0"
                                                     Width="6" Height="6"
                                                     Fill="{x:Bind DotColor, Converter={StaticResource ColorToBrush}}"
                                                     Margin="0,0,12,0"
                                                     VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind Name}"
                                                       FontFamily="Consolas, Courier New, monospace"
                                                       FontSize="15"
                                                       Foreground="{ThemeResource HeatmapCityNameBrush}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind DisplayValue, Mode=OneWay, Converter={StaticResource Number}}"
                                                       FontFamily="Consolas, Courier New, monospace"
                                                       FontSize="15"
                                                       FontWeight="Medium"
                                                       Foreground="{ThemeResource HeatmapCityValueBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════ -->
                <!-- COMPACT REGION HEATMAPS (side by side) -->
                <!-- ══════════════════════════════════════ -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Region East -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardGlassCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="16">

                            <TextBlock Text="Region East"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-25"/>

                            <!-- Compact Heatmap Grid (8 cols x 6 rows) -->
                            <Border Background="{ThemeResource HeatmapContainerBgBrush}"
                                    CornerRadius="8"
                                    Padding="6"
                                    HorizontalAlignment="Center">
                                <Grid>
                                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RegionEastCells}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout Orientation="Horizontal"
                                                               ItemsStretch="None"
                                                               MinItemWidth="16"
                                                               MinItemHeight="16"
                                                               MinRowSpacing="2"
                                                               MinColumnSpacing="2"
                                                               MaximumRowsOrColumns="8"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:HeatmapCell">
                                                <Border Width="16" Height="16"
                                                        CornerRadius="2"
                                                        Background="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToBrush}}"
                                                        Opacity="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToOpacity}}"
                                                        ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <Border CornerRadius="4"
                                            IsHitTestVisible="False"
                                            Background="{ThemeResource HeatmapOverlayBrush}"/>
                                </Grid>
                            </Border>

                            <!-- Region Stats -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind ViewModel.DisplayRegionEast, Mode=OneWay, Converter={StaticResource Currency}}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                           CharacterSpacing="-50"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="13"
                                           Foreground="{x:Bind ViewModel.RegionEastChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.RegionEastChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                </TextBlock>
                            </Grid>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Region West -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardGlassCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="16">

                            <TextBlock Text="Region West"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-25"/>

                            <!-- Compact Heatmap Grid (8 cols x 6 rows) -->
                            <Border Background="{ThemeResource HeatmapContainerBgBrush}"
                                    CornerRadius="8"
                                    Padding="6"
                                    HorizontalAlignment="Center">
                                <Grid>
                                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.RegionWestCells}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout Orientation="Horizontal"
                                                               ItemsStretch="None"
                                                               MinItemWidth="16"
                                                               MinItemHeight="16"
                                                               MinRowSpacing="2"
                                                               MinColumnSpacing="2"
                                                               MaximumRowsOrColumns="8"/>
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:HeatmapCell">
                                                <Border Width="16" Height="16"
                                                        CornerRadius="2"
                                                        Background="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToBrush}}"
                                                        Opacity="{x:Bind Intensity, Mode=OneWay, Converter={StaticResource IntensityToOpacity}}"
                                                        ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}"/>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>

                                    <Border CornerRadius="4"
                                            IsHitTestVisible="False"
                                            Background="{ThemeResource HeatmapOverlayBrush}"/>
                                </Grid>
                            </Border>

                            <!-- Region Stats -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{x:Bind ViewModel.DisplayRegionWest, Mode=OneWay, Converter={StaticResource Currency}}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                           CharacterSpacing="-50"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="13"
                                           Foreground="{x:Bind ViewModel.RegionWestChange, Mode=OneWay, Converter={StaticResource PercentageToBrush}}"
                                           VerticalAlignment="Center">
                                    <Run Text="{x:Bind ViewModel.RegionWestChange, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                </TextBlock>
                            </Grid>
                        </utu:AutoLayout>
                    </Border>
                </Grid>

                <!-- ══════════════════════════════════════ -->
                <!-- CITY PERFORMANCE CARDS                 -->
                <!-- ══════════════════════════════════════ -->
                <utu:AutoLayout Orientation="Vertical" Spacing="8">
                    <TextBlock Text="Top Cities"
                               FontFamily="{StaticResource MonoFont}"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                               CharacterSpacing="-25"
                               Margin="0,8,0,8"/>
                </utu:AutoLayout>

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- City cards generated from Cities collection -->
                    <!-- Los Angeles -->
                    <Border Grid.Column="0" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapMonthlyDotBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Los Angeles"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="15"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.Cities[0].DisplayValue, Mode=OneWay, Converter={StaticResource Number}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>

                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{x:Bind ViewModel.Cities[0].Change, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                <Run Text="{x:Bind ViewModel.Cities[0].Change, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                <Run Text=" vs prev" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                            </TextBlock>
                        </utu:AutoLayout>
                    </Border>

                    <!-- New York -->
                    <Border Grid.Column="1" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapYearlyDotBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="New York"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="15"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.Cities[1].DisplayValue, Mode=OneWay, Converter={StaticResource Number}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>

                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{x:Bind ViewModel.Cities[1].Change, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                <Run Text="{x:Bind ViewModel.Cities[1].Change, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                <Run Text=" vs prev" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                            </TextBlock>
                        </utu:AutoLayout>
                    </Border>

                    <!-- Montreal -->
                    <Border Grid.Column="2" Style="{StaticResource DashboardSmallCardStyle}">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <utu:AutoLayout Orientation="Vertical" Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Ellipse Width="8" Height="8"
                                         Fill="{ThemeResource HeatmapTertiaryAccentBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock Text="Montreal"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="15"
                                           FontWeight="Medium"
                                           Foreground="{ThemeResource HeatmapTextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.Cities[2].DisplayValue, Mode=OneWay, Converter={StaticResource Number}}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource HeatmapTextPrimaryBrush}"
                                       CharacterSpacing="-50"/>

                            <TextBlock FontFamily="{StaticResource MonoFont}"
                                       FontSize="12"
                                       Foreground="{x:Bind ViewModel.Cities[2].Change, Mode=OneWay, Converter={StaticResource PercentageToBrush}}">
                                <Run Text="{x:Bind ViewModel.Cities[2].Change, Mode=OneWay, Converter={StaticResource Percentage}}"/>
                                <Run Text=" vs prev" Foreground="{ThemeResource HeatmapTextMutedBrush}"/>
                            </TextBlock>
                        </utu:AutoLayout>
                    </Border>
                </Grid>

            </utu:AutoLayout>
        </ScrollViewer>
    </Grid>
</Page>
